&НаСервере
// Процедура - заполнить таблицу значений РезультатПланирования.
// 
Процедура ЗаполнитьТаблицуРезультатПланирования(Знач ВыбПериод, Знач ИнтервалыРаботы, Знач Сотрудник)
	
	РезультатПланированияРазовый.Очистить();
	
	Если ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный Тогда
	    ИнтервалыРаботыПредст = "Б";
		СуммаРабочегоВремени  = 0;
    ИначеЕсли ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск Тогда
	    ИнтервалыРаботыПредст = "О";
		СуммаРабочегоВремени  = 0;
	Иначе
		ИнтервалыРаботыПредст = ПредставлениеИнтервалаВремени(ИнтервалыРаботы);
		СуммаРабочегоВремени  = СуммаИнтерваловВМинутахНаСервере(ИнтервалыРаботы);
	КонецЕсли;
	
	НоваяСтрока                       = РезультатПланированияРазовый.Добавить();
	НоваяСтрока.Дата                  = ВыбПериод; 
	НоваяСтрока.ИнтервалыРаботы       = ИнтервалыРаботы;
	НоваяСтрока.ИнтервалыРаботыПредст = ИнтервалыРаботыПредст;
	НоваяСтрока.СуммаРабочегоВремени  = СуммаРабочегоВремени;
	НоваяСтрока.Сотрудник             = Сотрудник;
	НоваяСтрока.ТипРабочегоВремени    = ТипРабочегоВремени;
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить результат планирования на сервере
// 
// Параметры:
//  ДатаНачалаПериода	 - 	 - 
//  ДатаКонцаПериода	 - 	 - 
//  СтруктураПоиска		 - 	 - 
// 
Процедура ЗаполнитьРезультатПланированияНаСервере(Знач ВыбраннаяДата, Знач ПериодКопирования)
	
	День = 86400;
	РезультатПланированияРазовый.Очистить();
	СтруктураПоиска = ПолучитьПараметрыПоиска();
	
	// Определим период-источник
	Если ПериодКопирования = "День" Тогда
		ДатаНачалаПериодаИсточника 	= НачалоДня(ВыбраннаяДата - День*7);
		ДатаКонцаПериодаИсточника 	= КонецДня(ДатаНачалаПериодаИсточника);
	ИначеЕсли ПериодКопирования = "Неделя" Тогда
		ДатаНачалаПериодаИсточника 	= ОбщегоНазначенияКлиентСерверСтоматология.ДатаПоНомеруНедели(НеделяГода(ВыбраннаяДата) - 1, Год(ВыбраннаяДата));
		ДатаКонцаПериодаИсточника 	= КонецНедели(ДатаНачалаПериодаИсточника); 
	ИначеЕсли ПериодКопирования = "Месяц" Тогда 
		ДатаНачалаПериодаИсточника 	= НачалоМесяца(НачалоМесяца(ВыбраннаяДата)-1);
		ДатаКонцаПериодаИсточника 	= КонецМесяца(НачалоМесяца(ВыбраннаяДата)-1); 
	КонецЕсли;
	
	// Период-источник не пересекается с буфером
	Если ДатаНачалаПериодаИсточника < ОтборПериод.ДатаНачала И ДатаКонцаПериодаИсточника < ОтборПериод.ДатаНачала Тогда 
		ТаблицаЗанятий = ПолучитьДанныеВнеБуфера(ДатаНачалаПериодаИсточника, ДатаКонцаПериодаИсточника, СтруктураПоиска);
		// Период-источник пересекается с буфером
	ИначеЕсли ДатаНачалаПериодаИсточника < ОтборПериод.ДатаНачала И	ДатаКонцаПериодаИсточника > ОтборПериод.ДатаНачала Тогда 
		ТаблицаЗанятий = БуферФормирования.Выгрузить();
		ТаблицаЗанятий = ТаблицаЗанятий.СкопироватьКолонки();
		ТаблицаЗанятийВнеБуфера = ПолучитьДанныеВнеБуфера(ДатаНачалаПериодаИсточника, КонецДня(НачалоДня(ОтборПериод.ДатаНачала)-1), СтруктураПоиска);
		Для Каждого СтрокаТЗ Из ТаблицаЗанятийВнеБуфера Цикл 
			НоваяСтрока = ТаблицаЗанятий.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		КонецЦикла;
		// Дополним таблицу из буфера
		Для Каждого СтрокаТЗ Из БуферФормирования Цикл 
			НоваяСтрока = ТаблицаЗанятий.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		КонецЦикла;	
		// Период-источник находится в буфере
	ИначеЕсли ДатаНачалаПериодаИсточника >= ОтборПериод.ДатаНачала И ДатаКонцаПериодаИсточника <= ОтборПериод.ДатаОкончания Тогда 
		ТаблицаЗанятий = БуферФормирования.Выгрузить();
	КонецЕсли;	
	
	// Заполняем результат планирования	
	Если ПериодКопирования = "День" Тогда
		
		СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаИсточника);			
		МассивСтрок = ТаблицаЗанятий.НайтиСтроки(СтруктураПоиска); 
		Для Каждого ЭлементМассива Из МассивСтрок Цикл
			НоваяСтрока                     = РезультатПланированияРазовый.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
			НоваяСтрока.Дата 				= НачалоДня(ВыбраннаяДата);
		КонецЦикла;
		
	ИначеЕсли ПериодКопирования = "Неделя" Тогда 
		
		Пока ДатаНачалаПериодаИсточника < ДатаКонцаПериодаИсточника Цикл 
			Если НЕ (ДатаНачалаПериодаИсточника + День*7 < ОтборПериод.ДатаНачала ИЛИ ДатаНачалаПериодаИсточника + День*7 > ОтборПериод.ДатаОкончания) Тогда
				СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаИсточника);			
				МассивСтрок = ТаблицаЗанятий.НайтиСтроки(СтруктураПоиска); 
				Для Каждого ЭлементМассива Из МассивСтрок Цикл
					НоваяСтрока                     = РезультатПланированияРазовый.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
					НоваяСтрока.Дата 				= НоваяСтрока.Дата + День*7;
				КонецЦикла;
			КонецЕсли;
			ДатаНачалаПериодаИсточника = ДатаНачалаПериодаИсточника + День;
		КонецЦикла;
		
	ИначеЕсли ПериодКопирования = "Месяц" Тогда
		
		ДатаНачалаПериодаПриемника = ДобавитьМесяц(ДатаНачалаПериодаИсточника, 1);
		ДатаКонцаПериодаИсточника = КонецДня(ДобавитьМесяц(ДобавитьМесяц(ДатаКонцаПериодаИсточника, 1), -1));
		Пока ДатаНачалаПериодаИсточника < ДатаКонцаПериодаИсточника Цикл 
			
			Если ДеньНедели(ДатаНачалаПериодаПриемника) > ДеньНедели(ДатаНачалаПериодаИсточника) Тогда 
				ДатаНачалаПериодаИсточника = ДатаНачалаПериодаИсточника + День;
			ИначеЕсли ДеньНедели(ДатаНачалаПериодаПриемника) < ДеньНедели(ДатаНачалаПериодаИсточника) Тогда	
				ДатаНачалаПериодаПриемника = ДатаНачалаПериодаПриемника + День*(ДеньНедели(ДатаНачалаПериодаИсточника) - ДеньНедели(ДатаНачалаПериодаПриемника));
			КонецЕсли;
			
			Если ДеньНедели(ДатаНачалаПериодаПриемника) = ДеньНедели(ДатаНачалаПериодаИсточника) Тогда
				Если НЕ (ДобавитьМесяц(ДатаНачалаПериодаИсточника, 1) < ОтборПериод.ДатаНачала ИЛИ ДобавитьМесяц(ДатаНачалаПериодаИсточника, 1) > ОтборПериод.ДатаОкончания) Тогда
					СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаИсточника);			
					МассивСтрок = ТаблицаЗанятий.НайтиСтроки(СтруктураПоиска); 
					Для Каждого ЭлементМассива Из МассивСтрок Цикл
						Если НЕ ТакоеЗанятиеУжеЕсть(СтруктураПоиска, ДатаНачалаПериодаПриемника, ЭлементМассива) Тогда 
							НоваяСтрока                       = РезультатПланированияРазовый.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
							НоваяСтрока.Дата 				= ДатаНачалаПериодаПриемника;
							НоваяСтрока.ДатаВремяНачала 	= НачалоДня(ДатаНачалаПериодаПриемника) + Час(НоваяСтрока.ДатаВремяНачала)*60*60 + Минута(НоваяСтрока.ДатаВремяНачала)*60;
							НоваяСтрока.ДатаВремяОкончания 	= НачалоДня(ДатаНачалаПериодаПриемника) + Час(НоваяСтрока.ДатаВремяОкончания)*60*60 + Минута(НоваяСтрока.ДатаВремяОкончания)*60;
						КонецЕсли;						
					КонецЦикла;
				КонецЕсли;
				ДатаНачалаПериодаИсточника = ДатаНачалаПериодаИсточника + День;
				ДатаНачалаПериодаПриемника = ДатаНачалаПериодаПриемника + День;
			КонецЕсли;
			
			Если ДатаНачалаПериодаПриемника > КонецМесяца(ДатаНачалаПериодаПриемника) Тогда 
				Прервать;
			КонецЕсли;	
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Получить параметры поиска
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьПараметрыПоиска()
	
	СтруктураПоиска = Новый Структура;
	
	Если ЗначениеЗаполнено(ОтборСотрудник) Тогда 
		СтруктураПоиска.Вставить("Сотрудник", ОтборСотрудник);
	КонецЕсли;
	
	Возврат СтруктураПоиска;
	
КонецФункции

&НаСервере
// Функция - Получить данные вне буфера
// 
// Параметры:
//  ДатаНачалаПериода	 - 	 - 
//  ДатаКонцаПериода	 - 	 - 
//  СтруктураПоиска		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьДанныеВнеБуфера(Знач ДатаНачалаПериода, Знач ДатаКонцаПериода, Знач СтруктураПоиска)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ДатаВремяНачала,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ДатаВремяОкончания,
	|	ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
	|	ВремяРаботыСотрудниковПлан.Сотрудник.Должность КАК Должность,
	|	ВремяРаботыСотрудниковПлан.Минуты КАК КолМинут
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	|ГДЕ
	|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВЫБОР
	|			КОГДА &Сотрудник <> НЕОПРЕДЕЛЕНО
	|					И &ГруппаСотрудников = ИСТИНА
	|				ТОГДА ВремяРаботыСотрудниковПлан.Сотрудник В ИЕРАРХИИ (&Сотрудник)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &Сотрудник <> НЕОПРЕДЕЛЕНО
	|					И &ГруппаСотрудников = ЛОЖЬ
	|				ТОГДА ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяНачала >= &НачалоПериода
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяОкончания <= &ОкончаниеПериода
	|	И ВремяРаботыСотрудниковПлан.ТипРабочегоВремени <> ЗНАЧЕНИЕ(Перечисление.ТипыРабочегоВремени.Отпуск)
	|	И ВремяРаботыСотрудниковПлан.ТипРабочегоВремени <> ЗНАЧЕНИЕ(Перечисление.ТипыРабочегоВремени.Больничный)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВремяРаботыСотрудниковПлан.МесяцОтбор,
	|	Сотрудник,
	|	Должность,
	|	ДатаВремяНачала");
	
	Запрос.УстановитьПараметр("НачалоПериода"    , НачалоДня(ДатаНачалаПериода));
	Запрос.УстановитьПараметр("ОкончаниеПериода" , КонецДня(ДатаКонцаПериода));
	Запрос.УстановитьПараметр("ГруппаСотрудников", ?(СтруктураПоиска.Свойство("Сотрудник") И ЗначениеЗаполнено(СтруктураПоиска.Сотрудник) И СтруктураПоиска.Сотрудник.ЭтоГруппа, Истина, Ложь));
	Запрос.УстановитьПараметр("Сотрудник"        , ?(СтруктураПоиска.Свойство("Сотрудник") И ЗначениеЗаполнено(СтруктураПоиска.Сотрудник), СтруктураПоиска.Сотрудник, Неопределено));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница" , ОтборСтруктурнаяЕдиница);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТЗ_ВремяРаботыСотрудников = БуферФормирования.Выгрузить();
	ТЗ_ВремяРаботыСотрудников = ТЗ_ВремяРаботыСотрудников.СкопироватьКолонки();
	
	ТекДень            	= Неопределено;
	ПредДень           	= Неопределено;
	ТекСтрока_ТЗ    	= Неопределено;
	ПредСтрока_ТЗ   	= Неопределено;
	ПредставлениеИнтервала = "";
	
	Пока Выборка.Следующий() Цикл
		// Получаем дату тек. дня
		ТекДень = День(Выборка.ДатаВремяНачала);
		// Если тек дата не совпадает или указанные параметры
		// создаем новую строку бофуера, иначе считаем что это след. интервал в тот же день
		Если ТекДень <> ПредДень 
			ИЛИ ТекСтрока_ТЗ = Неопределено 
			ИЛИ ТекСтрока_ТЗ.Сотрудник <> Выборка.Сотрудник
			ИЛИ ТекСтрока_ТЗ.Должность <> Выборка.Должность Тогда
			// ИЛИ ТекСтрока_ТЗ.Помещение <> Выборка.Помещение Тогда
			
			ТекСтрока_ТЗ = ТЗ_ВремяРаботыСотрудников.Добавить();
			ЗаполнитьЗначенияСвойств(ТекСтрока_ТЗ, Выборка);
			ТекСтрока_ТЗ.ИдентификаторОбласти  = Новый УникальныйИдентификатор;
			ТекСтрока_ТЗ.Дата                  = Выборка.ДатаВремяНачала;
			ТекСтрока_ТЗ.СуммаРабочегоВремени  = Выборка.КолМинут;
		Иначе
			ТекСтрока_ТЗ.СуммаРабочегоВремени = ТекСтрока_ТЗ.СуммаРабочегоВремени + Выборка.КолМинут;
		КонецЕсли;
		
		// Переменная оптимизации. Кеширует массив данных на время серверного вызова
		МассивНадстрочныхСимволов = Неопределено;
		ПериодРаботы              = Новый Структура("НачалоРаботы, ОкончаниеРаботы,ВсегоМинут", Выборка.ДатаВремяНачала
		, Выборка.ДатаВремяОкончания
		, Выборка.КолМинут);	  
		НачалоПредст              = Формат(ПериодРаботы.НачалоРаботы	, "ДФ=HH:mm"); // Обработки.ПланированиеГрафикаРаботыСотрудников.ПредставлениеВремениСНадстрочнымиСимволами(ПериодРаботы.НачалоРаботы, МассивНадстрочныхСимволов);
		КонецПредст               = Формат(ПериодРаботы.ОкончаниеРаботы	, "ДФ=HH:mm"); // Обработки.ПланированиеГрафикаРаботыСотрудников.ПредставлениеВремениСНадстрочнымиСимволами(ПериодРаботы.ОкончаниеРаботы, МассивНадстрочныхСимволов);
		
		ВремяИнтервала 			= ?(Выборка.КолМинут > 60, Строка(ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьМинутыВЧасы(Выборка.КолМинут)), Строка(Выборка.КолМинут) + " мин.");
		
		ПредставлениеИнтервала = НачалоПредст + " - " + КонецПредст + " (" + ВремяИнтервала + ")";
		ТекСтрока_ТЗ.ИнтервалыРаботы.Добавить(ПериодРаботы, ПредставлениеИнтервала);
		ТекСтрока_ТЗ.ИнтервалыРаботыПредст = Обработки.ГрафикРаботыСотрудников.ПолучитьПредставлениеСпискаИнтервалов(ТекСтрока_ТЗ.ИнтервалыРаботы);
		
		ПредДень      = ТекДень;
		ПредСтрока_ТЗ = ТекСтрока_ТЗ;	  
	КонецЦикла;	 
	
	Возврат ТЗ_ВремяРаботыСотрудников;
	
КонецФункции

&НаСервере
// Функция - Такое занятие уже есть
// 
// Параметры:
//  СтруктураПоиска				 - 	 - 
//  ДатаНачалаПериодаПриемника	 - 	 - 
//  СтрокаИсточника				 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ТакоеЗанятиеУжеЕсть(Знач СтруктураПоиска, Знач ДатаНачалаПериодаПриемника, Знач СтрокаИсточника)
	
	Флаг = Ложь;
	ДатаНачалаПериодаИсточника = СтруктураПоиска.Дата;
	СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаПриемника);
	МассивСтрокПриемника = БуферФормирования.НайтиСтроки(СтруктураПоиска);
	Если МассивСтрокПриемника.Количество() > 0 Тогда 
		Для Каждого ЭлементМассива Из МассивСтрокПриемника Цикл 
			Если СтрокаИсточника.Сотрудник = ЭлементМассива.Сотрудник
				И Час(СтрокаИсточника.ДатаВремяНачала) = Час(ЭлементМассива.ДатаВремяНачала)
				И Минута(СтрокаИсточника.ДатаВремяНачала) = Минута(ЭлементМассива.ДатаВремяНачала)
				И Час(СтрокаИсточника.ДатаВремяОкончания) = Час(ЭлементМассива.ДатаВремяОкончания)
				И Минута(СтрокаИсточника.ДатаВремяОкончания) = Минута(ЭлементМассива.ДатаВремяОкончания) Тогда 
				
				Флаг = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Флаг;			
	
КонецФункции

&НаКлиенте         
// Функция проверяет буфер формирования на пересечение периодов
// 
Функция ПроверитьБуферФормированияНаПересечениеПериодов()
	
	// проверем список периодов на пересечение по времени
	Для каждого СтрокаБуфера из БуферФормирования Цикл
		Если (СтрокаБуфера.Операция = "" или СтрокаБуфера.Операция = "Создание") и СтрокаБуфера.ИнтервалыРаботы.Количество() > 0 Тогда
			ПервыйПериодВСписке = СтрокаБуфера.ИнтервалыРаботы[0].Значение;
			Для Каждого ИнтервалСписка ИЗ СтрокаБуфера.ИнтервалыРаботы Цикл
				Если СтрокаБуфера.ИнтервалыРаботы.Индекс(ИнтервалСписка) = 0 Тогда
					Продолжить;
				КонецЕсли;    				
				
				// приоритет отдан этому механизму выявления пересечения периодов
				Если Макс(ПервыйПериодВСписке.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы) < Мин(ПервыйПериодВСписке.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для сотрудника " + СтрокаБуфера.Сотрудник + " " + Формат(СтрокаБуфера.Дата, "ДЛФ = ДДММГГГГ") + " обнаружено пересечение времени: с " + Формат(Макс(ПервыйПериодВСписке.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы), "ДФ=HH:mm") + " по " + Формат(Мин(ПервыйПериодВСписке.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы), "ДФ=HH:mm"), ЭтотОбъект);
					Возврат Ложь;	
					Прервать;
				КонецЕсли;   				
			КонецЦикла;	
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

