// Функция, создает новую сделку клиенту.
//
Функция СоздатьСделку(ВидСделки)
			
	НоваяСделка = Справочники.Сделки.СоздатьЭлемент();		
	ПерыйЭтап 	= ПолучитьПервыйЭтапВидаСделки(ВидСделки);
	
	ДанныеЗаполнения = Новый Структура();
	ДанныеЗаполнения.Вставить("ВидСделки",          ВидСделки);
	ДанныеЗаполнения.Вставить("ЭтапСделки",         ПерыйЭтап);
	ДанныеЗаполнения.Вставить("ДатаСделки",         ТекущаяДатаСеанса());
	ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	НоваяСделка.Заполнить(ДанныеЗаполнения);
	
	Попытка
		
		НоваяСделка.Записать();
		Возврат НоваяСделка.Ссылка;
		
	Исключение		
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось создать сделку: '; en = 'Failed to create a deal: '") + ОписаниеОшибки());	
	КонецПопытки;
		
КонецФункции

