#Область ОписаниеПеременных

&НаКлиенте
Перем ИскомыйКлиент;   

#КонецОбласти
 
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);
	ПризнакТолькоПросмотрКолонкиЦенаИСумма = Элементы.Запасы.ПодчиненныеЭлементы.ЗапасыЦена.ТолькоПросмотр;	
		
	// Установим реквизиты
	СкладДокумента = Объект.Склад;
	Если Не ЗначениеЗаполнено(Объект.ВидЦен) Тогда
		Объект.ВидЦен = ?(Не Объект.СтруктурнаяЕдиница.ВидЦенРеализации.Пустая(), Объект.СтруктурнаяЕдиница.ВидЦенРеализации, Справочники.ВидыЦен.Розничная);
	КонецЕсли;
	
	// Сформируем надпись
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);
	
	// Установить отображение закладок скидки/наценки, подарки	
	// ОбщегоНазначенияСтоматология.УстановитьОтображениеЗакладокСкидкиНаценкиПодарки(ЭтаФорма);	
	
	УстановитьДоступностьПечатиЧека();
	
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("Запасы"			, "ГруппаЗапасы");
	СтруктураМеню.Вставить("Услуги"			, "ГруппаУслуги");
	СтруктураМеню.Вставить("СкидкиНаценки"	, "ГруппаСкидкиНаценки");
	СтруктураМеню.Вставить("Подарки"		, "ГруппаПодарки");
	СтруктураМеню.Вставить("Дополнительно"	, "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() И (Объект.Запасы.Количество() > 0 Или Объект.Услуги.Количество() > 0) Тогда
		УстановитьВидимостьЭлементов();
	Иначе
		ПроставитьТипСкидкиНаценки();
		ЗаполнитьВирутальныеРеквизитыПодарков();
		ЗаполнитьТЧДоступныеОплатыБонусами();
		УстановитьВидимостьЭлементов();
		ПересчитатьАвтоматическиеСкидки();
	КонецЕсли;   
	
	ОтобразитьИнформациюПоОплате();
	
	Элементы.Договор.Видимость = ЗначениеЗаполнено(Объект.Контрагент) 
		И ?(ТипЗнч(Объект.Контрагент) = Тип("СправочникСсылка.Контрагенты") 
		И Объект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Ложь, Истина);
		
	МаксимальнаяРучнаяСкидка = РегистрыСведений.НастройкиСотрудников.ПолучитьМаксимальнуюСкидкуСотрудника(ПараметрыСеанса.АвторизованныйПользователь.Сотрудник, Объект.СтруктурнаяЕдиница);
	
	СсылкиНаОплатуИСБП.ОбновитьИнформациюПоИспользованиюСсылкиНаОплату(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик события "ПриОткрытии" формы
//
Процедура ПриОткрытии(Отказ)
	
	// МеханизмВнешнегоОборудования
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";
		
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		ПоддерживаемыеТипыВО.Добавить("СчитывательМагнитныхКарт");
		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	// Конец МеханизмВнешнегоОборудования 
	Для Каждого СтрокаТЧ Из Объект.Запасы Цикл		
		Если Не ЗначениеЗаполнено(СтрокаТЧ.ВидЦен) Тогда 			
			СтрокаТч.ВидЦен = Объект.ВидЦен;
		КонецЕсли;
		СтрокаТЧ.Бесплатно = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "Бесплатно");
	КонецЦикла;
	
	УстановитьСуммуДокумента();
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	УстановитьОтображениеЗакладокСкидкиНаценкиПодаркиАвансы();  
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ОбработкаОповещения
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			ПолученыШтрихкоды(Данные);
		ИначеЕсли ИмяСобытия = "TracksData" Тогда
			Если Параметр[1] = Неопределено Тогда
				ПолученКодКарты(Параметр[0], Параметр[0]);
			Иначе
				ПолученКодКарты(Параметр[0], Параметр[1][1]);
			КонецЕсли;
		ИначеЕсли ИмяСобытия = "DataCollectionTerminal" Тогда
			ПолученыШтрихкоды(Параметр);
		КонецЕсли;
	КонецЕсли;
	// Конец ВнешнееОборудование 	
	
	Если Источник = "ВнешнееОборудование" И ИмяСобытия = "НеизвестныеШтрихкоды" 
		И УникальныйИдентификатор = Параметр.ФормаВладелецУникальныйИдентификатор Тогда
		ПолученыШтрихкоды(Параметр.ЗарегистрированныеШтрихкоды);
	КонецЕсли;	
	
	Если ИмяСобытия = "ОбновитьИнформациюОСсылкахНаОплату" И ТипЗнч(Параметр) = Тип("Массив") И Параметр.Найти(Объект.Ссылка) <> Неопределено Тогда
		
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();
		
	ИначеЕсли ИмяСобытия = "СБП_УспешнаяОплата" Тогда
		
		ОбсужденияСистемыВзаимодействияКлиент.ОбработкаОповещенияОбУспешностиОплатыСБП(ЭтаФорма, Параметр);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Результат = ПередЗаписьюПроверкаСтатусовНоменклатуры();
	
	Если Не Результат Тогда
		
		Отказ = Истина;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере"
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Для Каждого СтрокаЗапасы из Объект.Запасы Цикл
				
		Если СтрокаЗапасы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
		   И СтрокаЗапасы.Номенклатура.ИспользоватьПартии
		   И СтрокаЗапасы.Партия.Пустая() Тогда
		   
		   Отказ = Истина;
		   ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке № " + СтрокаЗапасы.НомерСтроки + " табличной части " + """" + "Запасы" + """" + " не заполнено поле " + """"+ "Характеристика, серия" + """");
		КонецЕсли; 
		
	КонецЦикла; 
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПослеЗаписиНаСервере"
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы); 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи"
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиентСтоматология.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

 &НаКлиенте
// Процедура печати чека на фискальном регистраторе.
//
Процедура НапечататьЧек(Команда)
	
	Если ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда
		ПоказатьПредупреждение(, "Документ уже пробит на фискальном регистраторе! Номер чека:" + Объект.НомерЧекаККМ);
		Возврат;
	КонецЕсли;  
	
	Если Не ЗначениеЗаполнено(Объект.Касса) Тогда
		ПоказатьПредупреждение(, "Не заполнена касса!");
		Возврат;
	КонецЕсли;    
	
	Если Объект.Проведен = Ложь 
		ИЛИ ЭтаФорма.Модифицированность = Истина Тогда
		
		ПоказатьПредупреждение(, НСтр("ru='Предварительно документ необходимо провести.';en='Pre document is necessary conduct.'"));
		Возврат;
	КонецЕсли; 	
	
	// Проверяем ставку НДС.
	СтавкаНДС = ОбщегоНазначенияСтоматология.ПолучитьСтавкуНДС(Объект.СтруктурнаяЕдиница);			
	Если Не ЗначениеЗаполнено(СтавкаНДС) Тогда
		ПоказатьПредупреждение(, "Заполните ставку НДС в организации и повторите операцию оплаты.");
		ОткрытьФорму("Справочник.Организации.Форма.ФормаЭлемента", 
					Новый Структура("Ключ", ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.СтруктурнаяЕдиница, "Организация")));
		Возврат;	
	КонецЕсли;  

	// Выполнить контроль кассовой смены
	ОписаниеОшибки					= Неопределено;
	ВыполнятьОперациюНаФискальнике  = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Касса, "ИспользоватьБезПодключенияОборудования") = Ложь; 
	ПараметрыИспользованияКассовойСмены = Новый Структура("ВыполнятьОперациюНаФискальнике", ВыполнятьОперациюНаФискальнике);
	РозничныеПродажиКлиент.ВыполнитьКонтрольИспользованияКассовойСмены(ЭтотОбъект, Объект.Касса, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки);
	
КонецПроцедуры

&НаКлиенте
// Процедура оработчик команды "Подбор"
//
Процедура Подбор(Команда)
	
	ИмяТабличнойЧасти  = "Запасы";
	ЕстьПартии		   = Истина;
		
	ПараметрыПодбора = Новый Структура;
	
	ПараметрыПодбора.Вставить("Период"					, Объект.Дата);
	ПараметрыПодбора.Вставить("Склад"					, Объект.Склад);
	ПараметрыПодбора.Вставить("СтруктурнаяЕдиница"		, Объект.СтруктурнаяЕдиница);
	ПараметрыПодбора.Вставить("ВидЦен"					, Объект.ВидЦен);
	ПараметрыПодбора.Вставить("ИспользуетсяСодержание"	, Истина);

	Если Объект[ИмяТабличнойЧасти].Количество() > 0 Тогда
		АдресЗапасовВХранилище = ПоместитьЗапасыВХранилище(ИмяТабличнойЧасти, ЕстьПартии);
		ПараметрыПодбора.Вставить("АдресЗапасовДокумента", АдресЗапасовВХранилище);
	КонецЕсли; 
	
	ТипНоменклатуры = Новый СписокЗначений;
	Для каждого ЭлементМассива Из Элементы[ИмяТабличнойЧасти + "Номенклатура"].ПараметрыВыбора Цикл
		Если ЭлементМассива.Имя = "Отбор.ТипНоменклатуры" Тогда
			Если ТипЗнч(ЭлементМассива.Значение) = Тип("ФиксированныйМассив") Тогда
				Для каждого ЭлементФиксМассива Из ЭлементМассива.Значение Цикл
					ТипНоменклатуры.Добавить(ЭлементФиксМассива);
				КонецЦикла; 
			Иначе
				ТипНоменклатуры.Добавить(ЭлементМассива.Значение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ПараметрыПодбора.Вставить("ТипНоменклатуры",	   ТипНоменклатуры);
		
	СтатусПартии = Новый СписокЗначений;
	Для каждого ЭлементМассива Из Элементы[ИмяТабличнойЧасти + "Партия"].ПараметрыВыбора Цикл
		Если ЭлементМассива.Имя = "Отбор.Статус" Тогда			
			Если ТипЗнч(ЭлементМассива.Значение) = Тип("ФиксированныйМассив") Тогда
				Для каждого ЭлементФиксМассива Из ЭлементМассива.Значение Цикл
					СтатусПартии.Добавить(ЭлементФиксМассива);
				КонецЦикла; 
			Иначе
				СтатусПартии.Добавить(ЭлементМассива.Значение);
			КонецЕсли;			
		КонецЕсли;
	КонецЦикла;
	ПараметрыПодбора.Вставить("СтатусПартии",	   		СтатусПартии);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяТабличнойЧасти", ИмяТабличнойЧасти);
	ДополнительныеПараметры.Вставить("ЕстьПартии", ЕстьПартии);

	ОткрытьФорму("ОбщаяФорма.ФормаПодбора",
	ПараметрыПодбора,,,,,
	Новый ОписаниеОповещения("ПодборЗавершение", ЭтотОбъект, ДополнительныеПараметры), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора подбора
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПодборЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда
		ПолучитьЗапасыИзХранилища(РезультатВыбора, ДополнительныеПараметры.ИмяТабличнойЧасти, ДополнительныеПараметры.ЕстьПартии);
		ПересчитатьАвтоматическиеСкидки();
        УстановитьСуммуДокумента();
		Модифицированность = Истина;
	КонецЕсли; 	

	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);

КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды вызывает форму настройки и редактирования цен.
//
Процедура РедактироватьЦены(Команда)
	
	// 1. Формируем структуру параметров для заполнения формы "Цены и Валюта".
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ВидЦен", 	  			Объект.ВидЦен);
	СтруктураПараметров.Вставить("ПерезаполнитьЦены",	Ложь);
	
	// 2. Открвыаем форму "Цены и Валюта".
	ОткрытьФорму("ОбщаяФорма.ФормаЦены", СтруктураПараметров,,,,, Новый ОписаниеОповещения("РедактироватьЦеныЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Редактировать цены завершение
//
// Параметры:
//  СтруктураЦены			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура РедактироватьЦеныЗавершение(СтруктураЦены, ДополнительныеПараметры) Экспорт
	
	// 3. Перезаполняем табличную часть "Запасы" если были внесены изменения в форме "Цены и Валюта".
	Если ТипЗнч(СтруктураЦены) = Тип("Структура") И СтруктураЦены.БылиВнесеныИзменения Тогда
		
		Объект.ВидЦен = СтруктураЦены.ВидЦен;
		
		// Пересчитываем цены по виду цен.					
		Если СтруктураЦены.ПерезаполнитьЦены Тогда
			ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Запасы");
			ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Услуги");
			ПересчитатьАвтоматическиеСкидки();
			УстановитьСуммуДокумента();	
