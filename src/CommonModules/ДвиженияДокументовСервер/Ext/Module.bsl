// Выполняет движения регистра сведения ЦеныНоменклатуры.
//  Параметры:
//   ДополнительныеСвойства - структура, дополнительные свойства для проведения документа;
//   Движения - набор движений документа;
//   Отказ    - булево, признак отказа записи набора данных.
//
Процедура УстановкаЦен(ДополнительныеСвойства, Движения, Отказ) Экспорт
	
	ТаблицаУстановкаЦен = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаУстановкаЦен;
	Если Отказ = Истина Тогда
		Возврат;
	КонецЕсли;

	// Удаляем цены из регистра по документу
	ДвиженияДокументовСервер.УдалениеЦен(ДополнительныеСвойства.ДляПроведения.Ссылка, Движения, Отказ);
	
	// Добавляем цены в регистр
	Для Каждого СтрокаУстановкаЦен Из ТаблицаУстановкаЦен Цикл
		ЦеныНоменклатуры = РегистрыСведений.ЦеныНоменклатуры;    
		СтруктураРесурсов = ЦеныНоменклатуры.ПолучитьПоследнее(СтрокаУстановкаЦен.Период, СтрокуТаблицыЗначенийВСтруктуру(СтрокаУстановкаЦен, ТаблицаУстановкаЦен.СкопироватьКолонки("Номенклатура, СтруктурнаяЕдиница, ВидЦен, Упаковка")));
		Если СтруктураРесурсов.Цена = NULL ИЛИ СтруктураРесурсов.Цена = Неопределено ИЛИ СтруктураРесурсов.Цена <> СтрокаУстановкаЦен.Цена Тогда			
			ДвиженияУстановкаЦен = ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(ДвиженияУстановкаЦен, СтрокаУстановкаЦен);
			ДвиженияУстановкаЦен.ДокументРегистратор = ДополнительныеСвойства.ДляПроведения.Ссылка;
			ДвиженияУстановкаЦен.Записать();
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

// Удаляет движения регистра сведения ЦеныНоменклатуры.
//  Параметры:
//   ДокументДвижения - Документ, который производил движение по регистру;
//
Процедура УдалениеЦен(ДокументРегистратор, Движения, Отказ) Экспорт
	
	Если Отказ = Истина Тогда
		Возврат;
	КонецЕсли;
	
	// Удаляем цены из регистра по документу
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатуры.Период,
	|	ЦеныНоменклатуры.СтруктурнаяЕдиница,
	|	ЦеныНоменклатуры.ВидЦен,
	|	ЦеныНоменклатуры.Номенклатура,
	|	ЦеныНоменклатуры.Упаковка
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	|ГДЕ
	|	ЦеныНоменклатуры.ДокументРегистратор = &ДокументРегистратор";

	
	Запрос.УстановитьПараметр("ДокументРегистратор", ДокументРегистратор);
	

	ТаблицаЗаписей = Запрос.Выполнить().Выгрузить();
	
	Для каждого СтрокаТаблицы Из ТаблицаЗаписей Цикл
		НаборЗаписей = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(СтрокаТаблицы.Период);
		НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтрокаТаблицы.СтруктурнаяЕдиница);
		НаборЗаписей.Отбор.ВидЦен.Установить(СтрокаТаблицы.ВидЦен);
		НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТаблицы.Номенклатура);
		НаборЗаписей.Отбор.Упаковка.Установить(СтрокаТаблицы.Упаковка);
		НаборЗаписей.Записать();
	КонецЦикла;	

КонецПроцедуры

#КонецОбласти