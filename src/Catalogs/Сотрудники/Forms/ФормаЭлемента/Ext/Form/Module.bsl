// Функция, возвращает номер телефона мастера.
// 
Функция ПолучитьНомерТелефонаСотрудника(Сотрудник, НормализоватьТелефон = Истина)
	
	Возврат МенеджерОборудованияВызовСервера.ПолучитьКонтактнуюИнформацию(Сотрудник).Телефон;
	
КонецФункции

&НаСервереБезКонтекста
Функция МестаРаботыСотрудника(Сотрудник,ТипВозвращаемыхДанных = "Список")
	Возврат Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(Сотрудник,ТипВозвращаемыхДанных);
КонецФункции

&НаСервере
// Функция, выполняет синхронизацию доступа к личному расписанию.
// 
Функция АктуализироватьДоступКЛичномуРасписанию(ОписаниеОшибки, ВнешняяСистема)	
	
	РезультатЗапроса = ЛичныйКабинет.АктуализироватьДоступКЛичномуРасписанию_CRM(ВнешняяСистема, Объект.Ссылка);	
	
	Если Не РезультатЗапроса.ВыполненоУспешно Тогда
		
		ОписаниеОшибки = РезультатЗапроса.ОписаниеОшибки;
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат РезультатЗапроса.ПараметрыРезультата.app_status;
	
КонецФункции

#КонецОбласти 

#Область ОбработчикиОповещенийАсинхронныхСобытий 

&НаКлиенте
// Процедура - Выбор варианта действия с кассой.
// 
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ВыборВариантаДействияСКассой(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Попытка
		
		Если ВыбранныйЭлемент = Неопределено Тогда 
			Возврат;
		ИначеЕсли ВыбранныйЭлемент.Значение = 0 Тогда 	
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ДополнительныеПараметры.Касса));
		ИначеЕсли ВыбранныйЭлемент.Значение = 1 Тогда
			// Сброс по всем строкам.
			Для Каждого СтрокаТ ИЗ ДоступныеКассы Цикл
				СтрокаТ.Основная = Ложь;
			КонецЦикла;		
			ДополнительныеПараметры.Основная = Истина;
			Модифицированность = Истина;
			ОбновитьЭлементыГруппы("ГруппаДоступныеКассыВыбранные");
		КонецЕсли;
		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Создание связи с классификатором социальных статусов.
// Завершение немодального открытия окна "ПоказатьВопрос()" 
// Параметры:
//  РезультатВопроса - Ответ на вопрос
//  Параметры	     - Параметры вопроса 
//
Процедура СозданиеСвязиСКлассификаторомДолжностейЗавершение(РезультатВопроса, Параметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да  Тогда
		ПараметрыОткрытия = Новый Структура("Ключ", Объект.Должность);
		ОткрытьФорму("Справочник.Должности.Форма.ФормаЭлемента", ПараметрыОткрытия);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Функция - Проверка даты увольнения.
// 
// Параметры:
//  ДатаУвольнения	 - 	 - 
//  ДатаПриема		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПроверкаДатыУвольнения(ДатаУвольнения, ДатаПриема)
	
	Возврат НЕ (ДатаПриема <> Дата(1,1,1) И ДатаУвольнения < ДатаПриема);
	
КонецФункции

#КонецОбласти 