	Запрос.УстановитьПараметр("ТекущаяДатаСеанса"						, ТекущаяДатаСеанса());	
	Запрос.УстановитьПараметр("ТекущееВремяСеанса"						, Дата(1, 1, 1, Час(ТекущаяДатаСеанса()), Минута(ТекущаяДатаСеанса()), 0));
	
	ПакетРезультирующихТаблиц 							= Запрос.ВыполнитьПакет();
	
	ТаблицаРегламентныхТриггеров 						= ПакетРезультирующихТаблиц[2].Выгрузить();
	ТаблицаЗапланированныхТриггеров 					= ПакетРезультирующихТаблиц[4].Выгрузить();
	ТаблицаЗапланированныхТриггеровВРазрезеКонтрагентов = ПакетРезультирующихТаблиц[5].Выгрузить();
	ТаблицаЗапланированныхТриггеровСменыСтатусаКлиентов = ПакетРезультирующихТаблиц[6].Выгрузить();
	
	ТаблицаОбъектов = ТаблицаЗапланированныхТриггеровВРазрезеКонтрагентов.Скопировать(, "ОбъектСобытия");
	ТаблицаОбъектов.Свернуть("ОбъектСобытия");
	МассивОбъектов = ТаблицаОбъектов.ВыгрузитьКолонку("ОбъектСобытия");
	ТаблицаОбъектов = ТаблицаЗапланированныхТриггеровСменыСтатусаКлиентов.Скопировать(, "ДатаСменыСтатуса, Контрагент");
