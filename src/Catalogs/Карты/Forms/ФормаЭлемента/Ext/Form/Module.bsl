Функция УдалитьКартуНаСервере()
	
	РезультатОбновления = Справочники.Карты.ОбновитьКартуWallet(Объект.Ссылка, ВнешняяСистемаWallet,, Истина);
	
	РезультатУдаления = Новый Структура("Успешно, ОписаниеОшибки", Ложь, РезультатОбновления.ОписаниеОшибки);
	Если РезультатОбновления.Успешно Тогда 
		
		РезультатУдаления = Справочники.Карты.УдалитьКартуWallet(Объект.Ссылка, ВнешняяСистемаWallet);
		
		Объект.КартаУдалена = Истина;
		Объект.ПометкаУдаления = Истина;
	КонецЕсли; 
	
	Возврат РезультатУдаления; 
	
