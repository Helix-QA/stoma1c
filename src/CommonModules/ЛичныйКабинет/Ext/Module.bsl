// 
// Параметры:
//  Организация	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция УдалитьРегистрациюОрганизацииВиджета(Организация) 
	
	Попытка 
		
		ПараметрыОрганизации = Новый Структура("id", ЛичныйКабинет.ПолучитьУИДИнформационнойБазы());
		
		МассивОрганизаций = Новый Массив;
		МассивОрганизаций.Добавить(ПараметрыОрганизации);
		
		ПарамтерыЗапроса = Новый Структура("organizations", МассивОрганизаций);
		РезультатЗапроса = ВыполнитьPOSTЗапросВReservi("remove_org", ПарамтерыЗапроса);
		
		РезультатаОперции = СтруктураСтандартынхПараметровРезОперации();
		
		Если РезультатЗапроса.КодСостояния <> 200 Тогда
			ВызватьИсключение "КодОшибки = " + РезультатЗапроса.КодСостояния + ", Ошибка: " +  РезультатЗапроса.ПолучитьТелоКакСтроку();
		Иначе
			
			Ответ = РезультатЗапроса.ПолучитьТелоКакСтроку();
			
			Если СтрНайти(Ответ, """status"":true") > 0 Тогда 
				РезультатаОперции.ВыполненоУспешно = Истина;
			Иначе
				ВызватьИсключение "Ошибка: " + Ответ;
			КонецЕсли;
			
		КонецЕсли;
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатаОперции;
		
КонецФункции

#КонецОбласти

#Область ВнешниеПодключаемыеОбработчики

// Процедура - При начале работы системы
// 
Процедура ПриНачалеРаботыСистемы(ПараметрыКлиента = Неопределено) Экспорт
	
	Если (ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных())
		ИЛИ (ПараметрыКлиента <> Неопределено И ПараметрыКлиента.Свойство("НеобходимоОбновлениеПараметровРаботыПрограммы") И ПараметрыКлиента.НеобходимоОбновлениеПараметровРаботыПрограммы = Истина) Тогда
		
		Возврат ;
		
	КонецЕсли;
	
	Если ПользовательИмеетПравоНаРаботуСличнымКабинетом() = Истина Тогда
		
		ДанныеАнкеты = ПолучитьДанныеРегистрационнойАнкеты();
		
		Если ДанныеАнкеты = Неопределено
			ИЛИ ДанныеАнкеты.Свойство("ИдентификацияПрограммногоПродуктаВыполнена") = Ложь
			ИЛИ НЕ ДанныеАнкеты.ИдентификацияПрограммногоПродуктаВыполнена = Истина Тогда
						
			ЗарегистрироватьПрограммныйПродукт();
			
		КонецЕсли;
					
	КонецЕсли;
		
КонецПроцедуры

// Функция - Фоновое задание запустить
// 
// Параметры:
//  ПланОбмена					 - 	 - 
//  УникальныйИдентификаторФормы - 	 - 
// Возвращаемое значение:
//   - 
Функция ПроверитьБалансаСмсСервисаИПредложитьПополнение() Экспорт
		
	Если ТекущийПользовательИмеетПравоНаРаботуССмсСервисами() = Ложь Тогда		
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = "Проверка баланса";
	ПараметрыВыполнения.ОжидатьЗавершение           = 0;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне("ЛичныйКабинет.ПроверитьБалансаСмсСервисаДлительнаяОперация", Новый Структура, ПараметрыВыполнения);

КонецФункции

// Процедура - Проверить необходимость предложения пополнения баланса смс сервиса helix
// 
// Параметры:
//  СтруктураПараметров		 - 	 - 
//  АдресХранилищаРезультата - 	 - 
// 
Процедура ПроверитьБалансаСмсСервисаДлительнаяОперация(СтруктураПараметров, АдресХранилищаРезультата = Неопределено, СервисSMSРассылки = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(СервисSMSРассылки) Тогда
		СервисСмс = СервисSMSРассылки;
	ИначеЕсли Константы.СервисSMSРассылкиПоУмолчанию.Получить().Пустая() Тогда
		СервисСмс = Справочники.СервисыРассылки.НайтиПоРеквизиту("SMSСервис", Перечисления.СервисыSMSРассылки.HelixSMS);
	Иначе
		СервисСмс = Константы.СервисSMSРассылкиПоУмолчанию.Получить();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СервисСмс)
		И СервисСмс.ПометкаУдаления = Ложь
		И СервисСмс.SMSСервис = Перечисления.СервисыSMSРассылки.HelixSMS Тогда
		
		Баланс = Неопределено;
		
		Попытка
			Баланс = Справочники.СервисыРассылки.ПолучитьБалансАккаунтаSMS(СервисСмс);
		Исключение
			ЗаписатьОшибкуВЖурналРегистрации(ИнформацияОбОшибке());
		КонецПопытки;
		
		Если Баланс <> Неопределено
			И Баланс.Ошибка = Ложь Тогда
			
			РезультатаОперции   = ПолучитьПредложениеДляПополенияБалансаСмсСервиса(СервисСмс);							
			МинимальныйБаланс   = 1000;
			ПараметрыПополнения = Новый Структура();
			
			Если РезультатаОперции.ВыполненоУспешно = Истина
				И РезультатаОперции.ПараметрыРезультата <> Неопределено Тогда	
				
				ПараметрыПополнения = РезультатаОперции.ПараметрыРезультата; 
				МинимальныйБаланс   = РезультатаОперции.ПараметрыРезультата.min_balance;
				
			ИначеЕсли РезультатаОперции.ВыполненоУспешно = Ложь Тогда 	
				
				ПараметрыПополнения.Вставить("КодОшибки", РезультатаОперции.КодОшибки);
				
			КонецЕсли;		
			
			ПараметрыПополнения.Вставить("ТекущийБаланс",Баланс.Баланс);
			
			ПоместитьВоВременноеХранилище(ПараметрыПополнения, АдресХранилищаРезультата);  
			
			// Если это проверка пополнения баланса
			Если СтруктураПараметров = Неопределено
				ИЛИ НЕ СтруктураПараметров.Свойство("НеКонтролироватьДатаПоследнегоСчета")
				ИЛИ СтруктураПараметров.НеКонтролироватьДатаПоследнегоСчета = Ложь Тогда
				
				Если Баланс.Баланс <= МинимальныйБаланс Тогда  
					
					ДанныеАнкеты = ПолучитьДанныеРегистрационнойАнкеты();
					
					Если ДанныеАнкеты <> Неопределено
						И ДанныеАнкеты.Свойство("ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса")
						И ЗначениеЗаполнено(ДанныеАнкеты.ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса) Тогда
						
						Период = (НачалоДня(ТекущаяДата()) - НачалоДня(ДанныеАнкеты.ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса)) / 86400;
						
						Если Период < 3 Тогда
							
							ПоместитьВоВременноеХранилище(Неопределено, АдресХранилищаРезультата);
							Возврат;
						КонецЕсли;
						
					КонецЕсли;
					
				Иначе
					ПоместитьВоВременноеХранилище(Неопределено, АдресХранилищаРезультата);
					Возврат;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		ПоместитьВоВременноеХранилище(Неопределено, АдресХранилищаРезультата);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

