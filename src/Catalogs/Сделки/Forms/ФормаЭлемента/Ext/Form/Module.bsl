// Процедура, ИзменитьЭтапНаСервере.
//
Процедура ИзменитьЭтапНаСервере()
	
	ИмяЭлемента = ЭтаФорма.ТекущийЭлемент.Имя;
	Индекс 		= ПолучитьИндексСтроки(ИмяЭлемента);
	Если НЕ Объект.ЭтапСделки = ЭтотОбъект.ЭтапыСделок[Индекс].Ссылка Тогда 
