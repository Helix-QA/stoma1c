// Процедура, обработчик завершения асинхронного события.
//
Процедура ПерейтиВЧатЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Результат.Значение.Идентификатор) Тогда
		ОбновлятьДанныеВнешнихСистем = Истина;
	КонецЕсли;
	
	ОписаниеОшибки = "";
	ИдСообщения = УстановитьОжиданиеСообщения(
		Результат.Значение.Идентификатор,
		Результат.Значение.ВнешняяСистема,
		ОписаниеОшибки,
		ЭтотОбъект.Контрагент,
		Результат.Значение.НомерМессенджера
	);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
		
	КонецЕсли;
	
	Если ОбновлятьДанныеВнешнихСистем = Истина Тогда
		ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(ЭтотОбъект.Контрагент, Объект.СтруктурнаяЕдиница);
	КонецЕсли;
	
	ДанныеКанала = Новый Структура;
	ДанныеКанала.Вставить("ИдКлиента"		, Результат.Значение.Идентификатор);
	ДанныеКанала.Вставить("ВнешняяСистема"	, Результат.Значение.ВнешняяСистема);
	ДанныеКанала.Вставить("ИдСообщения"		, ИдСообщения);
	
	ПараметрыОткрытия = Новый Структура("ДанныеКанала", ДанныеКанала);
	
	Оповестить("ОткрытьДиалог", ПараметрыОткрытия);
	ОткрытьФорму("Обработка.Мессенджер_Стоматология.Форма", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

