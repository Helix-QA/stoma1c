		//		Оповещение = Новый ОписаниеОповещения("НапечататьЧекЗавершение", ЭтотОбъект);
		//		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаПараметровЧекаККТ", ПараметрыФормы, ЭтаФорма,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		//		Возврат;
