&НаКлиенте
// Процедура - Установить период день
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура УстановитьПериодОтображенияИнформации(Команда)
	
	ОбновитьДанные 							= Истина;
	СдвинутьВременнойИнтервал 				= Ложь;
	НаправлениеДвиженияВременногоИнтервала 	= "";
	
	Если Команда.Имя = "УстановитьПериодДень" Тогда 
		ВыбранныйПериод 		= 0;
		ВыбранныйПериодТиповой 	= ВыбранныйПериод;
	ИначеЕсли Команда.Имя = "УстановитьПериодЧетыреДня" Тогда	
		ВыбранныйПериод 		= 1;
		ВыбранныйПериодТиповой 	= ВыбранныйПериод;
	ИначеЕсли Команда.Имя = "УстановитьПериодНеделя" Тогда	
		ВыбранныйПериод 		= 2;
		ВыбранныйПериодТиповой 	= ВыбранныйПериод;
	ИначеЕсли Команда.Имя = "УстановитьПериодМесяц" Тогда	
		ВыбранныйПериод 		= 3;
		ВыбранныйПериодТиповой 	= ВыбранныйПериод;
	ИначеЕсли Команда.Имя = "УстановитьПериодПроизвольный" Тогда	
		Диалог = Новый ДиалогРедактированияСтандартногоПериода();
		Диалог.Период = ПериодОтбора;
		Диалог.Показать(Новый ОписаниеОповещения("ОтборПериодаПланированииПриИзменении", ЭтаФорма)); 
		ОбновитьДанные = Ложь;
	ИначеЕсли Команда.Имя = "ПериодВперед" Тогда
		СдвинутьВременнойИнтервал 				= Истина;
		НаправлениеДвиженияВременногоИнтервала 	= "Вперед";
	ИначеЕсли Команда.Имя = "ПериодНазад" Тогда
		СдвинутьВременнойИнтервал 				= Истина;
		НаправлениеДвиженияВременногоИнтервала 	= "Назад";		
	КонецЕсли;
	
	Если ОбновитьДанные Тогда 
		ОбновитьДанныеДляОтображения(Истина, СдвинутьВременнойИнтервал, НаправлениеДвиженияВременногоИнтервала);
	КонецЕсли;
	
КонецПроцедуры

