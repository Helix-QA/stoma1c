
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДинамическоеОбновлениеСпискаЗадач = Ложь;
	
	ЗаполнитьСписокНастроек();
	СформироватьПериодОтбора();
	// УстановитьСвойстваОтображенияЭлементов();
	Список.Параметры.УстановитьЗначениеПараметра("ПериодОтбораДатаНачала" 	, ПериодОтбора.ДатаНачала);
	Список.Параметры.УстановитьЗначениеПараметра("ПериодОтбораДатаОкончания", ПериодОтбора.ДатаОкончания);
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Инициализируем настройки при первом открытии формы
	Если ХранилищеСистемныхНастроек.Загрузить("Задача.Взаимодействие.Форма.ФормаСпискаНовая/ТекущиеДанные") = Неопределено Тогда
		Настройки = Новый Соответствие;
		ХранилищеСистемныхНастроек.Сохранить("Задача.Взаимодействие.Форма.ФормаСпискаНовая/ТекущиеДанные", ,Настройки);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);	
	ЭтоКорп = ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП();
	
КонецПроцедуры

&НаСервере
// Процедура - При загрузке данных из настроек на сервере
//
// Параметры:
//  Настройки	 - 	 - 
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	ДинамическоеОбновлениеСпискаЗадач = Истина;
	
	РежимОтображенияФормы_ЗначениеХранилища = Настройки.Получить("РежимОтображенияФормы");
	Если РежимОтображенияФормы_ЗначениеХранилища = Неопределено Тогда 
		ЭтаФорма.РежимОтображенияФормы = 1;
	Иначе 
		ЭтаФорма.РежимОтображенияФормы = РежимОтображенияФормы_ЗначениеХранилища;
	КонецЕсли;	
	Если Параметры.Отбор <> Неопределено И ТипЗнч(Параметры.Отбор) = Тип("Структура") И Параметры.Отбор.Свойство("МассивСтатусовЗадач") Тогда
		Если Параметры.Отбор.МассивСтатусовЗадач.Найти("Просрочена") <> Неопределено Тогда 
			ЭтаФорма.РежимОтображенияФормы = 0;
		КонецЕсли;	
	КонецЕсли;	
	// УстановтьРежимОтображения(Ложь);
	
	ИнициализироватьМеханизмФильтрацииДанных(Параметры.Отбор, Истина);
	СоздатьУсловноеОформление();
	
	Если ЭтаФорма.РежимОтображенияФормы = 0 Тогда
		
		Элементы.ГруппаСписок.Видимость 		 = Истина;
		Элементы.СтраницаПланировщик.Видимость 	 = Ложь;
		Элементы.ГруппаКоманднаяПанель.Видимость = Истина;
		
	ИначеЕсли ЭтаФорма.РежимОтображенияФормы = 1 Тогда
		
		Элементы.ГруппаСписок.Видимость 		 = Ложь;
		Элементы.СтраницаПланировщик.Видимость 	 = Истина; 
		Элементы.ГруппаКоманднаяПанель.Видимость = Ложь;
		ОбновитьДанныеДляОтображения();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)
	
	Если ДинамическоеОбновлениеСпискаЗадач = Ложь Тогда 
		ИнициализироватьМеханизмФильтрацииДанных(Параметры.Отбор, Истина);
		СоздатьУсловноеОформление();
		ДинамическоеОбновлениеСпискаЗадач = Истина;		
    КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ОТБОРЫ_СПИСКА_ВЗАИМОДЕЙСТВИЙ" Тогда 
		ИнициализироватьМеханизмФильтрацииДанных(Параметр.Отбор, Истина);
	КонецЕсли;
	
	Если ИмяСобытия = "ИзменениеЗадачи" Тогда		
		ОбновитьЗанятиеПланировщика(Планировщик, Параметр, РежимОтображенияФормы);
	ИначеЕсли ИмяСобытия = "ОбновлениеМонитораЗадач" Тогда
		ПолучитьЗначенияОтборов();
	ИначеЕсли ИмяСобытия = "ОбновитьСписокЗадачМенеджера" И Не Элементы.ГруппаСписок.Видимость Тогда 
		УстановтьРежимОтображения();		
	КонецЕсли;	

	
КонецПроцедуры

#КонецОбласти

