		ПолучитьЗначенияОтборов();  
		Возврат;
		
	КонецЕсли;
	
	Если ТипЗнч(НовыйПериод)=Тип("СтандартныйПериод") Тогда
		ЭтотОбъект.ОтборДатаЗапланированнойЗадачи = НовыйПериод;
	ИначеЕсли ТипЗнч(НовыйПериод)=Тип("Дата") Тогда
		ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаОкончания = НовыйПериод;
	КонецЕсли;
	
	Элементы.ОтборЗапланированнаяЗадача.Заголовок = РаботаСОтборами.ОбновитьПредставлениеПериода(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи, НСтр("ru='Запланированная задача: ';en='Scheduled task: '"));
	ПолучитьЗначенияОтборов();	
	
	#Если ВебКлиент Тогда
		ОбновитьОтображениеДанных();
	#КонецЕсли 
	
КонецПроцедуры

&НаСервере
// Процедура, СоздатьУсловноеОформление.
//
Процедура СоздатьУсловноеОформление()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(ЭтапыСделок.ЦветЭтапа КАК СТРОКА(100)) КАК ЦветЭтапа
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	НЕ (ВЫРАЗИТЬ(ЭтапыСделок.ЦветЭтапа КАК СТРОКА(100))) = """"";
	
	ТаблицаЦветов = Запрос.Выполнить().Выгрузить();
		
	Для Каждого СтрокаТЧ Из ТаблицаЦветов Цикл
		
		ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЦветЭтапа");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = СтрокаТЧ.ЦветЭтапа;
		ЭлементОтбора.Использование  = Истина;
		
		ЦветЭтапа = ЗначениеИзСтрокиВнутр(СтрокаТЧ.ЦветЭтапа);
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветЭтапа);
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ПолучитьЦветТекстаПоФону(ЦветЭтапа));
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ТекущийЭтапСделки");
		ПолеОформления.Использование = Истина;
		
		// Условное оформление для успеха.
		ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТекущийЭтапСделки");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.ПравоеЗначение = Справочники.ЭтапыСделок.Успех;
		ЭлементОтбора.Использование  = Истина;
		
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветФона"  , Новый Цвет(72, 193, 123));
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(255, 255, 255));
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ТекущийЭтапСделки");
		ПолеОформления.Использование = Истина;
		
		// Условное оформление для отказа.
		ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТекущийЭтапСделки");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Справочники.ЭтапыСделок.Отказ;
		ЭлементОтбора.Использование  = Истина;
		
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветФона"  , Новый Цвет(246, 110, 110));
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста",(Новый Цвет(255, 255, 255)));
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ТекущийЭтапСделки");
		ПолеОформления.Использование = Истина;
		
	КонецЦикла;
	
	// СледующаяЗадача.ЗадачаОписание 
	ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("СледующаяЗадача");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Задачи.Взаимодействие.ПустаяСсылка();
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста",(Новый Цвет(255, 0, 0)));
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Текст", Нстр("ru = 'Запланируйте задачу'; en = 'Schedule task'"));
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("СледующаяЗадача.ЗадачаОписание");
	ПолеОформления.Использование = Истина;
	
	// Этап сделки
	ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТекущаяСделка");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Справочники.Сделки.ПустаяСсылка();
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста",(Новый Цвет(255, 0, 0)));
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Текст", Нстр("ru = 'Запланируйте сделку'; en = 'Schedule deal'"));
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ТекущаяСделка");
	ПолеОформления.Использование = Истина;
	
	// СледующаяЗадача.ЗадачаТема
	ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("СледующаяЗадача.ЗадачаНазначеннаяДата");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Меньше;
	ЭлементОтбора.ПравоеЗначение = ТекущаяДатаСеанса();
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста",(Новый Цвет(255, 0, 0)));
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Текст", Нстр("ru = 'Просрочена'; en = 'Expired'"));
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("СледующаяЗадача.ЗадачаТема");
	ПолеОформления.Использование = Истина;
			
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает цвет текста от передаваемого цвета фона.
//
Функция ПолучитьЦветТекстаПоФону(ЦветФона)
	
	Если (ЦветФона.Зеленый + ЦветФона.Красный + ЦветФона.Синий) > 383 Тогда
		Возврат Новый Цвет(60,60,60);		
	Иначе
		Возврат Новый Цвет(255,255,255);
	КонецЕсли;
	
КонецФункции

