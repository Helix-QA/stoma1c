
#Область ОбработчикиСобытий

&НаКлиенте
// Процедура - Обработка команды
//
// Параметры:
//  ПараметрКоманды				 - 	 - 
//  ПараметрыВыполненияКоманды	 - 	 - 
//
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	// Формируем параметры			
	ПараметрыОтбора = Новый Структура();
	ПараметрыОтбора.Вставить("ОчиститьВсеОтборы"	, Ложь);
	ПараметрыОтбора.Вставить("ПерейтиЗадачиКлиента"	, Истина);
	ОтборКлиент = Новый Массив;
	ОтборКлиент.Добавить(ПараметрКоманды);
	ПараметрыОтбора.Вставить("МассивКлиентов"		, ОтборКлиент);		
	
	// Форму не нашли - открываем	
	ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаСпискаПерейти", Новый Структура("Отбор", ПараметрыОтбора), ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);	
	
КонецПроцедуры

#КонецОбласти
