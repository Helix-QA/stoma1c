// Функция - Контрагент это клиент
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьТипыКонтрагентовПоВидуОперации(ВидОперации, ТипДенежныхСредств)
	
	Массив = Новый Массив;
	
	Если ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыОтПоставщика 
		Или ВидОперации = Перечисления.ВидыОпераций.ОплатаПоставщику Тогда
		
		 Массив.Добавить(Перечисления.ТипыКонтрагентов.Поставщик);
		 
	ИначеЕсли ВидОперации = Перечисления.ВидыОпераций.ВозвратЗайма Тогда
		
    	 Массив.Добавить(Перечисления.ТипыКонтрагентов.Поставщик);
		 Массив.Добавить(Перечисления.ТипыКонтрагентов.Клиенты);
		 Массив.Добавить(Перечисления.ТипыКонтрагентов.КорпоративныеКонтрагенты);
		 
	ИначеЕсли ВидОперации = Перечисления.ВидыОпераций.ОплатаОтСтраховойКомпании Тогда
		 Массив.Добавить(Перечисления.ТипыКонтрагентов.СтраховаяКомпания);
	Иначе
		
		Массив.Добавить(Перечисления.ТипыКонтрагентов.Клиенты);
		
	КонецЕсли;
	
	Возврат Массив;
	
КонецФункции

