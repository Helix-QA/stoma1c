		Элементы._ГруппаНаборПодарков.Видимость 					= Ложь;
		Элементы._ГруппаНаборПокупкиДляПолученияПодарков.Видимость 	= Ложь;				
		ПроцедураОбработкиНажатияМенюНаСервере(Элементы["_ГруппаПолучатели"]);
	КонецЕсли;	

	Элементы["_ГруппаНаборПодарков"].Видимость                    = НЕ Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок;
	Элементы["_ГруппаНаборПокупкиДляПолученияПодарков"].Видимость = Истина;
	
	Если Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок Тогда 
		Если Объект.СкидкаНаЕдиныйКомплект Тогда
			ПроцедураОбработкиНажатияМенюНаСервере(Элементы["_ГруппаНаборПокупкиДляПолученияПодарков"]);		
		Иначе 
			ПроцедураОбработкиНажатияМенюНаСервере(Элементы["_ГруппаНаборПодарков"]);
		КонецЕсли;	
	КонецЕсли;		 
		 
	// СегментБазыРасчетаСкидки
	// Элементы.ГруппаСП2.Видимость = НЕ (Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок);
	// Элементы.ПризнакИспользованиеНаУсмотрение.Видимость = (Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок);
	Элементы.ПризнакИспользованиеНаУсмотрение.Доступность = НЕ (Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВидЦен
																ИЛИ Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВыдачаКарты);
	Элементы.ПризнакИспользованиеПоУмолчанию.Видимость = (Объект.ПризнакИспользованиеНаУсмотрение = Истина);
	
	Элементы.Получатели.ТолькоПросмотр = Ложь;
	// Установка ограничения типа получателя
	Если Объект.ТипПолучателя = Перечисления.ТипыПолучателейСкидкиНаценки.ОграниченоСегментомКлиентов Тогда
		Элементы.ПолучателиПолучатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.СегментыКонтрагентов");
	ИначеЕсли Объект.ТипПолучателя = Перечисления.ТипыПолучателейСкидкиНаценки.ОграниченоСпискомКлиентов Тогда
		Элементы.ПолучателиПолучатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	ИначеЕсли Объект.ТипПолучателя = Перечисления.ТипыПолучателейСкидкиНаценки.ОграниченоВидамиДисконтныхКарт Тогда
		Элементы.ПолучателиПолучатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.ВидыКарт");
	Иначе
		Элементы.ПолучателиПолучатель.ОграничениеТипа = Новый ОписаниеТипов;
		Элементы.Получатели.ТолькоПросмотр            = Истина;
	КонецЕсли;	
	
	Элементы.СтраницыУсловийПредоставленияСкидки.Видимость    = Истина;	
	
	Элементы.ГруппаНеНачислятьБонусПриНаличииСкидки.Видимость = Объект.НачислениеБонусами
	И (Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Всегда
	ИЛИ Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Количество
	ИЛИ Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Сумма
	ИЛИ Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.ОстатокНаЛицевомСчете);
	
	Элементы.ГруппаНеСуммироватьЛицевыеСчетаРодственников.Видимость = Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.ОстатокНаЛицевомСчете;
	Если Элементы.ГруппаНеСуммироватьЛицевыеСчетаРодственников.Видимость = Истина Тогда
		Элементы.ДекорацияНеНачислятьБонусПриНаличииСкидок.Ширина = 30;
	Иначе
		Элементы.ДекорацияНеНачислятьБонусПриНаличииСкидок.Ширина = 25;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДобавитьВПараметрыКэшируемыеДанные()
	
	Параметры.КэшируемыеДанные = Новый Структура;
	
	Параметры.КэшируемыеДанные.Вставить("УсловияПредоставленияСкидки", ВернутьСтруктуруЗначенийПеречисления("УсловияПредоставленияСкидки"));
	Параметры.КэшируемыеДанные.Вставить("ОбъектСкидок", ВернутьСтруктуруЗначенийПеречисления("ОбъектСкидок"));
	Параметры.КэшируемыеДанные.Вставить("Периодичность", ВернутьСтруктуруЗначенийПеречисления("Периодичность"));
	Параметры.КэшируемыеДанные.Вставить("СпособПредоставленияСкидки", ВернутьСтруктуруЗначенийПеречисления("СпособПредоставленияСкидки"));
	
КонецПроцедуры

&НаСервере
Функция ВернутьСтруктуруЗначенийПеречисления(ИмяПеречисления)

	СтруктураОбъекта = Новый Структура;
	
	МетаданныеПеречисления = Перечисления[ИмяПеречисления][0].Метаданные();

	Для Каждого ЭлементМетаданных Из МетаданныеПеречисления.ЗначенияПеречисления Цикл
		СтруктураОбъекта.Вставить(ЭлементМетаданных.Имя, Перечисления[ИмяПеречисления][ЭлементМетаданных.Имя]);
	КонецЦикла;

	Возврат СтруктураОбъекта;

КонецФункции

&НаКлиенте
// Процедура формирует текстовое описание скидки
//
// Параметры
//  Нет
//
Процедура СформироватьОписаниеСкидкиНаценки()
	
	Валюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();

	Если Объект.ТипПолучателя <> ПредопределенноеЗначение("Перечисление.ТипыПолучателейСкидкиНаценки.КлиентРекламныйИсточник") Тогда
		ТекстОписания = НСтр("ru= 'Пациент';en ='patient'");	
	Иначе
		ТекстОписания = НСтр("ru= 'Рекламный источник (пациент клиники)';en ='Advertising source (clinic patient)'");
	КонецЕсли;

	Если Объект.СпособПредоставленияСкидки = Параметры.КэшируемыеДанные.СпособПредоставленияСкидки.Процент Тогда
		Если Объект.УсловиеПредоставленияСкидки = Параметры.КэшируемыеДанные.УсловияПредоставленияСкидки.БонусРефералу Тогда
			ТекстОписания = ТекстОписания + " получит бонус " + Строка(Объект.ЗначениеСкидкиНаценки) + " %";
		Иначе
			Если Объект.ЗначениеСкидкиНаценки <= 0 Тогда
				ТекстОписания = ТекстОписания + " получит наценку " + Строка(-Объект.ЗначениеСкидкиНаценки) + " %";
			Иначе
				ТекстОписания = ТекстОписания + " получит скидку " + Строка(Объект.ЗначениеСкидкиНаценки) + " %";
			КонецЕсли;		
			Если Объект.НачислениеБонусами = Истина Тогда
				ТекстОписания = ТекстОписания + " суммой на бонусный счет";
			Иначе
				ТекстОписания = ТекстОписания + " на сумму документа";
			КонецЕсли;		
			Если ЗначениеЗаполнено(Объект.СегментБазыРасчетаСкидки) Тогда
				ТекстОписания = ТекстОписания + " на номенклатуру сегмента """ + Объект.СегментБазыРасчетаСкидки + """";
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли Объект.СпособПредоставленияСкидки = Параметры.КэшируемыеДанные.СпособПредоставленияСкидки.Сумма
			ИЛИ Объект.СпособПредоставленияСкидки = Параметры.КэшируемыеДанные.СпособПредоставленияСкидки.СуммаНаДокумент Тогда	
			
		Если Объект.ЗначениеСкидкиНаценки <= 0 Тогда
			ТекстОписания = ТекстОписания + " получит наценку " + Строка(-Объект.ЗначениеСкидкиНаценки) + Валюта;
		Иначе
			ТекстОписания = ТекстОписания + " получит скидку " + Строка(Объект.ЗначениеСкидкиНаценки) + Валюта;
		КонецЕсли;		
		Если Объект.НачислениеБонусами = Истина Тогда
			ТекстОписания = ТекстОписания + " суммой на бонусный счет";
		Иначе
			ТекстОписания = ТекстОписания + " на сумму документа";
		КонецЕсли;				
		Если ЗначениеЗаполнено(Объект.СегментБазыРасчетаСкидки) Тогда
			ТекстОписания = ТекстОписания + " на номенклатуру сегмента """ + Объект.СегментБазыРасчетаСкидки + """";
		ИначеЕсли ЗначениеЗаполнено(Объект.СегментНоменклатуры) Тогда
			ТекстОписания = ТекстОписания + " на номенклатуру сегмента """ + Объект.СегментНоменклатуры + """";
		КонецЕсли;
		Если Объект.УсловиеПредоставленияСкидки = Параметры.КэшируемыеДанные.УсловияПредоставленияСкидки.БонусРефералу Тогда
			ТекстОписания = ТекстОписания + " получит бонус " + Строка(Объект.ЗначениеСкидкиНаценки) + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		Иначе 	
			Если Объект.ЗначениеСкидкиНаценки <= 0 Тогда
				ТекстОписания = ТекстОписания + " получит наценку " + Строка(-Объект.ЗначениеСкидкиНаценки) + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
			Иначе
				ТекстОписания = ТекстОписания + " получит скидку " + Строка(Объект.ЗначениеСкидкиНаценки) + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
			КонецЕсли;		
		КонецЕсли;
		
	ИначеЕсли Объект.СпособПредоставленияСкидки = Параметры.КэшируемыеДанные.СпособПредоставленияСкидки.Подарок Тогда		
