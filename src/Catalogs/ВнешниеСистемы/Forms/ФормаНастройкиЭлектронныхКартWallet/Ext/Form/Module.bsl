// Процедура, обработчик события "ДекорацияНастройкиНажатие".
//
Процедура ДекорацияНастройкиНажатие(Элемент)
	
	МассивСоответствий = Новый Массив();
	
	Если ЗначениеЗаполнено(ПараметрыВнешнейСистемы) 
		И ПараметрыВнешнейСистемы.Свойство("ВидыКартПоУмолчанию") Тогда
		
		МассивСоответствий = ПараметрыВнешнейСистемы.ВидыКартПоУмолчанию.МассивСоответствий;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(МассивСоответствий) Тогда
		
		ПустоеЗначение = Новый Структура("СтруктурнаяЕдиница, ВидКарты", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка"), ПредопределенноеЗначение("Справочник.ВидыКарт.ПустаяСсылка"));
		
		МассивСоответствий = Новый_Массив(ПустоеЗначение);
		
	КонецЕсли;
	
	ОткрытьФорму("Справочник.ВидыКарт.Форма.ФормаИмпортаПроектов", Новый Структура("ВидыКарт", МассивСоответствий),,,,, Новый ОписаниеОповещения("ИмпортПроектовЗавершение", ЭтотОбъект));	
	
КонецПроцедуры

