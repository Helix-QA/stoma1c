// Получить массив обязательных для заполнения реквизитов реквизитов
//
Процедура ПолучитьМассивыОбязательныхРеквизитов(ДокументОбъект, МассивОбязательныхРеквизитов) Экспорт
	
	МассивОбязательныхРеквизитов.Добавить("Контрагент");
	МассивОбязательныхРеквизитов.Добавить("СтруктурнаяЕдиница");
	МассивОбязательныхРеквизитов.Добавить("ВидЦен");
	МассивОбязательныхРеквизитов.Добавить("Склад");	
	// ---------------------------Запасы-----------------------------
	МассивОбязательныхРеквизитов.Добавить("Запасы.Номенклатура");
	МассивОбязательныхРеквизитов.Добавить("Запасы.Количество");
	МассивОбязательныхРеквизитов.Добавить("Запасы.КоличествоУпаковок");	
	МассивОбязательныхРеквизитов.Добавить("Запасы.Цена");
	МассивОбязательныхРеквизитов.Добавить("Запасы.СтавкаНДС");	
	// ---------------------------Лечение----------------------------
    МассивОбязательныхРеквизитов.Добавить("Лечение.Номенклатура");
	МассивОбязательныхРеквизитов.Добавить("Лечение.Количество");
    МассивОбязательныхРеквизитов.Добавить("Лечение.КоличествоУпаковок");
	МассивОбязательныхРеквизитов.Добавить("Лечение.Цена");
	МассивОбязательныхРеквизитов.Добавить("Лечение.СтавкаНДС");	

	Если НЕ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьНулевуюСумму, Ложь) Тогда
		МассивОбязательныхРеквизитов.Добавить("Запасы.Сумма");
		МассивОбязательныхРеквизитов.Добавить("Лечение.Сумма");
	КонецЕсли;	
	 
КонецПроцедуры

// Функция вернет массив не повторяющихся ссылок на документы аванса из указанного приема
Функция ПолучитьДокументыАванса(ДокументСсылка) Экспорт
	
	МассивВозврата  = Новый Массив;
	Для Каждого СтрокаТЧ ИЗ ДокументСсылка.Лечение Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) И МассивВозврата.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда
		    МассивВозврата.Добавить(СтрокаТЧ.ДокументАванса);	
		КонецЕсли;
	КонецЦикла;
		Для Каждого  СтрокаТЧ ИЗ ДокументСсылка.Запасы Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) И МассивВозврата.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда
		    МассивВозврата.Добавить(СтрокаТЧ.ДокументАванса);	
		КонецЕсли;
	КонецЦикла;

	Возврат  МассивВозврата;
КонецФункции

// Функция, возвращает данные для возврата.
// 
Функция ПолучитьДанныеВозврата(СтруктурнаяЕдиница
								, Контрагент
								, НачалоПериода = Неопределено
								, КонецПериода = Неопределено
								, ДокументПродажи = Неопределено
								, ИсключениеТекущийДокумент = Неопределено) Экспорт
	
	ТаблицаТоваров        = ПолучитьДанныеВозвратаТоваров(СтруктурнаяЕдиница, Контрагент, НачалоПериода, КонецПериода, ДокументПродажи, ИсключениеТекущийДокумент);
	ТаблицаУслуг          = ПолучитьДанныеВозвратаУслуг(СтруктурнаяЕдиница, Контрагент, НачалоПериода, КонецПериода, ДокументПродажи, ИсключениеТекущийДокумент);
		//ТаблицаСертификатов   = ПолучитьДанныеВозвратаПоСертификатам(СтруктурнаяЕдиница, Контрагент, НачалоПериода, КонецПериода, ДокументПродажи, ИсключениеТекущийДокумент);
		
	Для Каждого СтрокаТ ИЗ ТаблицаТоваров Цикл
		
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТ);
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТ);	

		Если НЕ ЗначениеЗаполнено(СтрокаТ.Партия) Тогда
			СтрокаТ.Партия = Справочники.ПартииНоменклатуры.ПустаяСсылка();
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаТ ИЗ ТаблицаУслуг Цикл
		
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТ);
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТ);	

	КонецЦикла;
	
	Возврат Новый Структура("ТаблицаЗапасы, ТаблицаУслуги", ТаблицаТоваров, ТаблицаУслуг);
	
КонецФункции

// Функция - Получить данные возврата товаров
// 
// Параметры:
//  Дата						 - 	 - 
//  СтруктурнаяЕдиница			 - 	 - 
//  Контрагент					 - 	 - 
//  ДокументПродажи				 - 	 - 
//  ИсключениеТекущийДокумент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьДанныеВозвратаТоваров(СтруктурнаяЕдиница, Контрагент, НачалоПериода = Неопределено, КонецПериода = Неопределено, ДокументПродажи = Неопределено, ИсключениеТекущийДокумент = Неопределено)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемЗапасы.Ссылка КАК Ссылка,
	|	ПриемЗапасы.КлючСтроки КАК КлючСтроки,
	|	ПриемЗапасы.Номенклатура КАК Номенклатура,
	|	ПриемЗапасы.Партия КАК Партия,
	|	ПриемЗапасы.Количество КАК Количество,
	|	ПриемЗапасы.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ПриемЗапасы.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	|	ПриемЗапасы.СуммаАвтоматическойСкидкиНаценки КАК СуммаАвтоматическойСкидкиНаценки,
	|	ПриемЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ПриемЗапасы.Сумма КАК Сумма,
	|	ПриемЗапасы.Цена КАК Цена,
	|	ПриемЗапасы.Ссылка.Склад КАК Склад,
	|	ПриемЗапасы.СтавкаНДС КАК СтавкаНДС,
	|	ПриемЗапасы.СуммаНДС КАК СуммаНДС,
	|	ПриемЗапасы.Упаковка КАК Упаковка,
	|	ПриемЗапасы.Ссылка.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ВременнаяТаблицаПриемыРеализации
	|ИЗ
	|	Документ.Прием.Запасы КАК ПриемЗапасы
	|ГДЕ
	|	ПриемЗапасы.Ссылка.Проведен = ИСТИНА
	|	И (ПриемЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|			ИЛИ ПриемЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество))
	|	И ПриемЗапасы.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ПриемЗапасы.Ссылка.Контрагент = &Контрагент
	|	И &УсловиеНачалоПериодаПрием
	|	И &УсловиеКонецПериодаПрием
	|	И &УсловиеДокументПрием
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияЗапасы.Ссылка,
	|	РеализацияЗапасы.КлючСтроки,
	|	РеализацияЗапасы.Номенклатура,
	|	РеализацияЗапасы.Партия,
	|	РеализацияЗапасы.Количество,
	|	РеализацияЗапасы.КоличествоУпаковок,
	|	РеализацияЗапасы.СуммаРучнойСкидки,
	|	РеализацияЗапасы.СуммаАвтоматическойСкидкиНаценки,
	|	РеализацияЗапасы.ПроцентСкидкиНаценки,
	|	РеализацияЗапасы.Сумма,
	|	РеализацияЗапасы.Цена,
	|	РеализацияЗапасы.Ссылка.Склад,
	|	РеализацияЗапасы.СтавкаНДС,
	|	РеализацияЗапасы.СуммаНДС,
	|	РеализацияЗапасы.Упаковка,
	|	РеализацияЗапасы.Ссылка.Сотрудник
	|ИЗ
	|	Документ.Реализация.Запасы КАК РеализацияЗапасы
	|ГДЕ
	|	РеализацияЗапасы.Ссылка.Проведен = ИСТИНА
	|	И (РеализацияЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|			ИЛИ РеализацияЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество))
	|	И РеализацияЗапасы.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеализацияЗапасы.Ссылка.Контрагент = &Контрагент
	|	И &УсловиеНачалоПериодаРеализация
	|	И &УсловиеКонецПериодаРеализация
	|	И &УсловиеДокументРеализация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВозвратОтПокупателяЗапасы.Ссылка.ДокументОснования КАК ОснованиеВозврата,
	|	ВозвратОтПокупателяЗапасы.КлючСтроки КАК КлючСтроки,
	|	ВозвратОтПокупателяЗапасы.Номенклатура КАК Номенклатура,
	|	ВозвратОтПокупателяЗапасы.Партия КАК Партия,
	|	ВозвратОтПокупателяЗапасы.Упаковка КАК Упаковка,
	|	СУММА(ВозвратОтПокупателяЗапасы.Количество) КАК Количество,
	|	СУММА(ВозвратОтПокупателяЗапасы.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(ВозвратОтПокупателяЗапасы.СуммаРучнойСкидки) КАК СуммаРучнойСкидки,
	|	СУММА(ВозвратОтПокупателяЗапасы.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
	|	СУММА(ВозвратОтПокупателяЗапасы.Сумма) КАК Сумма,
	|	СУММА(ВозвратОтПокупателяЗапасы.Цена) КАК Цена,
	|	ВозвратОтПокупателяЗапасы.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ВозвратОтПокупателяЗапасы.СуммаНДС) КАК СуммаНДС,
	|	ЕСТЬNULL(ВременнаяТаблицаПриемыРеализации.Сотрудник, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК Сотрудник,
	|	ВозвратОтПокупателяЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки
	|ПОМЕСТИТЬ ВременнаяТаблицаВозвраты
	|ИЗ
	|	Документ.ВозвратОтПокупателя.Запасы КАК ВозвратОтПокупателяЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаПриемыРеализации КАК ВременнаяТаблицаПриемыРеализации
	|		ПО ВозвратОтПокупателяЗапасы.КлючСтроки = ВременнаяТаблицаПриемыРеализации.КлючСтроки
	|ГДЕ
	|	ВозвратОтПокупателяЗапасы.Ссылка.Проведен = ИСТИНА
	|	И (ВозвратОтПокупателяЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|			ИЛИ ВозвратОтПокупателяЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество))
	|	И ВозвратОтПокупателяЗапасы.Ссылка.ДокументОснования.Контрагент = &Контрагент
	|	И ВозвратОтПокупателяЗапасы.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И &УсловиеДокументВозвратОтПокупателя
	|	И ВозвратОтПокупателяЗапасы.Ссылка <> &ИсключаемыйДокументВозврата
	|
	|СГРУППИРОВАТЬ ПО
	|	ВозвратОтПокупателяЗапасы.Ссылка.ДокументОснования,
	|	ВозвратОтПокупателяЗапасы.КлючСтроки,
	|	ВозвратОтПокупателяЗапасы.Номенклатура,
	|	ВозвратОтПокупателяЗапасы.Партия,
	|	ВозвратОтПокупателяЗапасы.Упаковка,
	|	ВозвратОтПокупателяЗапасы.СтавкаНДС,
	|	ЕСТЬNULL(ВременнаяТаблицаПриемыРеализации.Сотрудник, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)),
	|	ВозвратОтПокупателяЗапасы.ПроцентСкидкиНаценки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.КлючСтроки КАК КлючСтроки,
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	ВложенныйЗапрос.Партия КАК Партия,
	|	ВложенныйЗапрос.Упаковка КАК Упаковка,
	|	СУММА(ВложенныйЗапрос.Количество) КАК Количество,
	|	СУММА(ВложенныйЗапрос.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(ВложенныйЗапрос.СуммаРучнойСкидки) КАК СуммаРучнойСкидки,
	|	СУММА(ВложенныйЗапрос.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
	|	СУММА(ВложенныйЗапрос.СуммаРучнойСкидки + ВложенныйЗапрос.СуммаАвтоматическойСкидкиНаценки) КАК СуммаСкидки,
	|	ВложенныйЗапрос.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	СУММА(ВложенныйЗапрос.Сумма) КАК Сумма,
	|	СУММА(ВложенныйЗапрос.Сумма) КАК Всего,
	|	ВложенныйЗапрос.Цена КАК Цена,
	|	ВложенныйЗапрос.Склад КАК Склад,
	|	ВложенныйЗапрос.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ВложенныйЗапрос.СуммаНДС) КАК СуммаНДС,
	|	ВложенныйЗапрос.ДокументПродажи КАК ДокументПродажи,
	|	ВложенныйЗапрос.Сотрудник КАК Сотрудник,
	|	ВложенныйЗапрос.ДокументПродажи.Дата КАК ДатаДокумента,
	|	ВложенныйЗапрос.Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|	ВложенныйЗапрос.ДокументПродажи.Представление КАК ДокументПродажиПредставление
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВременнаяТаблицаПриемыРеализации.Ссылка КАК ДокументПродажи,
	|		ВременнаяТаблицаПриемыРеализации.КлючСтроки КАК КлючСтроки,
	|		ВременнаяТаблицаПриемыРеализации.Номенклатура КАК Номенклатура,
	|		ВременнаяТаблицаПриемыРеализации.Партия КАК Партия,
	|		ВременнаяТаблицаПриемыРеализации.Количество - ЕСТЬNULL(ВременнаяТаблицаВозвраты.Количество, 0) КАК Количество,
	|		ВременнаяТаблицаПриемыРеализации.КоличествоУпаковок - ЕСТЬNULL(ВременнаяТаблицаВозвраты.КоличествоУпаковок, 0) КАК КоличествоУпаковок,
	|		ВременнаяТаблицаПриемыРеализации.СуммаРучнойСкидки - ЕСТЬNULL(ВременнаяТаблицаВозвраты.СуммаРучнойСкидки, 0) КАК СуммаРучнойСкидки,
	|		ВременнаяТаблицаПриемыРеализации.СуммаАвтоматическойСкидкиНаценки - ЕСТЬNULL(ВременнаяТаблицаВозвраты.СуммаАвтоматическойСкидкиНаценки, 0) КАК СуммаАвтоматическойСкидкиНаценки,
	|		ВременнаяТаблицаПриемыРеализации.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|		ВременнаяТаблицаПриемыРеализации.Сумма - ЕСТЬNULL(ВременнаяТаблицаВозвраты.Сумма, 0) КАК Сумма,
	|		ВременнаяТаблицаПриемыРеализации.Цена КАК Цена,
	|		ВременнаяТаблицаПриемыРеализации.Склад КАК Склад,
	|		ВременнаяТаблицаПриемыРеализации.СтавкаНДС КАК СтавкаНДС,
	|		ВременнаяТаблицаПриемыРеализации.СуммаНДС - ЕСТЬNULL(ВременнаяТаблицаВозвраты.СуммаНДС, 0) КАК СуммаНДС,
	|		ВременнаяТаблицаПриемыРеализации.Упаковка КАК Упаковка,
	|		ВременнаяТаблицаПриемыРеализации.Сотрудник КАК Сотрудник
	|	ИЗ
	|		ВременнаяТаблицаПриемыРеализации КАК ВременнаяТаблицаПриемыРеализации
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаВозвраты КАК ВременнаяТаблицаВозвраты
	|			ПО ВременнаяТаблицаПриемыРеализации.КлючСтроки = ВременнаяТаблицаВозвраты.КлючСтроки) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Упаковка,
	|	ВложенныйЗапрос.КлючСтроки,
	|	ВложенныйЗапрос.Номенклатура,
	|	ВложенныйЗапрос.Партия,
	|	ВложенныйЗапрос.ПроцентСкидкиНаценки,
	|	ВложенныйЗапрос.Цена,
	|	ВложенныйЗапрос.Склад,
	|	ВложенныйЗапрос.СтавкаНДС,
	|	ВложенныйЗапрос.ДокументПродажи,
	|	ВложенныйЗапрос.Сотрудник,
	|	ВложенныйЗапрос.ДокументПродажи.Дата,
	|	ВложенныйЗапрос.Номенклатура.ТипНоменклатуры,
	|	ВложенныйЗапрос.ДокументПродажи.Представление
	|
	|ИМЕЮЩИЕ
	|	СУММА(ВложенныйЗапрос.КоличествоУпаковок) > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументПродажи УБЫВ");
	
	Если ЗначениеЗаполнено(НачалоПериода) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаПрием"		, "ПриемЗапасы.Ссылка.Дата >= &НачалоПериода");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаРеализация"	, "РеализацияЗапасы.Ссылка.Дата >= &НачалоПериода");		
		Запрос.УстановитьПараметр("НачалоПериода"              , НачалоПериода);		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаПрием"		, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаРеализация"	, "ИСТИНА");		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонецПериода) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаПрием"		, "ПриемЗапасы.Ссылка.Дата <= &КонецПериода");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаРеализация"	, "РеализацияЗапасы.Ссылка.Дата <= &КонецПериода");		
		Запрос.УстановитьПараметр("КонецПериода"              , КонецПериода);		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаПрием"		, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаРеализация"	, "ИСТИНА");		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументПродажи) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументПрием"				, "ПриемЗапасы.Ссылка = &ДокументПродажи");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументРеализация"			, "РеализацияЗапасы.Ссылка = &ДокументПродажи");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументВозвратОтПокупателя"	, "ВозвратОтПокупателяЗапасы.Ссылка.ДокументОснования = &ДокументПродажи");
		Запрос.УстановитьПараметр("ДокументПродажи" 		, ДокументПродажи);		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументПрием"				, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументРеализация"			, "ИСТИНА");		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументВозвратОтПокупателя"	, "ИСТИНА");		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"         , СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Контрагент"                 , Контрагент);
	Запрос.УстановитьПараметр("ИсключаемыйДокументВозврата", ИсключениеТекущийДокумент);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Функция - Получить данные возврата по реализациям для услуг.
// 
// Параметры:
//  Дата						 - 	 - 
//  СтруктурнаяЕдиница			 - 	 - 
//  Контрагент					 - 	 - 
//  ДокументПродажи				 - 	 - 
//  ИсключениеТекущийДокумент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьДанныеВозвратаУслуг(СтруктурнаяЕдиница, Контрагент, НачалоПериода = Неопределено, КонецПериода = Неопределено, ДокументПродажи = Неопределено, ИсключениеТекущийДокумент = Неопределено)

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемУслуги.Ссылка КАК Ссылка,
	|	ПриемУслуги.КлючСтроки КАК КлючСтроки,
	|	ПриемУслуги.Номенклатура КАК Номенклатура,
	|	ПриемУслуги.Количество КАК Количество,
	|	ПриемУслуги.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ПриемУслуги.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	|	ПриемУслуги.СуммаАвтоматическойСкидкиНаценки КАК СуммаАвтоматическойСкидкиНаценки,
	|	ПриемУслуги.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ПриемУслуги.Сумма КАК Сумма,
	|	ПриемУслуги.Цена КАК Цена,
	|	ПриемУслуги.Ссылка.Склад КАК Склад,
	|	ПриемУслуги.СтавкаНДС КАК СтавкаНДС,
	|	ПриемУслуги.СуммаНДС КАК СуммаНДС,
	|	ПриемУслуги.Упаковка КАК Упаковка,
	|	ПриемУслуги.Ссылка.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ВременнаяТаблицаПриемыРеализации
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемУслуги
	|ГДЕ
	|	ПриемУслуги.Ссылка.Проведен = ИСТИНА
	|	И ПриемУслуги.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И ПриемУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ПриемУслуги.Ссылка.Контрагент = &Контрагент
	|	И &УсловиеНачалоПериодаПрием
	|	И &УсловиеКонецПериодаПрием
	|	И &УсловиеДокументПрием
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияУслуги.Ссылка,
	|	РеализацияУслуги.КлючСтроки,
	|	РеализацияУслуги.Номенклатура,
	|	РеализацияУслуги.Количество,
	|	РеализацияУслуги.КоличествоУпаковок,
	|	РеализацияУслуги.СуммаРучнойСкидки,
	|	РеализацияУслуги.СуммаАвтоматическойСкидкиНаценки,
	|	РеализацияУслуги.ПроцентСкидкиНаценки,
	|	РеализацияУслуги.Сумма,
	|	РеализацияУслуги.Цена,
	|	РеализацияУслуги.Ссылка.Склад,
	|	РеализацияУслуги.СтавкаНДС,
	|	РеализацияУслуги.СуммаНДС,
	|	РеализацияУслуги.Упаковка,
	|	РеализацияУслуги.Ссылка.Сотрудник
	|ИЗ
	|	Документ.Реализация.Услуги КАК РеализацияУслуги
	|ГДЕ
	|	РеализацияУслуги.Ссылка.Проведен = ИСТИНА
	|	И РеализацияУслуги.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И РеализацияУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеализацияУслуги.Ссылка.Контрагент = &Контрагент
	|	И &УсловиеНачалоПериодаРеализация
	|	И &УсловиеКонецПериодаРеализация
	|	И &УсловиеДокументРеализация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВозвратОтПокупателяУслуги.Ссылка.ДокументОснования КАК ОснованиеВозврата,
	|	ВозвратОтПокупателяУслуги.КлючСтроки КАК КлючСтроки,
	|	ВозвратОтПокупателяУслуги.Номенклатура КАК Номенклатура,
	|	ВозвратОтПокупателяУслуги.Упаковка КАК Упаковка,
	|	СУММА(ВозвратОтПокупателяУслуги.Количество) КАК Количество,
	|	СУММА(ВозвратОтПокупателяУслуги.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(ВозвратОтПокупателяУслуги.СуммаРучнойСкидки) КАК СуммаРучнойСкидки,
	|	СУММА(ВозвратОтПокупателяУслуги.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
	|	СУММА(ВозвратОтПокупателяУслуги.Сумма) КАК Сумма,
	|	СУММА(ВозвратОтПокупателяУслуги.Цена) КАК Цена,
	|	ВозвратОтПокупателяУслуги.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ВозвратОтПокупателяУслуги.СуммаНДС) КАК СуммаНДС
	|ПОМЕСТИТЬ ВременнаяТаблицаВозвраты
	|ИЗ
	|	Документ.ВозвратОтПокупателя.Лечение КАК ВозвратОтПокупателяУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаПриемыРеализации КАК ВременнаяТаблицаПриемыРеализации
	|		ПО ВозвратОтПокупателяУслуги.КлючСтроки = ВременнаяТаблицаПриемыРеализации.КлючСтроки
	|ГДЕ
	|	ВозвратОтПокупателяУслуги.Ссылка.Проведен = ИСТИНА
	|	И ВозвратОтПокупателяУслуги.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И ВозвратОтПокупателяУслуги.Ссылка.ДокументОснования.Контрагент = &Контрагент
	|	И ВозвратОтПокупателяУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И &УсловиеДокументВозвратОтПокупателя
	|	И ВозвратОтПокупателяУслуги.Ссылка <> &ИсключаемыйДокументВозврата
	|
	|СГРУППИРОВАТЬ ПО
	|	ВозвратОтПокупателяУслуги.Ссылка.ДокументОснования,
	|	ВозвратОтПокупателяУслуги.КлючСтроки,
	|	ВозвратОтПокупателяУслуги.Номенклатура,
	|	ВозвратОтПокупателяУслуги.Упаковка,
	|	ВозвратОтПокупателяУслуги.СтавкаНДС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.КлючСтроки КАК КлючСтроки,
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	ВложенныйЗапрос.Упаковка КАК Упаковка,
	|	СУММА(ВложенныйЗапрос.Количество) КАК Количество,
	|	СУММА(ВложенныйЗапрос.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(ВложенныйЗапрос.СуммаРучнойСкидки) КАК СуммаРучнойСкидки,
	|	СУММА(ВложенныйЗапрос.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
	|	СУММА(ВложенныйЗапрос.СуммаРучнойСкидки + ВложенныйЗапрос.СуммаАвтоматическойСкидкиНаценки) КАК СуммаСкидки,
	|	ВложенныйЗапрос.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	СУММА(ВложенныйЗапрос.Сумма) КАК Сумма,
	|	СУММА(ВложенныйЗапрос.Сумма) КАК Всего,
	|	ВложенныйЗапрос.Цена КАК Цена,
	|	ВложенныйЗапрос.Склад КАК Склад,
	|	ВложенныйЗапрос.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ВложенныйЗапрос.СуммаНДС) КАК СуммаНДС,
	|	ВложенныйЗапрос.ДокументПродажи КАК ДокументПродажи,
	|	ВложенныйЗапрос.ДокументПродажи.Дата КАК ДатаДокумента,
	|	ВложенныйЗапрос.Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|	ВложенныйЗапрос.ДокументПродажи.Представление КАК ДокументПродажиПредставление
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВременнаяТаблицаПриемыРеализации.Ссылка КАК ДокументПродажи,
	|		ВременнаяТаблицаПриемыРеализации.КлючСтроки КАК КлючСтроки,
	|		ВременнаяТаблицаПриемыРеализации.Номенклатура КАК Номенклатура,
	|		ВременнаяТаблицаПриемыРеализации.Количество - ЕСТЬNULL(ВременнаяТаблицаВозвраты.Количество, 0) КАК Количество,
	|		ВременнаяТаблицаПриемыРеализации.КоличествоУпаковок - ЕСТЬNULL(ВременнаяТаблицаВозвраты.КоличествоУпаковок, 0) КАК КоличествоУпаковок,
	|		ВременнаяТаблицаПриемыРеализации.СуммаРучнойСкидки - ЕСТЬNULL(ВременнаяТаблицаВозвраты.СуммаРучнойСкидки, 0) КАК СуммаРучнойСкидки,
	|		ВременнаяТаблицаПриемыРеализации.СуммаАвтоматическойСкидкиНаценки - ЕСТЬNULL(ВременнаяТаблицаВозвраты.СуммаАвтоматическойСкидкиНаценки, 0) КАК СуммаАвтоматическойСкидкиНаценки,
	|		ВременнаяТаблицаПриемыРеализации.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|		ВременнаяТаблицаПриемыРеализации.Сумма - ЕСТЬNULL(ВременнаяТаблицаВозвраты.Сумма, 0) КАК Сумма,
	|		ВременнаяТаблицаПриемыРеализации.Цена КАК Цена,
	|		ВременнаяТаблицаПриемыРеализации.Склад КАК Склад,
	|		ВременнаяТаблицаПриемыРеализации.СтавкаНДС КАК СтавкаНДС,
	|		ВременнаяТаблицаПриемыРеализации.СуммаНДС - ЕСТЬNULL(ВременнаяТаблицаВозвраты.СуммаНДС, 0) КАК СуммаНДС,
	|		ВременнаяТаблицаПриемыРеализации.Упаковка КАК Упаковка
	|	ИЗ
	|		ВременнаяТаблицаПриемыРеализации КАК ВременнаяТаблицаПриемыРеализации
	|			ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаВозвраты КАК ВременнаяТаблицаВозвраты
	|			ПО ВременнаяТаблицаПриемыРеализации.КлючСтроки = ВременнаяТаблицаВозвраты.КлючСтроки) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Упаковка,
	|	ВложенныйЗапрос.КлючСтроки,
	|	ВложенныйЗапрос.Номенклатура,
	|	ВложенныйЗапрос.ПроцентСкидкиНаценки,
	|	ВложенныйЗапрос.Цена,
	|	ВложенныйЗапрос.Склад,
	|	ВложенныйЗапрос.СтавкаНДС,
	|	ВложенныйЗапрос.ДокументПродажи,
	|	ВложенныйЗапрос.ДокументПродажи.Дата,
	|	ВложенныйЗапрос.Номенклатура.ТипНоменклатуры,
	|	ВложенныйЗапрос.ДокументПродажи.Представление
	|
	|ИМЕЮЩИЕ
	|	СУММА(ВложенныйЗапрос.КоличествоУпаковок) > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументПродажи УБЫВ");	
	
	Если ЗначениеЗаполнено(НачалоПериода) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаПрием"		, "ПриемУслуги.Ссылка.Дата >= &НачалоПериода");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаРеализация"	, "РеализацияУслуги.Ссылка.Дата >= &НачалоПериода");		
		Запрос.УстановитьПараметр("НачалоПериода"              , НачалоПериода);		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаПрием"		, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНачалоПериодаРеализация"	, "ИСТИНА");		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонецПериода) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаПрием"		, "ПриемУслуги.Ссылка.Дата <= &КонецПериода");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаРеализация"	, "РеализацияУслуги.Ссылка.Дата <= &КонецПериода");		
		Запрос.УстановитьПараметр("КонецПериода"              , КонецПериода);		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаРеализация"				, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонецПериодаВводНачальныхОстатков"	, "ИСТИНА");		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументПродажи) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументПрием"				, "ПриемУслуги.Ссылка = &ДокументПродажи");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументРеализация"			, "РеализацияУслуги.Ссылка = &ДокументПродажи");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументВозвратОтПокупателя" 	, "ВозвратОтПокупателяУслуги.Ссылка.ДокументОснования = &ДокументПродажи");
		Запрос.УстановитьПараметр("ДокументПродажи"            , ДокументПродажи);		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументПрием"				, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументРеализация"			, "ИСТИНА");		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДокументВозвратОтПокупателя"	, "ИСТИНА");		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"         , СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Контрагент"                 , Контрагент);
	Запрос.УстановитьПараметр("ИсключаемыйДокументВозврата", ИсключениеТекущийДокумент);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
			
	Возврат РезультатЗапроса;
		
КонецФункции

// Функция - Получить объединенную таблицу данных возврата.
//
Функция ПолучитьОбъединеннуюТаблицуДанныхВозврата(СтруктурнаяЕдиница
												, Контрагент
												, НачалоПериода = Неопределено
												, КонецПериода = Неопределено
												, ДокументПродажи = Неопределено
												, ИсключениеТекущийДокумент = Неопределено) Экспорт

	ДанныеВозврата = ПолучитьДанныеВозврата(СтруктурнаяЕдиница
											, Контрагент
											, НачалоПериода
											, КонецПериода
											, ДокументПродажи
											, ИсключениеТекущийДокумент);
		
	РезультирующаяТаблица = ДанныеВозврата.ТаблицаЗапасы.Скопировать();	
	
	ОбщегоНазначения.ОбъединитьТаблицыЗначений(РезультирующаяТаблица, ДанныеВозврата.ТаблицаУслуги);	
	РезультирующаяТаблица.Сортировать("ДатаДокумента Убыв");
	
	Возврат РезультирующаяТаблица;
												
КонецФункции												
												
												
