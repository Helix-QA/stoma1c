			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ИсточникЗаписи) И ТипЗнч(ДанныеТриггера.ИсточникЗаписи) = Тип("СправочникСсылка.ИсточникиЗаписей") Тогда
			Запрос.УстановитьПараметр("ИсточникЗаписи", ДанныеТриггера.ИсточникЗаписи);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.ИсточникЗаписи = &ИсточникЗаписи", "ИСТИНА");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СтатусЗаписи) Тогда 
			Запрос.УстановитьПараметр("ПереходНаСтатус", ДанныеТриггера.СтатусЗаписи);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Статус = &ПереходНаСтатус", "ИСТИНА");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментУслуг) Тогда 
		//	Если ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.Номенклатура") Тогда 
		//		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗанятиеСоставЗанятия.Ссылка.Номенклатура В(&СегментУслуг)", "ЗанятиеСоставЗанятия.Ссылка.Номенклатура = &СегментУслуг");
		//		Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
		//	ИначеЕсли ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
		//		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗанятиеСоставЗанятия.Ссылка.Номенклатура В(&СегментУслуг)",
		//		"ЗанятиеСоставЗанятия.Ссылка.Номенклатура В
		//		|			(ВЫБРАТЬ
		//		|				СоставСегментов.ОбъектСегмента
		//		|			ИЗ
		//		|				РегистрСведений.СоставСегментов КАК СоставСегментов
		//		|			ГДЕ
		//		|				СоставСегментов.Сегмент = &СегментУслуг)");
		//		Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
		//	КонецЕсли;	
		// Иначе 
		//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗанятиеСоставЗанятия.Ссылка.Номенклатура В(&СегментУслуг)", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		
#КонецОбласти
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
