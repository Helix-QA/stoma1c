&НаСервере
// Процедура - обработчик события ПриОткрытии формы.
//
Процедура ОбновитьТаблицуСотрудников()
	
	Если (ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач или ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач)
		и ПЗОтборПоСотрудникамРежимФильтра = 0 Тогда
		ДеревоСотрудниковРучн.ПолучитьЭлементы().Очистить();
		СтрокаРодитель1                     = ДеревоСотрудниковРучн.ПолучитьЭлементы().Добавить();
		СтрокаРодитель1.Сотрудник           = ?(ЗначениеЗаполнено(ПараметрыСеанса.ТекущийПользователь.Сотрудник), ПараметрыСеанса.ТекущийПользователь.Сотрудник, "Все");		
		СтрокаРодитель1.ИндексКартинки      = ?(ЗначениеЗаполнено(ПараметрыСеанса.ТекущийПользователь.Сотрудник),2, 0);
		СтрокаРодитель1.Доступность         = Истина;	
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкаСотрудников.Сотрудник КАК Сотрудник,
	|	НастройкаСотрудников.Сотрудник.Должность КАК Должность
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкаСотрудников
	|ГДЕ
	|	НастройкаСотрудников.Сотрудник.ПометкаУдаления = ЛОЖЬ
	|	И НастройкаСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|	И НастройкаСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВЫБОР
	|			КОГДА &ОтоборСотрудниковСУчетомГрафикаРаботы = ИСТИНА
	|				ТОГДА НастройкаСотрудников.Сотрудник В
	|						(ВЫБРАТЬ
	|							РабочиеДниСотрудников.Сотрудник
	|						ИЗ
	|							РегистрСведений.ВремяРаботыСотрудниковПлан КАК РабочиеДниСотрудников
	|						ГДЕ
	|							НАЧАЛОПЕРИОДА(РабочиеДниСотрудников.ДатаВремяНачала, ДЕНЬ) >= НАЧАЛОПЕРИОДА(&ДатаНачала, ДЕНЬ)
	|							И НАЧАЛОПЕРИОДА(РабочиеДниСотрудников.ДатаВремяНачала, ДЕНЬ) <= НАЧАЛОПЕРИОДА(&ДатаКонца, ДЕНЬ)
	|							И РабочиеДниСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА НЕ НастройкаСотрудников.Сотрудник.Должность = ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
	|				ТОГДА НастройкаСотрудников.Сотрудник.Должность.ОтображатьВЖурналеПредварительнойЗаписи = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	НастройкаСотрудников.Сотрудник,
	|	НастройкаСотрудников.Сотрудник.Должность
	|
	|УПОРЯДОЧИТЬ ПО
	|	НастройкаСотрудников.Сотрудник.Наименование
	|ИТОГИ ПО
	|	Должность";
	
	Если ПЗГрафикаРежимотОбражения = 0 Тогда		 
		ДатаНачало = НачалоДня(Объект.Дата);
		ДатаКонец  = КонецДня(Объект.Дата);
	ИначеЕсли ПЗГрафикаРежимотОбражения = 1 Тогда
		ДатаНачало = НачалоНедели(Объект.Дата);
		ДатаКонец  = КонецНедели(Объект.Дата);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"                   , Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ОтоборСотрудниковСУчетомГрафикаРаботы", ПЗОтборПоСотрудникамРежимФильтра = 1);
	Запрос.УстановитьПараметр("ДатаНачала"                           , ДатаНачало);
	Запрос.УстановитьПараметр("ДатаКонца"                            , ДатаКонец);
	ТаблицаСотрудников = Запрос.Выполнить().Выгрузить();
	
	
	ДеревоСотрудниковРучн.ПолучитьЭлементы().Очистить();	
	// В зависимости от режима графика ПЗ выставляем возможность отбора по всем сотрудникам
	Если ПЗГрафикаРежимотОбражения = 0  Тогда
		СтрокаРодитель1                     = ДеревоСотрудниковРучн.ПолучитьЭлементы().Добавить();
		СтрокаРодитель1.Сотрудник           = "Все";
		СтрокаРодитель1.ИндексКартинки      = 0;
		СтрокаРодитель1.Доступность         = Истина;
		Если СтрокаРодитель1.Сотрудник      = ПЗФиьтрГрафикаТекущаяСтрока Тогда				
			ТекущаяСтрока = СтрокаРодитель1;
		КонецЕсли;
	Иначе
		СтрокаРодитель1 = ДеревоСотрудниковРучн;
	КонецЕсли;
	
	ТекущаяСтрока          = Неопределено;
	// Заполнение дерева сотрудников
	Для Каждого СтрокаСотрудник из  ТаблицаСотрудников Цикл
		Если Не ЗначениеЗаполнено(СтрокаСотрудник.Сотрудник) Тогда
			СтрокаРодитель2                     = СтрокаРодитель1.ПолучитьЭлементы().Добавить();
			СтрокаРодитель2.Сотрудник           = СтрокаСотрудник.Должность;
			Если ПЗФиьтрГрафикаТекущаяСтрока = СтрокаРодитель2.Сотрудник И ПЗГрафикаРежимотОбражения = 0 Тогда 
				ТекущаяСтрока = СтрокаРодитель2;
			КонецЕсли;	 
			СтрокаРодитель2.ИндексКартинки      = 0;
			СтрокаРодитель2.Доступность         = ?(Элементы.Неделя.Пометка, Ложь, Истина);			
		Иначе	
			СтрокаРодитель3                     = СтрокаРодитель2.ПолучитьЭлементы().Добавить();
			СтрокаРодитель3.Сотрудник           = СтрокаСотрудник.Сотрудник;
			Если ПЗФиьтрГрафикаТекущаяСтрока = СтрокаРодитель3.Сотрудник Тогда
				ТекущаяСтрока = СтрокаРодитель3;
			КонецЕсли;
			
			СтрокаРодитель3.ИндексКартинки = 2;
			СтрокаРодитель3.Доступность    = Истина;
		КонецЕсли;
	КонецЦикла;
	
	// Установим текущего сотрудника
	Если ПЗГрафикаРежимОтображения = 1 Тогда
		Если ЗначениеЗаполнено(ВыбранныйСотрудник_РежимНеделя) Тогда 
			ЭлВерхнегоУровня = ДеревоСотрудниковРучн.ПолучитьЭлементы();
			ПрерватьЦикл = Ложь;
			Для Каждого ЭлементВерхнегоУровня Из ЭлВерхнегоУровня Цикл 
				ЭлНижнегоУровня = ЭлементВерхнегоУровня.ПолучитьЭлементы();
				Для Каждого ЭлементНижнегоУровня Из ЭлНижнегоУровня Цикл
					Если ЭлементНижнегоУровня.Сотрудник = ВыбранныйСотрудник_РежимНеделя Тогда 
						ТекущаяСтрока = ЭлементНижнегоУровня;
						ПЗФиьтрГрафикаТекущаяСтрока = ЭлементНижнегоУровня.Сотрудник;
						ПрерватьЦикл = Истина;
						Прервать;
					КонецЕсли;				
				КонецЦикла;
				Если ПрерватьЦикл Тогда 
					Прервать;
				КонецЕсли;	
			КонецЦикла;
		Иначе
			Если ТекущаяСтрока = Неопределено Тогда
				ЭлВерхнегоУровня = ДеревоСотрудниковРучн.ПолучитьЭлементы();
				Если ЭлВерхнегоУровня.Количество() > 0 Тогда
					ЭлНижнегоУровня = ЭлВерхнегоУровня[0].ПолучитьЭлементы();
					Если ЭлНижнегоУровня.Количество() > 0 Тогда
						ТекущаяСтрока               	= ЭлНижнегоУровня[0];
						ПЗФиьтрГрафикаТекущаяСтрока 	= ЭлНижнегоУровня[0].Сотрудник;
						ВыбранныйСотрудник_РежимНеделя 	= ЭлНижнегоУровня[0].Сотрудник;
					КонецЕсли;
				КонецЕсли;
			Иначе 
				ВыбранныйСотрудник_РежимНеделя 	= ТекущаяСтрока.Сотрудник;
			КонецЕсли;				
		КонецЕсли;
	ИначеЕсли ПЗГрафикаРежимОтображения = 0 Тогда
		ЭлВерхнегоУровня = ДеревоСотрудниковРучн.ПолучитьЭлементы();
		Для Каждого ЭлементВерхнегоУровня Из ЭлВерхнегоУровня Цикл
			Если ТипЗнч(ЭлементВерхнегоУровня.Сотрудник) = Тип("Строка") И ЭлементВерхнегоУровня.Сотрудник = "Все" Тогда 
				ТекущаяСтрока = ЭлементВерхнегоУровня;
				ПЗФиьтрГрафикаТекущаяСтрока = ЭлементВерхнегоУровня.Сотрудник;
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;	
	
	// Если не удалось найти предыдущий выбранный элемент, берем первый в дереве	
	Если ТекущаяСтрока = Неопределено Тогда
		ЭлВерхнегоУровня = ДеревоСотрудниковРучн.ПолучитьЭлементы();
		Если ЭлВерхнегоУровня.Количество() > 0 Тогда
			Если ПЗГрафикаРежимотОбражения = 0 Тогда
				ТекущаяСтрока               = ЭлВерхнегоУровня[0];
				ПЗФиьтрГрафикаТекущаяСтрока = ЭлВерхнегоУровня[0].Сотрудник;
			Иначе
				ЭлНижнегоУровня = ЭлВерхнегоУровня[0].ПолучитьЭлементы();
				Если ЭлНижнегоУровня.Количество() > 0 Тогда
					ТекущаяСтрока               = ЭлНижнегоУровня[0];
					ПЗФиьтрГрафикаТекущаяСтрока = ЭлНижнегоУровня[0].Сотрудник;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Позиционирование текущего элемента
	Если НЕ ТекущаяСтрока = Неопределено Тогда
		Элементы.ДеревоСотрудников.ТекущаяСтрока = ТекущаяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Рекурсивное заполнение дерева
//
Функция ДобавитьВДеревоРекурсивно(ДеревоИсточник, ДеревоПриемник)
	
	ТекущаяСтрока = Неопределено;
	Если Не ДеревоИсточник.Помещение.Пустая() Тогда
		НовыйЭлемент             = ДеревоПриемник.ПолучитьЭлементы().Добавить();
		НовыйЭлемент.Помещение   = ДеревоИсточник.Помещение;
		НовыйЭлемент.ИндексКартинки = ?(НовыйЭлемент.Помещение.ЭтоГруппа, 0, 2);
		НовыйЭлемент.Доступность = ?(НовыйЭлемент.Помещение.ЭтоГруппа И ПЗГрафикаРежимОтображения = 1, Ложь, Истина);	
		// Проверка на возможность позиционирования
		Если НовыйЭлемент.Помещение = ПЗФиьтрГрафикаТекущаяСтрока Тогда
			ТекущаяСтрока = НовыйЭлемент;
		КонецЕсли;	
	Иначе
		НовыйЭлемент = ДеревоПриемник;
	КонецЕсли;
	// Рекурсивный вызов
	Для Каждого ЭлементДерева Из ДеревоИсточник.Строки Цикл
		Временная    =  ДобавитьВДеревоРекурсивно(ЭлементДерева, НовыйЭлемент);
		Если НЕ Временная = Неопределено Тогда
			ТекущаяСтрока = Временная;
		КонецЕсли;
	КонецЦикла;	
	Возврат ТекущаяСтрока;
	
КонецФункции

////////////////////////// ОБРАБОТЧИКИ КОМАНДНОЙ ПАНЕЛИ ТАБЛИЦЫ ЗАДАЧ///////////////////////////

&НаКлиенте
// Процедура, обработчик "ПриИзменении" таблицы задач
//
Процедура ТаблицаЗадачиПриИзменении(Элемент)
	
	Задача = Элементы.ТаблицаЗадачи.ТекущиеДанные;
	Если Задача <> Неопределено Тогда 
		ИзменитьПометкуАктивности(Задача.Ссылка);
	КонецЕсли;
	Элементы.ТаблицаЗадачи.Обновить();	
	
КонецПроцедуры

&НаСервере
// Процедура изменяет пометку активности исходя из пометки на удаление
//
Процедура ИзменитьПометкуАктивности(Задача)
	
	Если Задача.ПометкаУдаления Тогда 
		ЗадачаОбъект                         = Задача.ПолучитьОбъект();
		ЗадачаОбъект.НапоминаниеИспользовать = Ложь;
		ЗадачаОбъект.Записать();
	ИначеЕсли НЕ Задача.ПометкаУдаления Тогда 
		ЗадачаОбъект                         = Задача.ПолучитьОбъект();
		ЗадачаОбъект.НапоминаниеИспользовать = Истина;
		ЗадачаОбъект.Записать(); 		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "Создать"
//
Процедура СоздатьЗадачу(Команда)
	
	Параметр = Новый Структура;
	Если Не Контрагент.Пустая() Тогда	
		Параметр.Вставить("Предмет", Контрагент);	
	КонецЕсли;
	
	ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаЗадачи", Параметр, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "Отработано"
//
Процедура Отработано(Команда)
	
	Если Элементы.ТаблицаЗадачи.ТекущиеДанные <> Неопределено Тогда
		УстановитьОтработку(Элементы.ТаблицаЗадачи.ТекущиеДанные.Ссылка);
		Элементы.ТаблицаЗадачи.Обновить();
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет установку активности Задачи "ЗадачаПользователей"
//
Процедура УстановитьОтработку(ЗадачаСсылка)
	
	ЗадачаОбъект                = ЗадачаСсылка.ПолучитьОбъект();
	ЗадачаОбъект.ДатаИсполнения = ТекущаяДата();
	ЗадачаОбъект.Выполнена      = Истина;
	ЗадачаОбъект.Записать();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "АктивныеЗадачи"
//
Процедура АктивныеЗадачи(Команда)
	
	Элементы.ТаблицаЗадачиКнопкаАктивные.Пометка = Не Элементы.ТаблицаЗадачиКнопкаАктивные.Пометка;
	Если Элементы.ТаблицаЗадачиКнопкаАктивные.Пометка Тогда
		ТаблицаЗадачи.Параметры.УстановитьЗначениеПараметра("Отработано", Ложь);
	Иначе 
		ТаблицаЗадачи.Параметры.УстановитьЗначениеПараметра("Отработано", Истина);
	КонецЕсли;
	Элементы.ТаблицаЗадачи.Обновить();
	
КонецПроцедуры

&НаКлиенте
//
//
Процедура ВходящийЗвонок(Команда)
	
	ПараметрыОткрытия = Новый Структура("Клиент", Контрагент);
	ОткрытьФорму("Документ.Взаимодействие.Форма.ФормаДокумента", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Записать на прием.
//
Процедура ЗаписатьНаПрием(Команда)
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
		
		ПараметрыОткрытия = Новый Структура("Контрагент, ЗакрыватьПриИзмененииСобытия", Контрагент, Ложь);
		
		ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыОткрытия, "ФормаЗаписи");
		
		Форма = ПолучитьФорму(ИмяФормыПланировщика, ПараметрыОткрытия,, "ФормаПланировщикКлючУникальности");
		Форма.Открыть();
		
		Оповестить("СозданиеСобытияСКонтрагентом", ПараметрыОткрытия);

	КонецЕсли;

КонецПроцедуры

