
#Область ПрограммныйИнтерфейс

// Функция - Запуск при начале работы системы разрешен.
// 
Функция ЗапускПриНачалеРаботыСистемыРазрешен() Экспорт
	
	Возврат (НЕ ОбновлениеИнформационнойБазы.НеобходимоОбновлениеИнформационнойБазы());
		
КонецФункции

// Функция - Кассовый сервер в системе используется
// 
// Возвращаемое значение:
//   - 
//
Функция ВТекущемСеансеРазрешенЗапускКассовогоСервера() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = КассовыйСервер.ВТекущемСеансеРазрешенЗапускКассовогоСервера();
	Возврат Результат;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецФункции

// Функция - Касса кассового сервера
// 
// Возвращаемое значение:
//   - 
//
Функция КассаКассовогоСервера(Организация = Неопределено) Экспорт
	
	Параметры = ПодключаемоеОборудованиеКассовыйСервер.ПараметрыКассовогоСервера(Организация);
	Возврат ?(Параметры <> Неопределено И Параметры.Свойство("КассаОплаты"), Параметры.КассаОплаты, Неопределено);
	
КонецФункции

// Функция - Получить рабочее место кассового сервера
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьРабочееМестоКассовогоСервера() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Касса = КассовыйСерверПовтИсп.КассаКассовогоСервера();
	РабочееМесто = ?(ЗначениеЗаполнено(Касса), Касса.ВнешнееОборудование.РабочееМесто, Неопределено);
	
	УстановитьПривилегированныйРежим(Ложь);

	Возврат РабочееМесто;
	
КонецФункции

// Функция - Кассовы сервер работает в режиме сеанс пользователя
// 
// Возвращаемое значение:
//   - 
//
Функция КассовыСерверРаботаетВРежимеСеансПользователя() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = ПодключаемоеОборудованиеКассовыйСервер.РежимРаботыКассовогоСервера() = 2;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Результат;
	
КонецФункции

// Функция - Получить дату отбора из очереди кассового сервера
//
// Параметры:
//  КассаОплаты	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДатуОтбораИзОчередиКассовогоСервера(КассаОплаты) Экспорт
	
	Возврат КассовыйСервер.ПолучитьДатуОтбораИзОчередиКассовогоСервера(КассаОплаты);	

КонецФункции


#КонецОбласти

