&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
	Если Параметры.Свойство("Контрагент") Тогда
		Объект.Контрагент = Параметры.Контрагент; 
	КонецЕсли;
	
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.ДатаДоговора = ТекущаяДатаСеанса();
	КонецЕсли;
	
	// Формирует переключатель закладок
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("ОтборНоменклатуры"	, "ГруппаОтборНоменклатуры");
	СтруктураМеню.Вставить("ОграничениеЗубов"	, "ГруппаОграничениеЗубов");
	
	Если Объект.Ссылка.Пустая() = Ложь Тогда
		СтруктураМеню.Вставить("ОтборПолисы"		, "ГруппаПолисы");		
		ЭтотОбъект.Полисы.Параметры.УстановитьЗначениеПараметра("Договор", Объект.Ссылка);	
	КонецЕсли;
	Если Объект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания Тогда 	
		ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	КонецЕсли;
	УстановитьВидимостьИЗаголовки();
	ЭтаФорма.ОснованаяКопияСсылка = ?(ЗначениеЗаполнено(Параметры.ЗначениеКопирования), Параметры.ЗначениеКопирования, Неопределено);
	ЗаполнитьДерево(ОснованаяКопияСсылка);
	ЗаполнитьДеревоНоменклатур(ОснованаяКопияСсылка);
	УстановитьНачальныеФлагиНаГруппы();
	УстановитьДоступностьДобавленияУслугНаСервере();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события формы "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УстановитьФильтр();
	УстановитьВидимостьМеток();

КонецПроцедуры

