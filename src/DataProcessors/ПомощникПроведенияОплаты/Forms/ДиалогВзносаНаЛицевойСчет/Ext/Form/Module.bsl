&НаСервере
// Функция рекурсивного поиска в дереве доступных видов оплаты.
//
Функция НайтиВДеревеДоступныхВидовОплатСервер(	
	ТипДенСредств,
	ЛицевойСчет = Неопределено,								 
	ЭквайрингНомерПлатежнойКарты = Неопределено,
	ИсточникДанных = Неопределено,
	ПервуюСтроку = Ложь,
	ПоследнююСтроку = Ложь,
	ЭквайринговыйТерминал = Неопределено)
	
	Если ИсточникДанных = Неопределено Тогда
		ИсточникДанных = ЭтотОбъект.ВидыОплат;
	КонецЕсли;
	
	МассивСтрок = Новый Массив;
	
	Для Каждого ЭлементВерхУр ИЗ ИсточникДанных.ПолучитьЭлементы() Цикл	
		
		Если ЭлементВерхУр.ТипДенежныхСредств <> ТипДенСредств Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Если ЛицевойСчет = Неопределено 
			И ЭквайрингНомерПлатежнойКарты = Неопределено 
			И ЭквайринговыйТерминал = Неопределено Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если ЛицевойСчет <> Неопределено 
			И ЭлементВерхУр.ЛицевойСчет = ЛицевойСчет Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если ЭквайрингНомерПлатежнойКарты <> Неопределено 
			И ЭлементВерхУр.ЭквайрингНомерПлатежнойКарты = ЭквайрингНомерПлатежнойКарты Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если ЭквайринговыйТерминал <> Неопределено 
			И ЭлементВерхУр.ЭквайринговыйТерминал = ЭквайринговыйТерминал Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Для Каждого ЭлементНизУр ИЗ ЭлементВерхУр.ПолучитьЭлементы() Цикл	
			
			Если ЭлементНизУр.ТипДенежныхСредств <> ТипДенСредств Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			Если ЛицевойСчет = Неопределено 
				И ЭквайрингНомерПлатежнойКарты = Неопределено
				И ЭквайринговыйТерминал = Неопределено Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ЛицевойСчет <> Неопределено 
				И ЭлементНизУр.ЛицевойСчет = ЛицевойСчет Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ЭквайрингНомерПлатежнойКарты <> Неопределено 
				И ЭлементНизУр.ЭквайрингНомерПлатежнойКарты = ЭквайрингНомерПлатежнойКарты Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ЭквайринговыйТерминал <> Неопределено 
				И ЭлементНизУр.ЭквайринговыйТерминал = ЭквайринговыйТерминал Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если ПервуюСтроку = Истина Тогда
		Если МассивСтрок.Количество() > 0 Тогда
			Возврат МассивСтрок[0];
		Иначе
			Возврат Неопределено;
		КонецЕсли;		
	ИначеЕсли ПоследнююСтроку = Истина Тогда
		Если МассивСтрок.Количество() > 0 Тогда
			Возврат МассивСтрок[МассивСтрок.Количество() - 1];
		Иначе
			Возврат Неопределено;
		КонецЕсли;		
	Иначе	
		Возврат МассивСтрок;
	КонецЕсли;
	
КонецФункции

