
#Область ОбработчикиКомандФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	ДоступноРедактированиеПоПравам 				= ДоступноРедактированияВидовВзаимодействий();
	ДоступноРедактированиеТипВзаимодействия 	= НЕ Объект.Предопределенный ИЛИ (Объект.Предопределенный И НЕ ЗначениеЗаполнено(Объект.ВидВзаимодействия));
	Элементы.Наименование.ТолькоПросмотр      	= НЕ ДоступноРедактированиеПоПравам ИЛИ Объект.Предопределенный;
	Элементы.ВидВзаимодействия.ТолькоПросмотр 	= НЕ ДоступноРедактированиеПоПравам ИЛИ НЕ ДоступноРедактированиеТипВзаимодействия;
	
	Если Объект.Предопределенный Тогда 
		Элементы.Код.ТолькоПросмотр = Объект.Предопределенный;	
	КонецЕсли;
	
	СформироватьЭлементыМенюКартинкиВзаимодействия();
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	Если НЕ ЗначениеЗаполнено(Объект.ТемаПоУмолчанию) Тогда 
		ЭтаФорма.ТекущийЭлемент = Элементы.Заголовок;
	Иначе 
		ЭтаФорма.ТекущийЭлемент = Элементы.ФормаКнопкаСохранитьИЗакрыть;
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

