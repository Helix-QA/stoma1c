	Попытка
		ЗаписатьДокумент(ЧленствоОбъект, , , (ЧленствоОбъект.Проведен И ЧленствоОбъект.СрокДействияДатой <> ЧленствоОбъект.Ссылка.СрокДействияДатой));												
	Исключение
		// Запись в лог
		ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + СтрШаблон(НСтр("ru = 'Ошибка сохранения док-та Членство/Пакет услуг клиента ""%1"" Номер контракта: %2';en= 'Error saving document Membership/Client service package ""%1"" Contract number: %2'"), Строка(СтруктураРеквизитов.Клиент), СокрЛП(СтруктураРеквизитов.НомерКонтракта) + Символы.ПС + ОписаниеОшибки()));						
	КонецПопытки;	
	
	//// Доступные структурные единицы
