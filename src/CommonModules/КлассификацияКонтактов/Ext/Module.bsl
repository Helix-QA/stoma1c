#Область ФормаОбъекта

// Процедура создает элементы отображения тегов в форме объекта
//
// Параметры:
//  Форма	 - 	 - 
Процедура ОбновитьОблакоТегов(Форма, ОбъектДанных = Неопределено, УдалениеРазрешено = Истина, ВыводитьРодственников = Ложь) Экспорт
	
	// Отключаем механизм вывода родственников с тегами
	ВыводитьРодственников = Ложь;
	
	Элементы = Форма.Элементы;
	Если ОбъектДанных = Неопределено Тогда
		Объект = Форма.Объект;
	Иначе
		Объект = ОбъектДанных;
	КонецЕсли;
	
	МассивУдаляемых = Новый Массив;
	Для Каждого ЭлементТег Из Элементы.ОблакоТегов.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементТег.Имя, 12) = "СтрокаТегов_" И НЕ ЭлементТег.Имя = "СтрокаТегов_1" Тогда
			МассивУдаляемых.Добавить(ЭлементТег);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементТег Из Элементы.СтрокаТегов_1.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементТег.Имя, 4) = "Тег_" Тогда
			МассивУдаляемых.Добавить(ЭлементТег);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементТег Из МассивУдаляемых Цикл
		Элементы.Удалить(ЭлементТег);
	КонецЦикла;
	
	ЭтоФормаИнтерфейсаРецепциониста = Форма.ИмяФормы = "Обработка.РабочийСтол.Форма.ФормаИнтерфейсРецепциониста";
	
	МаксДлинаПервойСтроки    = ?(ЭтоФормаИнтерфейсаРецепциониста, 61 + 24, 45);
	МаксДлинаСтроки          = ?(ЭтоФормаИнтерфейсаРецепциониста, МаксДлинаПервойСтроки, 45);
	НомерЭлемента            = 0;
	НомерСтрокиЭлементов     = 1;
	ТекущаяДлинаСтроки       = 0;
	ГруппаТегов              = Элементы.СтрокаТегов_1;
	
	ПредыдущийЭлементТег = Ложь;
	ВозможностьРедактирования = ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты);
	// Получим таблицу тегов
	ТаблицаТегов = ПолучитьТаблицуТегов(Объект, ВыводитьРодственников);
	
	Для Каждого СтрокаТегов Из ТаблицаТегов Цикл //Для Каждого СтрокаТегов Из Объект.Теги Цикл
		
		НомерЭлемента = НомерЭлемента + 1;
		
		ЭтоТег = ЗначениеЗаполнено(СтрокаТегов.Тег);
		
		Если ЭтоТег Тогда 
			ПредставлениеТега = "#" + Строка(СтрокаТегов.Тег);
		Иначе 
			ПредставлениеТега = Строка(СтрокаТегов.Родственник); //ПредставлениеТега = Строка(СтрокаТегов.Родственник) + ". "; 
		КонецЕсли;
		
		Если ЭтоТег Тогда
			Если ЭтоФормаИнтерфейсаРецепциониста Тогда 
				Если СтрДлина(ПредставлениеТега) > 25 Тогда
					ПредставлениеТега = Лев(ПредставлениеТега, 25) + "...";
					ДлинаТега = 25 + 1;
				Иначе
					ДлинаТега = СтрДлина(ПредставлениеТега) + 2;
				КонецЕсли;
			Иначе 	
				Если СтрДлина(ПредставлениеТега) > 17 Тогда
					ПредставлениеТега = Лев(ПредставлениеТега, 17) + "...";
					ДлинаТега = 17 + 1;
				Иначе
					ДлинаТега = СтрДлина(ПредставлениеТега) + 2;
				КонецЕсли;
			КонецЕсли;	
		Иначе 
			ДлинаТега = СтрДлина(ПредставлениеТега); // + СтрДлина(Строка(СтрокаТегов.СтепеньРодства) + ". ");
		КонецЕсли;
		
		ТекущаяДлинаСтроки = ТекущаяДлинаСтроки + ДлинаТега;
		
		// Добавим новую группу
		Если (НомерСтрокиЭлементов = 1 И ТекущаяДлинаСтроки > МаксДлинаПервойСтроки)
			ИЛИ (НомерСтрокиЭлементов > 1 И ТекущаяДлинаСтроки > МаксДлинаСтроки)  Тогда 
			//ИЛИ (НЕ ЭтоТег И ПредыдущийЭлементТег) Тогда
			
			ТекущаяДлинаСтроки   = ДлинаТега;
			НомерСтрокиЭлементов = НомерСтрокиЭлементов + 1;
			
			ГруппаТегов                         	= Элементы.Добавить("СтрокаТегов_" + НомерСтрокиЭлементов, Тип("ГруппаФормы"), ?(НомерСтрокиЭлементов = 1, Элементы.ПерваяСтрока, Элементы.ОблакоТегов));
			ГруппаТегов.Вид                     	= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаТегов.Группировка             	= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаТегов.ОтображатьЗаголовок     	= Ложь;
			ГруппаТегов.Отображение             	= ОтображениеОбычнойГруппы.Нет;
			ГруппаТегов.РастягиватьПоГоризонтали 	= Ложь;
			ГруппаТегов.Ширина 						= МаксДлинаСтроки;
			ГруппаТегов.РастягиватьПоВертикали  	= Ложь;
			ГруппаТегов.Высота                  	= 1;
			//Если ВыводитьРодственников Тогда 
			//	//ГруппаТегов.ЦветФона 					= ?(ЭтоТег, ЦветаСтиля.ФонОблакаТегов, ЦветаСтиля.ДобавленныйРеквизитФон);
			//	ГруппаТегов.ЦветФона 					= ?(ЭтоТег, ЦветаСтиля.ФонОблакаТегов, Новый Цвет());			
			//КонецЕсли;			
		Иначе 
			//Если ВыводитьРодственников Тогда 
			//	//ГруппаТегов.ЦветФона 					= ?(ЭтоТег, ЦветаСтиля.ФонОблакаТегов, ЦветаСтиля.ДобавленныйРеквизитФон);
			//	ГруппаТегов.ЦветФона 					= ?((ЭтоТег ИЛИ НомерСтрокиЭлементов = 1), ЦветаСтиля.ФонОблакаТегов, Новый Цвет());			
			//КонецЕсли;			
		КонецЕсли;
		
	
		КомпонентыТега = Новый Массив;
		Если ЭтоТег Тогда 
			КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(ПредставлениеТега + " "));
			Если УдалениеРазрешено = Истина Тогда
				//Если ТипЗнч(СтрокаТегов) = Тип("СправочникТабличнаяЧастьСтрока.Контрагенты.Теги") Тогда
				//	КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Очистить, , , , "ТегИД_" + СтрокаТегов.НомерСтроки));
				//Иначе	
					КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.ОчиститьДанные, , , , СтрокаТегов.УИД_Тега));
				//КонецЕсли;
			КонецЕсли;			
		Иначе 
			КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(ПредставлениеТега, , , , ПолучитьНавигационнуюСсылку(СтрокаТегов.Родственник)));
			//КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(Строка(СтрокаТегов.СтепеньРодства) + ". ", Новый Шрифт(, , Истина, Истина)));
			КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(" (" + Строка(СтрокаТегов.СтепеньРодства) + ")"));
			//КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Лупа, , , , ПолучитьНавигационнуюСсылку(СтрокаТегов.Родственник)));//Строка(СтрокаТегов.Родственник.УникальныйИдентификатор())));
		КонецЕсли;
		         
	    // Добавим тег
		ЭлементТег                          = Элементы.Добавить("Тег_" + НомерЭлемента, Тип("ДекорацияФормы"), ГруппаТегов);
		ЭлементТег.Вид                      = ВидДекорацииФормы.Надпись;
		ЭлементТег.Заголовок                = Новый ФорматированнаяСтрока(КомпонентыТега, , ЦветаСтиля.ТекстВторостепеннойНадписи);
		ЭлементТег.Подсказка                = Строка(СтрокаТегов.Тег);
		//ЭлементТег.ЦветФона                 = ?(ЭтоТег, ЦветаСтиля.ЦветФонаФормы, ЦветаСтиля.ЗаказЗакрыт);
		//ЭлементТег.Рамка                   	= Новый Рамка(ТипРамкиЭлементаУправления.Одинарная, 1);
		ЭлементТег.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Центр;
		ЭлементТег.МаксимальнаяШирина       = ДлинаТега; //СтрДлина(ПредставлениеТега) + 2;
		ЭлементТег.АвтоМаксимальнаяШирина 	= Ложь;
		ЭлементТег.Шрифт			 		= Новый Шрифт(ЭлементТег.Шрифт,,11);

		Если ЭтоТег Тогда 
			Если УдалениеРазрешено = Истина Тогда
				ЭлементТег.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ТегОбработкаНавигационнойСсылки");		
			КонецЕсли;
			ЭлементТег.Доступность 			= ВозможностьРедактирования;
		Иначе
			ЭлементТег.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ТегОбработкаНавигационнойСсылки");
		КонецЕсли;
		ПредыдущийЭлементТег = ЗначениеЗаполнено(СтрокаТегов.Тег);
	КонецЦикла;
	
	//Если Не ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты) Тогда
	//	Элементы.ОблакоТегов.Доступность = Ложь;
	//КонецЕсли;   
	
КонецПроцедуры

// Процедура - Обновить облако тегов контрагента
//
// Параметры:
//  Форма					 - 	 - 
//  Контрагент				 - 	 - 
//  УдалениеРазрешено		 - 	 - 
//  ВыводитьРодственников	 - 	 - 
//
Процедура ОбновитьОблакоТеговКонтрагента(Форма, Контрагент = Неопределено, УдалениеРазрешено = Истина, ВыводитьРодственников = Ложь) Экспорт
	
	// Отключаем механизм вывода родственников с тегами
	ВыводитьРодственников = Ложь;
	
	// Актуализируем теги
	Если ЗначениеЗаполнено(Контрагент) Тогда 
		Форма.Теги.Загрузить(Контрагент.Теги.Выгрузить());
	КонецЕсли;	
		
	Элементы = Форма.Элементы;
	
	// Очищаем облако тегов
	МассивУдаляемых = Новый Массив;
	Для Каждого ЭлементТег Из Элементы.ОблакоТегов.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементТег.Имя, 12) = "СтрокаТегов_" И НЕ ЭлементТег.Имя = "СтрокаТегов_1" Тогда
			МассивУдаляемых.Добавить(ЭлементТег);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементТег Из Элементы.СтрокаТегов_1.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементТег.Имя, 4) = "Тег_" Тогда
			МассивУдаляемых.Добавить(ЭлементТег);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементТег Из МассивУдаляемых Цикл
		Элементы.Удалить(ЭлементТег);
	КонецЦикла;
	
	ЭтоФормаБП_ПродажаЧленства = Форма.ИмяФормы = "БизнесПроцесс.ПродажаЧленства_КОРП.Форма.ФормаБизнесПроцесса";
	
	МаксДлинаПервойСтроки    = ?(ЭтоФормаБП_ПродажаЧленства, 42, 45);
	МаксДлинаСтроки          = ?(ЭтоФормаБП_ПродажаЧленства, МаксДлинаПервойСтроки, 45);
	НомерСтрокиЭлементов     = 1;
	ТекущаяДлинаСтроки       = 0;
	ГруппаТегов              = Элементы.СтрокаТегов_1;
	
	ПредыдущийЭлементТег = Ложь;
	ВозможностьРедактирования = ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты);
	
	//// Получим таблицу тегов
	//ТаблицаТегов = ПолучитьТаблицуТегов(Объект, ВыводитьРодственников);
	
	Для Каждого СтрокаТегов Из Форма.Теги Цикл //Для Каждого СтрокаТегов Из Объект.Теги Цикл
		
		ИндексТега 		= Форма.Теги.Индекс(СтрокаТегов);
		УИД_Тега 		= "ТегИД_" + СтрокаТегов.ПолучитьИдентификатор();
		
		ЭтоТег = ЗначениеЗаполнено(СтрокаТегов.Тег);
		
		Если ЭтоТег Тогда 
			ПредставлениеТега = "#" + Строка(СтрокаТегов.Тег);
		КонецЕсли;
		
		Если ЭтоТег Тогда
			Если ЭтоФормаБП_ПродажаЧленства Тогда 
				Если СтрДлина(ПредставлениеТега) > 17 Тогда
					ПредставлениеТега = Лев(ПредставлениеТега, 17) + "...";
					ДлинаТега = 17 + 1;
				Иначе
					ДлинаТега = СтрДлина(ПредставлениеТега) + 2;
				КонецЕсли;
			Иначе 	
				Если СтрДлина(ПредставлениеТега) > 17 Тогда
					ПредставлениеТега = Лев(ПредставлениеТега, 17) + "...";
					ДлинаТега = 17 + 1;
				Иначе
					ДлинаТега = СтрДлина(ПредставлениеТега) + 2;
				КонецЕсли;
			КонецЕсли;	
		Иначе 
			ДлинаТега = СтрДлина(ПредставлениеТега); // + СтрДлина(Строка(СтрокаТегов.СтепеньРодства) + ". ");
		КонецЕсли;
		
		ТекущаяДлинаСтроки = ТекущаяДлинаСтроки + ДлинаТега;
		
		// Добавим новую группу
		Если (НомерСтрокиЭлементов = 1 И ТекущаяДлинаСтроки > МаксДлинаПервойСтроки)
			ИЛИ (НомерСтрокиЭлементов > 1 И ТекущаяДлинаСтроки > МаксДлинаСтроки)  Тогда 
			//ИЛИ (НЕ ЭтоТег И ПредыдущийЭлементТег) Тогда
			
			ТекущаяДлинаСтроки   = ДлинаТега;
			НомерСтрокиЭлементов = НомерСтрокиЭлементов + 1;
			
			ГруппаТегов                         	= Элементы.Добавить("СтрокаТегов_" + НомерСтрокиЭлементов, Тип("ГруппаФормы"), ?(НомерСтрокиЭлементов = 1, Элементы.ПерваяСтрока, Элементы.ОблакоТегов));
			ГруппаТегов.Вид                     	= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаТегов.Группировка             	= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаТегов.ОтображатьЗаголовок     	= Ложь;
			ГруппаТегов.Отображение             	= ОтображениеОбычнойГруппы.Нет;
			ГруппаТегов.РастягиватьПоГоризонтали 	= Ложь;
			ГруппаТегов.Ширина 						= МаксДлинаСтроки;
			ГруппаТегов.РастягиватьПоВертикали  	= Ложь;
			ГруппаТегов.Высота                  	= 1;
			//Если ВыводитьРодственников Тогда 
			//	//ГруппаТегов.ЦветФона 					= ?(ЭтоТег, ЦветаСтиля.ФонОблакаТегов, ЦветаСтиля.ДобавленныйРеквизитФон);
			//	ГруппаТегов.ЦветФона 					= ?(ЭтоТег, ЦветаСтиля.ФонОблакаТегов, Новый Цвет());			
			//КонецЕсли;			
		Иначе 
			//Если ВыводитьРодственников Тогда 
			//	//ГруппаТегов.ЦветФона 					= ?(ЭтоТег, ЦветаСтиля.ФонОблакаТегов, ЦветаСтиля.ДобавленныйРеквизитФон);
			//	ГруппаТегов.ЦветФона 					= ?((ЭтоТег ИЛИ НомерСтрокиЭлементов = 1), ЦветаСтиля.ФонОблакаТегов, Новый Цвет());			
			//КонецЕсли;			
		КонецЕсли;
		
	
		КомпонентыТега = Новый Массив;
		Если ЭтоТег Тогда 
			КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(ПредставлениеТега + " "));
			Если УдалениеРазрешено = Истина Тогда
				//Если ТипЗнч(СтрокаТегов) = Тип("СправочникТабличнаяЧастьСтрока.Контрагенты.Теги") Тогда
				//	КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Очистить, , , , "ТегИД_" + СтрокаТегов.НомерСтроки));
				//Иначе	
					КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.ОчиститьДанные, , , , УИД_Тега));
				//КонецЕсли;
			КонецЕсли;			
		Иначе 
			КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(ПредставлениеТега, , , , ПолучитьНавигационнуюСсылку(СтрокаТегов.Родственник)));
			//КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(Строка(СтрокаТегов.СтепеньРодства) + ". ", Новый Шрифт(, , Истина, Истина)));
			КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(" (" + Строка(СтрокаТегов.СтепеньРодства) + ")"));
			//КомпонентыТега.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Лупа, , , , ПолучитьНавигационнуюСсылку(СтрокаТегов.Родственник)));//Строка(СтрокаТегов.Родственник.УникальныйИдентификатор())));
		КонецЕсли;
		         
	    // Добавим тег
		ЭлементТег                          = Элементы.Добавить("Тег_" + ИндексТега, Тип("ДекорацияФормы"), ГруппаТегов);
		ЭлементТег.Вид                      = ВидДекорацииФормы.Надпись;
		ЭлементТег.Заголовок                = Новый ФорматированнаяСтрока(КомпонентыТега, , ЦветаСтиля.ТекстВторостепеннойНадписи);
		ЭлементТег.Подсказка                = Строка(СтрокаТегов.Тег);
		//ЭлементТег.ЦветФона                 = ?(ЭтоТег, ЦветаСтиля.ЦветФонаФормы, ЦветаСтиля.ЗаказЗакрыт);
		//ЭлементТег.Рамка                   	= Новый Рамка(ТипРамкиЭлементаУправления.Одинарная, 1);
		ЭлементТег.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Центр;
		ЭлементТег.МаксимальнаяШирина       = ДлинаТега; //СтрДлина(ПредставлениеТега) + 2;
		ЭлементТег.АвтоМаксимальнаяШирина 	= Ложь;
		ЭлементТег.Шрифт			 		= Новый Шрифт(ЭлементТег.Шрифт,,11);

		Если ЭтоТег Тогда 
			Если УдалениеРазрешено = Истина Тогда
				ЭлементТег.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ТегОбработкаНавигационнойСсылки");		
			КонецЕсли;
			ЭлементТег.Доступность 			= ВозможностьРедактирования;
		Иначе
			ЭлементТег.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ТегОбработкаНавигационнойСсылки");
		КонецЕсли;
		ПредыдущийЭлементТег = ЗначениеЗаполнено(СтрокаТегов.Тег);
	КонецЦикла;
	
	//Если Не ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты) Тогда
	//	Элементы.ОблакоТегов.Доступность = Ложь;
	//КонецЕсли;   
	
КонецПроцедуры

// Процедура создает элементы отображения тегов в форме объекта
//
// Параметры:
//  Форма	 - 	 - 
Процедура ОбновитьОблакоТеговКонтрагентаНовый(Форма, ОбъектДанных = Неопределено) Экспорт
		
	Элементы = Форма.Элементы;
	Объект   = ?(ОбъектДанных = Неопределено, Форма.Объект, ОбъектДанных);	
					
	//ВозможностьРедактирования = ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты);
		
	МассивДанных    = Новый Массив;	
	ТаблицаВсехТегов = Справочники.Теги.ПолучитьТаблицуТегов();
	
	ИмяМеню    = "МенюТеги"; 	
	ОтборТегов = УправлениеИнтерфейсамиСервер.ЗначениеВыбораВсплывающегоДинамическогоМеню(Форма, ИмяМеню);
	
	Если ОтборТегов = Неопределено Тогда 
		ТаблицаТегов = ПолучитьТаблицуТегов(Объект, Ложь);
		ОтборТегов   = ТаблицаТегов.ВыгрузитьКолонку("Тег");
	КонецЕсли;	
	
	Для Каждого Тег Из ТаблицаВсехТегов Цикл
						
		ПредставлениеТега = "#" + СокрЛП(Тег.Наименование);		
				
		Если СтрДлина(ПредставлениеТега) > 17 Тогда
			
			ПредставлениеТега = Лев(ПредставлениеТега, 17) + "...";
			ДлинаЭлемента     = 17 + 1;
		Иначе
			ДлинаЭлемента = СтрДлина(ПредставлениеТега) + 2;
		КонецЕсли;
		
		ПараметрыДанных = Новый Структура;
		ПараметрыДанных.Вставить("Значение"     , Тег.Ссылка);
		ПараметрыДанных.Вставить("Представление", ПредставлениеТега);
		ПараметрыДанных.Вставить("ДлинаЭлемента", ДлинаЭлемента);
		ПараметрыДанных.Вставить("Код"          , Тег.Ссылка.УникальныйИдентификатор());
		ПараметрыДанных.Вставить("Предпоказ"    , Ложь);
		ПараметрыДанных.Вставить("Выбор"        , Ложь);	
		
		Если ОтборТегов.Найти(Тег.Ссылка) <> Неопределено Тогда 
			
			ПараметрыДанных.Вставить("Предпоказ", Истина);
			ПараметрыДанных.Вставить("Выбор"    , Истина);	
						
		КонецЕсли;	
		
		МассивДанных.Добавить(ПараметрыДанных);
		
	КонецЦикла;	
		
	УправлениеИнтерфейсамиСервер.СоздатьДинамическоеМенюВсплывающихГрупп(
	ИмяМеню,
	Форма,
	МассивДанных,
	Элементы.ГруппаТегиКонтрагента,
	"ОбработчикНажатияЭлементаДинамическогоМеню",
	Тип("СправочникСсылка.Теги"),
	"ВсплывающаяГруппа",
	5,
	Новый Структура("МаксимальнаяШиринаПредпоказ", 37),
	Истина,
	"ОбновитьТеги",
	Новый Структура("ВсплывающееМеню, ПустоеМеню", НСтр("ru = 'Теги'; en = 'Tags'"), НСтр("ru = '+ Тег'; en = '+ Tag'")));
	
КонецПроцедуры

// Процедура - Обновить табличную часть тегов контрагента
//
// Параметры:
//  Форма		 - 	 - 
//  ОбъектДанных - 	 - 
//
Процедура ОбновитьТабличнуюЧастьТеговКонтрагента(Форма, ОбъектДанных = Неопределено) Экспорт
		
	Если ОбъектДанных = Неопределено Тогда
		Объект = Форма.Объект;
	Иначе
		Объект = ОбъектДанных;
	КонецЕсли;

	ИмяМеню    = "МенюТеги"; 	
	ОтборТегов = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(Форма, ИмяМеню);
	
	Форма.ЗаблокироватьДанныеФормыДляРедактирования();
	Форма.Модифицированность = Истина;
	
	Объект.Теги.Очистить();
	
	Для Каждого Тег Из ОтборТегов Цикл  
		
		НоваяСтрока     = Объект.Теги.Добавить();
		НоваяСтрока.Тег = Тег;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура создает элементы отображения интересов в форме объекта
//
// Параметры:
//  Форма	 - 	 - 
Процедура ОбновитьОблакоИнтересовКонтрагентаНовый(Форма, ОбъектДанных = Неопределено) Экспорт
		
	Элементы = Форма.Элементы;
	Объект   = ?(ОбъектДанных = Неопределено, Форма.Объект, ОбъектДанных);	
				
	//ВозможностьРедактирования = ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты);
		
	МассивДанных         = Новый Массив;	
