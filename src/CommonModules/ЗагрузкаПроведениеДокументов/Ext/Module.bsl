//   - 
//
Функция ПолучитьСтепеньРодстваПрочее() 
	
	СтепениРодстваПрочее = Справочники.СтепеньРодства.НайтиПоНаименованию("Прочее");
	
	Если СтепениРодстваПрочее.Пустая() Тогда
		НоваяСтепеньРодства = Справочники.СтепеньРодства.СоздатьЭлемент();
		НоваяСтепеньРодства.Наименование = "Прочее";
		НоваяСтепеньРодства.Записать();
		НоваяСтепеньРодства.ОбратнаяСвязьМуж = НоваяСтепеньРодства.Ссылка;
		НоваяСтепеньРодства.ОбратнаяСвязьЖен = НоваяСтепеньРодства.Ссылка;
		НоваяСтепеньРодства.КемПриходится = "Прочее";
		НоваяСтепеньРодства.Записать();
		Возврат НоваяСтепеньРодства.Ссылка;
	Иначе
		Возврат СтепениРодстваПрочее;
	КонецЕсли;
	
КонецФункции

// Процедура - Записать документ
//
// Параметры:
//  Документ_Объект			 - 	 - 
//  ОбменДанными_Загрузка	 - 	 - 
//
Процедура ЗаписатьДокумент(Документ_Объект, ОбменДанными_Загрузка = Истина, ВидИмпортаДанных = Ложь, ОтменитьПроведение = Ложь)
	
	Если ОбменДанными_Загрузка = Истина И НЕ ЗначениеЗаполнено(Документ_Объект.Номер) Тогда 
		Документ_Объект.УстановитьНовыйНомер();			
	КонецЕсли;
	Если ОбменДанными_Загрузка = Истина Тогда 	
		Документ_Объект.ОбменДанными.Загрузка = ОбменДанными_Загрузка;
	КонецЕсли;
	Документ_Объект.ДополнительныеСвойства.Вставить("РегистрироватьНаУзлахПлановОбменаПриОбновленииИБ", Неопределено);	
	Если НЕ Документ_Объект.ЭтоНовый() Тогда
		Документ_Объект.ОбменДанными.Получатели.АвтоЗаполнение = Ложь;
	КонецЕсли;	
	Если ОтменитьПроведение Тогда 
		Документ_Объект.Записать(РежимЗаписиДокумента.Запись);
		Документ_Объект.ОбменДанными.Загрузка = Ложь;
		Документ_Объект.ДополнительныеСвойства.Вставить("ЭтоОтменаПроведенияЗагруженныхДанных", Истина);		
		Документ_Объект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	Иначе 
		Если ВидИмпортаДанных = Истина И Документ_Объект.Проведен Тогда 
			Документ_Объект.Записать(РежимЗаписиДокумента.Запись);				
			// Документ_Объект.Записать(РежимЗаписиДокумента.ОтменаПроведения);		
		Иначе 	
			Документ_Объект.Записать(РежимЗаписиДокумента.Запись);		
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура СформироватьТаблицуИерархииГрупп(СтрокаГруппы, ТаблицаИерархииГрупп, Таблица_Групп_Номенклатуры, ОсновнаяГруппаЗагрузки)
	
	// НоваяСтрока 		= ТаблицаИерархииГрупп.Добавить();
	// ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаГруппы);
	// НоваяСтрока.Уровень = ТаблицаИерархииГрупп.Индекс(НоваяСтрока);
	
	Если ЗначениеЗаполнено(СтрокаГруппы.ИДРодительскойГруппы) Тогда
		СтрокаГруппыСуществующей = ТаблицаИерархииГрупп.Найти(СтрокаГруппы.ИДРодительскойГруппы, "ИДГруппы");
		Если СтрокаГруппыСуществующей = Неопределено Тогда
			НоваяСтрока 		= ТаблицаИерархииГрупп.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаГруппы);
			НоваяСтрока.Уровень = ТаблицаИерархииГрупп.Индекс(НоваяСтрока);			
			СтрокаРодительскойГруппы = Таблица_Групп_Номенклатуры.Найти(СтрокаГруппы.ИДРодительскойГруппы, "ИДГруппы");
			Если НЕ СтрокаРодительскойГруппы = Неопределено Тогда 
				СформироватьТаблицуИерархииГрупп(СтрокаРодительскойГруппы, ТаблицаИерархииГрупп, Таблица_Групп_Номенклатуры, ОсновнаяГруппаЗагрузки);
			КонецЕсли;
		Иначе
			МассивГрупп = Таблица_Групп_Номенклатуры.НайтиСтроки(Новый Структура("НаименованиеГруппы", СтрокаГруппыСуществующей.НаименованиеГруппы)); 
			Если МассивГрупп.Количество() <> 0 Тогда
				ИДРодительскойГруппы = 0;
				Для Каждого СтрокаПовторяющиесяГруппы Из МассивГрупп Цикл 
					Если СтрокаПовторяющиесяГруппы.ИдГруппы <> СтрокаГруппы.ИДРодительскойГруппы Тогда 
						ИДРодительскойГруппы = СтрокаПовторяющиесяГруппы.ИдГруппы;
						Прервать;
					КонецЕсли;	
				КонецЦикла;
				СтрокаГруппы.ИДРодительскойГруппы = ИДРодительскойГруппы;	
				СформироватьТаблицуИерархииГрупп(СтрокаГруппы, ТаблицаИерархииГрупп, Таблица_Групп_Номенклатуры, ОсновнаяГруппаЗагрузки);
			Иначе
				НоваяСтрока 		= ТаблицаИерархииГрупп.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаГруппы);
				НоваяСтрока.Уровень = ТаблицаИерархииГрупп.Индекс(НоваяСтрока);
				СтрокаГруппы.ИДРодительскойГруппы = 0;
				НоваяСтрока.Ссылка = ОсновнаяГруппаЗагрузки;
			КонецЕсли;
		КонецЕсли;
	Иначе
		НоваяСтрока 		= ТаблицаИерархииГрупп.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаГруппы);
		НоваяСтрока.Уровень = ТаблицаИерархииГрупп.Индекс(НоваяСтрока);		
		НоваяСтрока.Ссылка = ОсновнаяГруппаЗагрузки;
	КонецЕсли;	
	
КонецПроцедуры	

 #КонецОбласти 

#Область ДОПОЛНИТЕЛЬНЫЙ_ФУНКЦИОНАЛ

// Процедура - Пауза БСП
//
// Параметры:
//  Секунд	 - 	 - 
//
Процедура ПаузаБСП(Секунд = 1) Экспорт
    
    ТекущийСеансИнформационнойБазы = ПолучитьТекущийСеансИнформационнойБазы();
    ФоновоеЗадание = ТекущийСеансИнформационнойБазы.ПолучитьФоновоеЗадание();
    
    Если ФоновоеЗадание = Неопределено Тогда
        Параметры = Новый Массив;
        Параметры.Добавить(Секунд);
        ФоновоеЗадание = ФоновыеЗадания.Выполнить("ЗагрузкаПроведениеДокументов.ПаузаБСП", Параметры);
    КонецЕсли;
        
    Попытка
        Задание = ФоновоеЗадание.ОжидатьЗавершенияВыполнения(Секунд);
    Исключение
		Возврат;
    КонецПопытки;
	
КонецПроцедуры

// Процедура - Пауза запуском приложения
//
// Параметры:
//  Секунд	 - 	 - 
//
Процедура ПаузаЗапускомПриложения(Секунд = 1) Экспорт
    
    ИнформацияОСистеме = Новый СистемнаяИнформация();
    Если ИнформацияОСистеме.ТипПлатформы = ТипПлатформы.Windows_x86 ИЛИ ИнформацияОСистеме.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда
        ЗапуститьПриложение("ping -n " + Формат(1 + Секунд, "ЧДЦ=0; ЧГ=") + " 127.0.0.1", , Истина);// windows
    Иначе
        ЗапуститьПриложение("ping -c " + Формат(1 + Секунд, "ЧДЦ=0; ЧГ=") + " 127.0.0.1", , Истина);// linux
	КонецЕсли;
	
КонецПроцедуры

// Функция - Начать добавление клиента в стек формирования сегментов
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьДобавлениеКлиентаВСтекФормированияСегментов(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт 
	
	ВыполнитьВФоне = (СтруктураПараметров.Свойство("ВыполнятьВФоне") И СтруктураПараметров.ВыполнятьВФоне = ИСТИНА);
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() ИЛИ НЕ ВыполнитьВФоне Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;	
		ДобавитьКлиентаВСтекФормированияСегментов(СтруктураПараметров, Неопределено);
		Возврат Неопределено;
	Иначе
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания", Истина);
	КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.ДобавитьКлиентаВСтекФормированияСегментов",
	ПараметрыПроцедуры,
	НСтр("ru='Добавление клиента в стек формирования сегментов...';en='Adding a client to the segment generation stack...'"));
	Возврат Результат;
	
КонецФункции

// Функция - Добавить клиента в стек формирования сегментов
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДобавитьКлиентаВСтекФормированияСегментов(ПараметрыЗадания, АдресРезультата) Экспорт
	
	Если ПараметрыЗадания.Свойство("Пауза") И ТипЗнч(ПараметрыЗадания.Пауза) = Тип("Число") Тогда 
		ПаузаБСП(ПараметрыЗадания.Пауза);	
	КонецЕсли;	
	
	// Контрагент 				= ПараметрыЗадания.Контрагент;
	ОбменДаннымиЗагрузка 	= Истина;
	Если ПараметрыЗадания.Свойство("ОбменДаннымиЗагрузка") Тогда 
		ОбменДаннымиЗагрузка = ПараметрыЗадания.ОбменДаннымиЗагрузка;
	КонецЕсли;

	Сегменты.ВыполнитьПериодическоеФормирование(, ПараметрыЗадания.Контрагент);	
	
КонецФункции

// Функция - Начать актуализацию статуса пациента
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьАктуализациюСтатусаПациента(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт 
	
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;	
		АктуализироватьСтатусПациента(СтруктураПараметров, Неопределено);
		Возврат Неопределено;
	Иначе
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания"	, Истина);				
	КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийСотрудник);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.АктуализироватьСтатусПациента",
	ПараметрыПроцедуры,
	НСтр("ru='Актуализация статуса пациента...';en='Client status update...'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Актуализировать статус пациента
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура АктуализироватьСтатусПациента(ПараметрыЗадания, АдресРезультата) Экспорт 
	
	Если ПараметрыЗадания.Свойство("Пауза") И ТипЗнч(ПараметрыЗадания.Пауза) = Тип("Число") Тогда 
		ПаузаБСП(ПараметрыЗадания.Пауза);	
	КонецЕсли;	
	
	Контрагент 						= ПараметрыЗадания.Контрагент;
	// ПриемИсключение 				= ?(ПараметрыЗадания.Свойство("ПриемИсключение"), ПараметрыЗадания.ПриемИсключение, Неопределено);
	ИспользоватьБизнесЛогику 		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадания, "ИспользоватьБизнесЛогику"		, Ложь);
	ИспользоватьБлокировкуЗаписи 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадания, "ИспользоватьБлокировкуЗаписи"	, Ложь);
	
	Если ТипЗнч(Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда 
		Если НЕ ЗначениеЗаполнено(Контрагент) Тогда 
			Возврат;
		КонецЕсли;
		ЗапросАктальныхСтатусов			= Новый Запрос;		
		ЗапросАктальныхСтатусов.Текст 	= РегистрыСведений.СтатусыКонтрагентов.ПолучитьТекстЗапросаАктуализацииСтатусовПациента();
		ЗапросТекущихСтатусов 			= Новый Запрос;
		ЗапросТекущихСтатусов.Текст 	= РегистрыСведений.СтатусыКонтрагентов.ПолучитьТекстЗапросаТекущихСтатусов();		
	ИначеЕсли ТипЗнч(Контрагент) = Тип("Массив") Тогда
		Если Контрагент.Количество() = 0 ИЛИ НЕ ЗначениеЗаполнено(Контрагент) Тогда 
			Возврат;
		КонецЕсли;
		ЗапросАктальныхСтатусов 		= Новый Запрос;				
		ЗапросАктальныхСтатусов.Текст 	= СтрЗаменить(РегистрыСведений.СтатусыКонтрагентов.ПолучитьТекстЗапросаАктуализацииСтатусовПациента(), ".Контрагент = &Контрагент", ".Контрагент В (&Контрагент)");
		ЗапросАктальныхСтатусов.Текст 	= СтрЗаменить(ЗапросАктальныхСтатусов.Текст, "И Контрагенты.Ссылка = &Контрагент", "И Контрагенты.Ссылка В (&Контрагент)");
		ЗапросТекущихСтатусов 			= Новый Запрос;
		ЗапросТекущихСтатусов.Текст 	= СтрЗаменить(РегистрыСведений.СтатусыКонтрагентов.ПолучитьТекстЗапросаТекущихСтатусов(), ".Контрагент = &Контрагент", ".Контрагент В (&Контрагент)");				
	Иначе
		Возврат;
	КонецЕсли;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;	
	
	// Если ЗначениеЗаполнено(ПриемИсключение) Тогда
	//	ЗапросАктальныхСтатусов.УстановитьПараметр("ИсключаемыйПрием", ПриемИсключение);
	// Иначе 	
	//	ЗапросАктальныхСтатусов.Текст 	= СтрЗаменить(ЗапросАктальныхСтатусов.Текст, "РеализацияЗапасы.Ссылка <> &ИсключаемыйПрием", "ИСТИНА");
	// КонецЕсли;
	
	ЗапросАктальныхСтатусов.УстановитьПараметр("ТекущаяДата"				, КонецДня(ТекущаяДатаСеанса()));
	ЗапросАктальныхСтатусов.УстановитьПараметр("ГраницаПериодаНеактивности"	, НачалоДня(ТекущаяДатаСеанса()) - ((Константы.ПериодПоискаНеВернувшихсяКлиентов.Получить() + 1) * 60*60*24));
	ЗапросАктальныхСтатусов.УстановитьПараметр("ДнейОтсутствия"				, Константы.ПериодПоискаНеВернувшихсяКлиентов.Получить() + 1);
	ЗапросАктальныхСтатусов.УстановитьПараметр("Контрагент"					, Контрагент);
	ЗапросАктальныхСтатусов.УстановитьПараметр("ВидСделкиНовыйПациент"		, ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"));
	ЗапросАктальныхСтатусов.УстановитьПараметр("ВидСделкиПостоянныйПациент"	, ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.ПостоянныеПациенты"));
	
	ТаблицаАктуальныхСтатусовПациентов = ЗапросАктальныхСтатусов.Выполнить().Выгрузить();  
	                                                                 
	Если НЕ ТаблицаАктуальныхСтатусовПациентов.Количество() = 0 Тогда 
		ТаблицаПациентов 	= ТаблицаАктуальныхСтатусовПациентов.Скопировать(, "Контрагент");
		ТаблицаПациентов.Свернуть("Контрагент");
		// Получаем набор текущих статусов пациента для анализа	
		ЗапросТекущихСтатусов.УстановитьПараметр("Контрагент", Контрагент);
		ТаблицаТекущихСтатусовПациента = ЗапросТекущихСтатусов.Выполнить().Выгрузить();
		// Актуализируем статусы пациента
		Для Каждого СтрокаПациент Из ТаблицаПациентов Цикл
			КоллекцияСтрок 						= ТаблицаАктуальныхСтатусовПациентов.НайтиСтроки(Новый Структура("Контрагент", СтрокаПациент.Контрагент));
			Если КоллекцияСтрок.Количество() = 0 Тогда 
				Продолжить;
			Иначе 
				СтрокаАктуальныйСтатусПациента 	= КоллекцияСтрок[0];
			КонецЕсли;	
			МассивТекущихСтатусовПациента 		= ТаблицаТекущихСтатусовПациента.НайтиСтроки(Новый Структура("Контрагент", СтрокаПациент.Контрагент));
			ПериодУстановкиАктуальногоСтатуса 	= СтрокаАктуальныйСтатусПациента.Период;
			СтруктураПоследнейЗаписи 			= Новый Структура("Период, Контрагент, Статус");		
			Для Каждого ЭлементМассива Из МассивТекущихСтатусовПациента Цикл
				Если НЕ ЗначениеЗаполнено(ЭлементМассива.Статус) Тогда 
					// Удалим неактуальный статус
					РегистрыСведений.СтатусыКонтрагентов.УдалитьСтатусКлиента(ЭлементМассива, ИспользоватьБизнесЛогику, ИспользоватьБлокировкуЗаписи);
					Продолжить;
				КонецЕсли;	
				Если НЕ ЗначениеЗаполнено(СтрокаАктуальныйСтатусПациента.Период) Тогда 
					ПериодУстановкиАктуальногоСтатуса = ЭлементМассива.Период;
				КонецЕсли;				
				Если ЭлементМассива.Период < СтрокаАктуальныйСтатусПациента.Период Тогда
					ЗаполнитьЗначенияСвойств(СтруктураПоследнейЗаписи, ЭлементМассива);
				Иначе 
					// Удалим неактуальный статус
					РегистрыСведений.СтатусыКонтрагентов.УдалитьСтатусКлиента(ЭлементМассива, ИспользоватьБизнесЛогику, ИспользоватьБлокировкуЗаписи);
				КонецЕсли;
			КонецЦикла;
			Если ЗначениеЗаполнено(СтруктураПоследнейЗаписи.Статус) И СтруктураПоследнейЗаписи.Статус = СтрокаАктуальныйСтатусПациента.Статус И НЕ СтрокаАктуальныйСтатусПациента.Статус = Перечисления.СтатусыКонтрагентов.Потенциальный Тогда 
				// Удалим неактуальный статус
				РегистрыСведений.СтатусыКонтрагентов.УдалитьСтатусКлиента(СтруктураПоследнейЗаписи, ИспользоватьБизнесЛогику, ИспользоватьБлокировкуЗаписи);	
			ИначеЕсли ЗначениеЗаполнено(СтруктураПоследнейЗаписи.Статус) И СтруктураПоследнейЗаписи.Статус = СтрокаАктуальныйСтатусПациента.Статус И СтрокаАктуальныйСтатусПациента.Статус = Перечисления.СтатусыКонтрагентов.Потенциальный Тогда 
				Продолжить;
			КонецЕсли;	
			СтрокаАктуальныйСтатусПациента.Период = ПериодУстановкиАктуальногоСтатуса;
			РегистрыСведений.СтатусыКонтрагентов.ЗаписатьАктуальныйСтатусКлиента(СтрокаАктуальныйСтатусПациента, ИспользоватьБизнесЛогику, ИспользоватьБлокировкуЗаписи);
		КонецЦикла;	
	КонецЕсли;
    ТаблицаАктуальныхСтатусовПациентов 		= Неопределено;
	ТаблицаПациентов 						= Неопределено;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Ложь;	
	
КонецПроцедуры

// Функция - Начать регистрацию триггерного события
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьРегистрациюТриггерногоСобытия(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	//// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)
	// Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда 
	//	ЗарегистрироватьТриггерноеСобытие(СтруктураПараметров, Неопределено);
	//	Возврат Неопределено;
	// Иначе 
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания", Истина);				
	// КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.ЗарегистрироватьТриггерноеСобытие",
	ПараметрыПроцедуры,
	НСтр("ru='Регистрация триггерного события...';en='Registering a trigger event...'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Зарегистрировать триггерное событие
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗарегистрироватьТриггерноеСобытие(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПаузаБСП(5);
	Если ОбщегоНазначения.МодульТриггерныеСобытияСуществует() Тогда
		ОбщегоНазначения.ПолучитьМодульТриггерныеСобытия().ЗарегистрироватьСобытие(ПараметрыЗадания.ДанныеТриггера,
													ПараметрыЗадания.РегистрацияПоПодписке,
													ПараметрыЗадания.РегистрацияЗапланированных,
													ПараметрыЗадания.ОбъектСобытия,
													ПараметрыЗадания.МассивИсключительноРегламентныхТриггеров,
													ПараметрыЗадания.РегистрацияВФоне);
	КонецЕсли;	
	
КонецПроцедуры

// Функция - Начать актуализацию стека оповещений
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьАктуализациюСтекаОповещений(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт 
	
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;			
		АктуализироватьСтекОповещений(СтруктураПараметров, Неопределено);
		Возврат Неопределено;
	Иначе 
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания", Истина);				
	КонецЕсли;	
	
	УникальныйИдентификаторФормы = Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.АктуализироватьСтекОповещений",
	ПараметрыПроцедуры,
	НСтр("ru='Актуализация стека оповещений по взаимодействиям...';en='Updating the interaction notification stack...'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Актуализировать стек оповещений
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура АктуализироватьСтекОповещений(ПараметрыЗадания, АдресРезультата) Экспорт 
	
	ЗадачаОбъект = ПараметрыЗадания.ЗадачаОбъект;
	
	Если ЗадачаОбъект.ПометкаУдаления ИЛИ ЗадачаОбъект.Выполнена ИЛИ НЕ ЗначениеЗаполнено(ЗадачаОбъект.Исполнитель) Тогда 
		РегистрыСведений.СтекОповещенийПоВзаимодействиям.УдалитьОповещенияПоВзаимодействию(ЗадачаОбъект.ЗадачаСсылка);
	    Возврат;
	КонецЕсли;
	
	ТаблицаОповещенийПоВзаимодействию = Неопределено;
	ИнициализироватьСтекОповещений = (ЗадачаОбъект.ДополнительныеСвойства.Свойство("ОбъектНовый") ИЛИ ЗадачаОбъект.ДополнительныеСвойства.Свойство("ОтменаВыполнения") 
		ИЛИ ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьДатуОповещенияВСтеке") ИЛИ ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьИсполнителяВСтеке"));
	
	Если ИнициализироватьСтекОповещений Тогда 
		ТаблицаОповещенийПоВзаимодействию = РегистрыСведений.СтекОповещенийПоВзаимодействиям.ИнициализироватьСтекОповещенийВзаимодействия(ЗадачаОбъект, ПараметрыЗадания.ТекущийПользователь);
	ИначеЕсли ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьУникальноеОповещениеВСтеке") Тогда 
		ТаблицаОповещенийПоВзаимодействию = РегистрыСведений.СтекОповещенийПоВзаимодействиям.ИнициализироватьСтекУникальныхОповещенийВзаимодействия(ЗадачаОбъект, ПараметрыЗадания.ТекущийПользователь);
	КонецЕсли;
	
	Если ТаблицаОповещенийПоВзаимодействию <> Неопределено Тогда 
		НачатьТранзакцию();
		Попытка
			НаборЗаписейОповещения = РегистрыСведений.СтекОповещенийПоВзаимодействиям.СоздатьНаборЗаписей(); 
			НаборЗаписейОповещения.Отбор.Взаимодействие.Установить(ЗадачаОбъект.ЗадачаСсылка);
			Если ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьДатуОповещенияВСтеке") ИЛИ ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьИсполнителяВСтеке") Тогда 
				НаборЗаписейОповещения.Отбор.ВариантОповещения.Установить(Перечисления.ВариантыНапоминаний.ЗаВремяОтносительноСобытия);
			КонецЕсли;	
			Если ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьУникальноеОповещениеВСтеке") Тогда 
				НаборЗаписейОповещения.Отбор.Уникальное.Установить(Истина);
			КонецЕсли;	
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрСведений.СтекОповещенийПоВзаимодействиям");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.УстановитьЗначение("Взаимодействие"	, ЗадачаОбъект.ЗадачаСсылка);
			Если ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьДатуОповещенияВСтеке") ИЛИ ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьИсполнителяВСтеке") Тогда
				ЭлементБлокировки.УстановитьЗначение("ВариантОповещения", Перечисления.ВариантыНапоминаний.ЗаВремяОтносительноСобытия);			
			КонецЕсли;
			Если ЗадачаОбъект.ДополнительныеСвойства.Свойство("АктуализироватьУникальноеОповещениеВСтеке") Тогда
				ЭлементБлокировки.УстановитьЗначение("Уникальное", Истина);			
			КонецЕсли;						
			БлокировкаДанных.Заблокировать();
			
			НаборЗаписейОповещения.Загрузить(ТаблицаОповещенийПоВзаимодействию);
			НаборЗаписейОповещения.ОбменДанными.Загрузка = Истина;			
			НаборЗаписейОповещения.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

// Функция - Начать восстановление последовательности
//
// Параметры:
