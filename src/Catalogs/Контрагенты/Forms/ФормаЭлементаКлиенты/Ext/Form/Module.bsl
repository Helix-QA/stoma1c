// Процедура, собирает данные для открытия формы ОтправкиСообщения.
//
Процедура ПодготовкаКОтправкеСообщения(ПараметрыОткрытия)
	
	// Получаем данные контактной информации.
	МассивНомеровТелефонов = ЭтотОбъект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид, НеУчаствоватьВРассылке", Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, Ложь));
	МассивАдресовЭП 	   = ЭтотОбъект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", Справочники.ВидыКонтактнойИнформации.EmailКлиента));
	
	ДоступнаОтправкаВМессенджер = ПолучитьПризнакДоступностиОтправкиВМессенджер(Объект.Ссылка, МассивНомеровТелефонов);
	
	ДоступныеНомераТелефонов = Новый Массив;
	ДоступныеАдресаЭП		 = Новый Массив;
	ДоступныеКаналыРассылки  = Новый Массив;
	КартыКлиента		  	 = Новый Массив;
	
	Для Каждого СтрокаКИ Из МассивНомеровТелефонов Цикл
		Если СтрокаКИ.НеУчаствоватьВРассылке = Ложь И ЗначениеЗаполнено(СтрокаКИ.Значение) Тогда
			ДоступныеНомераТелефонов.Добавить(СтрокаКИ.Представление);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаКИ Из МассивАдресовЭП Цикл
		Если СтрокаКИ.НеУчаствоватьВРассылке = Ложь Тогда
			ДоступныеАдресаЭП.Добавить(СтрокаКИ.Представление);
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ДоступныеНомераТелефонов) 
		И Не ЗначениеЗаполнено(ДоступныеАдресаЭП)  
		И ДоступнаОтправкаВМессенджер = Ложь Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='У клиента нет доступных каналов для рассылки sms сообщений, push-уведомлений и электронных писем'; en='The client has no available channels for newsletter sms posts, push notifications and electronic letters'"));
		Возврат;
		
	КонецЕсли;
	
	ЭтотОбъект.ВзаимодействиеПисьмоСписокАдресовЭП.ЗагрузитьЗначения(ДоступныеАдресаЭП);
	ЭтотОбъект.ВзаимодействиеSMSСписокНомеровТелефонов.ЗагрузитьЗначения(ДоступныеНомераТелефонов);
	
	Если Не (ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеSMSНомерТелефона)
		И ДоступныеНомераТелефонов.Найти(ЭтотОбъект.ВзаимодействиеSMSНомерТелефона) <> Неопределено)
		И ДоступныеНомераТелефонов.Количество() > 0 Тогда
		
		ЭтотОбъект.ВзаимодействиеSMSНомерТелефона = ДоступныеНомераТелефонов[0];
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Контрагент"						, Объект.Ссылка);
	ПараметрыОткрытия.Вставить("ДоступныеНомераТелефонов"		, ЭтотОбъект.ВзаимодействиеSMSСписокНомеровТелефонов);
	ПараметрыОткрытия.Вставить("ШаблоныSms"						, ЭтотОбъект.ВзаимодействиеSMSСписокШаблонов);
	ПараметрыОткрытия.Вставить("ВзаимодействиеSMSНомерТелефона" , ЭтотОбъект.ВзаимодействиеSMSНомерТелефона); 
	ПараметрыОткрытия.Вставить("ДоступныеАдресаЭП"				, ЭтотОбъект.ВзаимодействиеПисьмоСписокАдресовЭП);
	ПараметрыОткрытия.Вставить("ШаблоныПисьма"					, ЭтотОбъект.ВзаимодействиеПисьмоСписокШаблонов);
	ПараметрыОткрытия.Вставить("ВзаимодействиеСделка"			, ЭтотОбъект.ВзаимодействиеСделка);
	ПараметрыОткрытия.Вставить("МессенджерВключен"				, ДоступнаОтправкаВМессенджер);
	ПараметрыОткрытия.Вставить("ШаблоныМессенджера"			    , ЭтотОбъект.ВзаимодействиеМессенджерСписокШаблонов);
	
КонецПроцедуры

// Функция проверяет существование расширения
//
Функция ИспользуетсяРасширение(ИмяРасширения)
    
    // Получить само расширение
    УстановитьПривилегированныйРежим(Истина);
	
    МассивРасширений = РасширенияКонфигурации.Получить();
	НужноеРасширение = Новый Массив;  
	
	Для Каждого ЭлементМ Из МассивРасширений Цикл
		Если СтрЧислоВхождений(ЭлементМ.Имя, ИмяРасширения) > 0 Тогда
			НужноеРасширение.Добавить(ЭлементМ);
		КонецЕсли;
	КонецЦикла;
	
	Если НужноеРасширение.Количество() <> 1 Тогда
        Возврат Ложь;
    КонецЕсли;
    Расширение = НужноеРасширение[0];
    
    // Проверить активность

    Если НЕ Расширение.Активно Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверить возможность применения
    ПроблемыПрименимости = Расширение.ПроверитьВозможностьПрименения();
	Если ПроблемыПрименимости.Количество() > 0 Тогда
		Для Каждого ЭлементМ Из ПроблемыПрименимости Цикл
			Если Не Строка(ЭлементМ.Расширение.ОбластьДействия) = "Информационная база" Тогда	
				Возврат Ложь;       
			КонецЕсли;
		КонецЦикла;
    КонецЕсли;
    
    Возврат Истина;
	
КонецФункции

