// Функция - OKTELLRun function POST
//
// Параметры:
//  Запрос	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция OKTELLRunFunctionPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.OKTELLRunFunction", УровеньЖурналаРегистрации.Информация, , , 
				"Вызов функции '" + Запрос.ПараметрыURL.Получить("ИмяФункции") + "'"
				+ Символы.ПС + "Переданные параметры:"
				+ Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
				
	Ответ1С = Новый Структура("Success, Description", Истина, "");
	
	Попытка
		
		// Чтение данных JSON из тела
		ИмяФункции = Запрос.ПараметрыURL.Получить("ИмяФункции");
		ПараметрыJSON = ДекодироватьИзJSON(Запрос.ПолучитьТелоКакСтроку());
		
		// Проверка Аутоидентификации
		IPТелефонияПодключаемоеОборудование = IPТелефония.ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсOKTELL);
		Если Не ЗначениеЗаполнено(IPТелефонияПодключаемоеОборудование) Тогда
			Ответ1С.Success = Ложь;
			Ответ1С.Description = "Аутентификация не пройдена (Сервис IP-телефонии в не настроен)";
			Возврат ПолучитьHTTPОтветAPI(401, Ответ1С, Истина);
		КонецЕсли;
		
		// Обработка события
		Если ИмяФункции = "GetInternalManager" Тогда
			СтруктураЛичныйМенеджер = IPТелефония.ПолучитьЛичногоМенеджераДляПереадресации(ПараметрыJSON.ExternalNumber, Ответ1С.Description);
			Если НЕ ЗначениеЗаполнено(Ответ1С.Description) Тогда
				Для Каждого ПараметрСтруктуры Из СтруктураЛичныйМенеджер Цикл
					Ответ1С.Вставить(ПараметрСтруктуры.Ключ, ПараметрСтруктуры.Значение);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
		Если ИмяФункции = "GetInternalManager" Тогда
			ИмяФункции = "IncomingCall";
		КонецЕсли;
		
		Ответ1С.Success = IPТелефония.OKTELL_СобытиеЗвонок(IPТелефонияПодключаемоеОборудование, ИмяФункции, ПараметрыJSON, Ответ1С.Description);
		
		Если Ответ1С.Success = Ложь Тогда
			ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.OKTELLRunFunction", УровеньЖурналаРегистрации.Предупреждение, , , 
						ИмяФункции + Символы.ПС + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
		КонецЕсли;				
		
		Возврат ПолучитьHTTPОтветAPI(?(Ответ1С.Success, 200, 400), Ответ1С, Истина);
		
	Исключение
				
		Ответ1С.Success = Ложь;
		Ответ1С.Description = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());		
		
		ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.OKTELLRunFunction", УровеньЖурналаРегистрации.Ошибка, , , 
						ИмяФункции + Символы.ПС + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
						
		Возврат ПолучитьHTTPОтветAPI(500, Ответ1С, Истина);
						
	КонецПопытки;
			
КонецФункции

// Функция - MANGOEvents call POST
//
// Параметры:
//  Запрос	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция MANGOEventsCallPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.MANGOEventsCall", УровеньЖурналаРегистрации.Информация, , , 
						"Вызов функции. Переданные параметры: " + Символы.ПС + РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL));
						
	Ответ1С = Новый Структура("Success, Description", Истина, "");
						
	Попытка
		
		// Чтение данных JSON из тела
		ТелоЗапроса = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);
		СтруктураПараметрыТелоЗапроса = Новый Структура;
		ОжидаемыеПараметры = Новый Структура("vpbx_api_key, sign, json");
		Для Каждого ЭлементОжидаемыйПараметр Из ОжидаемыеПараметры Цикл
			Для Каждого ЭлементМассива Из СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ТелоЗапроса, "&") Цикл
				Если СтрНайти(ЭлементМассива, ЭлементОжидаемыйПараметр.Ключ) <> 0 Тогда
					СтруктураПараметрыТелоЗапроса.Вставить(ЭлементОжидаемыйПараметр.Ключ, СтрЗаменить(ЭлементМассива, ЭлементОжидаемыйПараметр.Ключ + "=", ""));
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;

		// Проверка Аутоидентификации
		IPТелефонияПодключаемоеОборудование = IPТелефония.ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсMANGO, СтруктураПараметрыТелоЗапроса.vpbx_api_key);
		Если Не ЗначениеЗаполнено(IPТелефонияПодключаемоеОборудование) Тогда
			Ответ1С.Success = Ложь;
			Ответ1С.Description = "Аутентификация не пройдена (Сервис IP-телефонии в настроен)";
			Возврат ПолучитьHTTPОтветAPI(401, Ответ1С, Истина);
		ИначеЕсли MANGOПроверитьАутоидентификацию(IPТелефонияПодключаемоеОборудование, СтруктураПараметрыТелоЗапроса.JSON, СтруктураПараметрыТелоЗапроса.Sign, Запрос.ОтносительныйURL) = Ложь Тогда
			Ответ1С.Success = Ложь;
			Ответ1С.Description = "Аутентификация не пройдена";
			Возврат ПолучитьHTTPОтветAPI(401, Ответ1С, Истина);
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(СтруктураПараметрыТелоЗапроса.JSON);
		ПараметрыЗапросаJSON = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		ОбязательныеПараметры = Новый Массив;
		ОбязательныеПараметры.Добавить("entry_id");
		ОбязательныеПараметры.Добавить("call_id");
		ОбязательныеПараметры.Добавить("timestamp");
		ОбязательныеПараметры.Добавить("seq");
		ОбязательныеПараметры.Добавить("call_state");
		ОбязательныеПараметры.Добавить("location");
		ОбязательныеПараметры.Добавить("to");
		ОбязательныеПараметры.Добавить("from");
		
		Для Каждого ОбязательныйПараметр Из ОбязательныеПараметры Цикл
			Если Не ПараметрыЗапросаJSON.Свойство(ОбязательныйПараметр) Тогда
				Ответ1С.Success = Ложь;					
				Ответ1С.Description = СтрШаблон(НСтр("ru='Отсутствует обязательный параметр %1.'"), ОбязательныйПараметр);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если Ответ1С.Success = Ложь Тогда
			Возврат ПолучитьHTTPОтветAPI(400, Ответ1С, Истина);	
		КонецЕсли;
		
		Ответ1С.Success = IPТелефония.MANGO_СобытиеЗвонок(IPТелефонияПодключаемоеОборудование, ПараметрыЗапросаJSON, Ответ1С.Description);
		
		Если Ответ1С.Success = Ложь Тогда
			ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.MANGOEventsCall", УровеньЖурналаРегистрации.Предупреждение, , , 
			"" + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
		КонецЕсли;		
		
		Возврат ПолучитьHTTPОтветAPI(?(Ответ1С.Success, 200, 400), Ответ1С, Истина, Истина);
		
	Исключение
				
		Ответ1С.Success = Ложь;
		Ответ1С.Description = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());		
		
		ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.MANGOEventsCall", УровеньЖурналаРегистрации.Ошибка, , , 
						"" + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
		
		Возврат ПолучитьHTTPОтветAPI(500, Ответ1С, Истина);
		
	КонецПопытки;
		
КонецФункции

