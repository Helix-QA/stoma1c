
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере.
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Контрагент") Тогда
		ЭтотОбъект.Контрагент = Параметры.Контрагент;
	КонецЕсли;
	
	Если Параметры.Свойство("Заявка") Тогда
		ЭтотОбъект.Заявка = Параметры.Заявка;
	КонецЕсли;  
	
	Если Параметры.Свойство("ДокументОснование") Тогда
		ЭтотОбъект.ДокументОснование = Параметры.ДокументОснование;
	КонецЕсли;	
	
	Если Параметры.Свойство("ДоступныеНомераТелефонов") Тогда
		ЭтотОбъект.ВзаимодействиеSMSСписокНомеровТелефонов = Параметры.ДоступныеНомераТелефонов;
	КонецЕсли;
	
	Если Параметры.Свойство("СписокНомеровТелефоновPush") Тогда
		ЭтотОбъект.ВзаимодействиеPushСписокНомеровТелефонов = Параметры.СписокНомеровТелефоновPush;
	КонецЕсли;
	
	Если Параметры.Свойство("ДоступныеАдресаЭП") Тогда
		ЭтотОбъект.ВзаимодействиеПисьмоСписокАдресовЭП = Параметры.ДоступныеАдресаЭП;
		Если ЭтотОбъект.ВзаимодействиеПисьмоСписокАдресовЭП.Количество() > 0 Тогда
			ЭтотОбъект.ВзаимодействиеПисьмоАдресЭП = ВзаимодействиеПисьмоСписокАдресовЭП[0].Значение; 
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Свойство("ВзаимодействиеSMSНомерТелефона") Тогда 
		ЭтотОбъект.ВзаимодействиеSMSНомерТелефона = Параметры.ВзаимодействиеSMSНомерТелефона;
	КонецЕсли;
	
	Если Параметры.Свойство("ВзаимодействиеPushНомерТелефона") Тогда
		ЭтотОбъект.ВзаимодействиеPushНомерТелефона = Параметры.ВзаимодействиеPushНомерТелефона;
	КонецЕсли;
	
	Если Параметры.Свойство("ТекстСообщенияSms") Тогда
		ЭтотОбъект.ВзаимодействиеSMSТекст = Параметры.ТекстСообщенияSms;	
	КонецЕсли;
	
	Если Параметры.Свойство("ВзаимодействиеСделка") Тогда
		ЭтотОбъект.ВзаимодействиеСделка = Параметры.ВзаимодействиеСделка;
		УстановитьАктуальнуюСделкуВзаимодействия();
	КонецЕсли;
	
	Если Параметры.Свойство("ЗаголовокФормы") Тогда
		ЭтаФорма.Заголовок = Параметры.ЗаголовокФормы;
	КонецЕсли;
	
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ЭтотОбъект.ТекущийПользователь 		 = ПараметрыСеанса.ТекущийПользователь;
	
	ЭтотОбъект.ВзаимодействиеPushВнешняяСистемаWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);
	
	Если Параметры.Свойство("МессенджерВключен") И Параметры.МессенджерВключен Тогда
		ЭтотОбъект.МессенджерДоступен = Истина;
		ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер");
		ЗаполнитьСписокТелефоновДляWhatsApp();
		УстановитьВидимостьОтправкиВМессенджер();
	Иначе
		Если Параметры.Свойство("ДоступныеНомераТелефонов") И Параметры.ДоступныеНомераТелефонов.Количество() > 0 Тогда
			ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS"); 
			Элементы.ГруппаКнопкиSms.ЦветФона    = Новый Цвет(25,  116, 206);		
			Элементы.ПереключательSms.ЦветТекста = Новый Цвет(255, 255, 255);
			Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Видимость = Истина;
		Иначе
			ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо"); 
			Элементы.ГруппаКнопкиПисьмо.ЦветФона    = Новый Цвет(25,  116, 206);		
			Элементы.ПереключательПисьмо.ЦветТекста = Новый Цвет(255, 255, 255);
		КонецЕсли;                                                           
		ЭтотОбъект.МессенджерДоступен = Ложь;
		Элементы.ГруппаПерейтиВЧат.Видимость = Ложь;
		Элементы.ГруппаКнопкиМессенджер.Видимость = Ложь;
		Элементы.ГруппаВыбораВнешнейСистемыМессенджера.Видимость = Ложь;
	КонецЕсли;
	
	ЗагрузитьСписокШаблоновСМСМессенджер();
	
	УстановитьВидимостьИДоступностьФормы(); 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	СоздатьSMSРассылкуНаКлиенте();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Взаимодействие SMSВыбрать телефон.
//
// Параметры:
//  Команда	 - 	 -
//
Процедура ВзаимодействиеSMSВыбратьТелефон(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ВзаимодействиеSMSВыбратьТелефонЗавершение", ЭтотОбъект);
	
	Если ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") 
		ИЛИ ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
		
		СписокЗначений = ЭтотОбъект.ВзаимодействиеSMSСписокНомеровТелефонов;
	ИначеЕсли ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо") Тогда
		СписокЗначений = ЭтотОбъект.ВзаимодействиеПисьмоСписокАдресовЭП;
	ИначеЕсли ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление")	Тогда
		СписокЗначений = ЭтотОбъект.ВзаимодействиеPushСписокНомеровТелефонов;
	КонецЕсли;
	
	ПоказатьВыборИзМеню(Оповещение, СписокЗначений);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие SMSВыбрать телефон завершение.
//
// Параметры:
//  Результат	 - 	 -
//  ДопПараметры - 	 -
//
Процедура ВзаимодействиеSMSВыбратьТелефонЗавершение(Результат, ДопПараметры) Экспорт
	
	ЭтаФорма.ТекущийЭлемент = Элементы.ВзаимодействиеSMSТекст;
	
	Если Результат <> Неопределено  Тогда
		
		ЭтотОбъект.ВзаимодействиеКаналРассылки = Результат.Значение;
		
		Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Заголовок = Результат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие SMS выбрать шаблон текста.
//
// Параметры:
//  Команда	 - 	 -
//
Процедура ВзаимодействиеSMSВыбратьШаблон(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ВзаимодействиеSMSВыбратьШаблонЗавершение", ЭтотОбъект);
	
	Если ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS")
		Или ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда		
		
		СписокЗначений = ЭтотОбъект.ВзаимодействиеSMSСписокШаблонов;
		
	ИначеЕсли ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
	    СписокЗначений = ЭтотОбъект.ВзаимодействиеМессенджерСписокШаблонов; 
		
	ИначеЕсли ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо") Тогда		
		СписокЗначений = ЭтотОбъект.ВзаимодействиеПисьмоСписокШаблонов;		
		
	КонецЕсли;
	
	ПоказатьВыборИзМеню(Оповещение, СписокЗначений);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие SMS выбрать шаблон текста завершение.
//
// Параметры:
//  Результат	 - 	 -
//  ДопПараметры - 	 -
//
Процедура ВзаимодействиеSMSВыбратьШаблонЗавершение(Результат, ДопПараметры) Экспорт
	
	ЭтаФорма.ТекущийЭлемент = Элементы.ВзаимодействиеSMSТекст;
	
	Если Результат <> Неопределено  Тогда
		
		ЭтотОбъект.ШаблонСообщения = Результат.Значение;
		ЭтотОбъект.ВзаимодействиеSMSТекст = ПолучитьСодержаниеШаблона(Результат.Значение, ЭтотОбъект.ТипСообщенияPushSMS);
		ВзаимодействиеSMSОбновитьСтатусВведеныхСимволов();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает содержание переданного шаблона.
//
Функция ПолучитьСодержаниеШаблона(ШаблонСообщения, ТипСообщения)
	
	//Если ТипСообщения = Перечисления.ТипыСобытий.ПушУведомление Тогда
	//	ИмяПоля = "СодержаниеPush";
	//	
	//Иначе
	Если ТипСообщения = Перечисления.ТипыСобытий.Мессенджер Тогда
		ИмяПоля = "СодержаниеМессенджер";
		
	Иначе
		ИмяПоля = "Содержание";
		
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ШаблоныСообщений." + ИмяПоля + " КАК Содержание
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	ШаблоныСообщений.Ссылка = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка", ШаблонСообщения);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Содержание, "");
	
КонецФункции

&НаКлиенте
// Процедура - Взаимодействие SMSНастроить сервис.
//
// Параметры:
//  Команда	 - 	 -
//
Процедура ВзаимодействиеSMSНастроитьСервис(Команда)
	
	Если НаличиеСервисовSMSРассылки() Тогда
		Оповещение = Новый ОписаниеОповещения("ВзаимодействиеSMSНастроитьСервисЗавершение", ЭтотОбъект);
		ОткрытьФорму("Справочник.СервисыРассылки.ФормаВыбора",, ЭтаФорма,,,, Оповещение);
	Иначе
		ОткрытьФорму("Справочник.СервисыРассылки.ФормаОбъекта",, ЭтаФорма);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие SMSНастроить сервис завершение.
//
// Параметры:
//  Результат	 - 	 -
//  ДопПаарметры - 	 -
//
Процедура ВзаимодействиеSMSНастроитьСервисЗавершение(Результат, ДопПараметры = Неопределено) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		ЗаполнитьСервисSMSРассылкиПоУмолчанию(Результат);
		Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость = Ложь;
		Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость        = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие SMSТекст при изменении.
//
Процедура ВзаимодействиеSMSТекстПриИзменении(Элемент)
	
	Если ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") 
		Или ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
		ВзаимодействиеSMSОбновитьСтатусВведеныхСимволов();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие SMS Отправить.
//
// Параметры:
//  Команда	 - 	 -
//
Процедура ВзаимодействиеSMSОтправить(Команда)
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеSMSТекст) Тогда
		
		Если (ЭтотОбъект.ТипСообщенияPushSMS <> ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") 
			И ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеКаналРассылки)) 
			Или (ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер")
			Или ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление"))Тогда
			
			ВзаимодействиеSMSPushОтправитьСервер();
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены параметры сообщения!");	
		КонецЕсли;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены данные сообщения!");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ПереключательSms".
//
Процедура ПереключательSms(Команда)
	
	УстановитьНеАктивностьПереключателямSmsPushMessage();
	
	Элементы.ГруппаКнопкиSms.ЦветФона    = Новый Цвет(25,  116, 206);		
	Элементы.ПереключательSms.ЦветТекста = Новый Цвет(255, 255, 255);
	
	ЭтаФорма.ТекущийЭлемент        = Элементы.ВзаимодействиеSMSТекст;
	ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS");
	
	ВзаимодействиеSMSТекст = "";
	ВзаимодействиеSMSОбновитьСтатусВведеныхСимволов();
	СоздатьSMSРассылкуНаКлиенте();
	ЗагрузитьСписокШаблоновСМСМессенджер();
	
КонецПроцедуры

&НаСервере
// Процедура - Загрузить список шаблонов СМСМессенджер
//
Процедура ЗагрузитьСписокШаблоновСМСМессенджер()

	Если ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") 
		Или ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда
		
		ДоступныеШаблоны = Справочники.ШаблоныСообщений.ПолучитьШаблоныСообщений(Перечисления.ТипыСобытий.SMS);
		ЭтотОбъект.ВзаимодействиеSMSСписокШаблонов.Очистить();
		Для Каждого Шаблон Из ДоступныеШаблоны Цикл 
			ЭтотОбъект.ВзаимодействиеSMSСписокШаблонов.Добавить(Шаблон.Ссылка, Шаблон.Наименование);	
		КонецЦикла;
		
	ИначеЕсли ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
		
		ДоступныеШаблоны = Справочники.ШаблоныСообщений.ПолучитьШаблоныСообщений(Перечисления.ТипыСобытий.Мессенджер);  
		ЭтотОбъект.ВзаимодействиеМессенджерСписокШаблонов.Очистить();
		Для Каждого Шаблон Из ДоступныеШаблоны Цикл 
			ЭтотОбъект.ВзаимодействиеМессенджерСписокШаблонов.Добавить(Шаблон.Ссылка, Шаблон.Наименование);	
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ПереключательPush".
//
Процедура ПереключательPush(Команда)
	
	УстановитьНеАктивностьПереключателямSmsPushMessage();
	
	Элементы.ГруппаКнопкиPush.ЦветФона    = Новый Цвет(25,  116, 206);	
	Элементы.ПереключательPush.ЦветТекста = Новый Цвет(255, 255, 255);
	
	ЭтаФорма.ТекущийЭлемент        = Элементы.ВзаимодействиеSMSТекст;
	ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление");
	ВзаимодействиеSMSТекст = "";
	
	СоздатьSMSРассылкуНаКлиенте();
	ЗагрузитьСписокШаблоновСМСМессенджер();

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПереключательПисьмо"
//
Процедура ПереключательПисьмо(Команда)
	
	УстановитьНеАктивностьПереключателямSmsPushMessage();
	
	Элементы.ГруппаКнопкиПисьмо.ЦветФона    = Новый Цвет(25,  116, 206);	
	Элементы.ПереключательПисьмо.ЦветТекста = Новый Цвет(255, 255, 255);
	
	ЭтаФорма.ТекущийЭлемент        = Элементы.ВзаимодействиеSMSТекст;
	ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо");
	ВзаимодействиеSMSТекст = "";
	
	СоздатьSMSРассылкуНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПереключательМессенджер"
//
Процедура ПереключательМессенджер(Команда)
	
	УстановитьНеАктивностьПереключателямSmsPushMessage();
	
	Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Видимость = Ложь;
	Элементы.ГруппаВыбораВнешнейСистемыМессенджера.Видимость = Истина;
	
	Элементы.ГруппаКнопкиМессенджер.ЦветФона    = Новый Цвет(25,  116, 206);	
	Элементы.ПереключательМессенджер.ЦветТекста = Новый Цвет(255, 255, 255);
	
	ЭтаФорма.ТекущийЭлемент        = Элементы.ВзаимодействиеSMSТекст;
	ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер");
	
	ВзаимодействиеSMSТекст = "";
	ВзаимодействиеSMSОбновитьСтатусВведеныхСимволов();
	
	СоздатьSMSРассылкуНаКлиенте();
	ЗагрузитьСписокШаблоновСМСМессенджер();

КонецПроцедуры

&НаКлиенте
