			// --------------------------------------------------------------------------------------------		
			Группа_Интервал = Элементы.Добавить("Группа_Интервал_" + ИндексИнтервала, Тип("ГруппаФормы"), РодительскаяГруппа);
			Группа_Интервал.Вид 													= ВидГруппыФормы.ОбычнаяГруппа;
			Группа_Интервал.Заголовок 												= Группа_Интервал.Имя;
			Группа_Интервал.Отображение 											= ОтображениеОбычнойГруппы.Нет;
			Группа_Интервал.Группировка 											= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			Группа_Интервал.ОтображатьЗаголовок 									= Ложь;
			// Группа_Интервал.ЦветФона 												= ЦветаСтиля.ЦветФонаЗадач;
			Группа_Интервал.ГоризонтальныйИнтервал 									= ИнтервалМеждуЭлементамиФормы.Половинный;
			Группа_Интервал.ГоризонтальноеПоложениеВГруппе   						= ГоризонтальноеПоложениеЭлемента.Центр;
			Группа_Интервал.ГоризонтальноеПоложениеПодчиненных 						= ГоризонтальноеПоложениеЭлемента.Центр;
			Группа_Интервал.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Центр;
			Группа_Интервал.ВертикальноеПоложениеПодчиненных						= ВертикальноеПоложениеЭлемента.Центр;		
			
			Если ЭтаФорма.Команды.Найти("Подключаемый_ВыборНачалаИнтервала_" + ИндексИнтервала) = Неопределено Тогда
				Команда 			= ЭтаФорма.Команды.Добавить("Подключаемый_ВыборНачалаИнтервала_" + ИндексИнтервала);
