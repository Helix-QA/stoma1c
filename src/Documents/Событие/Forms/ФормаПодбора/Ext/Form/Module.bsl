
#Область ОбработчикиСобытийФормы
/////////////////////// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ///////////////////////////   
      
&НаСервере
// При создании формы на сервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РежимПодбора = "Помещение";
	Если Параметры.Свойство("РежимПодбора") = Истина Тогда
		РежимПодбора = Параметры.РежимПодбора;
		Сотрудник = Параметры.Сотрудник;
		Если Параметры.Свойство("КоличествоПомещений") Тогда
			КоличествоПомещений = Параметры.КоличествоПомещений;
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Свойство("ДатаНачала") = Истина Тогда
		ДатаНачала = Параметры.ДатаНачала;
	КОнецЕсли;	
	Если Параметры.Свойство("ДатаОкончания") = Истина Тогда
		ДатаОкончания = Параметры.ДатаОкончания;
	КОнецЕсли;	
	Если РежимПодбора = "Помещение" Тогда
		 ВыбранноеЗначение = Справочники.Помещения.ПустаяСсылка();
	Иначе
		 ВыбранноеЗначение = Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;	 
	Если Параметры.Свойство("СтруктурнаяЕдиница") Тогда
		  СтруктурнаяЕденица = Параметры.СтруктурнаяЕдиница;
	КонецЕсли;	

	ЗаполнитьТаблицуЗначений();
	
КонецПроцедуры

&НаКлиенте
// При открытии формы на клиенте
Процедура ПриОткрытии(Отказ)
	
	Если РежимПодбора = "Сотрудник" Тогда
		 Элементы.НаборДанныхПодбираемоеЗначение.Заголовок = "Сотрудник";
		 Элементы.НаборДанныхДолжность.Видимость           = Истина;
		 Заголовок  = "Подбор сотрудника";
	 Иначе
		 Элементы.НаборДанныхПодбираемоеЗначение.Заголовок = "Помещение";
		 Элементы.НаборДанныхДолжность.Видимость           = Ложь;
		 Заголовок = "Подбор помещения";
    КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Заполнить таблицу подбора
Процедура ЗаполнитьТаблицуЗначений()
		 
	Если РежимПодбора="Помещение" Тогда	
		
		  Запрос=Новый Запрос();
		  Запрос.Текст="ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	Помещения.Ссылка КАК Помещение
		               |ИЗ
		               |	Справочник.Помещения КАК Помещения
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник
		               |		ПО Помещения.Ссылка = СвязкаПомещениеСотрудник.Помещение.Ссылка
		               |ГДЕ
		               |	Помещения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		               |	И Помещения.ЭтоГруппа = ЛОЖЬ
		               |	И Помещения.ОтображатьВРасписанииЗанятий = ИСТИНА
		               |	И ВЫБОР
		               |			КОГДА &КоличествоПомещений > 0
		               |				ТОГДА СвязкаПомещениеСотрудник.Сотрудник = &Сотрудник
		               |			ИНАЧЕ ИСТИНА
		               |		КОНЕЦ
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Помещения.Ссылка
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Помещения.Наименование";
		    Запрос.Параметры.Вставить("СтруктурнаяЕдиница",СтруктурнаяЕденица);
		    Запрос.Параметры.Вставить("Сотрудник",Сотрудник);
		    Запрос.Параметры.Вставить("КоличествоПомещений",КоличествоПомещений);
			Помещения = Запрос.Выполнить().Выбрать();
				
	     	Пока Помещения.Следующий()  Цикл
					  
			      Строка= ТаблицаЗначений.Добавить();
			      Строка.ПодбираемоеЗначение=Помещения.Помещение;
			      Строка.СтатусВозможности=ПолучитьСтатус(Помещения.Помещение);
		          Строка.ВремяКорректировки=КорректировкаВремени;				   
		    КонецЦикла;

	Иначе		
		Запрос       = Новый Запрос();
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СправочникСотрудники.Ссылка КАК Сотрудник
		|ИЗ
		|	Справочник.Сотрудники КАК СправочникСотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
		|		ПО СправочникСотрудники.Ссылка = НастройкиСотрудников.Сотрудник
		|ГДЕ
		|	СправочникСотрудники.ЭтоГруппа = ЛОЖЬ
		|	И (СправочникСотрудники.Ссылка В
		|				(ВЫБРАТЬ
		|					СвязкаПомещениеСотрудник.Сотрудник
		|				ИЗ
		|					РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник
		|				ГДЕ
		|					СвязкаПомещениеСотрудник.Помещение.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		|			ИЛИ НЕ СправочникСотрудники.Ссылка В
		|					(ВЫБРАТЬ
		|						СвязкаПомещениеСотрудник.Сотрудник
		|					ИЗ
		|						РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник))
		|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И ВЫБОР
		|			КОГДА &ИспользоватьПредварительнуюЗапись = ИСТИНА
		|				ТОГДА НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
		|						ИЛИ НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	СправочникСотрудники.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	СправочникСотрудники.Представление";

		Запрос.Параметры.Вставить("ИспользоватьПредварительнуюЗапись", Истина);
		Запрос.Параметры.Вставить("СтруктурнаяЕдиница"               , СтруктурнаяЕденица);
		Сотрудники = Запрос.Выполнить().Выгрузить();
		
		Индекс=0;
		Пока Индекс < Сотрудники.Количество() Цикл
			  Строка = ТаблицаЗначений.Добавить();
			  Строка.ПодбираемоеЗначение=Сотрудники[Индекс].Сотрудник;
              Строка.Должность=Сотрудники[Индекс].Сотрудник.Должность;
			  Строка.СтатусВозможности = ПолучитьСтатус(,Сотрудники[Индекс].Сотрудник);
			  Строка.ВремяКорректировки = КорректировкаВремени;
			  Индекс = Индекс+1;
        КонецЦикла;

	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Функция вернет документ с услугой в период выполнения, которой входит время планируемого посещения
Функция ПолучитьДокументСобытие(СтартоваяДата, ДатаОкончанияУслуги,Помещение=Неопределено,Сотрудник=Неопределено)
		
	ДополнительноеУсловие="";
	Если РежимПодбора="Помещение" Тогда
		 ДополнительноеУсловие=" И Событие.Помещение = &Помещение ";
	 Иначе
		 ДополнительноеУсловие=" И Событие.Сотрудник = &Сотрудник ";
	КонецЕсли;	 
	
	ЗапросСобытия=Новый Запрос();
	ЗапросСобытия.Текст = "ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	                      |	Событие.Ссылка КАК Событие,
						  | Событие.ДатаНачала,
						  | Событие.ДатаОкончания
						  | 
	                      |ИЗ
	                      |	Документ.Событие.Услуги КАК Событие
	                      |ГДЕ
	                      |	(Событие.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен))
	                      |	И Событие.Ссылка.Проведен = ИСТИНА
	                      |	И Событие.Ссылка.ПометкаУдаления = ЛОЖЬ
	                      |	И Событие.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                      |	И Событие.ДатаНачала < &ДатаОкончания 
						  | И Событие.ДатаОкончания > &СтартоваяДата"+ДополнительноеУсловие+ "
						  |СГРУППИРОВАТЬ ПО
	                      |	Событие.Ссылка,
	                      |	Событие.ДатаНачала,
	                      |	Событие.ДатаОкончания
				          |УПОРЯДОЧИТЬ ПО
                          |	ДатаНачала ";

						  
	ЗапросСобытия.Параметры.Вставить("СтруктурнаяЕдиница",СтруктурнаяЕденица);					  
	ЗапросСобытия.Параметры.Вставить("ДатаОкончания",ДатаОкончанияУслуги);
	ЗапросСобытия.Параметры.Вставить("СтартоваяДата",СтартоваяДата);

	Если РежимПодбора="Помещение" Тогда
		 ЗапросСобытия.Параметры.Вставить("Помещение",Помещение);
	Иначе	 
		 ЗапросСобытия.Параметры.Вставить("Сотрудник",Сотрудник);
	КонецЕсли;
		
	Возврат  ЗапросСобытия.Выполнить().Выгрузить();
	
КонецФункции

&НаСервере
// получить статус возможности подбора значения
Функция ПолучитьСтатус(Помещение=Неопределено,Сотрудник=Неопределено)
	
	  Продолжительность=(ДатаОкончания-ДатаНачала);
	  
	  ДокументCобытие=ПолучитьДокументСобытие(ДатаНачала,ДатаОкончания,Помещение,Сотрудник);
	  
	  Освободится="Занят";
	  МинВремяОсвобождения=0;
	  КорректировкаВремени=-1;
	  Если ДокументCобытие.Количество()=0 Тогда
		   // Если значение полностью свободно
			Освободится= "Свободен";
			КорректировкаВремени=0;
	  Иначе
			// проверка возможности вставить до занятого
			 Если ПолучитьДокументСобытие(ДокументCобытие[0].ДатаНачала-Продолжительность,ДокументCобытие[0].ДатаНачала,Помещение,Сотрудник).Количество()=0 Тогда
				 
				  МинВремяОсвобождения=ДокументCобытие[0].ДатаНачала-ДатаОкончания;
				  Если МинВремяОсвобождения<0 Тогда
						   МинВремяОсвобождения=МинВремяОсвобождения*-1;
				  КонецЕсли;
					   
				  Если (МинВремяОсвобождения/60)<=60 Тогда
	   			    
					   КорректировкаВремени=МинВремяОсвобождения*-1;
					   Освободится= "Освободится за "+Формат(МинВремяОсвобождения/60,"")+" мин. до начала";		
				  КонецЕсли;
			 КонецЕсли;	
			 
			  Индекс=0;
			  Если ДокументCобытие.Количество()>1 Тогда
				  Индекс=1;
			  КонецЕсли;
			  
			  // Проверка возможности вставить после занятого	
			  Если ПолучитьДокументСобытие(ДокументCобытие[Индекс].ДатаОкончания,ДокументCобытие[Индекс].ДатаОкончания+Продолжительность,Помещение,Сотрудник).Количество()=0 Тогда
						
					ВремяОсвобождения=ДокументCобытие[Индекс].ДатаОкончания-ДатаНачала;
					Если  ВремяОсвобождения< МинВремяОсвобождения ИЛИ МинВремяОсвобождения=0 Тогда
						    МинВремяОсвобождения=ВремяОсвобождения;

							Если (МинВремяОсвобождения/60)<=60 Тогда
								  МинВремяОсвобождения=ВремяОсвобождения;
								  КорректировкаВремени=МинВремяОсвобождения;
								  Освободится= "Освободится через "+Формат(МинВремяОсвобождения/60,"")+" мин.";	
						   КонецЕсли;	 
					КонецЕсли;  
			  КонецЕсли;

	   КонецЕсли;	
		   
	Возврат Освободится;  

КонецФункции

&НаКлиенте
// Обработка выбора подбираемого значения
Процедура НаборДанныхВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущаяСтрока = Элементы.НаборДанных.ТекущаяСтрока;
	Если ТекущаяСтрока > -1 И НЕ ТаблицаЗначений[ТекущаяСтрока].СтатусВозможности = "Занят" Тогда
		ВыбранноеЗначение    = ТаблицаЗначений[ТекущаяСтрока].ПодбираемоеЗначение;
		КорректировкаВремени = ТаблицаЗначений[ТекущаяСтрока].ВремяКорректировки;
		ОповеститьОВыборе(Новый Структура("ВыбранноеЗначение, КорректировкаВремени",ВыбранноеЗначение, КорректировкаВремени));
	Иначе
		Если РежимПодбора = "Помещение" Тогда		  
			ПоказатьПредупреждение(, "В указанное время помещение занято!");
		Иначе
			ПоказатьВопрос(Новый ОписаниеОповещения("НаборДанныхВыборЗавершение", ЭтотОбъект, Новый Структура("ТекущаяСтрока", ТекущаяСтрока)), "В указанное время сотрудник занят. Создать запись?",РежимДиалогаВопрос.ДаНет);
		КонецЕсли; 		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура - Набор данных выбор завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура НаборДанныхВыборЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если Не ДополнительныеПараметры.Свойство("ТекущаяСтрока") Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока = ДополнительныеПараметры.ТекущаяСтрока;

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ВыбранноеЗначение    = ТаблицаЗначений[ТекущаяСтрока].ПодбираемоеЗначение;
		КорректировкаВремени = ТаблицаЗначений[ТекущаяСтрока].ВремяКорректировки;
		ОповеститьОВыборе(Новый Структура("ВыбранноеЗначение, КорректировкаВремени",ВыбранноеЗначение, КорректировкаВремени));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 
