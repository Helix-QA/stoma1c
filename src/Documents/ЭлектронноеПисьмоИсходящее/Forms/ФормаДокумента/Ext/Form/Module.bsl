// Создать новое взаимодействие на основании данного существующего
//
Процедура СоздатьНовоеВзаимодействие(ВидОперацииВзаимодействия)
	
	// Если документ модифицирован необходимо его предварительно записать
	Если Объект.Ссылка.Пустая() ИЛИ Модифицированность Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьНовоеВзаимодействиеПослеВопроса", ЭтотОбъект, Новый Структура("ВидОперацииВзаимодействия", ВидОперацииВзаимодействия));
		ПоказатьВопрос(ОписаниеОповещения, "Документ должен быть записан! Записать?", РежимДиалогаВопрос.ДаНет);
        Возврат;
		
	КонецЕсли;
	
	// Открываем форму нового взаимодействия
	СоздатьНовоеВзаимодействиеЗавершение(ВидОперацииВзаимодействия); 
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовоеВзаимодействиеПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если КодВозвратаДиалога.Да = РезультатВопроса Тогда
		Если НЕ Записать() Тогда
			Возврат;
		КонецЕсли;
	Иначе
		Возврат;
	КонецЕсли;
	
	СоздатьНовоеВзаимодействиеЗавершение(ДополнительныеПараметры.ВидОперацииВзаимодействия);

КонецПроцедуры

