&НаКлиенте 
// Процедура - После вопроса об открытии кассовой смены
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВопросаОбОткрытииКассовойСмены(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ОткрытьФорму = ДополнительныеПараметры.ОткрытьФорму;
	ТекстОшибки = ДополнительныеПараметры.ТекстОшибки;
	
	Если (РезультатВопроса = КодВозвратаДиалога.Да)
		И (ЗначениеЗаполнено(Касса)) Тогда  				
		ОбщегоНазначенияКлиентСтоматология.ОткрытьКассовуюСмену(Касса, УникальныйИдентификатор, ОткрытьФорму);
		СостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Касса);
	Иначе
		Закрыть();
		Возврат;
	КонецЕсли;
	
	Если НЕ ОткрытьФорму Тогда
		Закрыть();
		Возврат;
	КонецЕсли; 
	
	ПечатьКвитанцииПриИзменении(Неопределено);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После вопроса о закрытии кассовой смены
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВопросаОЗакрытииКассовойСмены(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если (РезультатВопроса = КодВозвратаДиалога.Да)
		И (ЗначениеЗаполнено(Касса))  Тогда
		ОбщегоНазначенияКлиентСтоматология.ЗакрытьКассовуюСмену(Касса, УникальныйИдентификатор);
	КонецЕсли;
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения.
// 
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "СБП_УспешнаяОплата" Тогда		
		ОбсужденияСистемыВзаимодействияКлиент.ОбработкаОповещенияОбУспешностиОплатыСБП(ЭтаФорма, Параметр);	
	КонецЕсли;
	
КонецПроцедуры

