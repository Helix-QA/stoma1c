// Функция возвращает объект метаданных по полному имени
//
// Не обрабатываются точки маршрутов бизнес-процессов.
//
// Параметры:
//  ПолноеИмя    - Строка, полное имя объекта метаданных,
//                 например, "Справочник.Организации".
//
// Возвращаемое значение:
//  ОбъектМетаданных
// 
Функция ПолучитьОбъектМетаданныхПоПолномуИмени(ПолноеИмя) Экспорт
	
	ЧастиИмени = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ПолноеИмя, ".");
	
	КлассОМ = ЧастиИмени[0];
	ИмяОМ	= ЧастиИмени[1];
	
	Если      ВРег(КлассОМ) = "СПРАВОЧНИК" Тогда
		Возврат Метаданные.Справочники[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ДОКУМЕНТ" Тогда
		Возврат Метаданные.Документы[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "БИЗНЕСПРОЦЕСС" Тогда
		Возврат Метаданные.БизнесПроцессы[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ПЛАНВИДОВХАРАКТЕРИСТИК" Тогда
		Возврат Метаданные.ПланыВидовХарактеристик[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ПЛАНСЧЕТОВ" Тогда
		Возврат Метаданные.ПланыСчетов[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ПЛАНВИДОВРАСЧЕТА" Тогда
		Возврат Метаданные.ПланЫВидовРасчета[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ЗАДАЧА" Тогда
		Возврат Метаданные.Задачи[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ПЛАНОБМЕНА" Тогда
		Возврат Метаданные.ПланыОбмена[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ПЕРЕЧИСЛЕНИЕ" Тогда
		Возврат Метаданные.Перечисления[ИмяОМ];
	ИначеЕсли ВРег(КлассОМ) = "ОБРАБОТКА" Тогда
		Возврат Метаданные.Обработки[ИмяОМ];
	Иначе
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru='Неизвестный тип объекта метаданных (%1)'"), КлассОМ);
	КонецЕсли;
	
КонецФункции // МенеджерОбъектаПоПолномуИмени()

// Процедура, выполняет стандартные действия перед записью документов.
//
Процедура ПередЗаписьюДокумента(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	                 
	МетаданныеДокумента = Источник.Метаданные();	
	Если ЕстьРеквизитДокумента("СуммаДокумента", МетаданныеДокумента) Тогда		
		СуммаДокумента = 0;
		ОбновитьСумму  = Ложь;
		Если ЕстьТабличнаяЧастьДокумента("Запасы", МетаданныеДокумента) Тогда
			СуммаДокумента = Источник.Запасы.Итог("Сумма");
			ОбновитьСумму  = Истина;
		КонецЕсли;		
		Если ЕстьТабличнаяЧастьДокумента("Расходы", МетаданныеДокумента) Тогда
			СуммаДокумента = СуммаДокумента + Источник.Расходы.Итог("Сумма");
			ОбновитьСумму  = Истина;
		КонецЕсли;		
		Если ЕстьТабличнаяЧастьДокумента("Лечение", МетаданныеДокумента) Тогда   
			Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.Прием") Тогда
				СуммаДокумента = СуммаДокумента + Источник.Лечение.Итог("Всего");   
			Иначе
				СуммаДокумента = СуммаДокумента + Источник.Лечение.Итог("Сумма");
			КонецЕсли;	
			ОбновитьСумму  = Истина;
		КонецЕсли;
		Если ЕстьТабличнаяЧастьДокумента("Услуги", МетаданныеДокумента) Тогда
			СуммаДокумента = СуммаДокумента + Источник.Услуги.Итог("Сумма");
			ОбновитьСумму  = Истина;
		КонецЕсли;	
		Если ОбновитьСумму Тогда
		     Источник.СуммаДокумента = СуммаДокумента;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура добавления данных перед изменением/перед записью.
//
Процедура ДобавлениеДанныхПередИзменениемПередЗаписью(Источник, Отказ, РежимЗаписи = Неопределено, РежимПроведения = Неопределено) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Добавляем данные которые были перед записью
	Источник.ДополнительныеСвойства.Вставить("ДанныеПередЗаписью", Новый Структура);
	Для каждого РеквизитМетаданные Из Источник.Метаданные().СтандартныеРеквизиты Цикл
		Источник.ДополнительныеСвойства.ДанныеПередЗаписью.Вставить(РеквизитМетаданные.Имя, Источник.Ссылка[РеквизитМетаданные.Имя]);
	КонецЦикла;
	Для каждого РеквизитМетаданные Из Источник.Метаданные().Реквизиты Цикл
		Источник.ДополнительныеСвойства.ДанныеПередЗаписью.Вставить(РеквизитМетаданные.Имя, Источник.Ссылка[РеквизитМетаданные.Имя]);
		Если РеквизитМетаданные.Имя = "ИдентификаторДиалога" Тогда 
			Если Источник.Ссылка[РеквизитМетаданные.Имя] <> Источник[РеквизитМетаданные.Имя] Тогда 
				Источник.ДополнительныеСвойства.Вставить("РаботаСЧатБотом", Истина);
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	Для каждого РеквизитМетаданные Из Источник.Метаданные().ТабличныеЧасти Цикл
		Источник.ДополнительныеСвойства.ДанныеПередЗаписью.Вставить(РеквизитМетаданные.Имя, Источник.Ссылка[РеквизитМетаданные.Имя].Выгрузить());
	КонецЦикла;	
	
	Если Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Источник.Ссылка)) Тогда
		Источник.ДополнительныеСвойства.ДанныеПередЗаписью.Вставить("РежимЗаписи", РежимЗаписи);
	КонецЕсли;
	
	Источник.ДополнительныеСвойства.ДанныеПередЗаписью.Вставить("ЭтоНовый", Источник.ЭтоНовый());
	
КонецПроцедуры

// Процедура получает доступные СтруктурныеЕдиницы
//
Функция ДоступныеСтруктурныеЕдиницы() Экспорт
	
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК СотрудникиДоступныеСтруктурныеЕдиницы
	|ГДЕ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = &Сотрудник
	|	И НЕ СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("Сотрудник", ПараметрыСеанса.ТекущийСотрудник);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Возврат  РезультатЗапроса.ВыгрузитьКолонку("СтруктурнаяЕдиница");
	
КонецФункции

