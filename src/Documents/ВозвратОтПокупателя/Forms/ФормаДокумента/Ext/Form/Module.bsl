Процедура ТЧПередУдалением(Элемент, Отказ)
	Имятаблицы = Элемент.Имя; 
	ТекущиеДанные = Элементы[Имятаблицы].ТекущиеДанные;
	Если Не ТекущиеДанные = Неопределено Тогда
		НайденныеСтроки = Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("КлючСтроки", ТекущиеДанные.КлючСтроки));
		Для Каждого СтрокаМ из НайденныеСтроки Цикл
			Объект.СкидкиНаценки.Удалить(СтрокаМ);
		КонецЦикла;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте 
// Процедура, Дата при изменении.
//
Процедура ДатаПриИзменении(Элемент)
	
    ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры  

&НаСервереБезКонтекста  
// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Возвращает максимальное количество номенклатуры для возврата.
//
Функция ПолучитьМаксимальноеКоличествоДляВозврата(ОснованиеВозврата, КлючСтроки, ЭтоЗапас, ИсключаемыйВозврат)
	
	КоличествоУпаковокМаксимальное = 0;
	
	Если НЕ ЗначениеЗаполнено(ОснованиеВозврата) ИЛИ НЕ ЗначениеЗаполнено(КлючСтроки) ИЛИ НЕ ЗначениеЗаполнено(ЭтоЗапас) Тогда
		Возврат КоличествоУпаковокМаксимальное;
	КонецЕсли;
	
	ЭтоПрием = (ТипЗнч(ОснованиеВозврата) = Тип("ДокументСсылка.Прием"));	
	НаименованиеДокументаПродажи = "Документ." + ?(ЭтоПрием, "Прием.", "Реализация.") + ?(ЭтоЗапас, "Запасы", ?(ЭтоПрием, "Лечение", "Услуги"));	
	НаименованиеДокументаВозврата = "Документ.ВозвратОтПокупателя." + ?(ЭтоЗапас,  "Запасы", "Лечение");
			
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВозвратОтПокупателяТаблица.КоличествоУпаковок) КАК КоличествоУпаковокВозвращено,
	|	ВозвратОтПокупателяТаблица.КлючСтроки КАК КлючСтроки
	|ПОМЕСТИТЬ ВТКоличествоВозвращено
	|ИЗ
	|	&НаименованиеДокументаВозврата КАК ВозвратОтПокупателяТаблица
	|ГДЕ
	|	ВозвратОтПокупателяТаблица.Ссылка.Проведен = ИСТИНА
	|	И НЕ ВозвратОтПокупателяТаблица.Ссылка = &ИсключаемыйВозврат
	|	И ВозвратОтПокупателяТаблица.КлючСтроки = &КлючСтроки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВозвратОтПокупателяТаблица.КлючСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДокументТаблица.КоличествоУпаковок - ЕСТЬNULL(ВТКоличествоВозвращено.КоличествоУпаковокВозвращено, 0) КАК КоличествоУпаковокОстаток
	|ИЗ
	|	&НаименованиеДокументаПродажи КАК ДокументТаблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКоличествоВозвращено КАК ВТКоличествоВозвращено
	|		ПО ДокументТаблица.КлючСтроки = ВТКоличествоВозвращено.КлючСтроки
	|ГДЕ
	|	ДокументТаблица.Ссылка = &ДокументПродажи
	|	И ДокументТаблица.КлючСтроки = &КлючСтроки");
	
	Запрос.УстановитьПараметр("КлючСтроки", КлючСтроки);
	Запрос.УстановитьПараметр("ДокументПродажи", ОснованиеВозврата);
	Запрос.УстановитьПараметр("ИсключаемыйВозврат", ИсключаемыйВозврат);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&НаименованиеДокументаВозврата", НаименованиеДокументаВозврата); 
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&НаименованиеДокументаПродажи", НаименованиеДокументаПродажи);
	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		КоличествоУпаковокМаксимальное = Выборка.КоличествоУпаковокОстаток;	
	КонецЦикла;
	
	Возврат КоличествоУпаковокМаксимальное;
	
КонецФункции

#КонецОбласти

