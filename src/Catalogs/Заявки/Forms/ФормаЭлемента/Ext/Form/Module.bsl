// Функция, возвращает ссылку на документ по ид.
//
Функция ПолучитьСсылкуПоУид(Уид, ТипСобытия)
	
	Если ТипСобытия = "ЗадачаИсполнителя" Тогда
		Возврат Задачи.ЗадачаИсполнителя.ПолучитьСсылку(Уид);
	ИначеЕсли ТипСобытия = "Звонок" Тогда
		Возврат Справочники.Файлы.ПолучитьСсылку(Уид);
	Иначе
		Возврат Задачи.Взаимодействие.ПолучитьСсылку(Уид);
	КонецЕсли;
	
