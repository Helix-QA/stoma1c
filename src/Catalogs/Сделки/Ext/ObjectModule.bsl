	//		ПроверяемыеРеквизиты.Добавить("Специализация");
	//	КонецЕсли;
	//КонецЕсли;	
	
КонецПроцедуры

// Процедура - Перед записью.
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка = Истина Тогда 
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Код) Тогда	
		ЭтотОбъект.УстановитьНовыйКод();		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Наименование) Тогда		
		ЭтотОбъект.Наименование = Справочники.Сделки.СоздатьНаименованиеСделки(ЭтотОбъект);		
	КонецЕсли;
	ЭтотОбъект.НаименованиеСокращенное = Справочники.Сделки.ИнициализироватьСокращенноеНаименованиеСделки(ЭтотОбъект);		
	
	Если ЭтотОбъект.ИсточникИнформации <> Справочники.РекламныеИсточники.ДругойПациент Тогда		
		ЭтотОбъект.ИсточникИнформацииЗначение = Неопределено;		
	КонецЕсли;
	
	Если ЭтотОбъект.КаналПривлечения <> Справочники.КаналыПривлечения.ЧатСКлиентом Тогда		
		ЭтотОбъект.КаналПривлеченияЗначение = Неопределено;		
	КонецЕсли;
	
	// Установить статусы пациента 
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.СтатусПациента) Тогда
		ЭтотОбъект.СтатусПациента = Справочники.Сделки.ВернутьПризнакПервичногоПациента(ЭтотОбъект);
	КонецЕсли;

	// Фиксация даты завершения сделки
	ЗафиксироватьДатуЗавершенияСделки();
	
	// Инициализация дополнительных свойств объекта
	ИнициализироватьДополнительныеСвойстваОбъекта();
	
	//ВнешняяСистемаCalltouch = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Calltouch, Истина);
	//ВнешняяСистемаЯМетрика  = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.ЯндексАналитика, Истина);
		
	// Заполним специализацию
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Специализация) Тогда 
		Если ЗначениеЗаполнено(ЭтотОбъект.Врач) Тогда 
			ЭтотОбъект.Специализация = Справочники.Сотрудники.ПолучитьОсновнуюСпециализациюСотрудника(ЭтотОбъект.Врач);
		КонецЕсли;	
	КонецЕсли;
	
	// Заполним куратора	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Менеджер) Тогда 
		ТекущийСотрудник = ПараметрыСеанса.ТекущийСотрудник;
		Если ЗначениеЗаполнено(ТекущийСотрудник) И ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекущийСотрудник, "Служебный") = Ложь Тогда 
			ЭтотОбъект.Менеджер = ТекущийСотрудник;
		КонецЕсли;	
	КонецЕсли;
	
	// Проверка на существование сделок клиента с таким же видом и врачом
	ПроверитьБизнесЛогикуСоздания(, , Истина, Отказ);

	// Фиксация изменения этапа в истории (ТЧ)
	ЗафиксироватьИсториюИзмененияЭтапов();
	
	// Синхронизация сделки с заявкой
	СинхронизироватьОбъектСЗаявкой();
	
КонецПроцедуры

// Процедура, обработчик события "ПриЗаписи".
//
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка = Истина Тогда 
		Возврат;
	КонецЕсли;	
	
	Если ДополнительныеСвойства.Свойство("ПараметрыРегистрацииТриггера") Тогда
		ДополнительныеСвойства.ПараметрыРегистрацииТриггера.Вставить("ОбъектГенерации", ЭтотОбъект.Ссылка);		
		РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.ЗарегистрироватьСобытиеТриггера(ДополнительныеСвойства.ПараметрыРегистрацииТриггера);
	КонецЕсли;
	
	ОбновитьЗаписиРегистраКонтрагентыСведенияДляСписка();
	РегистрыСведений.СделкиСведенияДляСписка.АктуализироватьСведенияДляСписка(ЭтотОбъект.Ссылка, ЭтотОбъект.Контрагент);
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ИзмененЭтап", Ложь)
		И НЕ ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "РегламентнаяЗапись", Ложь) Тогда
		Если ЭтотОбъект.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда
			Если ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ЭтотОбъект.ВидСделки, 4) Тогда 
            	Документы.Событие.УстановитьСтатусПредварительнойЗаписи(Перечисления.СтатусыСобытия.Подтверждена, , ЭтотОбъект.Ссылка);
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
		
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "УстановленЭтапОтказ", Ложь) Тогда 
		РегистрыСведений.Профосмотры.АктуализироватьСтатусПланированияПриема(ЭтотОбъект.СтруктурнаяЕдиница
																			, ЭтотОбъект.Контрагент
																			, ЭтотОбъект.Ссылка
																			, 
																			, Перечисления.СтатусыПрофосмотров.Отказался
																			, ЭтотОбъект.ПричинаОтказа);
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ЭтоНовый", Ложь) Тогда
		ОповеститьСеансыОбИзмененииСделки("ДобавленаСделка");
	ИначеЕсли ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ИзмененЭтап", Ложь) Тогда
		ОповеститьСеансыОбИзмененииСделки("ИзмененЭтапСделки");
	КонецЕсли;
	
	ОбновитьСделкуВПродаже();
	
	ОбновитьСтатусКлиента();
	
	ИнициализироватьСтекСтатусовСквознойАналитики();
	
	// Синхронизации проведена. Фиксируем результаты, если есть.
	СинхронизироватьОбъектСЗаявкой();
	
	СинхронизироватьОбъектСЗадачей();
	
	// Завершаем связанные задачи
	Если ДополнительныеСвойства.Свойство("ЗавершитьВсеСвязанныеЗадачи") Тогда 
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("Сделка"					, Ссылка);
		СтруктураПараметров.Вставить("РезультатСделки"			, РезультатСделки);
		СтруктураПараметров.Вставить("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
		СтруктураПараметров.Вставить("ДополнительныеСвойства"	, ДополнительныеСвойства);
		ПараметрыДлительнойОперации = ЗагрузкаПроведениеДокументов.НачатьЗавершениеСвязанныхЗадач(Строка(Новый УникальныйИдентификатор()), СтруктураПараметров);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура - Зафиксировать дату завершения сделки
//
Процедура ЗафиксироватьДатуЗавершенияСделки()
	
	Если НЕ ЗначениеЗаполнено(ДатаЗавершенияСделки) Тогда 
		Если ЭтапСделки = Справочники.ЭтапыСделок.Успех И ЗначениеЗаполнено(Прием) Тогда 
			ДатаЗавершенияСделки = ТекущаяДатаСеанса();
		ИначеЕсли ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда 
			ДатаЗавершенияСделки = ТекущаяДатаСеанса();
		КонецЕсли;
	Иначе
		Если ЗначениеЗаполнено(РезультатСделки) Тогда
			ДатаЗавершенияСделки = ТекущаяДатаСеанса();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Проверить бизнес логику создания
//
// Параметры:
//  СделкаАналог - 	 - 
//  Комментарий	 - 	 - 
