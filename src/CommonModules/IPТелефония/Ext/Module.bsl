// Функция - Получить унифицированную структуру события
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьУнифицированнуюСтруктуруСобытия() Экспорт 
	
	УнифицированнаяСтруктураСобытия = Новый Структура;
	УнифицированнаяСтруктураСобытия.Вставить("ПОIPТелефонии"				, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("IDЗвонка"						, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("IDПлеча"						, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("НаправлениеВызова"			, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ЗвонокУспешен"				, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ПризнакЗвонокПропущен"		, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("СтатусЗвонка"					, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("НомерТелефонаFrom"			, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("НомерТелефонаTo"				, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ВнутреннийНомерСотрудника"	, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("НомерКонтрагента"				, Неопределено);		
	УнифицированнаяСтруктураСобытия.Вставить("ВремяПоступленияВызова"		, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ВремяОтветаНаВызов"			, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ВремяЗавершенияВызова"		, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("Продолжительность"			, Неопределено);	
	УнифицированнаяСтруктураСобытия.Вставить("ПринятДругимАбонентомГруппы"	, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("Контрагент"					, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("РекламныйИсточник"			, Неопределено);	
	УнифицированнаяСтруктураСобытия.Вставить("СсылкаНаЗаписьЗвонка"			, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ФайлСсылкаЗаписиРазговора"	, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ФинализирующееСобытие"		, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("СтруктурнаяЕдиница"		    , Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("Заявка"		                , Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("ИсточникЗвонка"				, Неопределено);
	УнифицированнаяСтруктураСобытия.Вставить("КоллтрекингНомер"				, Неопределено);
	                                
	Возврат УнифицированнаяСтруктураСобытия;
	
КонецФункции

// Функция - Добавить обновить звонок в историю
// 
// Параметры:
//  НомерТелефонаИз	 - 	 - 
//  НомерТелефонаВ	 - 	 - 
//  ПризнакИсходящийЗвонок	 - 	 - 
//  Продолжительность		 - 	 - 
//  СсылкаНаЗаписьЗвонка	 - 	 - 
//  Статус					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ДобавитьОбновитьЗвонокВИсторию(ПараметрыЗвонка = Неопределено, СтруктураСобытия) Экспорт  // , ПОТелефонии, IDЗвонка, НомерТелефонаИз, НомерТелефонаВ, ПризнакВходящийЗвонок, ДатаВремяИлиПродолжительность = 0, СсылкаНаЗаписьЗвонка = "", ФайлСсылкаЗаписиРазговора = Неопределено, Статус, ПринятДругимАбонентомГруппы = Ложь)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если СтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS 
			ИЛИ СтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM Тогда

		НомерТелефона	  = СтруктураСобытия.НомерТелефонаFrom;
		ПользовательSip	  = СтруктураСобытия.НомерТелефонаTo; 		
		// ТелефонныйАппарат = Справочники.ТелефонныеАппараты.ПолучитьТелефонныйАппаратПоНомеру(СтруктураСобытия.ВнутреннийНомерСотрудника);
	Иначе		
		НомерТелефона	  = ?(СтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий, СтруктураСобытия.НомерТелефонаFrom, СтруктураСобытия.НомерТелефонаTo);
		ПользовательSip	  = ?(СтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий, СтруктураСобытия.НомерТелефонаTo	, СтруктураСобытия.НомерТелефонаFrom);					
		IPТелефонияПараметры = СтруктураСобытия.ПОIPТелефонии.Параметры.Получить();		
	КонецЕсли; 		
	
	Контрагент = Неопределено;
	Если Не ЗначениеЗаполнено(СтруктураСобытия.ФайлСсылкаЗаписиРазговора) Тогда			
		ДанныеПоЗвонку = РегистрыСведений.ИсторияВызовов.ПолучитьПоIDЗвонка(СтруктураСобытия.IDЗвонка);
		Если НЕ ЗначениеЗаполнено(ДанныеПоЗвонку) ИЛИ НЕ ЗначениеЗаполнено(ДанныеПоЗвонку.Контрагент) Тогда
			НомерТелефонаДляПоиска	= ?(ЗначениеЗаполнено(НомерТелефона), НомерТелефона, ?(ЗначениеЗаполнено(ДанныеПоЗвонку), ДанныеПоЗвонку.НомерТелефона, ""));
			Контрагент				= ?(ЗначениеЗаполнено(СтруктураСобытия.Контрагент), СтруктураСобытия.Контрагент, ПолучитьКонтрагентаСотрудникаПоНомеруТелефона(НомерТелефонаДляПоиска));	
		КонецЕсли;		
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей(); 
	
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Установить(СтруктураСобытия.ПОIPТелефонии);
	НаборЗаписей.Отбор.IDЗвонка.Установить(СтруктураСобытия.IDЗвонка);
	
	НачатьТранзакцию();
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрСведений.ИсторияВызовов");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("IDЗвонка", СтруктураСобытия.IDЗвонка);
	БлокировкаДанных.Заблокировать();
	
	НаборЗаписей.Прочитать();
	
	Запись 									= Неопределено;
	ПоказатьУведомлениеОПропущенном 		= Ложь;
	УдалитьЗапланированныеУведомления 		= Ложь;	
	Если НаборЗаписей.Количество() > 0 Тогда 
		Запись = НаборЗаписей[0];
	ИначеЕсли НаборЗаписей.Количество() = 0 Тогда 
		Запись = НаборЗаписей.Добавить();
	КонецЕсли;
	
	Если Запись <> Неопределено Тогда 
		
		Если НЕ (СтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS 
					ИЛИ СтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM) Тогда
			
			ПользовательSip   = ?(ЗначениеЗаполнено(ПользовательSip), ПользовательSip, Запись.ПользовательSip);
			ТелефонныйАппарат = Справочники.ТелефонныеАппараты.ПолучитьТелефонныйАппаратПоНомеру(ПользовательSip);
			СтруктураСобытия.СтруктурнаяЕдиница = ?(ЗначениеЗаполнено(ТелефонныйАппарат), ТелефонныйАппарат.СтруктурнаяЕдиница, ?(IPТелефонияПараметры.Свойство("СтруктурнаяЕдиница"), IPТелефонияПараметры.СтруктурнаяЕдиница, Неопределено));
		КонецЕсли; 
		
		Если СтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS
				ИЛИ СтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM Тогда
				
			СписокАктивныхПользователей = ПолучитьСписокАктивныхПользователей(СтруктураСобытия.ВнутреннийНомерСотрудника);
		Иначе
			СписокАктивныхПользователей = ПолучитьСписокАктивныхПользователей(ПользовательSip);
		КонецЕсли;
			
		Запись.ОборудованиеТелефонии 		= СтруктураСобытия.ПОIPТелефонии;
		Запись.IDЗвонка 					= СтруктураСобытия.IDЗвонка;
		Запись.НомерТелефона 				= ?(ЗначениеЗаполнено(НомерТелефона), НомерТелефона, Запись.НомерТелефона);
		Запись.ВнутреннийНомерСотрудника	= ?(ЗначениеЗаполнено(СтруктураСобытия.ВнутреннийНомерСотрудника), СтруктураСобытия.ВнутреннийНомерСотрудника, Запись.ВнутреннийНомерСотрудника);
		Запись.ПользовательSip 				= ?(ЗначениеЗаполнено(ПользовательSip), ПользовательSip, Запись.ПользовательSip);
		Запись.НаправлениеВызова			= ?(ЗначениеЗаполнено(СтруктураСобытия.НаправлениеВызова), СтруктураСобытия.НаправлениеВызова, Запись.НаправлениеВызова);
		Запись.СтруктурнаяЕдиница 			= ?(ЗначениеЗаполнено(СтруктураСобытия.СтруктурнаяЕдиница), СтруктураСобытия.СтруктурнаяЕдиница, Запись.СтруктурнаяЕдиница);
		Запись.Пользователь					= ?(СписокАктивныхПользователей.Количество() > 0, СписокАктивныхПользователей[0].Пользователь, Запись.Пользователь);
		Запись.URLЗаписи					= ?(ЗначениеЗаполнено(СтруктураСобытия.СсылкаНаЗаписьЗвонка), СтруктураСобытия.СсылкаНаЗаписьЗвонка, Запись.URLЗаписи);
		Запись.ФайлЗаписи					= ?(ЗначениеЗаполнено(СтруктураСобытия.ФайлСсылкаЗаписиРазговора), СтруктураСобытия.ФайлСсылкаЗаписиРазговора, Запись.ФайлЗаписи);
		// Запись.ИсточникЗвонка				= ?(ЗначениеЗаполнено(СтруктураСобытия.ИсточникЗвонка), СтруктураСобытия.ИсточникЗвонка, Запись.ИсточникЗвонка);
		Запись.ИсходящийЗвонок				= ?(ЗначениеЗаполнено(СтруктураСобытия.НаправлениеВызова), СтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий, Запись.ИсходящийЗвонок);
		
		Если СтруктураСобытия.СтатусЗвонка = Перечисления.СтатусыЗвонка.Вызов Тогда
			
			Если ЗначениеЗаполнено(СтруктураСобытия.ВремяПоступленияВызова) Тогда 
				Запись.НачалоВызова 		= Макс(Запись.НачалоВызова, СтруктураСобытия.ВремяПоступленияВызова);
			КонецЕсли; 
			Запись.Статус 					= ?(НЕ ЗначениеЗаполнено(Запись.Статус), Перечисления.СтатусыЗвонка.Вызов, Запись.Статус);

		ИначеЕсли СтруктураСобытия.СтатусЗвонка = Перечисления.СтатусыЗвонка.Разговор Тогда
			
			// Если пришел статус "Разговор" - то мы должны в любом случае заполнить ресурс "НачалоРазговора", чтобы понимать что трубку подняли
			Если ЗначениеЗаполнено(СтруктураСобытия.ВремяОтветаНаВызов) Тогда
				Если ЗначениеЗаполнено(Запись.НачалоРазговора) И ЗначениеЗаполнено(СтруктураСобытия.ВремяОтветаНаВызов) Тогда 
					Запись.НачалоРазговора 	= Мин(Запись.НачалоРазговора, СтруктураСобытия.ВремяОтветаНаВызов);
				Иначе 	
					Запись.НачалоРазговора 	= Макс(Запись.НачалоРазговора, СтруктураСобытия.ВремяОтветаНаВызов);
				КонецЕсли;	
			ИначеЕсли ЗначениеЗаполнено(СтруктураСобытия.Продолжительность) И ТипЗнч(СтруктураСобытия.Продолжительность) = Тип("Число") Тогда
				Запись.НачалоРазговора 		= Макс(Запись.НачалоВызова, Запись.НачалоРазговора) + СтруктураСобытия.Продолжительность;
			Иначе 
				Запись.НачалоРазговора 		= Макс(Запись.НачалоВызова, Запись.НачалоРазговора);
			КонецЕсли;
			Запись.Статус = Перечисления.СтатусыЗвонка.Разговор; 
			
		ИначеЕсли СтруктураСобытия.СтатусЗвонка = Перечисления.СтатусыЗвонка.Пропущен ИЛИ СтруктураСобытия.СтатусЗвонка = Перечисления.СтатусыЗвонка.Завершен Тогда
			
			Если СтруктураСобытия.ФинализирующееСобытие	= Истина Тогда
				// Актуализируем даты
				Если ЗначениеЗаполнено(СтруктураСобытия.ВремяПоступленияВызова) Тогда 
					Если ЗначениеЗаполнено(Запись.НачалоВызова) Тогда 
						Запись.НачалоВызова 	= Мин(Запись.НачалоВызова, СтруктураСобытия.ВремяПоступленияВызова);
					Иначе 
						Запись.НачалоВызова 	= СтруктураСобытия.ВремяПоступленияВызова;
					КонецЕсли;	
				КонецЕсли;
				Если ЗначениеЗаполнено(СтруктураСобытия.ВремяОтветаНаВызов) Тогда
					Запись.НачалоРазговора 	= СтруктураСобытия.ВремяОтветаНаВызов;
				КонецЕсли;
				Если ЗначениеЗаполнено(СтруктураСобытия.ВремяЗавершенияВызова) Тогда
					Запись.ОкончаниеЗвонка 	= СтруктураСобытия.ВремяЗавершенияВызова;
				КонецЕсли;
			Иначе 
				Если ЗначениеЗаполнено(СтруктураСобытия.ВремяЗавершенияВызова) Тогда
					Запись.ОкончаниеЗвонка 	= Макс(Запись.ОкончаниеЗвонка, СтруктураСобытия.ВремяЗавершенияВызова);
				ИначеЕсли ЗначениеЗаполнено(СтруктураСобытия.Продолжительность) И ТипЗнч(СтруктураСобытия.Продолжительность) = Тип("Число") Тогда 
					Запись.ОкончаниеЗвонка 	= Макс(Запись.НачалоВызова, Запись.НачалоРазговора) + СтруктураСобытия.Продолжительность;
				Иначе 
					Запись.ОкончаниеЗвонка 	= Макс(Запись.НачалоВызова, Запись.НачалоРазговора);
				КонецЕсли;
			КонецЕсли;
			Запись.Статус 					= СтруктураСобытия.СтатусЗвонка;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтруктураСобытия.ФайлСсылкаЗаписиРазговора) Тогда
			НаборЗаписей.Записать(Истина);
			ЗафиксироватьТранзакцию();
		Иначе 	
			// Ищем и заполняем контрагента если он есть в базе
			Если НЕ ЗначениеЗаполнено(Запись.Контрагент) Тогда
				
				Если СтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсBINOTEL Тогда
					СписокНомеровТелефонов = ПолучитьСписокНомеровТелефоновBINOTEL(Запись.НомерТелефона);
				Иначе
					СписокНомеровТелефонов = Неопределено;
				КонецЕсли;
				
				Запись.Контрагент = ?(ЗначениеЗаполнено(СтруктураСобытия.Контрагент), СтруктураСобытия.Контрагент, ПолучитьКонтрагентаСотрудникаПоНомеруТелефона(Запись.НомерТелефона, СписокНомеровТелефонов));
				
			КонецЕсли;
			
			// Корректировка по статусу (Манго не возвращает статус что звонок пропущен или длительность его)
			Если Запись.Статус = Перечисления.СтатусыЗвонка.Завершен И НЕ ЗначениеЗаполнено(Запись.НачалоРазговора) Тогда
				Запись.Статус 		= ?(Запись.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий, Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.НеДозвон);
			ИначеЕсли (Запись.Статус = Перечисления.СтатусыЗвонка.Разговор ИЛИ Запись.Статус = Перечисления.СтатусыЗвонка.Завершен) И ЗначениеЗаполнено(Запись.НачалоРазговора) Тогда
				// Снимаем признак "Не обработан" с пропущенных ранее звонков
				АктуализироватьПропущенныеЗвонки(Запись);
			КонецЕсли;
			
			// Коррректировка по статусу "не дозвон", когда звонок исходящий и статус пропущен
			Если Запись.Статус = Перечисления.СтатусыЗвонка.Пропущен И Запись.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий Тогда		
				Запись.Статус = Перечисления.СтатусыЗвонка.НеДозвон;					
			КонецЕсли;			
			
			// Проставляем признак "Не обработан"
			Если Запись.НеОбработан = Истина И ЗначениеЗаполнено(Запись.НачалоРазговора) Тогда
				// События приходили не по порядку. Снимаем ошибочно установленный флаг "НеОбработан".
				Запись.НеОбработан 					= Ложь;
				УдалитьЗапланированныеУведомления 	= Истина;
			Иначе 	
				Запись.НеОбработан 					= Запись.Статус = Перечисления.СтатусыЗвонка.Пропущен;
				ПоказатьУведомлениеОПропущенном 	= Запись.НеОбработан;			
			КонецЕсли;	
			
			// Если входящий звонок поступил на группу и был пропущен - то в качестве пользователя запишем группу
			Если НЕ ПараметрыЗвонка = Неопределено И Запись.ИсходящийЗвонок = Ложь Тогда 
				Если Запись.Статус = Перечисления.СтатусыЗвонка.Пропущен Тогда 
					Если ПараметрыЗвонка.Свойство("to") И ПараметрыЗвонка.to.Свойство("acd_group") И ЗначениеЗаполнено(ПараметрыЗвонка.to.acd_group) Тогда 
						Запись.ПользовательSip 	= СокрЛП(ПараметрыЗвонка.to.acd_group);
						Запись.Пользователь 	= Справочники.Сотрудники.ПустаяСсылка();
					КонецЕсли;
				ИначеЕсли Запись.Статус = Перечисления.СтатусыЗвонка.Завершен Тогда
					Запись.ПользовательSip 	= ?(ЗначениеЗаполнено(ПользовательSip), ПользовательSip, Запись.ПользовательSip);
					Запись.Пользователь		= ?(СписокАктивныхПользователей.Количество() > 0, СписокАктивныхПользователей[0].Пользователь, Запись.Пользователь);
				КонецЕсли;
			КонецЕсли;	
			
			ТелефонВЧС = РегистрыСведений.ЗаблокированныеНомераТелефонов.ТелефонВЧерномСписке(Запись.НомерТелефона);
			ЭтоГородской = УправлениеКонтактнойИнформациейСтоматология.ЭтоГородскойРФ(Запись.НомерТелефона);

			Если НЕ ТелефонВЧС И Не Запись.ИсходящийЗвонок И Не ЭтоГородской Тогда
				
				// Новая обработка
				
				ПреобразованныйНомер = СтрЗаменить(СтрСоединить(СтрРазделить(Запись.НомерТелефона, "+&<>`“‘|%/\@() "), ""), Символы.НПП, "");
				Заявка = Справочники.Заявки.ПолучитьЗаявкуПоНомеруТелефона(ПреобразованныйНомер);
				МассивПациентов = СписокПациентов(ПреобразованныйНомер);   
				
				Если ЗначениеЗаполнено(МассивПациентов) И МассивПациентов.Количество() > 0 Тогда
					
					Пациент = МассивПациентов[0];
					Сделка = Справочники.Сделки.ПолучитьАктуальнуюСделкуКлиента(Пациент);	
					
					Если ЗначениеЗаполнено(Сделка) Тогда
						Заявка = Сделка;
					Иначе
						ПриемСуществует = ?(ЗначениеЗаполнено(Пациент), ПриемСуществует(Пациент), Ложь);
						
						Если ПриемСуществует Тогда
							ДанныеЗаполнения = Новый Структура();
							ДанныеЗаполнения.Вставить("ВидСделки"         , ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"));
							ДанныеЗаполнения.Вставить("Контрагент"        , Пациент);
							ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница", Запись.СтруктурнаяЕдиница);
							ДанныеЗаполнения.Вставить("ЭтапСделки"        , Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(Справочники.ВидыСделок.НовыеПациенты, 1));
							
							МассивСтатусов = Новый Массив;
							МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.НеОбработана);
							ЗаявкаОснование = Справочники.Заявки.ПолучитьЗаявкуКонтрагента(Пациент, МассивСтатусов,,Истина);						
							ДанныеЗаполнения.Вставить("Заявка"            , ЗаявкаОснование);
							
							Заявка = Справочники.Сделки.СоздатьНовуюСделку(ДанныеЗаполнения, Истина);
						ИначеЕсли Не ЗначениеЗаполнено(Заявка) Тогда
							
							Заявка = Справочники.Заявки.СоздатьВходящуюЗаявку(,,,Пациент.Фамилия,Пациент.Имя,Пациент.Отчество,Запись.НомерТелефона,,, Справочники.КаналыПривлечения.ВходящийЗвонок,,,, Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.IPТелефония,Истина),,Пациент,Запись.СтруктурнаяЕдиница);
							
						КонецЕсли;
					КонецЕсли;
					
				Иначе	
					
					Если Не ЗначениеЗаполнено(Заявка) Тогда
						Заявка = Справочники.Заявки.СоздатьВходящуюЗаявку(,,,,,,Запись.НомерТелефона,,, Справочники.КаналыПривлечения.ВходящийЗвонок,,,, Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.IPТелефония,Истина),,,Запись.СтруктурнаяЕдиница);	
					ИначеЕсли ЗначениеЗаполнено(Заявка.НомерТелефона) 
						И Не Запись.ИсходящийЗвонок 
						И Заявка.Статус <> Перечисления.СтатусыЗаявок.Отклонена 
						И Заявка.Статус <> Перечисления.СтатусыЗаявок.Принята Тогда
						
						Если Запись.Статус = Перечисления.СтатусыЗвонка.Пропущен Тогда
							ЗаявкаОбъект = Заявка.ПолучитьОбъект();
							ЗаявкаОбъект.Статус = Перечисления.СтатусыЗаявок.ПропущенныйЗвонок;
							ЗаявкаОбъект.Записать();	
						ИначеЕсли СтруктураСобытия.СтатусЗвонка = Перечисления.СтатусыЗвонка.Разговор Тогда	
