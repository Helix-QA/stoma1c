// Выполняет движения регистра бухгалтерии Управленческий.
//
Процедура Управленческий(ДополнительныеСвойства, Движения, Отказ) Экспорт
	
	ТаблицаУправленческий = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаУправленческий;
	
	Если Отказ
	 ИЛИ ТаблицаУправленческий.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДвиженияУправленческий = Движения.Управленческий;
	ДвиженияУправленческий.Записывать = Истина;
	
	Для каждого СтрокаТаблицаУправленческий Из ТаблицаУправленческий Цикл		
		// Заполнение основных реквизитов
		ДвижениеУправленческий = ДвиженияУправленческий.Добавить();
		ЗаполнитьЗначенияСвойств(ДвижениеУправленческий, СтрокаТаблицаУправленческий);
		
		ВидСубконтоДт1 = Неопределено;
		ВидСубконтоДт2 = Неопределено;
		ВидСубконтоДт3 = Неопределено;
		ВидСубконтоДт4 = Неопределено;

		ВидСубконтоКт1 = Неопределено;
		ВидСубконтоКт2 = Неопределено;
		ВидСубконтоКт3 = Неопределено;
		ВидСубконтоКт4 = Неопределено;
		
		// Определяем наличие субконто в данных
		Если ТаблицаУправленческий.Колонки.Найти("СубконтоДт1") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоДт1) Тогда
			ВидСубконтоДт1 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетДт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоДт1); 			
		КонецЕсли;
		Если ТаблицаУправленческий.Колонки.Найти("СубконтоДт2") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоДт2) Тогда
			ВидСубконтоДт2 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетДт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоДт2); 			
		КонецЕсли; 
		Если ТаблицаУправленческий.Колонки.Найти("СубконтоДт3") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоДт3) Тогда
			ВидСубконтоДт3 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетДт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоДт3); 			
		КонецЕсли;
		Если ТаблицаУправленческий.Колонки.Найти("СубконтоДт4") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоДт4) Тогда
			ВидСубконтоДт4 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетДт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоДт4); 			
		КонецЕсли; 
		
		Если ТаблицаУправленческий.Колонки.Найти("СубконтоКт1") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоКт1) Тогда
			ВидСубконтоКт1 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетКт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоКт1); 			
		КонецЕсли;
		Если ТаблицаУправленческий.Колонки.Найти("СубконтоКт2") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоКт2) Тогда
			ВидСубконтоКт2 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетКт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоКт2); 			
		КонецЕсли;
	    Если ТаблицаУправленческий.Колонки.Найти("СубконтоКт3") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоКт3) Тогда
			ВидСубконтоКт3 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетКт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоКт3); 			
		КонецЕсли;
		Если ТаблицаУправленческий.Колонки.Найти("СубконтоКт4") <> Неопределено И ЗначениеЗаполнено(СтрокаТаблицаУправленческий.СубконтоКт4) Тогда
			ВидСубконтоКт4 = ПланыВидовХарактеристик.ВидыСубконто.ПолучитьВидСубконтоПоЗначению(ДвижениеУправленческий.СчетКт.Ссылка.ВидыСубконто,СтрокаТаблицаУправленческий.СубконтоКт4); 			
		КонецЕсли;
	
		// Заполняем значения субконто
		Если ВидСубконтоДт1 <> Неопределено Тогда				
			ДвижениеУправленческий.СубконтоДт[ВидСубконтоДт1] = СтрокаТаблицаУправленческий.СубконтоДт1;
		КонецЕсли;
		Если ВидСубконтоДт2 <> Неопределено Тогда
			ДвижениеУправленческий.СубконтоДт[ВидСубконтоДт2] = СтрокаТаблицаУправленческий.СубконтоДт2;
		КонецЕсли;
		Если ВидСубконтоДт3 <> Неопределено Тогда				
			ДвижениеУправленческий.СубконтоДт[ВидСубконтоДт3] = СтрокаТаблицаУправленческий.СубконтоДт3;
		КонецЕсли;
		Если ВидСубконтоДт4 <> Неопределено Тогда
			ДвижениеУправленческий.СубконтоДт[ВидСубконтоДт4] = СтрокаТаблицаУправленческий.СубконтоДт4;
		КонецЕсли;
	
		Если ВидСубконтоКт1 <> Неопределено Тогда
			ДвижениеУправленческий.СубконтоКт[ВидСубконтоКт1] = СтрокаТаблицаУправленческий.СубконтоКт1;
		КонецЕсли;
        Если ВидСубконтоКт2 <> Неопределено Тогда
			ДвижениеУправленческий.СубконтоКт[ВидСубконтоКт2] = СтрокаТаблицаУправленческий.СубконтоКт2;
		КонецЕсли;
		Если ВидСубконтоКт3 <> Неопределено Тогда
			ДвижениеУправленческий.СубконтоКт[ВидСубконтоКт3] = СтрокаТаблицаУправленческий.СубконтоКт3;
		КонецЕсли;
        Если ВидСубконтоКт4 <> Неопределено Тогда
			ДвижениеУправленческий.СубконтоКт[ВидСубконтоКт4] = СтрокаТаблицаУправленческий.СубконтоКт4;
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

// Выполняет движения регистра накопления БонусныеСчета.
//  Параметры:
//   ДополнительныеСвойства - структура, дополнительные свойства для проведения документа;
//   Движения - набор движений документа;
//   Отказ    - булево, признак отказа записи набора данных.
//
Процедура БонусныеСчета(ДополнительныеСвойства, Движения, Отказ) Экспорт
	
	ТаблицаБонусныеСчета = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаБонусныеСчета;

	ДвиженияБонусныеСчета = Движения.БонусныеСчета;
	ДвиженияБонусныеСчета.Записывать = Истина;
	ДвиженияБонусныеСчета.Загрузить(ТаблицаБонусныеСчета);
	
КонецПроцедуры

// Процедура определяет ситуацию, когда при изменении своей даты документ 
// оказывается в другом периоде нумерации документов, и в это м случае
// присваивает документу новый уникальный номер.
//
// Параметры:
//  ДокументСсылка - ссылка на документ,из которого вызвана процедура 
//  НоваяДатаДокумента - новая дата документа 
//  НачальнаяДатаДокумента - начальная дата документа 
//
// Возвращаемое значение:
//  Число - разность дат.
//
Функция ПроверитьНомерДокумента(ДокументСсылка, НоваяДатаДокумента, НачальнаяДатаДокумента) Экспорт
	
	// Определяем назначенную для данного вида документов периодичность смены номера
	ПериодСменыНомера = ДокументСсылка.Метаданные().ПериодичностьНомера;
	
	// В зависимости от установленной периодичности смены номеров,
	// определяем разность старой и новой датами документа.
	Если ПериодСменыНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.Год Тогда
		РазностьДат = НачалоГода(НачальнаяДатаДокумента) - НачалоГода(НоваяДатаДокумента);
	ИначеЕсли ПериодСменыНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.Квартал Тогда
		РазностьДат = НачалоКвартала(НачальнаяДатаДокумента) - НачалоКвартала(НоваяДатаДокумента);
	ИначеЕсли ПериодСменыНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.Месяц Тогда
		РазностьДат = НачалоМесяца(НачальнаяДатаДокумента) - НачалоМесяца(НоваяДатаДокумента);
	ИначеЕсли ПериодСменыНомера = Метаданные.СвойстваОбъектов.ПериодичностьНомераДокумента.День Тогда
		РазностьДат = НачальнаяДатаДокумента - НоваяДатаДокумента;
	Иначе
		Возврат 0;
	КонецЕсли;
	
	Возврат РазностьДат;
	
КонецФункции

