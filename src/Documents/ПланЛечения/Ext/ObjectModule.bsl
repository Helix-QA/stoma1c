
#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаЗаполнения" объекта
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	СтруктурнаяЕдиница             = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ВидЦен                         = ?(Не СтруктурнаяЕдиница.ВидЦенРеализации.Пустая(), СтруктурнаяЕдиница.ВидЦенРеализации, Справочники.ВидыЦен.Розничная);	
	АвторДокумента	   			   = ПараметрыСеанса.ТекущийПользователь;
	ЗначениеНастройки              = ПользователиСтоматология.ПолучитьЗначениеПоУмолчаниюПользователя(АвторДокумента, "ОсновнаяКасса", СтруктурнаяЕдиница);	
	Касса 		                   = ?(ЗначениеЗаполнено(ЗначениеНастройки), ЗначениеНастройки, СтруктурнаяЕдиница.ОсновнаяКасса);
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда 
		Если ДанныеЗаполнения.Свойство("Контрагент") Тогда 
			Контрагент = ДанныеЗаполнения.Контрагент;
		КонецЕсли;
		Если ДанныеЗаполнения.Свойство("ПолисМедСтрахования") Тогда 
			ПолисМедСтрахования = ДанныеЗаполнения.ПолисМедСтрахования;
		КонецЕсли;		
	КонецЕсли;
	// Заполнение на основании документ ПЗ
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Событие") Тогда
		ДокументОснование   = ДанныеЗаполнения;
		Контрагент          = ДанныеЗаполнения.Контрагент;
		Сотрудник           = ЗаполнитьСотрудника(ДанныеЗаполнения);
		СтруктурнаяЕдиница  = ДанныеЗаполнения.СтруктурнаяЕдиница;
		ВидЦен              = ДанныеЗаполнения.ВидЦен;  
		ПолисМедСтрахования = ДанныеЗаполнения.ПолисМедСтрахования;
		
		ЗаполнитьТаблицуЛечение(ДанныеЗаполнения);
		СуммаДокумента = Лечение.Итог("Сумма");
	КонецЕсли;
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
		
КонецПроцедуры

// процедура обработчик события "Перед записью".
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)	
	
	Если ЭтотОбъект.Ссылка.ПометкаУдаления = Ложь И ПометкаУдаления Тогда
		РедактированиеРазрешено = (Статус <> Перечисления.СтатусыПланЛечения.Принят И Статус <> Перечисления.СтатусыПланЛечения.Закрыт)
		ИЛИ РольДоступна("ПолныеПрава") ИЛИ РольДоступна("АдминистраторСистемы");                                        
		
		Если НЕ РедактированиеРазрешено Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Удаление документа запрещено.",,,, Отказ);
			Возврат;
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

// Процедура - обработчик события "ПриЗаписи" объекта.
//
Процедура ПриЗаписи(Отказ)
	
	Если ЗначениеЗаполнено(ПолисМедСтрахования) 
		И ПолисМедСтрахования.ЛимитПолиса > 0 Тогда
		
		СуммаОплатПоПолису = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьСуммуОплатыПоПолису(ПолисМедСтрахования, Дата);
		Если СуммаОплатПоПолису + СуммаДокумента > ПолисМедСтрахования.ЛимитПолиса Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Превышен лимит по полису: %1. Общая сумма оплат: %2.", ПолисМедСтрахования.ЛимитПолиса, СуммаОплатПоПолису + СуммаДокумента));
			Отказ = Истина;
		КонецЕсли;		
		
	КонецЕсли;	
	
КонецПроцедуры

// Обработчик копирования объекта
//
Процедура ПриКопировании(ОбъектКопирования)
	
	СуммаОплачено = 0;
	Если Статус = Перечисления.СтатусыПланЛечения.Закрыт ИЛИ Статус = Перечисления.СтатусыПланЛечения.Отвергнут Тогда 
		Статус = Перечисления.СтатусыПланЛечения.Рассматривается;
	КонецЕсли;
	Для Каждого СтрокаТЧ Из Лечение Цикл 
		СтрокаТЧ.Прием = Неопределено;
	КонецЦикла;	
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	
КонецПроцедуры

// Процедура - обработчик события "ОбработкаПроверкиЗаполнения".
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Проверка табличной части на разрешения по значениям 
	Если ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьНулевуюСумму, Ложь) Тогда
		УдаляемыйЭлемент = ПроверяемыеРеквизиты.Найти("Запасы.Сумма");
		Если УдаляемыйЭлемент <> Неопределено Тогда
			ПроверяемыеРеквизиты.Удалить(УдаляемыйЭлемент);
		КонецЕсли;
	КонецЕсли;
	
	// 1. Определяем вид налога, если он не заполнен, для старых документов.	
	Если Лечение.Количество() > 0 Тогда
		ВидНалога    = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Лечение[0].Номенклатура, СтруктурнаяЕдиница);// Лечение[0].Номенклатура.ВидНалога;
		Номенклатура = Лечение[0].Номенклатура;
	Иначе
		Возврат;
	КонецЕсли;
	
	ЕстьРазличия = Ложь;
	Для Каждого СтрокаТЧ из Лечение Цикл
		Если НЕ Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(СтрокаТЧ.Номенклатура, СтруктурнаяЕдиница) = ВидНалога Тогда
			ЕстьРазличия = Истина;
			мНоменклатура = СтрокаТЧ.Номенклатура;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьРазличия Тогда
		Отказ = Истина;
		ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения. Номенклатура '%1' и '%2' используют разные режимы налогообложения";
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Номенклатура, мНоменклатура);	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;	

КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, Режим)
	
	// Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);	
	
	// Инициализация данных документа.	
	Документы.ПланЛечения.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);	
	
	ДополнительныеСвойства.ДляПроведения.Вставить("ВыполнятьДвиженияСебестоимость", Истина);
	
	// Движения по регистрам
	ДвиженияДокументовСервер.ПланыЛечения(ДополнительныеСвойства, Движения, Отказ);   	
	
	// Запись наборов записей.
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);	
	
	// Актуализация статуа клиента
	Если НЕ ДополнительныеСвойства.Свойство("НеАктуализироватьСтатус") И НЕ ДополнительныеСвойства.Свойство("ЭтоПроведениеЗагруженныхДанных") Тогда
		РегистрыСведений.СтатусыКонтрагентов.АктуализироватьСтатусПациента(ЭтотОбъект.Контрагент);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обработка удаления проведения
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	// Актуализация статуа клиента
	РегистрыСведений.СтатусыКонтрагентов.АктуализироватьСтатусПациента(ЭтотОбъект.Контрагент, Ссылка);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

//
//
Функция ЗаполнитьСотрудника(ДанныеЗаполнения)
	
	Если ДанныеЗаполнения.Услуги.Количество() > 0 Тогда
		СотрудникДляВовзрата = ДанныеЗаполнения.Услуги[0].Сотрудник;
	КонецЕсли;
	Для Каждого СтрокаУслуг Из ДанныеЗаполнения.Услуги Цикл
		Если ДанныеЗаполнения.Услуги[0].Сотрудник <> СтрокаУслуг.Сотрудник Тогда
			СотрудникДляВовзрата = Справочники.Сотрудники.ПустаяСсылка();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ?(СотрудникДляВовзрата <> Неопределено, СотрудникДляВовзрата, Справочники.Сотрудники.ПустаяСсылка());
	
КонецФункции

// Процедура заполняет табличную часть "Лечение".
//
Процедура ЗаполнитьТаблицуЛечение(Основание)
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.Событие") Тогда
		Для Каждого СтрокаТЧУслуги Из Основание.Услуги Цикл
			Если ЗначениеЗаполнено(СтрокаТЧУслуги.Номенклатура) Тогда
				НоваяСтрокаТЧ = Лечение.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ, СтрокаТЧУслуги);
				НоваяСтрокаТЧ.КлючСтроки         = Новый УникальныйИдентификатор;
				НоваяСтрокаТЧ.Количество         = 1;
				НоваяСтрокаТЧ.Зуб                = Перечисления.Зубы.ВсяПолость;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
