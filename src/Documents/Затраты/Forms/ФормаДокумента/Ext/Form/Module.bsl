
#Область ОбработчикиСобытийЭлементовФормы

  &НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("СтатьиЗатрат"	, "ГруппаСтатьиЗатрат");
	СтруктураМеню.Вставить("Дополнительно"	, "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Обработчик события "ПриНачалеРедактирования" элемента формы "Затраты"
//
Процедура ЗатратыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока И НЕ Копирование Тогда		
		Элемент.ТекущиеДанные.Период = ТекущаяДата();		
	КонецЕсли;
	Если НоваяСтрока = Истина И ЗначениеЗаполнено(Объект.СтатьяЗатрат) Тогда
		Элементы.Затраты.ТекущиеДанные.СтатьяЗатрат = Объект.СтатьяЗатрат;		
	КонецЕсли;		
КонецПроцедуры

&НаКлиенте
// При изменении заполнения
//
Процедура СтатьяЗатратПриИзменении(Элемент)
	
	ПоказатьВопрос(Новый ОписаниеОповещения("СтатьяЗатратПриИзмененииЗавершение", ЭтотОбъект), "Перезаполнять заполненные значения?",РежимДиалогаВопрос.ДаНет);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Статья затрат при изменении завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СтатьяЗатратПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ПерезаполнятьЗаполненные = РезультатВопроса = КодВозвратаДиалога.Да;
	Для Каждого СтрокаТ ИЗ Объект.СтатьиЗатрат Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТ.СтатьяЗатрат) ИЛИ ПерезаполнятьЗаполненные = Истина Тогда
			СтрокаТ.СтатьяЗатрат = Объект.СтатьяЗатрат;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик нажатия кнопки переключателя закладок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
КонецПроцедуры	

&НаКлиенте
// Процедура, Статьи затрат при изменении.
//
Процедура СтатьиЗатратПриИзменении(Элемент)
	
	ОбновитьЗаголовкиТабЧастей();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)

	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы


#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, Обновить заголовки таб частей.
//
Процедура ОбновитьЗаголовкиТабЧастей()
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

&НаСервереБезКонтекста  
// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции 

#КонецОбласти



