		// Клиентский метод. Юзаем цикл.
		Для Каждого СтрокаМоделируемыеНастройки Из Форма.МоделируемыеНастройкиКаналовУведомлений Цикл 
			Если СтрокаМоделируемыеНастройки.ИдентификаторДействия = ДанныеЭлемента.ИдентификаторДействия И СтрокаМоделируемыеНастройки.СтруктурнаяЕдиница = ТекущаяСтруктурнаяЕдиница Тогда 
				СтрокаНастройкиКаналовУведомлений = СтрокаМоделируемыеНастройки;
				Прервать;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	Возврат Новый Структура("ИмяТаблицы, ИндексСтроки, ДанныеЭлемента, СтрокаНастройкиКаналовУведомлений", ИмяТаблицы, ИндексСтроки, ДанныеЭлемента, СтрокаНастройкиКаналовУведомлений);
	
КонецФункции

// Функция, возвращает структуру данных документов физ. лиц 
// клиенту
//
Функция ПолучитьКлючСтруктурой(Знач СтруктураДанныеЭлемента)
	
	Если СтруктураДанныеЭлемента.ИмяТаблицы = "УдостоверенияЛичностиСуществующие" Тогда
		
		//СтруктураВозврата = Новый Структура("Период, ВидДокумента, Физлицо");	
		СтруктураВозврата = Новый Структура("ВидДокумента, Физлицо");
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, СтруктураДанныеЭлемента.ДанныеЭлемента);
		
	ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "РодственникиСуществующие" Тогда
		
		СтруктураВозврата = Новый Структура("Контрагент, Родственник");	
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, СтруктураДанныеЭлемента.ДанныеЭлемента);
		
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции 

