// Функция - Получить менеджеров отдела продаж
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВсехМенеджеровОтделаПродаж()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());	
	Запрос.УстановитьПараметр("ДатаНачало"			, НачалоДня(ОтборПериодЗначение.ДатаНачала));    
	Запрос.УстановитьПараметр("ДатаОкончание"		, КонецДня(ОтборПериодЗначение.ДатаОкончания));
		
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	СотрудникиМестаРаботы.Сотрудник КАК Сотрудник,
	               |	ИСТИНА КАК МенеджеровОтделаПродаж,
	               |	ЛОЖЬ КАК ИсполнителиЗадач
	               |ПОМЕСТИТЬ ТаблицаСотрудников
	               |ИЗ
	               |	РегистрСведений.НастройкиСотрудников КАК СотрудникиМестаРаботы
	               |ГДЕ
	               |	СотрудникиМестаРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |	И ВЫБОР
	               |			КОГДА СотрудникиМестаРаботы.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ СотрудникиМестаРаботы.ДатаУвольнения > &ТекущаяДата
	               |		КОНЕЦ
	               |	И СотрудникиМестаРаботы.Сотрудник.ПометкаУдаления = ЛОЖЬ
	               |	И СотрудникиМестаРаботы.Сотрудник.ЭтоГруппа = ЛОЖЬ
	               |	И СотрудникиМестаРаботы.Сотрудник.Роль В (ЗНАЧЕНИЕ(Перечисление.РольПользователя.Регистратура), ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Управляющий))
	               |	И СотрудникиМестаРаботы.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ
	               |	И СотрудникиМестаРаботы.СтруктурнаяЕдиница.ЭтоГруппа = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ТаблицаСотрудников.Сотрудник КАК Сотрудник,
	               |	ТаблицаСотрудников.Сотрудник.НаименованиеСокращенное КАК Представление
	               |ИЗ
	               |	ТаблицаСотрудников КАК ТаблицаСотрудников
	               |ГДЕ
	               |	ТаблицаСотрудников.МенеджеровОтделаПродаж = ИСТИНА
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Представление
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ТаблицаСотрудников.Сотрудник КАК Сотрудник,
	               |	ТаблицаСотрудников.Сотрудник.НаименованиеСокращенное КАК Представление
	               |ИЗ
	               |	ТаблицаСотрудников КАК ТаблицаСотрудников
	               |ГДЕ
	               |	ТаблицаСотрудников.ИсполнителиЗадач = ИСТИНА
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Представление
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ТаблицаСотрудников.Сотрудник КАК Сотрудник,
	               |	ТаблицаСотрудников.Сотрудник.НаименованиеСокращенное КАК Представление
	               |ИЗ
	               |	ТаблицаСотрудников КАК ТаблицаСотрудников
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Представление";
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "СотрудникиМестаРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли; 
	
	ПакетТаблицМенеджеров 			= Запрос.ВыполнитьПакет();
	ТаблицаМенеджеровПродаж			= ПакетТаблицМенеджеров[1].Выгрузить();
	ТаблицаИсполнителейЗадач 		= ПакетТаблицМенеджеров[2].Выгрузить();
	ТаблицаМенеджеров 				= ПакетТаблицМенеджеров[3].Выгрузить();
	
	СписокМенеджеровПоПродажам.ЗагрузитьЗначения(ТаблицаМенеджеровПродаж.ВыгрузитьКолонку("Сотрудник"));
	СписокМенеджеровДляЗадач.ЗагрузитьЗначения(ТаблицаИсполнителейЗадач.ВыгрузитьКолонку("Сотрудник"));
	
	Если СписокМенеджеровПоПродажам.НайтиПоЗначению(ТекущийПользователь) = Неопределено Тогда
		СписокМенеджеровПоПродажам.Добавить(ТекущийПользователь);
	КонецЕсли;
	
	Если СписокМенеджеровДляЗадач.Количество() = 0 Тогда 
		СписокМенеджеровДляЗадач.ЗагрузитьЗначения(ТаблицаМенеджеровПродаж.ВыгрузитьКолонку("Сотрудник"));
	КонецЕсли;	
	
	Если СписокМенеджеровДляЗадач.НайтиПоЗначению(ТекущийПользователь) = Неопределено Тогда
		СписокМенеджеровДляЗадач.Добавить(ТекущийПользователь);
	КонецЕсли;
	
	Возврат ТаблицаМенеджеровПродаж;
	
КонецФункции	

