&НаКлиенте
// Процедура - обработчик события "Выбор".
//
Процедура ТаблицаОснованийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ТаблицаОснованийДокументОснование" И ТипЗнч(Элемент.ТекущиеДанные.ДокументОснование) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") Тогда
		ОткрытьФорму("Документ.ПоступлениеДенежныхСредств.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.ДокументОснование));
	ИначеЕсли Поле.Имя = "ТаблицаОснованийДокументОснование" И ТипЗнч(Элемент.ТекущиеДанные.ДокументОснование) = Тип("ДокументСсылка.Реализация") Тогда
		ОткрытьФорму("Документ.Реализация.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.ДокументОснование));
	ИначеЕсли Поле.Имя = "ТаблицаОснованийДокументОснование" И ТипЗнч(Элемент.ТекущиеДанные.ДокументОснование) = Тип("ДокументСсылка.СписаниеДенежныхСредств") Тогда
		ОткрытьФорму("Документ.СписаниеДенежныхСредств.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.ДокументОснование));
	ИначеЕсли Поле.Имя = "ТаблицаОснованийДокументОснование" И ТипЗнч(Элемент.ТекущиеДанные.ДокументОснование) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
		ОткрытьФорму("Документ.ВозвратОтПокупателя.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.ДокументОснование));
	ИначеЕсли Поле.Имя = "ТаблицаОснованийДокументОснование" И ТипЗнч(Элемент.ТекущиеДанные.ДокументОснование) = Тип("ДокументСсылка.ВводНачальныхОстатков") Тогда
		ОткрытьФорму("Документ.ВводНачальныхОстатков.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.ДокументОснование));
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
// Заполняет чек коррекции на основании.
//
// Параметры:
//  Основание - ДокументСсылка - документ основание для создания чека коррекции.
//  Отказ - Булево - признак отказа от выполнения операции.
//
Процедура ЗаполнитьНаОсновании(Результат)
		
	ФискальнаяОперация = Результат.ДанныеФискальнойОперации;
	
	Основание = ФискальнаяОперация.ДокументОснование;
	Если ФискальнаяОперация = Неопределено Тогда
		
		ТекстСообщения = НСтр("ru = 'Нет сохраненной фискальной операции для документа %1'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Объект.ДокументОснование);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		Отказ = Истина;
		Возврат;
		
	ИначеЕсли ФискальнаяОперация.ЕстьКорректирующийДокумент Тогда
		
		ТекстСообщения = НСтр("ru = 'По данному документу ранее была создана корректировка документом %1. 
		|Создание повторной корректировки не возможно.'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, 
		ФискальнаяОперация.ЧекКоррекции);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		Отказ = Истина;
		Возврат;
		
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, ФискальнаяОперация);
	
	Для Каждого ЭлементМ Из ФискальнаяОперация.МассивОснований Цикл
		НоваяСтрока = Объект.ТаблицаОснований.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМ);
		Если ТипЗнч(НоваяСтрока.ДокументОснование) = Тип("ДокументСсылка.Прием") Или ТипЗнч(НоваяСтрока.ДокументОснование) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
			Если ФискальнаяОперация.МассивУчтенныеАвансы.Количество() > 0 Тогда
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ФискальнаяОперация.МассивУчтенныеАвансы[0]);
				НоваяСтрока.ИдентификаторФискальнойЗаписи = ФискальнаяОперация.МассивУчтенныеАвансы[0].ИдентификаторЗаписи;  
				Для Индекс = 1 по ФискальнаяОперация.МассивУчтенныеАвансы.Количество() - 1 Цикл
					НоваяСтрока = Объект.ТаблицаОснований.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМ);
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ФискальнаяОперация.МассивУчтенныеАвансы[Индекс]); 
					НоваяСтрока.ИдентификаторФискальнойЗаписи = ФискальнаяОперация.МассивУчтенныеАвансы[Индекс].ИдентификаторЗаписи;
				КонецЦикла; 				
			КонецЕсли;			
		КонецЕсли;		
	КонецЦикла;
		
	Объект.Дата								= ТекущаяДатаСеанса();
	Объект.АвторДокумента 					= ОбщегоНазначенияСтоматология.ТекущийПользователь();
	Объект.ДатаКоррекции 					= ФискальнаяОперация.ДатаРасчета;
	Объект.ДополнительныйРеквизит 			= ФискальнаяОперация.ФискальныйПризнак;
	Объект.ДанныеXMLКорректируемогоЧека		= ФискальнаяОперация.ДанныеXML.Получить();
	Объект.Касса							= ОбщегоНазначенияСтоматология.ПолучитьТекущуюСтруктурнуюЕдиницу().ОсновнаяКасса; //Справочники.Кассы.ПолучитьКассуККМПоУмолчанию(Объект.АвторДокумента);
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств")
		Или ТипЗнч(Основание) = Тип("ДокументСсылка.СписаниеДенежныхСредств") Тогда
		ВидОперации = Основание.ВидОперации;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.Реализация")
		Или ТипЗнч(Основание) = Тип("ДокументСсылка.Прием") Тогда
		ВидОперации = Перечисления.ВидыОпераций.Продажа;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
		ВидОперации = Перечисления.ВидыОпераций.Возврат;
	КонецЕсли;
	
	ОбщиеПараметры = МенеджерОборудованияВызовСервера.ЗагрузитьДанныеФискализацииИзXML(Объект.ДанныеXMLКорректируемогоЧека);
	
	ЗаполнитьЗначенияСвойств(Объект, ОбщиеПараметры, "СистемаНалогообложения, ТипРасчета, Кассир, КассирИНН");
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЧекКоррекции") Тогда
		Объект.Контрагент		= Основание.Покупатель;
		Объект.КонтрагентИНН	= Основание.ПокупательИНН;
	Иначе
		Объект.Контрагент		= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Основание			, "Контрагент");
		Если ТипЗнч(Объект.Контрагент) <> Тип("Строка")
			И ОбщегоНазначения.ЕстьРеквизитОбъекта("ИНН", Объект.Контрагент.Метаданные()) Тогда
			
			Объект.КонтрагентИНН	= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Контрагент	, "ИНН");
		КонецЕсли;
	КонецЕсли;
			
	Объект.СНОКорректируемогоДокумента = ОбщиеПараметры.СистемаНалогообложения;
	Объект.ПризнакАгента 			   = ОбщиеПараметры.ПризнакАгента;
	
	Обработки.СозданиеЧековКоррекции.ПолучитьДанныеДляПробитияЧекаККМ(ФискальнаяОперация.ДокументОснование, ОбщиеПараметры);
	ЗаполнитьПозицииЧекаПоОбщимПараметрам(ОбщиеПараметры);
	
	// Оплаты
	Для Каждого СтрокаОплаты Из ОбщиеПараметры.ТаблицаОплат Цикл
		НоваяСтрока = Объект.Оплата.Добавить();   		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОплаты);//,, "ТипОплаты"
		//Если НоваяСтрока.ТипОплаты <> Перечисления.ТипыОплатыККТ.Постоплата Тогда
		//	НоваяСтрока.ТипОплаты = Перечисления.ТипыОплатыККТ.ВстречноеПредоставление;    	
		//КонецЕсли;
	КонецЦикла;
	
	ОбновитьИтоги();
	
КонецПроцедуры

&НаСервере
// Процедура заполняет позиции чека по общим параметрам.
//
Процедура ЗаполнитьПозицииЧекаПоОбщимПараметрам(ОбщиеПараметры)
	
	Для Каждого ПозицияЧека Из ОбщиеПараметры.ПозицииЧека Цикл
		
		НоваяСтрока = Объект.ПозицииЧека.Добавить();
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ПозицияЧека);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ПозицияЧека.ДанныеКодаТоварнойНоменклатуры);
		
		НоваяСтрока.ДанныеПоставщикаИНН 			= ПозицияЧека.ДанныеПоставщика.ИНН;
		НоваяСтрока.ДанныеПоставщикаНаименование 	= ПозицияЧека.ДанныеПоставщика.Наименование;
		НоваяСтрока.ДанныеПоставщикаТелефон 		= ПозицияЧека.ДанныеПоставщика.Телефон;
		
		НоваяСтрока.НаименованиеПредметаРасчета		= ?(ПозицияЧека.Свойство("Номенклатура") И ЗначениеЗаполнено(ПозицияЧека.Номенклатура), 
																						ПозицияЧека.Номенклатура, ПозицияЧека.Наименование);
		НоваяСтрока.СуммаСоСкидками					= ПозицияЧека.Сумма;	
		НоваяСтрока.СтавкаНДС						= Обработки.СозданиеЧековКоррекции.ПолучитьСтавкуНДСПоЗначениюСтавки(ПозицияЧека.СтавкаНДС);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Функция - проверяет внесены ли изменения в чек коррекции по сравнению с исходным XML.
//
Функция ВнесеныИзменения()
	
	ЕстьИзменения = Ложь;	
	
	ОбъектИсходный = Новый Структура;
	Для Каждого Реквизит Из Метаданные.Обработки.СозданиеЧековКоррекции.Реквизиты Цикл
		ОбъектИсходный.Вставить(Реквизит.Имя);	
	КонецЦикла;
	
	ОбщиеПараметры = МенеджерОборудованияВызовСервера.ЗагрузитьДанныеФискализацииИзXML(Объект.ДанныеXMLКорректируемогоЧека);
	
	ЗаполнитьЗначенияСвойств(ОбъектИсходный, ОбщиеПараметры, "СистемаНалогообложения, ТипРасчета, Кассир, КассирИНН");
			
	ОбъектИсходный.СНОКорректируемогоДокумента = ОбщиеПараметры.СистемаНалогообложения;
	ОбъектИсходный.ПризнакАгента 			   = ОбщиеПараметры.ПризнакАгента;
	
	Обработки.СозданиеЧековКоррекции.ПолучитьДанныеДляПробитияЧекаККМ(ФискальнаяОперация.ДокументОснование, ОбщиеПараметры);
	
	ПозицииЧекаПроверка = Объект.ПозицииЧека.Выгрузить();
	ПозицииЧекаПроверка.Очистить();
	
	ИндексСтроки = 0;
	МассивИменРеквизитов = Новый Массив;
	Для Каждого Реквизит Из Метаданные.Обработки.СозданиеЧековКоррекции.ТабличныеЧасти.ПозицииЧека.Реквизиты Цикл
		МассивИменРеквизитов.Добавить(Реквизит.Имя);	
	КонецЦикла;   
	
	Для Каждого ПозицияЧека Из ОбщиеПараметры.ПозицииЧека Цикл
		
		НоваяСтрока = ПозицииЧекаПроверка.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ПозицияЧека);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ПозицияЧека.ДанныеКодаТоварнойНоменклатуры);
		
		НоваяСтрока.ДанныеПоставщикаИНН 			= ПозицияЧека.ДанныеПоставщика.ИНН;
		НоваяСтрока.ДанныеПоставщикаНаименование 	= ПозицияЧека.ДанныеПоставщика.Наименование;
		НоваяСтрока.ДанныеПоставщикаТелефон 		= ПозицияЧека.ДанныеПоставщика.Телефон;
		       		
		НоваяСтрока.НаименованиеПредметаРасчета	= ?(ПозицияЧека.Свойство("Номенклатура") И ЗначениеЗаполнено(ПозицияЧека.Номенклатура), ПозицияЧека.Номенклатура, ПозицияЧека.Наименование);
		НоваяСтрока.СуммаСоСкидками				= ПозицияЧека.Сумма;	
		НоваяСтрока.СтавкаНДС					= Обработки.СозданиеЧековКоррекции.ПолучитьСтавкуНДСПоЗначениюСтавки(ПозицияЧека.СтавкаНДС);
		
		Для Каждого ИмяРеквизита Из МассивИменРеквизитов Цикл
			Если НоваяСтрока[ИмяРеквизита] <> Объект.ПозицииЧека[ИндексСтроки][ИмяРеквизита] Тогда
				ЕстьИзменения = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	Если Не ЕстьИзменения Тогда
		
		ИндексСтроки = 0;
		МассивИменРеквизитов = Новый Массив;
		Для Каждого Реквизит Из Метаданные.Обработки.СозданиеЧековКоррекции.ТабличныеЧасти.Оплата.Реквизиты Цикл
			МассивИменРеквизитов.Добавить(Реквизит.Имя);	
		КонецЦикла;  
		
		Для Каждого СтрокаОплаты Из ОбщиеПараметры.ТаблицаОплат Цикл
			
			СтруктураДанныхСтроки = Новый Структура;
			Для Каждого ИмяРеквизита Из МассивИменРеквизитов Цикл
				СтруктураДанныхСтроки.Вставить(ИмяРеквизита);	
			КонецЦикла;
			
			ЗаполнитьЗначенияСвойств(СтруктураДанныхСтроки, СтрокаОплаты);
			
			Если ОбщиеПараметры.ТаблицаОплат.Количество() = Объект.Оплата.Количество() Тогда
				
				Для Каждого ИмяРеквизита Из МассивИменРеквизитов Цикл
					Если СтруктураДанныхСтроки[ИмяРеквизита] <> Объект.Оплата[ИндексСтроки][ИмяРеквизита] Тогда
						ЕстьИзменения = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;  
			Иначе                              
				ЕстьИзменения = Истина;
			КонецЕсли;
			
			ИндексСтроки = ИндексСтроки + 1;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ЕстьИзменения;
	
КонецФункции       

&НаКлиенте
// Процедура - пересчитывает сумму строки.
//
Процедура ПересчитатьСуммуСтроки(ТекущаяСтрока)
	
	ТекущаяСтрока.СуммаСоСкидками = ТекущаяСтрока.Количество * ТекущаяСтрока.ЦенаСоСкидками;
	
КонецПроцедуры

#КонецОбласти