////////////////////////////////////////////////////////////////////////////////
// Интерфейсные функции модуля, реализующие основные функции
// для пользователя при работе со списком присоединенных файлов.
// Это прежде всего команды (такие как Добавить файлы, Открыть, Редактировать).
//        

#Область СлужебныйПрограммныйИнтерфейс

#Область ОсновнаяРаботаСФайлами

#Область Добавление

// Процедура для обработки команды добавления файлов. Пользователь выбирает
// файлы в диалоге выбора файлов и система пытается поместить их в хранилище файлов,
// если это возможно (если удовлетворяются: условия максимально допустимого размера,
// имеет допустимое расширение, наличие свободного места в томе, при хранении файлов
// в томах, а так же возможны другие условия).
// Передаваемые параметры:
//	ВладелецФайла - любая ссылка - владелец файла
//	УникальныйИдентификатор - уникальный идентификатор формы
//
Процедура ДобавитьФайлы(ВладелецФайла, Знач УникальныйИдентификатор) Экспорт
	
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НастройкиРаботыСФайлами = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ДобавитьФайлыПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ВладелецФайла, НастройкиРаботыСФайлами, УникальныйИдентификатор", ВладелецФайла, НастройкиРаботыСФайлами, УникальныйИдентификатор)));
	
КонецПроцедуры

Процедура ДобавитьФайлыПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ВладелецФайла = ДополнительныеПараметры.ВладелецФайла;
	НастройкиРаботыСФайлами = ДополнительныеПараметры.НастройкиРаботыСФайлами;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
	
	Если Подключено Тогда
		
		ВыборФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		ВыборФайла.МножественныйВыбор = Истина;
		ВыборФайла.Заголовок = НСтр("ru = 'Выбор файла'");
		ВыборФайла.Фильтр = НСтр("ru = 'Все файлы (*.*)|*.*'");
		
		ВыборФайла.Показать(Новый ОписаниеОповещения("ДобавитьФайлыПослеВыбораФайла", ЭтотОбъект, Новый Структура("ВладелецФайла, ВыборФайла, НастройкиРаботыСФайлами, УникальныйИдентификатор", ВладелецФайла, ВыборФайла, НастройкиРаботыСФайлами, УникальныйИдентификатор)));
		
	Иначе // Если веб-клиент без подключенного расширения
		#Если ВебКлиент Тогда
			
			ОбрабочтикЗавершения = Новый ОписаниеОповещения("ПослеПоместитьВыбранныеФайлыВХранилищеВеб",ЭтотОбъект);
			ПоместитьВыбранныеФайлыВХранилищеВеб(ВладелецФайла, НастройкиРаботыСФайлами, УникальныйИдентификатор, ОбработчикЗавершения);
			
		#КонецЕсли
	КонецЕсли;

КонецПроцедуры

// Процедура - Добавить файлы после выбора файла
//
// Параметры:
//  ВыбранныеФайлы			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДобавитьФайлыПослеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	ВладелецФайла = ДополнительныеПараметры.ВладелецФайла;
	ВыборФайла = ДополнительныеПараметры.ВыборФайла;
	НастройкиРаботыСФайлами = ДополнительныеПараметры.НастройкиРаботыСФайлами;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
		
	Если ВыбранныеФайлы <> Неопределено Тогда
		ПрисоединенныеФайлыМассив = Новый Массив;
		ПоместитьВыбранныеФайлыВХранилище(ВыборФайла.ВыбранныеФайлы, ВладелецФайла,
		НастройкиРаботыСФайлами,
		ПрисоединенныеФайлыМассив,
		УникальныйИдентификатор);
		
		Если ПрисоединенныеФайлыМассив.Количество() = 1 Тогда
			ПрисоединенныйФайл = ПрисоединенныеФайлыМассив[0];
			
			ПоказатьОповещениеПользователя(
			НСтр("ru = 'Создание:'"),
			ПолучитьНавигационнуюСсылку(ПрисоединенныйФайл),
			ПрисоединенныйФайл,
			БиблиотекаКартинок.Информация32);
			
			ОткрытьФорму("ОбщаяФорма.ПрисоединенныйФайл", Новый Структура("ПрисоединенныйФайл", ПрисоединенныйФайл),, ПрисоединенныйФайл);
			Оповестить("ЗаписьНовогоПрисоединенногоФайла", ПрисоединенныйФайл);
		КонецЕсли;
		
		Если ПрисоединенныеФайлыМассив.Количество() > 0 Тогда
			ОповеститьОбИзменении(ПрисоединенныеФайлыМассив[0]);
			Оповестить("ЗаписьНовогоПрисоединенногоФайла", ПрисоединенныеФайлыМассив[0]);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - После поместить выбранные файлы в хранилище веб
//
// Параметры:
//  ПрисоединенныйФайл		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеПоместитьВыбранныеФайлыВХранилищеВеб(ПрисоединенныйФайл,ДополнительныеПараметры) Экспорт
	
	Если ПрисоединенныйФайл <> Неопределено Тогда
		ПоказатьОповещениеПользователя(
		НСтр("ru = 'Создание:'"),
		ПолучитьНавигационнуюСсылку(ПрисоединенныйФайл),
		ПрисоединенныйФайл,
		БиблиотекаКартинок.Информация32);
		ОповеститьОбИзменении(ПрисоединенныйФайл);
		ОткрытьФорму("ОбщаяФорма.ПрисоединенныйФайл", Новый Структура("ПрисоединенныйФайл", ПрисоединенныйФайл),, ПрисоединенныйФайл);
		Оповестить("ЗаписьНовогоПрисоединенногоФайла", ПрисоединенныйФайл);
	КонецЕсли;

КонецПроцедуры
	
#Если ВебКлиент Тогда

// Веб-клиент.
// Функция для помещения файла с диска в хранилище присоединенных файлов.
// 
// Параметры:
//  ВладелецФайла - любая ссылка - владелец файла
//  УникальныйИдентификатор - уникальный идентификатор формы
//
// Возвращаемое значение:
//	ссылка на файл
//
Процедура ПоместитьВыбранныеФайлыВХранилищеВеб(ВладелецФайла, НастройкиРаботыСФайлами, УникальныйИдентификатор,ОбработчикЗавершения)
	
	ВремяИзменения = ТекущаяДата(); // Т.к. не можем получить дату модификации файла на диске
	ВремяИзмененияУниверсальное = УниверсальноеВремя(ТекущаяДата());
	
	АдресВременногоХранилищаФайла = "";
	ИмяФайла = "";
	НачатьПомещениеФайла(Новый ОписаниеОповещения("ПоместитьВыбранныеФайлыВХранилищеВебПослеПомещения", ЭтотОбъект, 
	Новый Структура("ВладелецФайла, ВремяИзменения, ВремяИзмененияУниверсальное, НастройкиРаботыСФайлами, ОбработчикЗавершения", 
	ВладелецФайла, ВремяИзменения, ВремяИзмененияУниверсальное, НастройкиРаботыСФайлами, ОбработчикЗавершения)), 
	АдресВременногоХранилищаФайла, ИмяФайла, Истина, УникальныйИдентификатор);
	
КонецПроцедуры

// Процедура - Поместить выбранные файлы в хранилище веб после помещения
//
// Параметры:
//  Результат				 - 	 - 
//  Адрес					 - 	 - 
//  ИмяФайла				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПоместитьВыбранныеФайлыВХранилищеВебПослеПомещения(Результат, АдресВременногоХранилищаФайла, ИмяФайла, ДополнительныеПараметры) Экспорт
	
	ВладелецФайла = ДополнительныеПараметры.ВладелецФайла;
	ВремяИзменения = ДополнительныеПараметры.ВремяИзменения;
	ВремяИзмененияУниверсальное = ДополнительныеПараметры.ВремяИзмененияУниверсальное;
	НастройкиРаботыСФайлами = ДополнительныеПараметры.НастройкиРаботыСФайлами;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	
	Если НЕ Результат Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Неопределено);
		Возврат;
	КонецЕсли;
	
	СтрокиПути = ФайловыеФункцииКлиентСервер.РазложитьСтрокуПоТочкамИСлэшам(ИмяФайла);
	
	Если СтрокиПути.Количество() >= 2 Тогда
		Расширение = СтрокиПути[СтрокиПути.Количество()-1];
		ИмяБезРасширения = СтрокиПути[СтрокиПути.Количество()-2];
	Иначе
		ВызватьИсключение
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Ошибка при помещении файла в хранилище: %1'"),ИмяФайла);
	КонецЕсли;
	
	ЗапретЗагрузкиФайловПоРасширению	= НастройкиРаботыСФайлами.ЗапретЗагрузкиФайловПоРасширению;
	СписокЗапрещенныхРасширений			= НастройкиРаботыСФайлами.СписокЗапрещенныхРасширений;
	
	Если Не ФайловыеФункцииКлиентСервер.РасширениеФайлаРазрешеноДляЗагрузки(ЗапретЗагрузкиФайловПоРасширению, СписокЗапрещенныхРасширений, Расширение) Тогда
		ВызватьИсключение
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Загрузка файлов с расширением ""%1"" запрещена. Обратитесь к администратору системы.'"),
		Расширение);
	КонецЕсли;
	
	// Создадим карточку Файла в БД
	ПрисоединенныйФайл = ПрисоединенныеФайлы.ДобавитьФайл(
	ВладелецФайла,
	ИмяБезРасширения,
	Расширение,
	ВремяИзменения,
	ВремяИзмененияУниверсальное,
	АдресВременногоХранилищаФайла,
	"",
	Истина);
	
	ВыполнитьОбработкуОповещения(ОбработчикЗавершения,ПрисоединенныйФайл);
	Возврат;

КонецПроцедуры

#КонецЕсли

#КонецОбласти

#Область Открытие

// Процедура для обработки команды открытия файла. Если файл открывается для чтения,
// Получает файл в рабочий каталог пользователя, при этом ищет файл в рабочем каталоге
// и предлагает получить файл с сервера или открыть существующий. Если файл редактируется
// безусловно открывает файл в рабочем каталоге (если есть) или получает его сервера.
// Параметры:
//  ДанныеФайла - структура - данные файла
//  ФайлРедактируется - булево - истина, если файл открывается для редактирования, иначе ложь
//
Процедура ОткрытьФайл(ДанныеФайла, ДляРедактирования = Истина) Экспорт
	
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ОткрытьФайлПродолжение", ЭтотОбъект, Новый Структура("ДанныеФайла, ДляРедактирования", ДанныеФайла, ДляРедактирования)));
КонецПроцедуры

Процедура ОткрытьФайлПродолжение(Подключено, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ДляРедактирования = ДополнительныеПараметры.ДляРедактирования;
	
	
	Если Подключено Тогда
		
		ФайловыеФункцииКлиент.ПроинициализироватьПутьКРабочемуКаталогу();
		РабочийКаталогПользователя = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами().ПутьКЛокальномуКэшуФайлов;
		ПолноеИмяФайлаНаКлиенте = РабочийКаталогПользователя + ДанныеФайла.ОтносительныйПуть + ДанныеФайла.ИмяФайла;
		
		Отказ = Ложь;
		
		ФайлНаДиске = Новый Файл(ПолноеИмяФайлаНаКлиенте);
		
		Если ЗначениеЗаполнено(ДанныеФайла.Редактирует) // файл уже редактируется
			И ДляРедактирования
			И ФайлНаДиске.Существует() Тогда
			ФайлНаДиске.УстановитьТолькоЧтение(Ложь);
			ПолучитьФайл = Ложь;
		ИначеЕсли ФайлНаДиске.Существует() Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытьФайлЗавершение",ЭтотОбъект,Новый Структура("ДляРедактирования,ФайлНаДиске,ДанныеФайла,РабочийКаталогПользователя",ДляРедактирования,ФайлНаДиске,ДанныеФайла,РабочийКаталогПользователя));
			ДиалогНужноПолучитьФайлССервера(ПолноеИмяФайлаНаКлиенте, ДанныеФайла, Отказ,ДляРедактирования,ОписаниеОповещения);
			Возврат;
		Иначе
			ПолучитьФайл = Истина;
		КонецЕсли;
		
		ОткрытьФайлЗавершение(Новый Структура("Результат,Отказ",ПолучитьФайл,Отказ),Новый Структура("ДляРедактирования,ФайлНаДиске,ДанныеФайла,РабочийКаталогПользователя",ДляРедактирования,ФайлНаДиске,ДанныеФайла,РабочийКаталогПользователя));
		
	Иначе    
		
		Если ДанныеФайла.ФайлРедактируется И ДанныеФайла.ФайлРедактируетТекущийПользователь Тогда
			ФайловыеФункцииКлиент.ПоказатьНапоминаниеПриРедактировании();
		КонецЕсли;
		
		ПолучитьФайл(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла, ДанныеФайла.ИмяФайла, Истина);
		
	КонецЕсли;

КонецПроцедуры

// Процедура - ОткрытьФайлЗавершение
//
// Параметры:
//  ДанныеФайла			 - 	 - 
//  ДляРедактирования	 - 	 - 
//
Процедура ОткрытьФайлЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ПолучитьФайл               = Результат.ПолучитьФайл;
	Отказ                      = Результат.Отказ;
	ДляРедактирования          = ДополнительныеПараметры.ДляРедактирования;
	ФайлНаДиске        		   = ДополнительныеПараметры.ФайлНаДиске;
	ДанныеФайла        		   = ДополнительныеПараметры.ДанныеФайла; 
	РабочийКаталогПользователя = ДополнительныеПараметры.РабочийКаталогПользователя;
	ФайлМожноОткрывать = Истина;   
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если ПолучитьФайл Тогда
		ПолноеИмяФайлаНаКлиенте = "";
		ФайлМожноОткрывать = 
		ПолучитьФайлВРабочийКаталог(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла,
		ДанныеФайла.ОтносительныйПуть,
		ДанныеФайла.ДатаМодификацииУниверсальная,
		ДанныеФайла.ИмяФайла,
		РабочийКаталогПользователя,
		ПолноеИмяФайлаНаКлиенте);
	КонецЕсли;
	
	Если ФайлМожноОткрывать Тогда
		Если ДляРедактирования Тогда
			ФайлНаДиске.УстановитьТолькоЧтение(Ложь);
		Иначе
			ФайлНаДиске.УстановитьТолькоЧтение(Истина);
		КонецЕсли;
		ОткрытьФайлПриложением(ПолноеИмяФайлаНаКлиенте);
	КонецЕсли;
	
КонецПроцедуры
	
#КонецОбласти

#Область ОткрытьКаталог

// Обработчик команды открытия каталога с файлом. Если файла в каталоге нет,
// он получается в него из хранилища.
// Параметры
//  ДанныеФайла - структура с данными файла
//
Процедура ОткрытьКаталогСФайлом(ДанныеФайла) Экспорт
		
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ОткрытьКаталогСФайломПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ДанныеФайла", ДанныеФайла)));
	
КонецПроцедуры

// Процедура - Открыть каталог с файлом после подключения расширения
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОткрытьКаталогСФайломПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	   	
	Если Подключено Тогда
		
		ФайловыеФункцииКлиент.ПроинициализироватьПутьКРабочемуКаталогу();
		РабочийКаталогПользователя = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами().ПутьКЛокальномуКэшуФайлов;
		
		Если ПустаяСтрока(РабочийКаталогПользователя) Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Не задан путь к локальному кэшу файлов'"));
			Возврат;
		КонецЕсли;
		
		ПолныйПуть = РабочийКаталогПользователя + ДанныеФайла.ОтносительныйПуть + ДанныеФайла.ИмяФайла;
		
		Файл = Новый Файл(ПолныйПуть);
		
		Если НЕ Файл.Существует() Тогда
			ПоказатьВопрос(Новый ОписаниеОповещения("ОткрытьКаталогСФайломПослеВопроса", ЭтотОбъект, Новый Структура("ДанныеФайла, ПолныйПуть, РабочийКаталогПользователя", ДанныеФайла, ПолныйПуть, РабочийКаталогПользователя)), СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Файл ""%1"" отсутствует в рабочем каталоге! Получить файл с сервера?'"), Файл.Имя),
			РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли;
		
		ФайловыеФункцииКлиент.ОткрытьПроводникСФайлом(ПолныйПуть);
		
	Иначе
		#Если ВебКлиент Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Для выполнения данной операции вам нужно установить расширение работы с файлами.'"));
		#КонецЕсли
	КонецЕсли;

КонецПроцедуры

// Процедура - Открыть каталог с файлом после вопроса
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОткрытьКаталогСФайломПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ПолныйПуть = ДополнительныеПараметры.ПолныйПуть;
	РабочийКаталогПользователя = ДополнительныеПараметры.РабочийКаталогПользователя;
	
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяФайлаНаКлиенте = "";
	ПолучитьФайлВРабочийКаталог(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла, ДанныеФайла.ОтносительныйПуть, ДанныеФайла.ДатаМодификацииУниверсальная, ДанныеФайла.ИмяФайла, РабочийКаталогПользователя, ПолноеИмяФайлаНаКлиенте);
	
	ФайловыеФункцииКлиент.ОткрытьПроводникСФайлом(ПолныйПуть);

КонецПроцедуры

#КонецОбласти

#Область Сохранение

// Функция для обработки команды сохранения файла в каталог на диске.
// Так же используется как вспомогательная функция при сохранении файла с ЭЦП.
// Параметры:
//  ДанныеФайла - структура - данные файла
// Возвращаемое значение
//  имя сохраненного файла
//
Процедура СохранитьФайлКак(ДанныеФайла, ОбработчикЗавершения = Неопределено) Экспорт
	
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("СохранитьФайлКакПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ДанныеФайла, ОбработчикЗавершения", ДанныеФайла, ОбработчикЗавершения)));
	
КонецПроцедуры

Процедура СохранитьФайлКакПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
		
	Если Подключено Тогда
		
		ВыборФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
		ВыборФайла.МножественныйВыбор = Ложь;
		ВыборФайла.ПолноеИмяФайла = ДанныеФайла.ИмяФайла;
		ВыборФайла.Расширение = ДанныеФайла.Расширение;
		ВыборФайла.Фильтр = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Все файлы (*.%1)|*.%1'"), ДанныеФайла.Расширение, ДанныеФайла.Расширение);
		
		ВыборФайла.Показать(Новый ОписаниеОповещения("СохранитьФайлКакПослеВыбораФайла", ЭтотОбъект, Новый Структура("ВыборФайла, ДанныеФайла, ОбработчикЗавершения", ВыборФайла, ДанныеФайла, ОбработчикЗавершения)));
		Возврат;
	Иначе
		#Если ВебКлиент Тогда
			ПолучитьФайл(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла, ДанныеФайла.ИмяФайла, Истина);
			Возврат ДанныеФайла.ИмяФайла;
		#КонецЕсли
	КонецЕсли;

КонецПроцедуры

// Процедура - Сохранить файл как после выбора файла
//
// Параметры:
//  ВыбранныеФайлы			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СохранитьФайлКакПослеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	ВыборФайла = ДополнительныеПараметры.ВыборФайла;
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	
	Если НЕ (ВыбранныеФайлы <> Неопределено) Тогда
		Если ОбработчикЗавершения <> Неопределено Тогда
			ВыполнитьОбработкуОповещения(ОбработчикЗавершения,"");
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	РазмерВМб = ДанныеФайла.Размер / (1024 * 1024);
	
	ТекстПояснения =
	СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru = 'Выполняется сохранение файла ""%1"" (%2 Мб)...
	|Пожалуйста, подождите.'"),
	ДанныеФайла.ИмяФайла, ?(РазмерВМб >= 1,
	Формат(РазмерВМб, "ЧДЦ=0"),
	Формат(РазмерВМб, "ЧДЦ=1; ЧН=0") ) );
	
	Состояние(ТекстПояснения);
	
	ПолучаемыйФайл = Новый ОписаниеПередаваемогоФайла(ВыборФайла.ПолноеИмяФайла, ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);
	ПолучаемыеФайлы = Новый Массив;
	ПолучаемыеФайлы.Добавить(ПолучаемыйФайл);
	
	ПолученныеФайлы = Новый Массив;
	
	НачатьПолучениеФайловССервера(Новый ОписаниеОповещения("СохранитьФайлКакПослеВыбораФайлаЗавершение", ЭтотОбъект, Новый Структура("ВыборФайла, ОбработчикЗавершения", ВыборФайла, ОбработчикЗавершения)), ПолучаемыеФайлы);

КонецПроцедуры

Процедура СохранитьФайлКакПослеВыбораФайлаЗавершение(ПолученныеФайлы, ДополнительныеПараметры) Экспорт
	
	ВыборФайла = ДополнительныеПараметры.ВыборФайла;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	
	
	Если ПолученныеФайлы <> Неопределено Тогда
		Состояние(НСтр("ru = 'Файл успешно сохранен'"), , ВыборФайла.Имя);
	КонецЕсли;
	
	Если ОбработчикЗавершения <> Неопределено Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,ВыборФайла.Имя);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область РедактированиеИОбновление

// Обработчик команды окончания редактирования файлов, с помещением
// отредактированных файлов в хранилище.
// Параметры
//  ДанныеФайла - структура с данными файла
//  ИнформацияОФайле - структура с информацией о файле
//  УникальныйИдентификатор - уникальный идентификатор формы
Процедура ПоместитьРедактируемыйФайлНаДискеВХранилище(Знач ДанныеФайла, Знач УникальныйИдентификатор, ОбработчикЗавершения) Экспорт
	
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	ИнформацияОФайле = Новый Структура;	
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ПоместитьРедактируемыйФайлНаДискеВХранилищеПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ДанныеФайла, ИнформацияОФайле, ОбработчикЗавершения, УникальныйИдентификатор", ДанныеФайла, ИнформацияОФайле, ОбработчикЗавершения, УникальныйИдентификатор)));
	
КонецПроцедуры

// Процедура - Поместить редактируемый файл на диске в хранилище после подключения расширения
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПоместитьРедактируемыйФайлНаДискеВХранилищеПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ИнформацияОФайле = ДополнительныеПараметры.ИнформацияОФайле;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
	
	
	Если Подключено Тогда
		
		ФайловыеФункцииКлиент.ПроинициализироватьПутьКРабочемуКаталогу();
		РабочийКаталогПользователя = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами().ПутьКЛокальномуКэшуФайлов;
		
		ПолноеИмяФайлаНаКлиенте = РабочийКаталогПользователя + ДанныеФайла.ОтносительныйПуть + ДанныеФайла.ИмяФайла;
		
		Файл = Новый Файл(ПолноеИмяФайлаНаКлиенте);
		Если НЕ Файл.Существует() Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не найден файл в рабочем каталоге'"));
			ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Ложь,ИнформацияОФайле));
			Возврат;
		КонецЕсли;
		
		ПоместитьФайлНаДискеВХранилище(ДанныеФайла, ПолноеИмяФайлаНаКлиенте, УникальныйИдентификатор,ОбработчикЗавершения);
		
	Иначе
		#Если ВебКлиент Тогда
			ОбработчикПомещенияВХранилищеВеб = Новый ОписаниеОповещения("ПослеПоместитьФайлНаДискеВХранилищеВеб",ЭтотОбъект,Новый Структура("ОбработчикЗавершения,ДанныеФайла")); 
			ПоместитьФайлНаДискеВХранилищеВеб(ДанныеФайла, УникальныйИдентификатор, ОбработчикПомещенияВХранилищеВеб);
		#КонецЕсли
	КонецЕсли;

КонецПроцедуры 

// Процедура - После поместить файл на диске в хранилище веб
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеПоместитьФайлНаДискеВХранилищеВеб(Результат,ДополнительныеПараметры) Экспорт 
	
	ВыполненоУспешно = Результат.ВыполненоУспешно;
	ИнформацияОФайле = Результат.ИнформацияОФайле;

	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
   	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	
	Если НЕ ВыполненоУспешно Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",ВыполненоУспешно,ИнформацияОФайле));
		Возврат;
	КонецЕсли;
	
	Если ДанныеФайла.ИмяФайла <> ИнформацияОФайле.ИмяФайла Тогда
		ТекстВопроса = НСтр("ru = 'Имя выбранного файла (%1) отличается от имени файла в хранилище (%2), продолжить?'");
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстВопроса, ИнформацияОФайле.ИмяФайла, ДанныеФайла.ИмяФайла);
		ПоказатьВопрос(Новый ОписаниеОповещения("ПоместитьРедактируемыйФайлНаДискеВХранилищеПослеВопроса", ЭтотОбъект, 
		Новый Структура("ИнформацияОФайле, ОбработчикЗавершения, Результат", ИнформацияОФайле, ОбработчикЗавершения, Результат)), ТекстВопроса, РежимДиалогаВопрос.ОКОтмена);
		Возврат;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",ВыполненоУспешно,ИнформацияОФайле));
	Возврат;
	
КонецПроцедуры

// Процедура - Поместить редактируемый файл на диске в хранилище после вопроса
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПоместитьРедактируемыйФайлНаДискеВХранилищеПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ИнформацияОФайле = ДополнительныеПараметры.ИнформацияОФайле;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	Результат = ДополнительныеПараметры.Результат;

	Если РезультатВопроса <> КодВозвратаДиалога.ОК Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Ложь,ИнформацияОФайле));
		Возврат;			
	КонецЕсли;
		
	ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Результат,ИнформацияОФайле));

КонецПроцедуры

// Обработчик команды обновления присоединенного файла из другого файла.
// При этом пользователю предлагается выбрать файл, из которого следует обновить двоичные данные.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура - данные файла
//  УникальныйИдентификатор - уникальный идентификатор формы
Процедура ОбновитьПрисоединенныйФайл(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор) Экспорт
	
	ИнформацияОФайле = Новый Структура;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьПрисоединенныйФайлЗавершение",ЭтотОбъект,Новый Структура("ПрисоединенныйФайл, ДанныеФайла",ПрисоединенныйФайл, ДанныеФайла));
	ВыбратьФайлНаДискеИПоместитьВХранилище(ДанныеФайла, УникальныйИдентификатор,ОписаниеОповещения); 		
		
КонецПроцедуры

// Процедура - Обновить присоединенный файл завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОбновитьПрисоединенныйФайлЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если НЕ Результат.ВыполненоУспешно Тогда
		Возврат;
	КонецЕсли;
	
	ПрисоединенныеФайлы.ОбновитьПрисоединенныйФайл(ДополнительныеПараметры.ПрисоединенныйФайл, Результат.ИнформацияОФайле,
	#Если ВебКлиент Тогда
		Истина
	#Иначе
		Ложь
	#КонецЕсли
	);
	
КонецПроцедуры

// Используется как вспомогательная процедура для выбора файла с диска
// и помещения его во временное хранилище на сервере.
// Параметры:
//  ДанныеФайла - структура с данными файла
//  ИнформацияОФайле - структура с информацией о файле
//  УникальныйИдентификатор - уникальный идентификатор формы
// Возвращаемое значение
//  Истина - файл успешно выбран и помещен во временное хранилище, иначе Ложь
//
Процедура ВыбратьФайлНаДискеИПоместитьВХранилище(ДанныеФайла, Знач УникальныйИдентификатор,ОбработчикЗавершения) Экспорт
	
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ВыбратьФайлНаДискеИПоместитьВХранилищеПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ДанныеФайла, ОбработчикЗавершения, УникальныйИдентификатор", ДанныеФайла, ОбработчикЗавершения, УникальныйИдентификатор)));
	
КонецПроцедуры

Процедура ВыбратьФайлНаДискеИПоместитьВХранилищеПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
	
	Если Подключено Тогда
		
		ВыборФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		ВыборФайла.МножественныйВыбор = Ложь;
		ВыборФайла.ПолноеИмяФайла = ДанныеФайла.Наименование + "." + ДанныеФайла.Расширение;
		ВыборФайла.Расширение = ДанныеФайла.Расширение;
		ВыборФайла.Фильтр = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Все файлы (*.%1)|*.%1'"), ДанныеФайла.Расширение, ДанныеФайла.Расширение);
		ВыборФайла.Показать(Новый ОписаниеОповещения("ВыбратьФайлНаДискеИПоместитьВХранилищеПослеВыбораФайла", ЭтотОбъект, Новый Структура("ВыборФайла, ДанныеФайла, ОбработчикЗавершения, УникальныйИдентификатор", ВыборФайла, ДанныеФайла, ОбработчикЗавершения, УникальныйИдентификатор)));
		
	Иначе
		#Если ВебКлиент Тогда
			ПоместитьФайлНаДискеВХранилищеВеб(ДанныеФайла, УникальныйИдентификатор,ОбработчикЗавершения);
		#КонецЕсли
	КонецЕсли;

КонецПроцедуры

// Процедура - Выбрать файл на диске и поместить в хранилище после выбора файла
//
// Параметры:
//  ВыбранныеФайлы			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыбратьФайлНаДискеИПоместитьВХранилищеПослеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	ВыборФайла = ДополнительныеПараметры.ВыборФайла;
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;

	Если ВыбранныеФайлы = Неопределено Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Ложь,Новый Структура));
		Возврат;
	КонецЕсли;
	
	ПоместитьФайлНаДискеВХранилище(ДанныеФайла, ВыборФайла.ПолноеИмяФайла, УникальныйИдентификатор,ОбработчикЗавершения);

КонецПроцедуры

// Функция используется для помещения файла на диске с именем
// ПолноеИмяФайлаНаКлиенте во временное хранилище.
// Параметры
//  ДанныеФайла - структура с данными файла
//  ИнформацияОФайле (устанавливается в функции)- структура с информацией о файле
//  ПолноеИмяФайлаНаКлиенте - строка - имя файла на клиенте
//  УникальныйИдентификатор - уникальный идентификатор формы
// Возвращаемое значение
//	Булево - истина - файл успешно помещен в хранилище, иначе Ложь
//
Процедура ПоместитьФайлНаДискеВХранилище(ДанныеФайла, ПолноеИмяФайлаНаКлиенте, УникальныйИдентификатор,ОбработчикЗавершения)
	
	НастройкиРаботыСФайлами = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами();
	
	МаксРазмерФайла						= НастройкиРаботыСФайлами.МаксимальныйРазмерФайла;
	ЗапретЗагрузкиФайловПоРасширению	= НастройкиРаботыСФайлами.ЗапретЗагрузкиФайловПоРасширению;
	СписокЗапрещенныхРасширений			= НастройкиРаботыСФайлами.СписокЗапрещенныхРасширений;
	
	Файл = Новый Файл(ПолноеИмяФайлаНаКлиенте);
	
	Если Не ФайловыеФункцииКлиентСервер.РасширениеФайлаРазрешеноДляЗагрузки(ЗапретЗагрузкиФайловПоРасширению, СписокЗапрещенныхРасширений, Файл.Расширение) Тогда
		ВызватьИсключение
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Загрузка файлов с расширением ""%1"" запрещена. Обратитесь к администратору системы.'"),
				Файл.Расширение);
	КонецЕсли;
	
	Если Файл.Размер() > МаксРазмерФайла Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОПревышенииМаксимальноДопустимогоРазмераФайла(Файл.Размер(), МаксРазмерФайла, Файл.Имя));
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Ложь,Новый Структура));
		Возврат;
  	КонецЕсли;
	
	ИзвлекатьТекстыФайловНаСервере = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами().ИзвлекатьТекстыФайловНаСервере;
	
	Если ИзвлекатьТекстыФайловНаСервере Тогда
		АдресВременногоХранилищаТекста = "";
	Иначе
		АдресВременногоХранилищаТекста = ФайловыеФункцииКлиентСервер.ИзвлечьТекстВоВременноеХранилище(ПолноеИмяФайлаНаКлиенте, УникальныйИдентификатор);
	КонецЕсли;
	
	Описание = Новый ОписаниеПередаваемогоФайла(ПолноеИмяФайлаНаКлиенте, "");
	ПомещаемыеФайлы = Новый Массив;
	ПомещаемыеФайлы.Добавить(Описание);
	ПомещенныеФайлы = Новый Массив;
	
	Если НЕ ПоместитьФайлы(ПомещаемыеФайлы, ПомещенныеФайлы, , Ложь, УникальныйИдентификатор) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Ошибка передачи файла на сервер: %1'"), ПолноеИмяФайлаНаКлиенте) );
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Ложь,Новый Структура));
		Возврат;
	КонецЕсли;
	
	АдресФайлаВоВременномХранилище = ПомещенныеФайлы[0].Хранение;
	
	ИнформацияОФайле = Новый Структура("ДатаМодификацииУниверсальная, АдресФайлаВоВременномХранилище, АдресВременногоХранилищаТекста, Расширение",
										Файл.ПолучитьУниверсальноеВремяИзменения(),
										АдресФайлаВоВременномХранилище,
										АдресВременногоХранилищаТекста,
										Прав(Файл.Расширение, СтрДлина(Файл.Расширение)-1));
	
	ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Истина,ИнформацияОФайле));
	Возврат;
	
	
КонецПроцедуры

#Если ВебКлиент Тогда
// Аналог функции ПоместитьФайлНаДискеВХранилище для веб-клиента (без расширения для работы с файлами).
// Помещает файл с диска во временное хранилище.
//  ДанныеФайла - структура с данными файла
//  ИнформацияОФайле (устанавливается в функции)- структура с информацией о файле
//  УникальныйИдентификатор - уникальный идентификатор формы
//
Процедура ПоместитьФайлНаДискеВХранилищеВеб(ДанныеФайла, УникальныйИдентификатор, ОбработчикЗавершения)
	
	НастройкиРаботыСФайлами = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами();
	
	АдресВременногоХранилищаФайла = "";
	ВыбранноеИмяФайла = "";
	
	НачатьПомещениеФайла(Новый ОписаниеОповещения("ПоместитьФайлНаДискеВХранилищеВебПослеПомещения", ЭтотОбъект, Новый Структура(" НастройкиРаботыСФайлами, ОбработчикЗавершения",  НастройкиРаботыСФайлами, ОбработчикЗавершения)), АдресВременногоХранилищаФайла, ДанныеФайла.ИмяФайла, Истина, УникальныйИдентификатор);
	
КонецПроцедуры

// Процедура - Поместить файл на диске в хранилище веб после помещения
//
// Параметры:
//  Результат				 - 	 - 
//  Адрес					 - 	 - 
//  ВыбранноеИмяФайла		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПоместитьФайлНаДискеВХранилищеВебПослеПомещения(Результат, АдресВременногоХранилищаФайла, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
	НастройкиРаботыСФайлами = ДополнительныеПараметры.НастройкиРаботыСФайлами;
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	
	Если Не Результат Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Ложь,Новый Структура));
		Возврат;
	КонецЕсли;
	
	СтрокиПути = ФайловыеФункцииКлиентСервер.РазложитьСтрокуПоТочкамИСлэшам(ВыбранноеИмяФайла);
	
	Если СтрокиПути.Количество() >= 2 Тогда
		НовоеИмя = СтрокиПути[СтрокиПути.Количество()-2];
		НовоеРасширение = СтрокиПути[СтрокиПути.Количество()-1];
		ИмяФайла = НовоеИмя + "." + НовоеРасширение;
	ИначеЕсли СтрокиПути.Количество() = 1 Тогда
		НовоеИмя = СтрокиПути[0];
		НовоеРасширение = "";
		ИмяФайла = НовоеИмя;
	КонецЕсли;
	
	ЗапретЗагрузкиФайловПоРасширению	= НастройкиРаботыСФайлами.ЗапретЗагрузкиФайловПоРасширению;
	СписокЗапрещенныхРасширений			= НастройкиРаботыСФайлами.СписокЗапрещенныхРасширений;
	
	Если Не ФайловыеФункцииКлиентСервер.РасширениеФайлаРазрешеноДляЗагрузки(ЗапретЗагрузкиФайловПоРасширению, СписокЗапрещенныхРасширений, НовоеРасширение) Тогда
		ВызватьИсключение
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Загрузка файлов с расширением ""%1"" запрещена. Обратитесь к администратору системы.'"),
		НовоеРасширение);
	КонецЕсли;
	
	ИнформацияОФайле = Новый Структура("ДатаМодификацииУниверсальная, АдресФайлаВоВременномХранилище, АдресВременногоХранилищаТекста, ИмяФайла,Расширение",
	УниверсальноеВремя(ТекущаяДата()),
	АдресВременногоХранилищаФайла,
	"",
	ИмяФайла,
	НовоеРасширение);
	
	ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ВыполненоУспешно,ИнформацияОФайле",Истина,ИнформацияОФайле));
	Возврат;

КонецПроцедуры

#КонецЕсли



#КонецОбласти

#КонецОбласти

#Область РаботаСФормами

// Используется для открытия формы присоединенного файла, из "естественной"
// формы присоединенного файла (формы элемента справочника).
// Параметры
//  Форма - форма справочника присоединенных файлов (будет закрыта)
//
Процедура ПерейтиКФормеПрисоединенногоФайла(Форма) Экспорт
	
	ПрисоединенныйФайл = Форма.Ключ;
	
	Форма.Закрыть();
	
	Для Каждого ОкноКП Из ПолучитьОкна() Цикл
		
		Содержимое = ОкноКП.ПолучитьСодержимое();
		
		Если Содержимое = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если Содержимое.ИмяФормы = "ОбщаяФорма.ПрисоединенныйФайл" Тогда
			Если Содержимое.Параметры.Свойство("ПрисоединенныйФайл")
			   И Содержимое.Параметры.ПрисоединенныйФайл = ПрисоединенныйФайл Тогда
				ОкноКП.Активизировать();
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	ОткрытьФормуПрисоединенногоФайла(ПрисоединенныйФайл);
	
КонецПроцедуры

// Обработчик события выбора файла - функция вызывается для переопределения
// стандартного поведения.
// Параметры
//  ВладелецФайлов - ссылка на объект с файлами
//  Элемент - элемент формы, которому будет послано оповещение о выборе
//  СтандартнаяОбработка - булево, всегда устанавливается в Ложь
//
Процедура ОткрытьФормуВыбораФайлов(ВладелецФайлов, Элемент, СтандартнаяОбработка = Ложь) Экспорт
	
	СтандартнаяОбработка = Ложь;
	ПараметрыВыбораСписка = Новый Структура("ВладелецФайла, ЗакрыватьПриВыборе", ВладелецФайлов, Истина);
	ОткрытьФорму("ОбщаяФорма.ВыборПрисоединенныхФайлов", ПараметрыВыбораСписка, Элемент);
	
КонецПроцедуры

// Открывает форму присоединенного файла. Может использоваться как обработчик открытия
// присоединенного файла.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл, карточку которого нужно открыть
//  СтандартнаяОбработка - булево, всегда устанавливается в Ложь
//
Процедура ОткрытьФормуПрисоединенногоФайла(ПрисоединенныйФайл, СтандартнаяОбработка = Ложь) Экспорт
	
	СтандартнаяОбработка = Ложь;
	Если ЗначениеЗаполнено(ПрисоединенныйФайл) Тогда
		ПараметрыОткрытия = Новый Структура("ПрисоединенныйФайл", ПрисоединенныйФайл);
		ОткрытьФорму("ОбщаяФорма.ПрисоединенныйФайл", ПараметрыОткрытия,, ПрисоединенныйФайл);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ЭЦП

// Обработчик команды подписать формы списка. Предлагает пользователю выбрать
// ЭЦП для подписания, получает данные подписи и записывает файл с эцп в хранилище.
// Параметры
//  ПрисоединенныйФайл - присоединенный файл
//  ДанныеФайла - структура с данными файла
//  ОповещениеПослеФормирования - описание оповещения, которое обрабатывает результат формирования подписи
//
Процедура СформироватьПодписьФайла(ПрисоединенныйФайл, ДанныеФайла, ОповещениеПослеФормирования) Экспорт	
	
	ОповещениеПослеВыбора = Новый ОписаниеОповещения("ПослеВыбораИФормированияПодписи", ЭтотОбъект,Новый Структура("ПрисоединенныйФайл,ОповещениеПослеФормирования",ПрисоединенныйФайл,ОповещениеПослеФормирования));
	ВыбратьСертификатыЭЦПИСформироватьДанныеПодписи(ПрисоединенныйФайл, ДанныеФайла,,ОповещениеПослеВыбора);
	
КонецПроцедуры

// Предлагает пользователю диалог выбора сертификатов ЭЦП, подписывает двоичные данные
// присоединенного файла. Передает в вызывающую процедуру данные подписи.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//  ДанныеПодписи - структура с данными подписи
//
Процедура ВыбратьСертификатыЭЦПИСформироватьДанныеПодписи(ПрисоединенныйФайл, ДанныеФайла, ДанныеПодписи = Неопределено ,ОповещениеПослеВыбора) Экспорт
	
	СтруктураПараметровОповещения = Новый Структура("ПрисоединенныйФайл, ДанныеФайла, ДанныеПодписи,ОповещениеПослеВыбора", ПрисоединенныйФайл, ДанныеФайла, ДанныеПодписи,ОповещениеПослеВыбора);
	
	#Если ВебКлиент Тогда
		НачатьПодключениеРасширенияРаботыСКриптографией(Новый ОписаниеОповещения("ВыбратьСертификатыЭЦПИПослеПодключенияКриптографии", ЭтотОбъект,СтруктураПараметровОповещения));
		Возврат;
	#КонецЕсли
	
	ОткрытьФормуУстановкиПодписиЭЦП(СтруктураПараметровОповещения);
	
КонецПроцедуры

// Процедура - Выбрать сертификаты ЭЦПИПосле подключения криптографии
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыбратьСертификатыЭЦПИПослеПодключенияКриптографии(Подключено, ДополнительныеПараметры) Экспорт
	
	ПрисоединенныйФайл    = ДополнительныеПараметры.ПрисоединенныйФайл; 
	ДанныеФайла 	      = ДополнительныеПараметры.ДанныеФайла;
	ДанныеПодписи         = ДополнительныеПараметры.ДанныеПодписи;
	ОповещениеПослеВыбора = ДополнительныеПараметры.ОповещениеПослеВыбора;
	
	Если НЕ Подключено Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Расширение для работы с криптографией не подключено, операция прервана.'"));
		ВыполнитьОбработкуОповещения(ОповещениеПослеВыбора,Новый Структура("ВыполненоУспешно, ДанныеПодписи",Ложь,Новый Структура));
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуУстановкиПодписиЭЦП(ДополнительныеПараметры);
	
КонецПроцедуры

// Процедура - Открыть форму установка подписи ЭЦП
//
// Параметры:
//  СтруктураПараметровОповещения	 - 	 - 
//
Процедура ОткрытьФормуУстановкиПодписиЭЦП(СтруктураПараметровОповещения)
	
	МассивСтруктурСертификатов = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьМассивСтруктурСертификатов(Истина);
	
	ПараметрыФормы = Новый Структура("МассивСтруктурСертификатов, ОбъектСсылка", МассивСтруктурСертификатов, СтруктураПараметровОповещения.ПрисоединенныйФайл);
	
	ОткрытьФорму("ОбщаяФорма.УстановкаПодписиЭЦП", ПараметрыФормы,,,,,
	Новый ОписаниеОповещения("ВыбратьСертификатыЭЦПИПослеОткрытияФормыУстановкиПодписи",ЭтотОбъект,СтруктураПараметровОповещения)); 
	
КонецПроцедуры

// Предлагает пользователю диалог выбора сертификатов ЭЦП, подписывает двоичные данные
// присоединенного файла. Передает в вызывающую процедуру данные подписи.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//  ДанныеПодписи - структура с данными подписи
//
Процедура ВыбратьСертификатыЭЦПИПослеОткрытияФормыУстановкиПодписи(СтруктураПараметровПодписи, ДополнительныеПараметры) Экспорт
	
	ПрисоединенныйФайл    = ДополнительныеПараметры.ПрисоединенныйФайл; 
	ДанныеФайла 	      = ДополнительныеПараметры.ДанныеФайла;
	ДанныеПодписи         = ДополнительныеПараметры.ДанныеПодписи;
	ОповещениеПослеВыбора = ДополнительныеПараметры.ОповещениеПослеВыбора;
	
	Если ТипЗнч(СтруктураПараметровПодписи) <> Тип("Структура") Тогда
		ВыполнитьОбработкуОповещения(ОповещениеПослеВыбора,Новый Структура("ВыполненоУспешно, ДанныеПодписи",Ложь,Новый Структура)); 
		Возврат;
	КонецЕсли;
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);
	
	Отказ = Ложь;
	МенеджерКриптографии = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьМенеджерКриптографии(Отказ);
	Если Отказ Тогда
		ВыполнитьОбработкуОповещения(ОповещениеПослеВыбора,Новый Структура("ВыполненоУспешно, ДанныеПодписи",Ложь,Новый Структура));
		Возврат;
	КонецЕсли;
	
	ДанныеПодписи = ЭлектроннаяЦифроваяПодписьКлиент.СформироватьДанныеПодписи(
	МенеджерКриптографии,
	ПрисоединенныйФайл,
	ДвоичныеДанные,
	СтруктураПараметровПодписи);
	
	ВыполнитьОбработкуОповещения(ОповещениеПослеВыбора,Новый Структура("ВыполненоУспешно, ДанныеПодписи",Истина, ДанныеПодписи));
	
КонецПроцедуры

// Процедура - После выбора и формирования подписи
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВыбораИФормированияПодписи(ВозвращаемыйРезультат, ДополнительныеПараметры) Экспорт
	
	Если ВозвращаемыйРезультат.ВыполненоУспешно Тогда
		ПрисоединенныеФайлы.ЗанестиИнформациюОднойПодписи(ДополнительныеПараметры.ПрисоединенныйФайл, ВозвращаемыйРезультат.ДанныеПодписи);
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОповещениеПослеФормирования,Истина);
		Возврат;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОповещениеПослеФормирования,Ложь);
	
КонецПроцедуры

// Реализация команды сохранения файла вместе с ЭЦП
//
Процедура СохранитьВместеСЭЦП(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор) Экспорт
	
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("СохранитьВместеСЭЦППослеподключенияРасширения", ЭтотОбъект, Новый Структура("ДанныеФайла, ПрисоединенныйФайл, УникальныйИдентификатор", ДанныеФайла, ПрисоединенныйФайл, УникальныйИдентификатор)));
	
КонецПроцедуры

// Процедура - Сохранить вместе СЭЦППослеподключения расширения
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СохранитьВместеСЭЦППослеподключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	ПрисоединенныйФайл = ДополнительныеПараметры.ПрисоединенныйФайл;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
	
	
	Если Подключено Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеСохраненияФайла",ЭтотОбъект,Новый Структура("ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор",ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор));
		СохранитьФайлКак(ДанныеФайла,ОписаниеОповещения);
		
	Иначе
		#Если ВебКлиент Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Для выполнения данной операции вам нужно установить расширение работы с файлами.'"));
		#КонецЕсли
	КонецЕсли;

КонецПроцедуры

Процедура ПослеСохраненияФайла(ПолноеИмяФайла,ДополнительныеПараметры) Экспорт
	
	Если ПолноеИмяФайла = "" Тогда
		Возврат; // пользователь нажал Отмена или это веб клиент без расширения
	КонецЕсли;
	
	ПрисоединенныйФайл = ДополнительныеПараметры.ПрисоединенныйФайл;
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
	
	Настройка = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьПерсональныеНастройкиРаботыСЭЦП().ДействияПриСохраненииСЭЦП;
	
	МассивСтруктурПодписей = Неопределено;
	
	Если Настройка = "Спрашивать" Тогда
		ПараметрыФормы = Новый Структура("Объект, УникальныйИдентификатор", ПрисоединенныйФайл, УникальныйИдентификатор);
		ОткрытьФорму("ОбщаяФорма.ВыборПодписей", ПараметрыФормы,,,,, Новый ОписаниеОповещения("СохранитьВместеСЭЦППослеВыбораПодписей", ЭтотОбъект, Новый Структура("ПолноеИмяФайла, ПрисоединенныйФайл, УникальныйИдентификатор", ПолноеИмяФайла, ПрисоединенныйФайл, УникальныйИдентификатор)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		Возврат;
	ИначеЕсли Настройка = "СохранятьВсеПодписи" Тогда
		МассивСтруктурПодписей = ФайловыеФункции.ПолучитьВсеПодписи(ПрисоединенныйФайл, УникальныйИдентификатор);
	КонецЕсли;
	
	Если ТипЗнч(МассивСтруктурПодписей) = Тип("Массив") И МассивСтруктурПодписей.Количество() > 0 Тогда
		ФайловыеФункцииКлиент.СохранитьПодписи(ПрисоединенныйФайл, ПолноеИмяФайла, УникальныйИдентификатор, МассивСтруктурПодписей);
	КонецЕсли;
	
	
КонецПроцедуры

// Процедура - Сохранить вместе СЭЦППосле выбора подписей
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СохранитьВместеСЭЦППослеВыбораПодписей(Результат, ДополнительныеПараметры) Экспорт
	
	ПолноеИмяФайла          = ДополнительныеПараметры.ПолноеИмяФайла;
	ПрисоединенныйФайл      = ДополнительныеПараметры.ПрисоединенныйФайл;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
	МассивСтруктурПодписей  = Результат;
	
	Если ТипЗнч(МассивСтруктурПодписей) = Тип("Массив") И МассивСтруктурПодписей.Количество() > 0 Тогда
		ФайловыеФункцииКлиент.СохранитьПодписи(ПрисоединенныйФайл, ПолноеИмяФайла, УникальныйИдентификатор, МассивСтруктурПодписей);
	КонецЕсли;
	
КонецПроцедуры

// Добавить ЭЦП из файла(ов) на диске.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл, которому требуется добавить подпись
//  УникальныйИдентификатор - уникальный идентификатор формы
//
Процедура ДобавитьЭЦПИзФайла(ПрисоединенныйФайл, УникальныйИдентификатор = Неопределено) Экспорт
	
	#Если ВебКлиент Тогда
		НачатьПодключениеРасширенияРаботыСКриптографией(Новый ОписаниеОповещения("ДобавитьЭЦПИзФайлаПослеПодключенияКриптографии", ЭтотОбъект, Новый Структура("ПрисоединенныйФайл, УникальныйИдентификатор", ПрисоединенныйФайл, УникальныйИдентификатор)));
        Возврат;
	#КонецЕсли
	
	ДобавитьЭЦПИзФайлаФрагмент(ПрисоединенныйФайл, УникальныйИдентификатор);
	
КонецПроцедуры

// Процедура - Добавить ЭЦПИз файла после подключения криптографии
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДобавитьЭЦПИзФайлаПослеПодключенияКриптографии(Подключено, ДополнительныеПараметры) Экспорт
	
	ПрисоединенныйФайл = ДополнительныеПараметры.ПрисоединенныйФайл;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
	
	
	Если НЕ Подключено Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Расширение для работы с криптографией не подключено, операция прервана.'"));
		Возврат;
	КонецЕсли;
	
	ДобавитьЭЦПИзФайлаФрагмент(ПрисоединенныйФайл, УникальныйИдентификатор);

КонецПроцедуры

// Процедура - Добавить ЭЦПИз файла фрагмент
//
// Параметры:
//  ПрисоединенныйФайл		 - 	 - 
//  УникальныйИдентификатор	 - 	 - 
//
Процедура ДобавитьЭЦПИзФайлаФрагмент(Знач ПрисоединенныйФайл, Знач УникальныйИдентификатор)
		
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ДобавитьЭЦПИзФайлаФрагментПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ПрисоединенныйФайл, УникальныйИдентификатор", ПрисоединенныйФайл, УникальныйИдентификатор)));

КонецПроцедуры

Процедура ДобавитьЭЦПИзФайлаФрагментПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ПрисоединенныйФайл = ДополнительныеПараметры.ПрисоединенныйФайл;
	УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;	
	
	Если Подключено Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьЭЦПИзФайлаПослеВыбораМассиваПодписей",ЭтотОбъект,Новый Структура("ПрисоединенныйФайл,УникальныйИдентификатор",ПрисоединенныйФайл,УникальныйИдентификатор));
		НачатьПолучениеМассиваПодписей(ПрисоединенныйФайл, УникальныйИдентификатор,ОписаниеОповещения);
		
	Иначе
		#Если ВебКлиент Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Для выполнения данной операции вам нужно установить расширение работы с файлами.'"));
		#КонецЕсли
	КонецЕсли;

КонецПроцедуры 

// Процедура - Добавить ЭЦПИз файла после выбора массива подписей
//
// Параметры:
//  МассивПодписей			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДобавитьЭЦПИзФайлаПослеВыбораМассиваПодписей(МассивПодписей, ДополнительныеПараметры) Экспорт
	
	Если МассивПодписей.Количество() > 0 Тогда
		ПрисоединенныеФайлы.ЗанестиИнформациюОПодписях(ДополнительныеПараметры.ПрисоединенныйФайл, МассивПодписей, ДополнительныеПараметры.УникальныйИдентификатор);
		ОповеститьОДобавленииПодписиИзФайла(ДополнительныеПараметры.ПрисоединенныйФайл, МассивПодписей.Количество());
	КонецЕсли;
	
КонецПроцедуры

// Процедура вызывает диалог добавления подписей и создает структуру с подписями.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  УникальныйИдентификатор - уникальный идентификатор формы
//
// ОСОБЫЕ УСЛОВИЯ
// Требуется наличие подключенного расширения для работы с файлами
// и расширения для работы со средствами криптографии.
//
Процедура НачатьПолучениеМассиваПодписей(ПрисоединенныйФайл, УникальныйИдентификатор, ОповещениеПослеВыбораПодписей) Экспорт
	
	ОткрытьФорму("ОбщаяФорма.ДобавлениеПодписиИзФайла",,,,,, Новый ОписаниеОповещения("НачатьПолучениеМассиваПодписейПослеЗакртыияФормы", ЭтотОбъект, Новый Структура("ОповещениеПослеВыбораПодписей, ПрисоединенныйФайл, УникальныйИдентификатор", ОповещениеПослеВыбораПодписей, ПрисоединенныйФайл, УникальныйИдентификатор)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

// Процедура - Начать получение массива подписей после закртыия формы
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура НачатьПолучениеМассиваПодписейПослеЗакртыияФормы(Результат, ДополнительныеПараметры) Экспорт
	
	ОповещениеПослеВыбораПодписей = ДополнительныеПараметры.ОповещениеПослеВыбораПодписей;
	ПрисоединенныйФайл            = ДополнительныеПараметры.ПрисоединенныйФайл;
	УникальныйИдентификатор       = ДополнительныеПараметры.УникальныйИдентификатор;
	
	МассивФайловПодписей = Результат;
	
	Если ТипЗнч(МассивФайловПодписей) <> Тип("Массив") ИЛИ МассивФайловПодписей.Количество() = 0 Тогда
		ВыполнитьОбработкуОповещения(ОповещениеПослеВыбораПодписей,Новый Массив);  
		Возврат;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОповещениеПослеВыбораПодписей,ФайловыеФункцииКлиент.СформироватьПодписиДляЗанесениюВБазу(ПрисоединенныйФайл, МассивФайловПодписей, УникальныйИдентификатор));
	
КонецПроцедуры

// Служебная процедура используется для оповещения системы об изменении объекта,
// а так же для отображения оповещения пользователя о добавлении подписей.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл с добавленными подписями
//  КоличествоПодписей - количество добавленных подписей
//
Процедура ОповеститьОДобавленииПодписиИзФайла(ПрисоединенныйФайл, КоличествоПодписей) Экспорт
	
	ОповеститьОбИзменении(ПрисоединенныйФайл);
	
	Если КоличествоПодписей = 1 Тогда
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Добавлена подпись из файла для ""%1""'"),
		ПрисоединенныйФайл);
	Иначе
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Добавлены подписи из файлов для ""%1""'"),
		ПрисоединенныйФайл);
	КонецЕсли;
	
	Состояние(ТекстСообщения);
	
КонецПроцедуры


#КонецОбласти

#Область Зашифровать

// Обработчик команды шифрования файла. Выполняет шифрование файла, предварительно
// предлагает пользователю выбрать сертификаты для шифрования. Записывает зашифрованные
// данные вместе с отпечатками в хранилище и оповещает систему и пользователя об изменениях.
//
// Параметры
//  ПрисоединенныйФайл - ссылка на файл, который требуется зашифровать
//  ДанныеФайла - структура с данными файла
//  УникальныйИдентификатор - уникальный идентификатор формы
// 
Процедура Зашифровать(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор) Экспорт
	
	ПолучитьЗашифрованныеДанные(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, 
	Новый ОписаниеОповещения("ЗашифроватьПродолжение",ЭтотОбъект,Новый Структура("ПрисоединенныйФайл, ДанныеФайла",ПрисоединенныйФайл, ДанныеФайла)));
	
КонецПроцедуры  

// Процедура - Зашифровать продолжение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЗашифроватьПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если НЕ Результат.ВыполненоУспешно Тогда
		Возврат;
	КонецЕсли;
	
	ПрисоединенныеФайлы.Зашифровать(ДополнительныеПараметры.ПрисоединенныйФайл, Результат.ЗашифрованныеДанные, Результат.МассивОтпечатков);
	
	ОповеститьОбИзмененииИУдалитьФайлВРабочемКаталоге(ДополнительныеПараметры.ПрисоединенныйФайл, ДополнительныеПараметры.ДанныеФайла);

КонецПроцедуры

// Служебная функция используется для шифрования двоичных данных файла
// с помощью выбранных пользователем сертификатов шифрования.
// После шифрования возвращает зашифрованные данные и массив отпечатков.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//  УникальныйИдентификатор - уникальный идентификатор формы
//  ЗашифрованныеДанные - структура с зашифрованными данными (для записи)
//  МассивОтпечатков - массив отпечатков
//
Процедура ПолучитьЗашифрованныеДанные(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеЗашифровки) Экспорт
	
	#Если ВебКлиент Тогда
		
		НачатьПодключениеРасширенияРаботыСКриптографией(Новый ОписаниеОповещения("ПолучитьЗашифрованныеДанныеПослеПодключенияКриптографии", ЭтотОбъект, 
		Новый Структура("ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеЗашифровки", ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеЗашифровки)));
		Возврат;
	#КонецЕсли
	
	ПолучитьЗашифрованныеДанныеПродолжение(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеЗашифровки);
	
КонецПроцедуры

// Процедура - Получить зашифрованные данные после подключения криптографии
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПолучитьЗашифрованныеДанныеПослеПодключенияКриптографии(Подключено, ДополнительныеПараметры) Экспорт
	
	ОповещениеПослеЗашифровки = ДополнительныеПараметры.ОповещениеПослеЗашифровки;
	
	Если НЕ Подключено Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Расширение для работы с криптографией не подключено, операция прервана.'"));
		ВыполнитьОбработкуОповещения(ОповещениеПослеЗашифровки,Новый Структура("ВыполненоУспешно,ЗашифрованныеДанные,МассивОтпечатков",Ложь,Неопределено,Неопределено));
		Возврат;
	КонецЕсли;
	
    ПолучитьЗашифрованныеДанныеПродолжение(ДополнительныеПараметры.ПрисоединенныйФайл, ДополнительныеПараметры.ДанныеФайла, ДополнительныеПараметры.УникальныйИдентификатор, ДополнительныеПараметры.ОповещениеПослеЗашифровки);

КонецПроцедуры

// Служебная функция используется для шифрования двоичных данных файла
// с помощью выбранных пользователем сертификатов шифрования.
// После шифрования возвращает зашифрованные данные и массив отпечатков.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//  УникальныйИдентификатор - уникальный идентификатор формы
//  ЗашифрованныеДанные - структура с зашифрованными данными (для записи)
//  МассивОтпечатков - массив отпечатков
//
Процедура ПолучитьЗашифрованныеДанныеПродолжение(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеЗашифровки) Экспорт
	
	ЗашифрованныеДанные = Неопределено;
	МассивОтпечатков = Новый Массив;

	Если ДанныеФайла.Зашифрован Тогда
		ПоказатьПредупреждение(,СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
							НСтр("ru = 'Файл ""%1"" уже зашифрован.'"), Строка(ПрисоединенныйФайл)));
		ВыполнитьОбработкуОповещения(ОповещениеПослеЗашифровки,Новый Структура("ВыполненоУспешно,ЗашифрованныеДанные,МассивОтпечатков",Ложь,ЗашифрованныеДанные,МассивОтпечатков));
		Возврат;
	КонецЕсли;
	
	Если НЕ ДанныеФайла.Редактирует.Пустая() Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Нельзя зашифровать занятый файл.'"));
		ВыполнитьОбработкуОповещения(ОповещениеПослеЗашифровки,Новый Структура("ВыполненоУспешно,ЗашифрованныеДанные,МассивОтпечатков",Ложь,ЗашифрованныеДанные,МассивОтпечатков));
		Возврат;
	КонецЕсли;
	
	МассивСтруктурСертификатов = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьМассивСтруктурСертификатов(Ложь);
	
	ОтпечатокЛичногоСертификатаДляШифрования = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами().ОтпечатокЛичногоСертификатаДляШифрования;
	
	// Отпечаток сохраненный в ХранилищеНастроек мог устареть - сертификат могли уже удалить
	Если ОтпечатокЛичногоСертификатаДляШифрования <> Неопределено И НЕ ПустаяСтрока(ОтпечатокЛичногоСертификатаДляШифрования) Тогда
		Сертификат = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьСертификатПоОтпечатку(ОтпечатокЛичногоСертификатаДляШифрования, Истина); // ТолькоЛичные
		Если Сертификат = Неопределено Тогда
			ОтпечатокЛичногоСертификатаДляШифрования = "";
		КонецЕсли;
	КонецЕсли;
	
	СтруктураПараметровОповещения = Новый Структура("ДанныеФайла, ЗашифрованныеДанные, МассивОтпечатков, МассивСтруктурСертификатов, ОтпечатокЛичногоСертификатаДляШифрования, ОповещениеПослеЗашифровки, ПрисоединенныйФайл, УникальныйИдентификатор", 
	ДанныеФайла, ЗашифрованныеДанные, МассивОтпечатков, МассивСтруктурСертификатов, ОтпечатокЛичногоСертификатаДляШифрования, ОповещениеПослеЗашифровки, ПрисоединенныйФайл, УникальныйИдентификатор);
	Если ОтпечатокЛичногоСертификатаДляШифрования = Неопределено ИЛИ ПустаяСтрока(ОтпечатокЛичногоСертификатаДляШифрования) Тогда
		
		СтруктураПараметровОповещения.МассивСтруктурЛичныхСертификатов = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьМассивСтруктурСертификатов(Истина); // ТолькоЛичные
		
		ПараметрыФормы = Новый Структура("МассивСтруктурСертификатов", СтруктураПараметровОповещения.МассивСтруктурЛичныхСертификатов);
		СтруктураВозврата = Неопределено;

		ОткрытьФорму("ОбщаяФорма.ВыборСертификата", ПараметрыФормы,,,,, 
		Новый ОписаниеОповещения("ПолучитьЗашифрованныеДанныеПослеВыбораСертификата", ЭтотОбъект,СтруктураПараметровОповещения), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
        Возврат;
	КонецЕсли;
	
	ПолучитьЗашифрованныеДанныеПродолжение2(СтруктураПараметровОповещения);

КонецПроцедуры

// Процедура - Получить зашифрованные данные после выбора сертификата
//
// Параметры:
//  СтруктураВозврата		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПолучитьЗашифрованныеДанныеПослеВыбораСертификата(СтруктураВозврата, ДополнительныеПараметры) Экспорт
	
	
	Если ТипЗнч(СтруктураВозврата) = Тип("Структура") Тогда
		ОтпечатокЛичногоСертификатаДляШифрования = СтруктураВозврата.Отпечаток;
		ОбщегоНазначенияСтоматология.ХранилищеОбщихНастроекСохранитьИОбновитьПовторноИспользуемыеЗначения("ЭЦП", "ОтпечатокЛичногоСертификатаДляШифрования", ОтпечатокЛичногоСертификатаДляШифрования);
	Иначе
		ПоказатьПредупреждение(,НСтр("ru = 'Не выбран персональный сертификат для шифрования.'"));
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОповещениеПослеЗашифровки,Новый Структура("ВыполненоУспешно,ЗашифрованныеДанные,МассивОтпечатков",Ложь,ДополнительныеПараметры.ЗашифрованныеДанные,ДополнительныеПараметры.МассивОтпечатков));
		Возврат;
	КонецЕсли;
	
	ПолучитьЗашифрованныеДанныеПродолжение2(ДополнительныеПараметры);

КонецПроцедуры

// Процедура - Получить зашифрованные данные продолжение2
//
// Параметры:
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПолучитьЗашифрованныеДанныеПродолжение2(ДополнительныеПараметры)
	
	ДанныеФайла                = ДополнительныеПараметры.ДанныеФайла;
	ЗашифрованныеДанные 	   = ДополнительныеПараметры.ЗашифрованныеДанные;
	МассивОтпечатков 		   = ДополнительныеПараметры.МассивОтпечатков;
	МассивСтруктурСертификатов = ДополнительныеПараметры.МассивСтруктурСертификатов;
	ОповещениеПослеЗашифровки  = ДополнительныеПараметры.ОповещениеПослеЗашифровки;
	ПрисоединенныйФайл 		   = ДополнительныеПараметры.ПрисоединенныйФайл;
	УникальныйИдентификатор    = ДополнительныеПараметры.УникальныйИдентификатор;
    ОтпечатокЛичногоСертификатаДляШифрования =  ДополнительныеПараметры.ОтпечатокЛичногоСертификатаДляШифрования;
	
	ПараметрыФормы = Новый Структура("МассивСтруктурСертификатов, ФайлСсылка, ОтпечатокЛичногоСертификатаДляШифрования",
	МассивСтруктурСертификатов,
	ПрисоединенныйФайл,
	ОтпечатокЛичногоСертификатаДляШифрования);
	
	ОткрытьФорму("ОбщаяФорма.ВыборСертификатовШифрования", ПараметрыФормы,,,,, 
	Новый ОписаниеОповещения("ПолучитьЗашифрованныеДанныеПослеВыбораСертификатаШифрования", ЭтотОбъект, ДополнительныеПараметры), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

// Процедура - Получить зашифрованные данные после выбора сертификата шифрования
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПолучитьЗашифрованныеДанныеПослеВыбораСертификатаШифрования(Результат, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла               = ДополнительныеПараметры.ДанныеФайла;
	ЗашифрованныеДанные       = ДополнительныеПараметры.ЗашифрованныеДанные;
	МассивОтпечатков          = ДополнительныеПараметры.МассивОтпечатков;
	ОповещениеПослеЗашифровки = ДополнительныеПараметры.ОповещениеПослеЗашифровки;
	УникальныйИдентификатор   = ДополнительныеПараметры.УникальныйИдентификатор;
	
	МассивСертификатов = Результат;
	
	Если ТипЗнч(МассивСертификатов) = Тип("Массив") Тогда
		
		Результат = ВыполнитьШифрованиеПоПараметрам(МассивСертификатов,
		ДанныеФайла,
		УникальныйИдентификатор,
		ЗашифрованныеДанные,
		МассивОтпечатков);
		
		ВыполнитьОбработкуОповещения(ОповещениеПослеЗашифровки,Новый Структура("ВыполненоУспешно,ЗашифрованныеДанные,МассивОтпечатков",Результат,ЗашифрованныеДанные,МассивОтпечатков));
		Возврат;
		
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОповещениеПослеЗашифровки,Новый Структура("ВыполненоУспешно,ЗашифрованныеДанные,МассивОтпечатков",Ложь,ЗашифрованныеДанные,МассивОтпечатков));

КонецПроцедуры

// Служебная функция выполняет шифрование двоичных данных файла
// по переданному массиву сертификатов. Выполняет шифрование и возвращает
// структуру с зашифрованными данными.
// Параметры
//  МассивСертификатов - массив сертификатов для шифрования
//  ДанныеФайла - данные файла
//  УникальныйИдентификатор - уникальный идентификатор формы
//  ЗашифрованныеДанные - зашифрованные данные
//  МассивОтпечатков - массив отпечатков
// Возвращаемое значение
//  Истина - шифрование выполнено успешно, иначе Ложь
//
Функция ВыполнитьШифрованиеПоПараметрам(
				МассивСертификатов,
				ДанныеФайла,
				УникальныйИдентификатор,
				ЗашифрованныеДанные,
				МассивОтпечатков)
	
	МассивОтпечатков = Новый Массив;
	
	Для Каждого Сертификат Из МассивСертификатов Цикл
		Отпечаток = Base64Строка(Сертификат.Отпечаток);
		Представление = ЭлектроннаяЦифроваяПодписьКлиентСервер.ПолучитьПредставлениеПользователя(Сертификат.Субъект);
		ДвоичныеДанныеСертификата = Сертификат.Выгрузить();
		
		ОтпечатокСтруктура = Новый Структура("Отпечаток, Представление, Сертификат", Отпечаток, Представление, ДвоичныеДанныеСертификата);
		МассивОтпечатков.Добавить(ОтпечатокСтруктура);
	КонецЦикла;
	
	Состояние(НСтр("ru = 'Выполняется шифрование ...'"));
	
	Отказ = Ложь;
	МенеджерКриптографии = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьМенеджерКриптографии(Отказ);
	Если Отказ Тогда
		Возврат Ложь
	КонецЕсли;
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);
	ШифрованныйФайлДвоичныеДанные = МенеджерКриптографии.Зашифровать(ДвоичныеДанные, МассивСертификатов);
	АдресВременногоХранилища = ПоместитьВоВременноеХранилище(ШифрованныйФайлДвоичныеДанные, УникальныйИдентификатор);
	
	ЗашифрованныеДанные = Новый Структура("АдресВременногоХранилища", АдресВременногоХранилища);
	
	Состояние();
	
	Возврат Истина;
	
КонецФункции

// Служебная функция используется для оповещения системы и пользователя об
// успешном шифровании файла.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//
Процедура ОповеститьОбИзмененииИУдалитьФайлВРабочемКаталоге(ПрисоединенныйФайл, ДанныеФайла) Экспорт
	
	ОповеститьОбИзменении(ПрисоединенныйФайл);
	Состояние(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
							НСтр("ru = 'Файл ""%1"" зашифрован'"),
							ПрисоединенныйФайл) );
	
	ОбщегоНазначенияКлиентСтоматология.ПредложитьУстановкуРасширенияРаботыСФайлами();
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ОповеститьОбИзмененииИУдалитьФайлВРабочемКаталогеПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ДанныеФайла", ДанныеФайла)));
	
КонецПроцедуры

// Процедура - Оповестить об изменении и удалить файл в рабочем каталоге после подключения расширения
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОповеститьОбИзмененииИУдалитьФайлВРабочемКаталогеПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ДанныеФайла = ДополнительныеПараметры.ДанныеФайла;
	
	
	Если Подключено Тогда
		
		ФайловыеФункцииКлиент.ПроинициализироватьПутьКРабочемуКаталогу();
		РабочийКаталогПользователя = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами().ПутьКЛокальномуКэшуФайлов;
		ПолныйПутьКФайлу = РабочийКаталогПользователя + ДанныеФайла.ИмяФайла;
		
		Файл = Новый Файл(ПолныйПутьКФайлу);
		
		Если Файл.Существует() Тогда
			Попытка
				Файл.УстановитьТолькоЧтение(Ложь);
				НачатьУдалениеФайлов(Новый ОписаниеОповещения, ПолныйПутьКФайлу);
  			Исключение
				// пытаемся удалить файл с диска
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область Расшифровать

// Обработчик команды расшифровки файла. Показывает пользователю диалог с предложением
// расшифровать файл, далее получает двоичные данные и массив отпечатков и производит расшифровку.
// Далее расшифрованные данные записываются в хранилище.
//
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//  УникальныйИдентификатор - уникальный идентификатор формы
//
Процедура Расшифровать(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор) Экспорт
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеРасшифровки",Этотобъект,Новый Структура("ПрисоединенныйФайл, ДанныеФайла",ПрисоединенныйФайл, ДанныеФайла));
	
	ПолучитьРасшифрованныеДанные(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОписаниеОповещения);
	
КонецПроцедуры

// Процедура - После расшифровки
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеРасшифровки(Результат,ДополнительныеПараметры) Экспорт 
	
	Если НЕ Результат.ВыполненоУспешно Тогда
		Возврат;
	КонецЕсли;
	
	ПрисоединенныеФайлы.Расшифровать(ДополнительныеПараметры.ПрисоединенныйФайл, Результат.РасшифрованныеДанные);
	
	ОповеститьОРасшифровкеФайла(ДополнительныеПараметры.ПрисоединенныйФайл, ДополнительныеПараметры.ДанныеФайла)
	
КонецПроцедуры

// Оповещает систему и пользователя о расшифровке файла
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//
Процедура ОповеститьОРасшифровкеФайла(ПрисоединенныйФайл, ДанныеФайла) Экспорт
	
	ОповеститьОбИзменении(ПрисоединенныйФайл);
	Состояние(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Файл ""%1"" расшифрован'"), ПрисоединенныйФайл) );
	
КонецПроцедуры

// Служебная процедура, получает расшифрованные данные файла.
// Параметры
//  ПрисоединенныйФайл - ссылка на файл
//  ДанныеФайла - структура с данными файла
//  РасшифрованныеДанные - структура с расшифрованными данными, заполняется в процедуре
// УникальныйИдентификатор - уникальный идентификатор формы
// 
Процедура ПолучитьРасшифрованныеДанные(ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеРасшифровки) Экспорт
	
	СтруктураПараметров = Новый Структура("ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеРасшифровки", ПрисоединенныйФайл, ДанныеФайла, УникальныйИдентификатор, ОповещениеПослеРасшифровки); 
	#Если ВебКлиент Тогда
		НачатьПодключениеРасширенияРаботыСКриптографией(Новый ОписаниеОповещения("ПолучитьРасшифрованныеДанныеПослеПодключенияКриптографии", ЭтотОбъект, СтруктураПараметров));
		Возврат;
	#КонецЕсли

	ПолучитьРасшифрованныеДанныеПродолжение(СтруктураПараметров);  
	
КонецПроцедуры

// Процедура - Получить расшифрованные данные после подключения криптографии
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПолучитьРасшифрованныеДанныеПослеПодключенияКриптографии(Подключено, ДополнительныеПараметры) Экспорт
	
	ОповещениеПослеРасшифровки = ДополнительныеПараметры.ОповещениеПослеРасшифровки;
	
	Если НЕ Подключено Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Расширение для работы с криптографией не подключено, операция прервана.'"));
		ВыполнитьОбработкуОповещения(ОповещениеПослеРасшифровки,Новый Структура("ВыполненоУспешно,РасшифрованныеДанные",Ложь,Неопределено));
		Возврат;
	КонецЕсли;
	
	ПолучитьРасшифрованныеДанныеПродолжение(ДополнительныеПараметры);  
	
КонецПроцедуры
 
// Процедура - Получить расшифрованные данные продолжение
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
//
Процедура ПолучитьРасшифрованныеДанныеПродолжение(СтруктураПараметров) Экспорт
	
	ПрисоединенныйФайл         = СтруктураПараметров.ПрисоединенныйФайл;
	ДанныеФайла                = СтруктураПараметров.ДанныеФайла;
	УникальныйИдентификатор    = СтруктураПараметров.УникальныйИдентификатор;
	ОповещениеПослеРасшифровки = СтруктураПараметров.ОповещениеПослеРасшифровки;
	
	ПредставленияСертификатов = "";
	
	МассивСертификатовШифрования = ДанныеФайла.МассивСертификатовШифрования;
	Для Каждого СтруктураСертификата Из МассивСертификатовШифрования Цикл
		Отпечаток = СтруктураСертификата.Отпечаток;
		Сертификат = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьСертификатПоОтпечатку(Отпечаток, Истина);
		Если Сертификат <> Неопределено Тогда 
			Если НЕ ПустаяСтрока(ПредставленияСертификатов) Тогда
				ПредставленияСертификатов = ПредставленияСертификатов + Символы.ПС;
			КонецЕсли;
			ПредставленияСертификатов = ПредставленияСертификатов + СтруктураСертификата.Представление;
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыФормы = Новый Структура("Заголовок, ПредставленияСертификатов, Файл",
									НСтр("ru = 'Введите пароль для расшифровки'"),
									ПредставленияСертификатов,
									ПрисоединенныйФайл);
	
	ОткрытьФорму("ОбщаяФорма.ВводПароляСОписаниями", ПараметрыФормы,,,,, 
	Новый ОписаниеОповещения("ПолучитьРасшифрованныеДанныеПослеВводаПароляСОписанием", ЭтотОбъект,СтруктураПараметров), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

// Процедура - Получить расшифрованные данные после ввода пароля с описанием
//
// Параметры:
//  КодВозврата				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПолучитьРасшифрованныеДанныеПослеВводаПароляСОписанием(КодВозврата, ДополнительныеПараметры) Экспорт
	
	ПрисоединенныйФайл         = ДополнительныеПараметры.ПрисоединенныйФайл;
	ДанныеФайла 	           = ДополнительныеПараметры.ДанныеФайла;
	ОповещениеПослеРасшифровки = ДополнительныеПараметры.ОповещениеПослеРасшифровки;
	УникальныйИдентификатор    = ДополнительныеПараметры.УникальныйИдентификатор;
	
	Если ТипЗнч(КодВозврата) = Тип("Строка") Тогда
		Пароль = КодВозврата;
	Иначе
		ВыполнитьОбработкуОповещения(ОповещениеПослеРасшифровки,Новый Структура("ВыполненоУспешно,РасшифрованныеДанные",Ложь,Неопределено));
		Возврат;
	КонецЕсли;
	
	Состояние(НСтр("ru = 'Выполняется расшифровка ...'"));
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);
	
	Отказ = Ложь;
	МенеджерКриптографии = ЭлектроннаяЦифроваяПодписьКлиент.ПолучитьМенеджерКриптографии(Отказ);
	Если Отказ Тогда
		ВыполнитьОбработкуОповещения(ОповещениеПослеРасшифровки,Новый Структура("ВыполненоУспешно,РасшифрованныеДанные",Ложь,Неопределено));
		Возврат;
	КонецЕсли;
	
	МенеджерКриптографии.ПарольДоступаКЗакрытомуКлючу = Пароль;
	ДвоичныеДанныеРасшифрованные = МенеджерКриптографии.Расшифровать(ДвоичныеДанные);
	АдресВременногоХранилищаРасшифрованныхДанных = ПоместитьВоВременноеХранилище(ДвоичныеДанныеРасшифрованные, УникальныйИдентификатор);
	
	#Если ВебКлиент Тогда
		АдресВременногоХранилищаТекста = "";
	#Иначе
		ИзвлекатьТекстыФайловНаСервере = ФайловыеФункцииКлиентПовтИсп.ПолучитьПерсональныеНастройкиРаботыСФайлами().ИзвлекатьТекстыФайловНаСервере;
		Если НЕ ИзвлекатьТекстыФайловНаСервере Тогда
			ПолныйПутьКФайлу = ПолучитьИмяВременногоФайла(ДанныеФайла.Расширение);
			ДвоичныеДанныеРасшифрованные.Записать(ПолныйПутьКФайлу);
			АдресВременногоХранилищаТекста = ФайловыеФункцииКлиентСервер.ИзвлечьТекстВоВременноеХранилище(ПолныйПутьКФайлу, УникальныйИдентификатор);
			НачатьУдалениеФайлов(Новый ОписаниеОповещения("ПолучитьРасшифрованныеДанныеПослеУдаленияФайлов", ЭтотОбъект, Новый Структура("АдресВременногоХранилищаРасшифрованныхДанных, АдресВременногоХранилищаТекста, ОповещениеПослеРасшифровки", АдресВременногоХранилищаРасшифрованныхДанных, АдресВременногоХранилищаТекста, ОповещениеПослеРасшифровки)), ПолныйПутьКФайлу);
            Возврат;
		Иначе
			АдресВременногоХранилищаТекста = "";
		КонецЕсли;
	#КонецЕсли
	
	РасшифрованныеДанные = Новый Структура("АдресВременногоХранилища, АдресВременногоХранилищаТекста",
	АдресВременногоХранилищаРасшифрованныхДанных,
	АдресВременногоХранилищаТекста);
	
	Состояние("");
	
	ВыполнитьОбработкуОповещения(ОповещениеПослеРасшифровки,Новый Структура("ВыполненоУспешно,РасшифрованныеДанные",Истина,РасшифрованныеДанные));

КонецПроцедуры

// Процедура - Получить расшифрованные данные после удаления файлов
//
// Параметры:
//  ДополнительныеПараметры1 - 	 - 
//
Процедура ПолучитьРасшифрованныеДанныеПослеУдаленияФайлов(ДополнительныеПараметры) Экспорт
	
	АдресВременногоХранилищаРасшифрованныхДанных = ДополнительныеПараметры.АдресВременногоХранилищаРасшифрованныхДанных;
	ОповещениеПослеРасшифровки = ДополнительныеПараметры.ОповещениеПослеРасшифровки;
	АдресВременногоХранилищаТекста = ДополнительныеПараметры.АдресВременногоХранилищаТекста;
	
	РасшифрованныеДанные = Новый Структура("АдресВременногоХранилища, АдресВременногоХранилищаТекста",
	АдресВременногоХранилищаРасшифрованныхДанных,
	АдресВременногоХранилищаТекста);
	
	Состояние("");
	
	ВыполнитьОбработкуОповещения(ОповещениеПослеРасшифровки,Новый Структура("ВыполненоУспешно,РасшифрованныеДанные",Истина,РасшифрованныеДанные));
	
КонецПроцедуры

#КонецОбласти

#Область Служебные
// Получает данные файла с сервера и записывает их в каталог на диске
// Параметры:
//  СсылкаНаДвоичныеДанныеФайла - адрес во временном хранилище с 
//  Двоичными данными, либо навигационная ссылка на данные файла в ИБ
//  ОтносительныйПуть - путь к файлу относительно рабочего каталога
//  ДатаМодификацииУниверсальная - Дата - универсальная дата модификации файла
//  ИмяФайла - Строка - имя файла (с расширением)
//
// Возвращаемое значение: булево
// Истина - файл получен и сохранен успешно, иначе Ложь
//
// ОСОБЫЕ УСЛОВИЯ
// Требуется наличие подключенного расширения для работы с файлами.
//
Функция ПолучитьФайлВРабочийКаталог(СсылкаНаДвоичныеДанныеФайла,
									ОтносительныйПуть,
									ДатаМодификацииУниверсальная,
									ИмяФайла,
									РабочийКаталогПользователя = "",
									ПолноеИмяФайлаНаКлиенте)
	
	
	Если РабочийКаталогПользователя = Неопределено Или ПустаяСтрока(РабочийКаталогПользователя) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	КаталогСохранения = РабочийКаталогПользователя + ОтносительныйПуть;
	
	Попытка
		СоздатьКаталог(КаталогСохранения);
	Исключение
		СообщениеОбОшибке = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		СообщениеОбОшибке = НСтр("ru = 'Ошибка создания каталога на диске:'") + " " + СообщениеОбОшибке;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОбОшибке);
		Возврат Ложь;
	КонецПопытки;
	
	Файл = Новый Файл(КаталогСохранения + ИмяФайла);
	Если Файл.Существует() Тогда
		Файл.УстановитьТолькоЧтение(Ложь);
		УдалитьФайлы(КаталогСохранения + ИмяФайла);
	КонецЕсли;
	
	ПолучаемыйФайл = Новый ОписаниеПередаваемогоФайла(КаталогСохранения + ИмяФайла, СсылкаНаДвоичныеДанныеФайла);
	ПолучаемыеФайлы = Новый Массив;
	ПолучаемыеФайлы.Добавить(ПолучаемыйФайл);
	
	ПолученныеФайлы = Новый Массив;
	
	Если ПолучитьФайлы(ПолучаемыеФайлы, ПолученныеФайлы, , Ложь) Тогда
		ПолноеИмяФайлаНаКлиенте = ПолученныеФайлы[0].Имя;
		Файл = Новый Файл(ПолноеИмяФайлаНаКлиенте);
		Файл.УстановитьУниверсальноеВремяИзменения(ДатаМодификацииУниверсальная);
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Процедура для помещения файлов с диска в хранилище присоединенных файлов
// Параметры:
//  ВыбранныеФайлы - массив - пути к файлам на диске
//  ВладелецФайла - любая ссылка - владелец файла
//  МаксРазмерФайла - число - максимальный размер файла
//  ИзвлекатьТекстыФайловНаСервере - булево - извлекать тексты файлов на сервере
//  УникальныйИдентификатор - уникальный идентификатор формы
//
//  ПрисоединенныеФайлыМассив - массив добавленных в хранилище файлов (ссылки)
//
Процедура ПоместитьВыбранныеФайлыВХранилище(
			ВыбранныеФайлы,
			ВладелецФайла,
			НастройкиРаботыСФайлами,
			ПрисоединенныеФайлыМассив,
			УникальныйИдентификатор)
	
	МаксРазмерФайла						= НастройкиРаботыСФайлами.МаксимальныйРазмерФайла;
	ИзвлекатьТекстыФайловНаСервере		= НастройкиРаботыСФайлами.ИзвлекатьТекстыФайловНаСервере;
	ЗапретЗагрузкиФайловПоРасширению	= НастройкиРаботыСФайлами.ЗапретЗагрузкиФайловПоРасширению;
	СписокЗапрещенныхРасширений			= НастройкиРаботыСФайлами.СписокЗапрещенныхРасширений;
	
	ТекущаяПозиция = 0;
	
	Для Каждого ПолноеИмяФайла Из ВыбранныеФайлы Цикл
		
		ТекущаяПозиция = ТекущаяПозиция + 1;
		
		Файл = Новый Файл(ПолноеИмяФайла);
		
		Если Файл.Размер() > МаксРазмерФайла Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОПревышенииМаксимальноДопустимогоРазмераФайла(Файл.Размер(), МаксРазмерФайла, Файл.Имя));
			Продолжить;
		КонецЕсли;
		
		Если Не ФайловыеФункцииКлиентСервер.РасширениеФайлаРазрешеноДляЗагрузки(ЗапретЗагрузкиФайловПоРасширению, СписокЗапрещенныхРасширений, Файл.Расширение) Тогда
			ВызватьИсключение
				СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Загрузка файлов с расширением ""%1"" запрещена. Обратитесь к администратору системы.'"),
					Файл.Расширение);
		КонецЕсли;
		
		Если ИзвлекатьТекстыФайловНаСервере Тогда
			АдресВременногоХранилищаТекста = "";
		Иначе
			АдресВременногоХранилищаТекста = ФайловыеФункцииКлиентСервер.ИзвлечьТекстВоВременноеХранилище(ПолноеИмяФайла, УникальныйИдентификатор);
		КонецЕсли;
	
		ВремяИзменения = ТекущаяДата();
		ВремяИзмененияУниверсальное = Файл.ПолучитьУниверсальноеВремяИзменения();
		
		Если ВыбранныеФайлы.Количество() >1 Тогда
			ОбновитьИндикаторПрогресса(ВыбранныеФайлы.Количество(), ТекущаяПозиция, Файл.Имя, Файл.Размер());
		Иначе
			ИнформироватьПользователяОСохраненииФайла(Файл.Имя, Файл.Размер());
		КонецЕсли;
		
		ПомещаемыеФайлы = Новый Массив;
		Описание = Новый ОписаниеПередаваемогоФайла(Файл.ПолноеИмя, "");
		ПомещаемыеФайлы.Добавить(Описание);
		
		ПомещенныеФайлы = Новый Массив;
		
		Если НЕ ПоместитьФайлы(ПомещаемыеФайлы, ПомещенныеФайлы, , Ложь, УникальныйИдентификатор) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Ошибка при помещении файла в хранилище: %1'"), Файл.ПолноеИмя) );
			Продолжить;
		КонецЕсли;
		
		АдресВременногоХранилищаФайла = ПомещенныеФайлы[0].Хранение;
		
		// Создадим карточку Файла в БД
		ПрисоединенныйФайл = ПрисоединенныеФайлы.ДобавитьФайл(
			ВладелецФайла,
			Файл.ИмяБезРасширения,
			ФайловыеФункцииКлиентСервер.РасширениеБезТочки(Файл.Расширение),
			ВремяИзменения,
			ВремяИзмененияУниверсальное,
			АдресВременногоХранилищаФайла,
			АдресВременногоХранилищаТекста,
			Ложь);
		
		Если ПрисоединенныйФайл = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПрисоединенныеФайлыМассив.Добавить(ПрисоединенныйФайл);
		
	КонецЦикла;
	
	Состояние("");
	
КонецПроцедуры

// Процедура - Диалог нужно получить файл с сервера
//
// Параметры:
//  ПолноеИмяФайлаНаКлиенте	 - 	 - 
//  ДанныеФайла				 - 	 - 
//  ФайлРедактируется		 - 	 - 
//  Отказ					 - 	 - 
//  ОбработчикЗавершения	 - 		 - 
//
Процедура ДиалогНужноПолучитьФайлССервера(Знач ПолноеИмяФайлаНаКлиенте, Знач ДанныеФайла, Знач ФайлРедактируется, Знач Отказ = Ложь, ОбработчикЗавершения)
	
	ФайлНаДиске = Новый Файл(ПолноеИмяФайлаНаКлиенте);
	
	ДатаФайлаВБазе = МестноеВремя(ДанныеФайла.ДатаМодификацииУниверсальная);
	ДатаФайлаНаДиске = МестноеВремя(ФайлНаДиске.ПолучитьУниверсальноеВремяИзменения());
	
	Если (ДатаФайлаНаДиске - ДатаФайлаВБазе) > 1 Тогда
		
		ПараметрыОткрытияФормы = Новый Структура;
		ПараметрыОткрытияФормы.Вставить("Файл",						ПолноеИмяФайлаНаКлиенте);
		ПараметрыОткрытияФормы.Вставить("ВремяИзмененияНаСервере",	ДатаФайлаВБазе);
		ПараметрыОткрытияФормы.Вставить("ВРабочемКаталоге",			ДатаФайлаНаДиске);
		ПараметрыОткрытияФормы.Вставить("Заголовок",				НСтр("ru = 'В рабочем каталоге более новый файл'"));
		
		Если ФайлРедактируется Тогда
			Сообщение = НСтр("ru = 'Файл на локальном компьютере, отмеченный как взятый на редактирование, имеет более позднюю дату изменения. Открыть файл из локального каталога или взять из информационной базы и перезаписать?'");
		Иначе
			Сообщение = НСтр("ru = 'Файл на локальном компьютере имеет более позднюю дату, возможно, он был изменен. Открыть существующий или взять с сервера и перезаписать?'");
		КонецЕсли;
		
		ПараметрыОткрытияФормы.Вставить("Сообщение", Сообщение);
		
		ОткрытьФорму("ОбщаяФорма.ВРабочемКаталогеБолееНовыйФайл", ПараметрыОткрытияФормы,,,,, 
		Новый ОписаниеОповещения("ДиалогНужноПолучитьФайлПослеОткрытияФормы1", ЭтотОбъект, Новый Структура("ОбработчикЗавершения, Отказ", ОбработчикЗавершения, Отказ)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
		Возврат;
		
	ИначеЕсли (ДатаФайлаВБазе - ДатаФайлаНаДиске) > 1 Тогда // в базе более новый
		Если ФайлРедактируется Тогда // В рабочем каталоге на редактирование
			ПараметрыОткрытияФормы = Новый Структура;
			ПараметрыОткрытияФормы.Вставить("Файл",						ДатаФайлаВБазе);
			ПараметрыОткрытияФормы.Вставить("ВремяИзмененияНаСервере",	ДатаФайлаВБазе);
			ПараметрыОткрытияФормы.Вставить("ВРабочемКаталоге",			ДатаФайлаНаДиске);
			ПараметрыОткрытияФормы.Вставить("Заголовок",				НСтр("ru = 'В рабочем каталоге более старый файл'"));
			
			Сообщение = НСтр("ru = 'Файл на локальном компьютере, отмеченный как взятый на редактирование, имеет более раннюю дату изменения, чем на сервере. Открыть файл из локального каталога или взять из информационной базы и перезаписать?'");
			ПараметрыОткрытияФормы.Вставить("Сообщение", Сообщение);
			
			ОткрытьФорму("ОбщаяФорма.ВРабочемКаталогеБолееНовыйФайл", ПараметрыОткрытияФормы,,,,, Новый ОписаниеОповещения("ДиалогНужноПолучитьФайлПослеОткрытияФормы2", ЭтотОбъект, Новый Структура("ОбработчикЗавершения, Отказ, ПолноеИмяФайлаНаКлиенте", ОбработчикЗавершения, Отказ, ПолноеИмяФайлаНаКлиенте)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
            Возврат; 
			
		Иначе // В рабочем каталоге на чтение
			УдалитьФайл(ПолноеИмяФайлаНаКлиенте);
			ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Истина,Отказ));
			Возврат;
			
		КонецЕсли;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Ложь,Отказ));
	Возврат;

КонецПроцедуры

Процедура ДиалогНужноПолучитьФайлПослеОткрытияФормы1(Результат, ДополнительныеПараметры) Экспорт
	
	ОбработчикЗавершения = ДополнительныеПараметры.ОбработчикЗавершения;
	Отказ                = ДополнительныеПараметры.Отказ;
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Ложь,Отказ));
		Возврат;
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Истина,Отказ));
		Возврат;
	Иначе
		Отказ = Истина;
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Неопределено,Отказ));
		Возврат;
	КонецЕсли;

КонецПроцедуры
	
Процедура ДиалогНужноПолучитьФайлПослеОткрытияФормы2(Ответ, ДополнительныеПараметры) Экспорт
	
	ОбработчикЗавершения    = ДополнительныеПараметры.ОбработчикЗавершения;
	Отказ                   = ДополнительныеПараметры.Отказ;
	ПолноеИмяФайлаНаКлиенте = ДополнительныеПараметры.ПолноеИмяФайлаНаКлиенте;
		
	Если Ответ = КодВозвратаДиалога.Да Тогда  // Открыть существующий
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Ложь,Отказ));
		Возврат;
	ИначеЕсли Ответ = КодВозвратаДиалога.Отмена Тогда // Выйти ничего не делая
		Отказ = Истина;
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Ложь,Отказ));
		Возврат;
	ИначеЕсли Ответ = КодВозвратаДиалога.Нет Тогда  // Перезаписать
		УдалитьФайл(ПолноеИмяФайлаНаКлиенте);
		ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Истина,Отказ));
		Возврат;	
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОбработчикЗавершения,Новый Структура("ПолучитьФайл,Отказ",Ложь,Отказ));
	Возврат;

КонецПроцедуры

#КонецОбласти

#Область Вспомогательные

// Процедура - Удалить файл
//
// Параметры:
//  ПолноеИмяФайла	 - 	 - 
//
Процедура УдалитьФайл(ПолноеИмяФайла)
	
	Файл = Новый Файл(ПолноеИмяФайла);
	Файл.УстановитьТолькоЧтение(Ложь);
	НачатьУдалениеФайлов(Новый ОписаниеОповещения, ПолноеИмяФайла);
	
КонецПроцедуры

// Функция - Сообщение о превышении максимально допустимого размера файла
//
// Параметры:
//  РазмерФайла				 - 	 - 
//  МаксимальныйРазмерФайла	 - 	 - 
//  ИмяФайла				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СообщениеОПревышенииМаксимальноДопустимогоРазмераФайла(РазмерФайла, МаксимальныйРазмерФайла, ИмяФайла)
	
	РазмерВМб = РазмерФайла / (1024 * 1024);
	РазмерВМбМакс = МаксимальныйРазмерФайла / (1024 * 1024);
	
	Возврат
	СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru = 'Размер файла ""%1"" (%2 Мб) превышает максимально допустимый размер файла (%3 Мб).'"),
	ИмяФайла,
	?(РазмерВМб >= 1, Формат(РазмерВМб, "ЧДЦ=0"), Формат(РазмерВМб, "ЧДЦ=1; ЧН=0")),
	?(РазмерВМбМакс >= 1, Формат(РазмерВМбМакс, "ЧДЦ=0"), Формат(РазмерВМбМакс, "ЧДЦ=1; ЧН=0")));
	
КонецФункции

// Процедура - Открыть файл приложением
//
// Параметры:
//  ИмяОткрываемогоФайла - 	 - 
//
Процедура ОткрытьФайлПриложением(ИмяОткрываемогоФайла)

	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ОткрытьФайлПриложениемПослеПодключенияРасширения", ЭтотОбъект, Новый Структура("ИмяОткрываемогоФайла", ИмяОткрываемогоФайла)));
	
КонецПроцедуры

// Процедура - Открыть файл приложением после подключения расширения
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОткрытьФайлПриложениемПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт
	
	ИмяОткрываемогоФайла = ДополнительныеПараметры.ИмяОткрываемогоФайла;
	
	
	Если Подключено Тогда
		// Открыть Файл
		Попытка
			
			НачатьЗапускПриложения(Новый ОписаниеОповещения,ИмяОткрываемогоФайла);
			
		Исключение
			
			Инфо = ИнформацияОбОшибке();
			ПоказатьПредупреждение(,СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Описание=""%1""'"),
			Инфо.Описание));
			
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

// Процедура - Обновить индикатор прогресса
//
// Параметры:
//  КоличествоФайлов - 	 - 
//  ТекущаяПозиция	 - 	 - 
//  ИмяФайла		 - 	 - 
//  РазмерФайла		 - 	 - 
//
Процедура ОбновитьИндикаторПрогресса(КоличествоФайлов, ТекущаяПозиция, ИмяФайла, РазмерФайла)
	
	ИндикаторПроцент = ТекущаяПозиция * 100 / КоличествоФайлов;
	
	РазмерВМб = РазмерФайла / (1024 * 1024);
	
	НадписьПодробнее =
	СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru = 'Обрабатывается файл ""%1"" (%2 Мб)...'"),
	ИмяФайла, ? (РазмерВМб >= 1, Формат(РазмерВМб, "ЧДЦ=0"), Формат(РазмерВМб, "ЧДЦ=1; ЧН=0") ) );
	
	ТекстСостояния = НСтр("ru = 'Импорт файлов с диска...'");
	
	Состояние(ТекстСостояния, ИндикаторПроцент, НадписьПодробнее, БиблиотекаКартинок.Информация32);
	
КонецПроцедуры

// Процедура - Информировать пользователя о сохранении файла
//
// Параметры:
//  ИмяФайла	 - 	 - 
//  РазмерФайла	 - 	 - 
//
Процедура ИнформироватьПользователяОСохраненииФайла(ИмяФайла, РазмерФайла)
	
	ТекстПояснения =
	СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru = 'Идет сохранение файла ""%1"" (%2 Мб).
	|Пожалуйста, подождите...'"),
	ИмяФайла,
	?(РазмерФайла >= 1, Формат(РазмерФайла, "ЧДЦ=0"), Формат(РазмерФайла, "ЧДЦ=1; ЧН=0")));
	
	Состояние(ТекстПояснения);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти