// Процедура - Записать параметры внешней системы на сервере
//
// Параметры:
//  ВнешняяСистемаСсылка - 	 - 
//  ТекстHTML			 - 	 - 
//
Процедура ЗаписатьПараметрыВнешнейСистемыНаСервере(ТекстHTML, ВнешняяСистемаСсылка)	
	
	Попытка
		ВнешняяСистемаОбъект    = ВнешняяСистемаСсылка.ПолучитьОбъект();
		ПараметрыВнешнейСистемы = ВнешняяСистемаОбъект.Параметры.Получить();
		
		Если ПараметрыВнешнейСистемы = Неопределено Тогда
			ПараметрыВнешнейСистемы = Новый Структура();
		КонецЕсли;
		
		ПараметрыВнешнейСистемы.Вставить("ПубличнаяОферта", ТекстHTML);
		
		ВнешняяСистемаОбъект.Параметры = Новый ХранилищеЗначения(ПараметрыВнешнейСистемы);
		ВнешняяСистемаОбъект.Записать();
	Исключение
		
	КонецПопытки;	
	
КонецПроцедуры

&НаСервере
// Процедура, проверяет публикацию информационной базы.
//
Процедура ПроверитьПубликациюИнформационнойБазы()
	
	УстановитьСлужебногоПользователя();
	
	РезультатПроверки = ЛичныйКабинет.ПроверитьПубликациюВнешнейСистемы(Константы.ВнешняяПубликацияАдрес.Получить());	
	Если НЕ (РезультатПроверки.ВыполненоУспешно  И РезультатПроверки.ПубликацияВерна = Истина) Тогда
			
		// Зачищаем пользователя внешней публикации, чтоб было видно, что публикация не верна. При следующей записи, он подтянется снова.
		Константы.ВнешняяПубликацияПользователь.Установить(Неопределено); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='При проверке публикации возникла ошибка: ';en='With checking publications originated mistake:'") + РезультатПроверки.ОписаниеОшибки);

	КонецЕсли;                                                           
		
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Установить служебного пользователя
//
Процедура УстановитьСлужебногоПользователя()
	
	Если НЕ ЗначениеЗаполнено(Константы.ВнешняяПубликацияПользователь.Получить()) Тогда
		                         
		СлужебныйПользователь = ПользователиСтоматология.СлужебныйПользовательAPI();
		
		Если НЕ ЗначениеЗаполнено(СлужебныйПользователь) Тогда
			
			СлужебныйПользователь = ПользователиСтоматология.СоздатьСлужебногоПользователяAPI();
			
		КонецЕсли;
		
		Константы.ВнешняяПубликацияПользователь.Установить(СлужебныйПользователь);
		
	КонецЕсли;

КонецПроцедуры

