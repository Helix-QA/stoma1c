			ГруппаСтрокиТабличнойЧасти.ГоризонтальныйИнтервал 							= ИнтервалМеждуЭлементамиФормы.Одинарный;
			ГруппаСтрокиТабличнойЧасти.Ширина											= ?(НесколькоВрачейВОдномПриеме, ?(Не НоменклатураЗаполнена, 57, 56), 58);
			ГруппаСтрокиТабличнойЧасти.РастягиватьПоГоризонтали							= Ложь;

			// Если Не НоменклатураЗаполнена Тогда
			//	
			//	Группа_Заглушка_НоваяСтрока = Элементы.Добавить("Группа_Заглушка_НоваяСтрока" + ПредставлениеТЧ, Тип("ГруппаФормы"), ГруппаСтрокиТабличнойЧасти);
