
#Область ОбработчикиСобытий

&НаСервере
// Функция снимает рассмотренность переданных входящих электронных писем
// Вернет "Истина", если рассмотренность была снята хотя бы у одного из переданных писем
//
Функция СброситьРассмотренностьПисьма(Знач МассивПисем)

	Результат = Ложь;
	
	Для Каждого Письмо Из МассивПисем Цикл
		
		Если Письмо.Рассмотрено = Ложь Тогда
			Продолжить;	// Если письмо и так не рассмотрено - нет смысла продолжать
		КонецЕсли;
		
		Попытка
			ПисьмоОбъект = Письмо.ПолучитьОбъект();
			ПисьмоОбъект.Рассмотрено = Ложь;
			ПисьмоОбъект.Записать();
		Исключение
			Продолжить;
		КонецПопытки;
		
		Результат = Истина; // Функция вернет истину, если хотя бы для одного письма все прошло успешно
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если ПараметрКоманды = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РассмотренностьСброшена = СброситьРассмотренностьПисьма(ПараметрКоманды);
	
	Если РассмотренностьСброшена Тогда
		Оповестить("ИзмененоЭлектронноеПисьмо", ПараметрКоманды);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти