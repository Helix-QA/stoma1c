
#Область ОбработчикиСобытий

// Процедура - Обработка получения представления
//
// Параметры:
//  Данные				 - 	 - 
//  Представление		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если Данные.ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	Представление = ?(Данные.НачислениеБонусами = Истина, НСтр("ru = 'Бонус: '; en = 'Bonus: '"), НСтр("ru = 'Скидка: '; en = 'Discount: '")) + Данные.Наименование;
	
КонецПроцедуры

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
    Поля.Добавить("Наименование");
	Поля.Добавить("НачислениеБонусами");
	Поля.Добавить("ЭтоГруппа");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Получить таблицу параметров скидки/наценки
Функция ПолучитьСкидкиДоступныеДляКлиента(Клиент) Экспорт
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка КАК Скидка,
	|	ДействиеСкидокНаценокСрезПоследних.ДатаНачала КАК ДатаНачала,
	|	ДействиеСкидокНаценокСрезПоследних.ДатаОкончания КАК ДатаОкончания,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя КАК ТипПолучателя,
	|	ВЫБОР
	|		КОГДА ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСпискомКлиентов)
	|			ТОГДА ""Персональная""
	|		ИНАЧЕ ""Общая""
	|	КОНЕЦ КАК ТипСкидки,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.СпособПредоставленияСкидки КАК СпособПредоставления,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.Наименование КАК Представление
	|ПОМЕСТИТЬ втСкидки
	|ИЗ
	|	РегистрСведений.ДействиеСкидокНаценок.СрезПоследних(
	|			,
	|			ВЫБОР
	|					КОГДА ГОД(ДатаНачала) <> 1
	|						ТОГДА ДатаНачала <= &ТекущаяДата
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ
	|				И ВЫБОР
	|					КОГДА ГОД(ДатаОкончания) <> 1
	|						ТОГДА ДатаОкончания >= &ТекущаяДата
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ) КАК ДействиеСкидокНаценокСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СкидкиНаценки.Получатели КАК СкидкиНаценкиПолучатели
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
	|			ПО СкидкиНаценкиПолучатели.Получатель = КонтрагентыСегмента.Сегмент
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Карты КАК Карты
	|			ПО (Карты.Заблокирована = ЛОЖЬ)
	|				И СкидкиНаценкиПолучатели.Получатель = Карты.ВидКарты
	|		ПО ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка = СкидкиНаценкиПолучатели.Ссылка
	|			И (ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСегментомКлиентов)
	|				ИЛИ ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСпискомКлиентов)
	|				ИЛИ ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоВидамиДисконтныхКарт))
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			КОГДА ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСпискомКлиентов)
	|				ТОГДА СкидкиНаценкиПолучатели.Получатель = &Клиент
	|			КОГДА ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСегментомКлиентов)
	|				ТОГДА КонтрагентыСегмента.Контрагент = &Клиент
	|			КОГДА ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоВидамиДисконтныхКарт)
	|				ТОГДА Карты.ВладелецКарты = &Клиент
	|		КОНЕЦ
	|	И ДействиеСкидокНаценокСрезПоследних.Актуальность = ИСТИНА
	|
	|СГРУППИРОВАТЬ ПО
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка,
	|	ДействиеСкидокНаценокСрезПоследних.ДатаНачала,
	|	ДействиеСкидокНаценокСрезПоследних.ДатаОкончания,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеСкидкиНаценки,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.СпособПредоставленияСкидки,
	|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.Наименование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Промокоды.Владелец КАК Владелец,
	|	Промокоды.Вид КАК Вид,
	|	Промокоды.Промокод КАК Промокод,
	|	Промокоды.Активен КАК Активен
	|ПОМЕСТИТЬ втПромокоды
	|ИЗ
	|	РегистрСведений.Промокоды КАК Промокоды
	|ГДЕ
	|	Промокоды.Владелец = &Клиент
	|	И Промокоды.Активен = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСкидки.Скидка КАК Скидка,
	|	втСкидки.ДатаНачала КАК ДатаНачала,
	|	втСкидки.ДатаОкончания КАК ДатаОкончания,
	|	втСкидки.ТипПолучателя КАК ТипПолучателя,
	|	втСкидки.ТипСкидки КАК ТипСкидки,
	|	втСкидки.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки,
	|	втСкидки.СпособПредоставления КАК СпособПредоставления,
	|	втСкидки.Представление КАК Представление
	|ИЗ
	|	втСкидки КАК втСкидки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПромокоды КАК втПромокоды
	|		ПО втСкидки.Скидка.Промокод = втПромокоды.Вид
	|ГДЕ
	|	ВЫБОР
	|			КОГДА втСкидки.Скидка.УсловиеПредоставленияСкидки = ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидки.БонусРефералу)
	|					И втСкидки.Скидка.НачислениеБонусами = ИСТИНА
	|				ТОГДА втПромокоды.Владелец = &Клиент
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ТекущаяДата",ТекущаяДата());
	Запрос.УстановитьПараметр("Клиент"     ,Клиент);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Опредить тип скидки наценки это бонус
//
// Параметры:
//  СкидкаНаценкаСсылкаРодитель	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОпредитьТипСкидкиНаценкиЭтоБонус(СкидкаНаценкаСсылкаРодитель) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РодительЭлемента", СкидкаНаценкаСсылкаРодитель);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ИСТИНА КАК ПризнакВхождения
	               |ГДЕ
	               |	&РодительЭлемента В ИЕРАРХИИ (ЗНАЧЕНИЕ(Справочник.СкидкиНаценки.Бонусы))";
	РезультатПризнаВхожденияВБонус = Запрос.Выполнить().Выбрать();
	
	Возврат РезультатПризнаВхожденияВБонус.Следующий();
	
КонецФункции

// Процедура, добавляет скидку переданному клиенту.
//
Процедура ДобавитьСкидкуКлиенту(ВыбраннаяСкидка, Клиент) Экспорт
	
	Если ВыбраннаяСкидка.ЭтоГруппа = Истина Тогда
		Возврат;
	Иначе
		
		СкидкаСуществует = ВыбраннаяСкидка.Получатели.Найти(Клиент, "Получатель"); 

		Если СкидкаСуществует = Неопределено Тогда
			
			// Получаем объект.
			СкидкаОбъект = ВыбраннаяСкидка.ПолучитьОбъект();
			
			// Добавляет клиента в эту скидку.
			СтрокаТЧ = СкидкаОбъект.Получатели.Добавить();
			СтрокаТЧ.Получатель = Клиент;
			
			Попытка
				СкидкаОбъект.Записать();
			Исключение
				
			КонецПопытки;
			
		КонецЕсли;
	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
