// Функция возвращает организацию и вид цен по указанной структурной единице.
//
Функция ПолучитьОрганизациюИВидЦен(СтруктурнаяЕдиница)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("Организация", СтруктурнаяЕдиница.Организация);
	СтруктураВозврата.Вставить("ВидЦен", СтруктурнаяЕдиница.ВидЦенРеализации);
	
