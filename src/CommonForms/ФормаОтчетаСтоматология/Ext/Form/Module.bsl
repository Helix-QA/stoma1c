// Процедура, обработчик команды завершение "ПоказатьСписокОпераций".
//
Процедура ПоказатьСписокОперацийЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
