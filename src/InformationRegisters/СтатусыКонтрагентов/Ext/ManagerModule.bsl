
#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентОбычноеПриложение Тогда
	
#Область СлужебныйПрограммныйИнтерфейс

// Процедура - Актуализировать статусы всех пациентов
//
// Параметры:
//  ОповещатьОХодеВыполнения - 	 - 
//
Процедура АктуализироватьСтатусыВсехПациентов(ОповещатьОХодеВыполнения = Ложь) Экспорт
	
	// Используется для регламентного задания "АктуализацияСтатусовПациентов"
	
	Если НЕ ПривилегированныйРежим() Тогда 															
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	

	Если ОповещатьОХодеВыполнения Тогда 
		ДатаНачалаПроцесса = ТекущаяДатаСеанса();
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Актуализация статусов пациентов...';en='Updating customer statuses...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, СозданоОбъектов", "Получение данных...", 0, "", 0));
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Контрагенты.Ссылка) КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	НЕ Контрагенты.ПометкаУдаления
		|	И НЕ Контрагенты.ЭтоГруппа
		|	И Контрагенты.ТипКонтрагента В (ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты), ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.ПустаяСсылка))";
		ВыборкаОбщегоКоличества = Запрос.Выполнить().Выбрать();
		Если ВыборкаОбщегоКоличества.Следующий() Тогда 
			ВсегоКлиентов = ВыборкаОбщегоКоличества.Ссылка;
		Иначе 
			ВсегоКлиентов = 0;	
		КонецЕсли;
		ВсегоКлиентов 			= ?(ВсегоКлиентов < 1, 1, ВсегоКлиентов);
		Счетчик 				= 0;
		ОсталосьВремени 		= Неопределено;				
	КонецЕсли;
	
	ТаблицаУстановленныхСтатусов 	= Неопределено;
	ТаблицаОбработанныхКонтрагентов = Новый ТаблицаЗначений;
	ТаблицаОбработанныхКонтрагентов.Колонки.Добавить("Контрагент", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	
	МетаданныеРегистра 				= Метаданные.РегистрыСведений.СтатусыКонтрагентов;
	ПредставлениеРегистра 			= МетаданныеРегистра.Представление();
	
	ВидСделкиНовыйПациент 			= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	ВидСделкиПостоянныйПациент		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.ПостоянныеПациенты");
	
	Пока ИСТИНА Цикл 
		ЗапросПорции = Новый Запрос;                          
		ЗапросПорции.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаОбработанныхКонтрагентов, "ТаблицаОбработанныхКонтрагентов");
		ЗапросПорции.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 300
		|	Контрагенты.Ссылка КАК Контрагент
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОбработанныхКонтрагентов КАК ТаблицаОбработанныхКонтрагентов
		|		ПО Контрагенты.Ссылка = ТаблицаОбработанныхКонтрагентов.Контрагент
		|ГДЕ
		|	НЕ Контрагенты.ПометкаУдаления
		|	И НЕ Контрагенты.ЭтоГруппа
		|	И Контрагенты.ТипКонтрагента В (ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты), ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.ПустаяСсылка))
		|	И ТаблицаОбработанныхКонтрагентов.Контрагент ЕСТЬ NULL";
	
		РезультатЗапроса = ЗапросПорции.Выполнить();
		ВсеОбработано = РезультатЗапроса.Пустой();
		Если ВсеОбработано Тогда
			ЗапросПорции.МенеджерВременныхТаблиц.Закрыть();
			Прервать;
		КонецЕсли;	
		ТаблицаКонтрагентовДляОбработки = РезультатЗапроса.Выгрузить();
	    ЗапросПорции.МенеджерВременныхТаблиц.Закрыть();
	   	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаКонтрагентовДляОбработки, ТаблицаОбработанныхКонтрагентов);
		
		// Получаем актуальные статусы порции пациентов
		ЗапросАктальныхСтатусов 		= Новый Запрос;
		ЗапросАктальныхСтатусов.Текст 	= ПолучитьТекстЗапросаАктуализацииСтатусовПациентов();
		ЗапросАктальныхСтатусов.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаКонтрагентовДляОбработки, "ТаблицаКонтрагентовДляОбработки");
		
		ЗапросАктальныхСтатусов.УстановитьПараметр("ТекущаяДата"				, КонецДня(ТекущаяДатаСеанса()));
		ЗапросАктальныхСтатусов.УстановитьПараметр("ГраницаПериодаНеактивности"	, НачалоДня(ТекущаяДатаСеанса()) - ((Константы.ПериодПоискаНеВернувшихсяКлиентов.Получить() + 1) * 60*60*24));
		ЗапросАктальныхСтатусов.УстановитьПараметр("ДнейОтсутствия"				, Константы.ПериодПоискаНеВернувшихсяКлиентов.Получить() + 1);
		ЗапросАктальныхСтатусов.УстановитьПараметр("ВидСделкиНовыйПациент"		, ВидСделкиНовыйПациент);
		ЗапросАктальныхСтатусов.УстановитьПараметр("ВидСделкиПостоянныйПациент"	, ВидСделкиПостоянныйПациент);
		
		ТаблицаАктуальныхСтатусовПациентов = ЗапросАктальныхСтатусов.Выполнить().Выгрузить();
		ЗапросАктальныхСтатусов.МенеджерВременныхТаблиц.Закрыть();
		
		//Если ТаблицаУстановленныхСтатусов = Неопределено Тогда  
		//	ТаблицаУстановленныхСтатусов = ТаблицаАктуальныхСтатусовПациентов.СкопироватьКолонки();
		//КонецЕсли;
		
		Если НЕ ТаблицаАктуальныхСтатусовПациентов.Количество() = 0 Тогда 
			ТаблицаПациентов 	= ТаблицаАктуальныхСтатусовПациентов.Скопировать(, "Контрагент");
			ТаблицаПациентов.Свернуть("Контрагент");
			// Получаем набор текущих статусов пациента для анализа
			ЗапросТекущихСтатусов 							= Новый Запрос;			
			ЗапросТекущихСтатусов.Текст 					= ПолучитьТекстЗапросаТекущихСтатусов(Истина);
			ЗапросТекущихСтатусов.МенеджерВременныхТаблиц 	= УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаКонтрагентовДляОбработки, "ТаблицаКонтрагентов");			
			ТаблицаТекущихСтатусовПациента 					= ЗапросТекущихСтатусов.Выполнить().Выгрузить();
			ЗапросТекущихСтатусов.МенеджерВременныхТаблиц.Закрыть();
			// Актуализируем статусы пациента
			Для Каждого СтрокаПациент Из ТаблицаПациентов Цикл
				Если ОповещатьОХодеВыполнения Тогда 
					Счетчик = Счетчик + 1;
					Прогресс = Цел(100 * Счетчик / ВсегоКлиентов);
					ОсталосьВремени 				= ОбщегоНазначенияКлиентСерверСтоматология.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
					ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПредставлениеВремени(ОсталосьВремени);
					ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Актуализация статусов пациентов...';en='Updating customer statuses...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", " Осталось: " + ПредставлениеОставшегосяВремени, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
				КонецЕсли;	
				
				КоллекцияСтрок 						= ТаблицаАктуальныхСтатусовПациентов.НайтиСтроки(Новый Структура("Контрагент", СтрокаПациент.Контрагент));
				Если КоллекцияСтрок.Количество() = 0 Тогда 
					Продолжить;
				Иначе 
					СтрокаАктуальныйСтатусПациента 	= КоллекцияСтрок[0];
				КонецЕсли;	
				МассивТекущихСтатусовПациента 		= ТаблицаТекущихСтатусовПациента.НайтиСтроки(Новый Структура("Контрагент", СтрокаПациент.Контрагент));
				ПериодУстановкиАктуальногоСтатуса 	= СтрокаАктуальныйСтатусПациента.Период;
				СтруктураПоследнейЗаписи 			= Новый Структура("Период, Контрагент, Статус");		
				Для Каждого ЭлементМассива Из МассивТекущихСтатусовПациента Цикл
					Если НЕ ЗначениеЗаполнено(ЭлементМассива.Статус) Тогда 
						// Удалим неактуальный статус
						УдалитьСтатусКлиента(ЭлементМассива);
						Продолжить;
					КонецЕсли;	
					Если НЕ ЗначениеЗаполнено(СтрокаАктуальныйСтатусПациента.Период) Тогда 
						ПериодУстановкиАктуальногоСтатуса = ЭлементМассива.Период;
					КонецЕсли;				
					Если ЭлементМассива.Период < СтрокаАктуальныйСтатусПациента.Период Тогда
						ЗаполнитьЗначенияСвойств(СтруктураПоследнейЗаписи, ЭлементМассива);
					Иначе 
						// Удалим неактуальный статус
						УдалитьСтатусКлиента(ЭлементМассива);
					КонецЕсли;
				КонецЦикла;
				Если ЗначениеЗаполнено(СтруктураПоследнейЗаписи.Статус) И СтруктураПоследнейЗаписи.Статус = СтрокаАктуальныйСтатусПациента.Статус И НЕ СтрокаАктуальныйСтатусПациента.Статус = Перечисления.СтатусыКонтрагентов.Потенциальный Тогда 
					// Удалим неактуальный статус
					УдалитьСтатусКлиента(СтруктураПоследнейЗаписи);	
				ИначеЕсли ЗначениеЗаполнено(СтруктураПоследнейЗаписи.Статус) И СтруктураПоследнейЗаписи.Статус = СтрокаАктуальныйСтатусПациента.Статус И СтрокаАктуальныйСтатусПациента.Статус = Перечисления.СтатусыКонтрагентов.Потенциальный Тогда 
					Продолжить;
				КонецЕсли;	
				СтрокаАктуальныйСтатусПациента.Период = ПериодУстановкиАктуальногоСтатуса;
				ЗаписатьАктуальныйСтатусКлиента(СтрокаАктуальныйСтатусПациента);
				//ЗаполнитьЗначенияСвойств(ТаблицаУстановленныхСтатусов.Добавить(), СтрокаАктуальныйСтатусПациента);				
			КонецЦикла;
			ТаблицаПациентов = Неопределено;
		КонецЕсли;
		ТаблицаАктуальныхСтатусовПациентов = Неопределено;
	КонецЦикла;	
	
	//// Регистрируем триггерные события смены статусов у клиентов, если настроены, отдельной процедурой,
	//// не задействуя общий механизм.
	//Если ТаблицаУстановленныхСтатусов.Количество() <> 0 Тогда
	//	Если ОбщегоНазначения.МодульТриггерныеСобытияСуществует() Тогда
	//		ОбщегоНазначения.ПолучитьМодульТриггерныеСобытия().ЗарегистрироватьСменуСтатусовКлиентов(ТаблицаУстановленныхСтатусов);
	//	КонецЕсли;	
	//КонецЕсли;
	
КонецПроцедуры

// Процедура - Актуализировать статус пациента
//
// Параметры:
//  Контрагент					 - 	 - 
//  ПриемИсключение				 - 	 - 
//  ИспользоватьБизнесЛогику	 - 	 - 
//  ИспользоватьБлокировкуЗаписи - 	 - 
//
Процедура АктуализироватьСтатусПациента(Знач Контрагент
										, ПриемИсключение 				= Неопределено
										, ИспользоватьБизнесЛогику 		= Ложь
										, ИспользоватьБлокировкуЗаписи 	= Ложь) Экспорт
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Контрагент"					, Контрагент);
	СтруктураПараметров.Вставить("ПриемИсключение"				, ПриемИсключение);
	СтруктураПараметров.Вставить("ИспользоватьБизнесЛогику"		, ИспользоватьБизнесЛогику);
	СтруктураПараметров.Вставить("ИспользоватьБлокировкуЗаписи"	, ИспользоватьБлокировкуЗаписи);	
	СтруктураПараметров.Вставить("Пауза"						, 3); //числовое значение в секундах
	ПараметрыДлительнойОперации = ЗагрузкаПроведениеДокументов.НачатьАктуализациюСтатусаПациента(Строка(Новый УникальныйИдентификатор()), СтруктураПараметров);
		
КонецПроцедуры

// Процедура, выполняет установку статуса контрагента
//
Процедура УстановитьСтатусКонтрагента(СтруктураЗаписи) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СтруктураЗаписи.Период) ИЛИ НЕ ЗначениеЗаполнено(СтруктураЗаписи.Контрагент) Тогда 
		Возврат;
	КонецЕсли;
	
	СрезПоследних = РегистрыСведений.СтатусыКонтрагентов.СрезПоследних(СтруктураЗаписи.Период - 24*60*60, Новый Структура("Контрагент", СтруктураЗаписи.Контрагент));
	
	ЗаписатьСтатус = Ложь;
	Если СрезПоследних.Количество() <> 0 Тогда 
		Если СрезПоследних[0].Статус <> СтруктураЗаписи.Статус Тогда 
			ЗаписатьСтатус = Истина;
		КонецЕсли;
	Иначе 
		ЗаписатьСтатус = Истина;
	КонецЕсли;	
	
	// Удаление старого статуса
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыКонтрагентов.Период КАК Период,
	|	СтатусыКонтрагентов.Контрагент КАК Контрагент
	|ИЗ
	|	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
	|ГДЕ
	|	СтатусыКонтрагентов.Период = &Период
	|	И СтатусыКонтрагентов.Контрагент = &Контрагент";
		
	Запрос.УстановитьПараметр("Период"		, СтруктураЗаписи.Период);
	Запрос.УстановитьПараметр("Контрагент"	, СтруктураЗаписи.Контрагент);
		
	Выборка = Запрос.Выполнить().Выбрать(); 

	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
		НаборЗаписей.Отбор.Контрагент.Установить(Выборка.Контрагент);
		НаборЗаписей.Записать();
	КонецЦикла;	
	
	//  Пишем новый статус
	Если ЗаписатьСтатус Тогда		
		
		НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Контрагент.Установить(СтруктураЗаписи.Контрагент);		
		НаборЗаписей.Отбор.Период.Установить(СтруктураЗаписи.Период);
		НоваяСтрока = НаборЗаписей.Добавить();
		НоваяСтрока.Контрагент         	= СтруктураЗаписи.Контрагент;
		НоваяСтрока.Период             	= СтруктураЗаписи.Период;
		НоваяСтрока.Статус 				= СтруктураЗаписи.Статус;
		НаборЗаписей.Записать();
		
	КонецЕсли;	
	
КонецПроцедуры

// Процедура - Установить статус пациенту
//
// Параметры:
//  Пациент				 - 	 - 
//  Статус				 - 	 -  
//  Период				 - 	 -  
//
Процедура УстановитьСтатусПациенту(Пациент, Статус, Период = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Пациент) ИЛИ НЕ ЗначениеЗаполнено(Статус) Тогда 
		Возврат;
	КонецЕсли;	
		
	Если НЕ ЗначениеЗаполнено(Период) Тогда 
		Период = ТекущаяДатаСеанса();
	КонецЕсли;
	
	НаборЗаписей 						= СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Период.Установить(Период);
	НаборЗаписей.Отбор.Контрагент.Установить(Пациент);		
	
	НоваяСтрока 						= НаборЗаписей.Добавить();
	НоваяСтрока.Период             		= Период;	
	НоваяСтрока.Контрагент         		= Пациент;	
	НоваяСтрока.Статус 					= Статус;
	
	НаборЗаписей.Записать();
		
КонецПроцедуры

// Функция - Статус контрагента
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СтатусКонтрагента(Контрагент) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус
	                      |ИЗ
	                      |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, Контрагент = &Контрагент) КАК СтатусыКонтрагентовСрезПоследних");
						  					  
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Результат = Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		
		Выборка = Результат.Выбрать(); 
		
		Если Выборка.Следующий() Тогда 
			Возврат Выборка.Статус;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Перечисления.СтатусыКонтрагентов.ПустаяСсылка();
	
КонецФункции

// Функция - Это контрагент со статусом отказ
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЭтоКонтрагентСоСтатусомОтказ(Контрагент) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент
	               |ИЗ
	               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, Контрагент = &Контрагент) КАК СтатусыКонтрагентовСрезПоследних
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПродажиСебестоимость.Обороты(, , , Контрагент = &Контрагент) КАК ПродажиСебестоимостьОбороты
	               |		ПО СтатусыКонтрагентовСрезПоследних.Контрагент = ПродажиСебестоимостьОбороты.Контрагент
	               |ГДЕ
	               |	СтатусыКонтрагентовСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ)
	               |	И ЕСТЬNULL(ПродажиСебестоимостьОбороты.КоличествоОборот, 0) = 0";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Возврат НЕ Запрос.Выполнить().Пустой();	
	
КонецФункции

// Процедура - Отфильтровать клиентов со статусом отказ
//
// Параметры:
//  МассивКонтрагентов	 - 	 - 
//
Процедура ОтфильтроватьКлиентовСоСтатусомОтказ(МассивКонтрагентов) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ТаблицаОтказников
	|ИЗ
	|	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, Контрагент В (&МассивКонтрагентов)) КАК СтатусыКонтрагентовСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПродажиСебестоимость.Обороты(, , , Контрагент В (&МассивКонтрагентов)) КАК ПродажиСебестоимостьОбороты
	|		ПО СтатусыКонтрагентовСрезПоследних.Контрагент = ПродажиСебестоимостьОбороты.Контрагент
	|ГДЕ
	|	СтатусыКонтрагентовСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ)
	|	И ЕСТЬNULL(ПродажиСебестоимостьОбороты.КоличествоОборот, 0) = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты.Ссылка КАК Контрагент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка В(&МассивКонтрагентов)
	|	И НЕ Контрагенты.Ссылка В
	|				(ВЫБРАТЬ
	|					ТаблицаОтказников.Контрагент
	|				ИЗ
	|					ТаблицаОтказников)");
	
	Запрос.УстановитьПараметр("МассивКонтрагентов", МассивКонтрагентов);
	
	МассивКонтрагентов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Контрагент");	
	
КонецПроцедуры

