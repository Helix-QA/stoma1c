
#Область СлужебныеПроцедурыИФункции

&НаСервере
// Функция помещает результаты подбора в хранилище
Функция ЗаписатьПодборВХранилище() 
	
	Для каждого СтрокаЗагрузки Из ОтобранныеЗапасы Цикл
		
		// СтрокаЗагрузки.КоличествоУпаковок	= СтрокаЗагрузки.КоличествоУпаковок;
		СтрокаЗагрузки.Количество 			= СтрокаЗагрузки.КоличествоУпаковок * ?(Не СтрокаЗагрузки.Упаковка.Пустая(), СтрокаЗагрузки.Упаковка.Коэффициент, 1);		
		
		Если ИспользуютсяЦены ИЛИ ИспользуютсяСкидкиНаценки Тогда			
			
			СтруктураДанные = Новый Структура;
			СтруктураДанные.Вставить("ДатаОбработки", 		Период);
			СтруктураДанные.Вставить("СтруктурнаяЕдиница",	СтруктурнаяЕдиница);
			СтруктураДанные.Вставить("ВидЦен", 				ВидЦен);
			СтруктураДанные.Вставить("Номенклатура", 		СтрокаЗагрузки.Номенклатура);
			СтруктураДанные.Вставить("Коэффициент", 		?(Не СтрокаЗагрузки.Упаковка.Пустая(), СтрокаЗагрузки.Упаковка.Коэффициент, 1));
			СтруктураДанные.Вставить("СтавкаНДС", 			СтрокаЗагрузки.СтавкаНДС);			
			СтруктураДанные.Вставить("Упаковка", 			СтрокаЗагрузки.Упаковка);
			СтруктураДанные.Вставить("Сотрудник", 			?(ЗначениеЗаполнено(СтрокаЗагрузки.Сотрудник), СтрокаЗагрузки.Сотрудник, СотрудникПоУмолчанию));
			
			Если НЕ ЗначениеЗаполнено(СтрокаЗагрузки.Цена) Тогда
				СтрокаЗагрузки.Цена 			= Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураДанные);
			КонецЕсли;
			СтрокаЗагрузки.СтавкаНДС 			= СтрокаЗагрузки.СтавкаНДС;
			СтрокаЗагрузки.Сумма 				= СтрокаЗагрузки.КоличествоУпаковок * СтрокаЗагрузки.Цена;
			СтрокаЗагрузки.Сумма 				= СтрокаЗагрузки.Сумма - (СтрокаЗагрузки.Сумма * СтрокаЗагрузки.ПроцентСкидкиНаценки / 100) - СтрокаЗагрузки.СуммаАвтоматическойСкидкиНаценки;
			СтрокаЗагрузки.СуммаНДС 			= Ценообразование.РассчитатьСуммуНДС(СтрокаЗагрузки.Сумма, СтрокаЗагрузки.СтавкаНДС);
			СтрокаЗагрузки.Всего 				= СтрокаЗагрузки.Сумма;
			СтрокаЗагрузки.Бесплатно            = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаЗагрузки.Номенклатура, "Бесплатно");
			
		КонецЕсли;
		
	КонецЦикла; 
	
	Возврат ПоместитьВоВременноеХранилище(ОтобранныеЗапасы.Выгрузить(), Новый УникальныйИдентификатор);
	
КонецФункции

&НаСервереБезКонтекста
// Получает набор данных с сервера для процедуры НоменклатураПриИзменении.
//
Функция ПолучитьУпаковкуНоменклатуры(Номенклатура)
	
	Возврат ?(Номенклатура <> Неопределено, Номенклатура.УпаковкаДляОтчета, Справочники.УпаковкиНоменклатуры.ПустаяСсылка());
	
КонецФункции // ПолучитьДанныеНоменклатураПриИзменении()

&НаКлиенте
// Процедура обновляет дерево номенклатуры.
//
Процедура ОбновитьСписокНоменклатуры()
	
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("Склад", Склад);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ВидЦен", ВидЦен);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("НаДату", Период);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("Группа", Группа);
	Если ЗначениеЗаполнено(ТипНоменклатуры) Тогда
		МассивТипНоменклатуры = Новый Массив;
		Для каждого ЭлементТипНоменклатуры Из ТипНоменклатуры Цикл
			МассивТипНоменклатуры.Добавить(ЭлементТипНоменклатуры.Значение);	
		КонецЦикла;
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ТипНоменклатуры", МассивТипНоменклатуры);
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("НетТипаНоменклатуры", Ложь);
	Иначе	
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ТипНоменклатуры", Новый Массив);
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("НетТипаНоменклатуры", Истина);
	КонецЕсли;
	
КонецПроцедуры	

 #КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)          
	
	Период = ?(Параметры.Свойство("Период"), Параметры.Период, ТекущаяДата());	
	СтруктурнаяЕдиница 			= Параметры.СтруктурнаяЕдиница;
	НазваниеСтруктурнойЕдиницы  = " "+Параметры.СтруктурнаяЕдиница;
	
	Если Параметры.Свойство("АдресЗапасовДокумента") Тогда
		ТаблицаЗапасов = ПолучитьИзВременногоХранилища(Параметры.АдресЗапасовДокумента);
		ИспользуетсяНДС = (ТаблицаЗапасов.Колонки.Найти("СтавкаНДС") <> Неопределено);
		Для каждого СтрокаТЧ Из ТаблицаЗапасов Цикл
			НоваяСтрока = ОтобранныеЗапасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			НоваяСтрока.ИспользуютсяХарактеристики = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "ИспользоватьПартии");
			НоваяСтрока.ЭтоСертификат              = (ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "ТипНоменклатуры")=ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат"));
			НоваяСтрока.Бесплатно = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(НоваяСтрока.Номенклатура, "Бесплатно");			
			Если ТаблицаЗапасов.Колонки.Найти("Сотрудник") <> Неопределено И Не ЗначениеЗаполнено(СотрудникПоУмолчанию) Тогда
				СотрудникПоУмолчанию = СтрокаТЧ.Сотрудник;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли; 
	
	Если Параметры.Свойство("Склад") Тогда
		Склад 					= Параметры.Склад;
	КонецЕсли;
	
	Если Параметры.Свойство("Сотрудник") Тогда
		СотрудникПоУмолчанию	= Параметры.Сотрудник;
		СегментНоменклатуры = ПолучитьСегментСотрудника();
	КонецЕсли;
	
	Если Параметры.Свойство("ТипНоменклатуры") Тогда
		Если ЗначениеЗаполнено(Параметры.ТипНоменклатуры)  Тогда			
			ТипНоменклатуры = Параметры.ТипНоменклатуры;
			
			МассивТипНоменклатуры = Новый Массив();
			Для каждого ЭлементТипНоменклатуры Из ТипНоменклатуры Цикл
				МассивТипНоменклатуры.Добавить(ЭлементТипНоменклатуры.Значение);
			КонецЦикла; 
			МассивОграниченияТипНоменклатуры = Новый ФиксированныйМассив(МассивТипНоменклатуры);
			НовыйПараметр 	= Новый ПараметрВыбора("Отбор.ТипНоменклатуры", МассивОграниченияТипНоменклатуры);
			НовыйМассив 	= Новый Массив();
			НовыйМассив.Добавить(НовыйПараметр);
			НовыеПараметры 	= Новый ФиксированныйМассив(НовыйМассив);
			Элементы.ОтобранныеЗапасыНоменклатура.ПараметрыВыбора = НовыеПараметры;			
		Иначе		
			ТипНоменклатуры = Неопределено;
		КонецЕсли;
	Иначе		
		ТипНоменклатуры = Неопределено;
	КонецЕсли;
	
	Если Параметры.Свойство("ВидЦен") И ЗначениеЗаполнено(Параметры.ВидЦен) Тогда
		ИспользуютсяЦены 		= Истина;
		ВидЦен 					= Параметры.ВидЦен;
	КонецЕсли;	
	
	Если Параметры.Свойство("СтавкаНДС") Тогда
		СтавкаНДСПриоритет 		= Параметры.СтавкаНДС;
	КонецЕсли;	
	
	Если Параметры.Свойство("ПодборДляПоступленияНаСклад") Тогда
		ПодборДляПоступленияНаСклад = Истина;
	КонецЕсли;	
	
	Группа = Справочники.Номенклатура.ПустаяСсылка();	
	ИспользуютсяПартии = Истина;	
	
	Если Параметры.Свойство("ЭтоЧек") и ЗначениеЗаполнено(СегментНоменклатуры) Тогда
		Отбор = Истина;		
	КонецЕсли;
	
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("Отбор", Отбор);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("СегментНоменклатуры", СегментНоменклатуры);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("Склад", Склад);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ВидЦен", ВидЦен);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("НаДату", Период);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("Группа", Группа);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ПоискАктивен", Ложь);
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("СтрокаПоиска", "");
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ПодчиненныеЭлементы", Истина);
	Если ЗначениеЗаполнено(ТипНоменклатуры) Тогда 		
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ТипНоменклатуры", МассивТипНоменклатуры);
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("НетТипаНоменклатуры", Ложь);
	Иначе	
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ТипНоменклатуры", Новый Массив);
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("НетТипаНоменклатуры", Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, возвращает сегмент сотрудника
//
Функция ПолучитьСегментСотрудника()
	Запрос = Новый ЗАпрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.СегментыНоменклатуры
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.Сотрудник = &Сотрудник
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
	Запрос.УстановитьПараметр("Сотрудник", СотрудникПоУмолчанию);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда
		Возврат Результат[0].СегментыНоменклатуры;
	КонецЕсли;                                    	
	
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// МеханизмВнешнегоОборудования
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";
		
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	// Конец МеханизмВнешнегоОборудования 
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик нажатия кнопки ОК.
//
Процедура ОК(Команда)
	Закрыть(ЗаписатьПодборВХранилище());
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик нажатия кнопки Обновить.
//
Процедура Обновить(Команда)
	ОбновитьСписокНоменклатуры();
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ОбработкаВыбора ТЧ ЗапасыИерархия.
//
Процедура ЗапасыИерархияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Группа = ВыбранноеЗначение;
	ОбновитьСписокНоменклатуры();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриСменеТекущегоРодителя ТЧ ЗапасыИерархия.
//
Процедура ЗапасыИерархияПриСменеТекущегоРодителя(Элемент)
	
	Группа = Элемент.ТекущийРодитель;
	ОбновитьСписокНоменклатуры();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события Выбор списка товаров.
//
Процедура СписокТоваровВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущаяСтрока = Элемент.ТекущиеДанные;	
	
	КоличествоУпаковок = 1;
	Упаковка = ПолучитьУпаковкуНоменклатуры(Неопределено);
	
	МассивНоменклатуры = Новый Массив;
	МассивНоменклатуры.Добавить(ТекущаяСтрока);
	
	// Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Элемент.ТекущиеДанные.Номенклатура, "ИспользоватьПартии") и ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Элемент.ТекущиеДанные.Номенклатура, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат") Тогда
	
	ЕстьПартии = ПроверкаНаличияПартий(Элемент.ТекущиеДанные.Номенклатура);
	
	Если ЕстьПартии Тогда
		ЗначениеОтбора = Новый Структура("Владелец", Элемент.ТекущиеДанные.Номенклатура);
		ПараметрыВыбораСписка = Новый Структура("Отбор", ЗначениеОтбора);
		ПараметрыВыбораСписка.Вставить("Владелец", Элемент.ТекущиеДанные.Номенклатура);
		ПараметрыВыбораСписка.Вставить("Склад", Склад);
		ПараметрыВыбораСписка.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
		ПараметрыВыбораСписка.Вставить("Дата", Период);
		ПараметрыВыбораСписка.Вставить("МножественныйВыбор", Ложь);
		Если ПодборДляПоступленияНаСклад Тогда
			ПараметрыВыбораСписка.Вставить("ОтборПоПартиям", Истина);
		Иначе
			ПараметрыВыбораСписка.Вставить("Фильтр", Истина);
		КонецЕсли;

		ОписаниеОповещения = Новый ОписаниеОповещения("СписокТоваровВыборФрагмент", ЭтотОбъект, Новый Структура("ЕстьПартии,Упаковка, ТекущаяСтрока, Элемент", ЕстьПартии, Упаковка, ТекущаяСтрока, Элемент));
		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", ПараметрыВыбораСписка,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
        Возврат;
	КонецЕсли;
	
	СписокТоваровВыборЗавершение(ЕстьПартии, Упаковка, МассивНоменклатуры, ТекущаяСтрока, Элемент);   
	
КонецПроцедуры

&НаКлиенте
Процедура СписокТоваровВыборФрагмент(Результат, ДополнительныеПараметры) Экспорт
	
	ЕстьПартии = ДополнительныеПараметры.ЕстьПартии;
	ТекущаяСтрока = ДополнительныеПараметры.ТекущаяСтрока;
	Элемент = ДополнительныеПараметры.Элемент;
    Упаковка = ДополнительныеПараметры.Упаковка;

	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		МассивНоменклатуры = Результат;
	ИначеЕсли НЕ Результат = Неопределено Тогда
		МассивНоменклатуры.Очистить();
		МассивНоменклатуры.Добавить(Результат);
	Иначе
		Возврат;
	КонецЕсли;
	
	СписокТоваровВыборЗавершение(ЕстьПартии, Упаковка, МассивНоменклатуры, ТекущаяСтрока, Элемент);

КонецПроцедуры

&НаКлиенте
Процедура СписокТоваровВыборЗавершение(Знач ЕстьПартии, Знач Упаковка, МассивНоменклатуры, ТекущаяСтрока, Знач Элемент)
		
	КоличествоУпаковок = 1;
	
	ОтфильтрованныйМассивНоменклатуры = Новый Массив; 
	
	Для Каждого ЭлементМассива Из МассивНоменклатуры Цикл
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Партия", ЭлементМассива);
		НайденныеСтроки = ОтобранныеЗапасы.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеСтроки.Количество() > 0 Тогда		
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Серийный номер "+ Строка(ЭлементМассива) + " уже был указан в документе!");	
		Иначе
			ОтфильтрованныйМассивНоменклатуры.Добавить(ЭлементМассива);
		КонецЕсли;
	КонецЦикла;
	
	МассивНоменклатуры = ОтфильтрованныйМассивНоменклатуры;  		
	Если ЗапрашиватьКоличество И НЕ ПроверкаНаличияПартий(Элемент.ТекущиеДанные.Номенклатура) Тогда 
		ОписаниеОповещения = Новый ОписаниеОповещения("СписокТоваровВыборКоличестваУпаковок", ЭтотОбъект, Новый Структура("ЕстьПартии, МассивНоменклатуры, Элемент", ЕстьПартии, МассивНоменклатуры, Элемент));
		ОткрытьФорму("ОбщаяФорма.ВыборКоличествоУпаковка", Новый Структура("Номенклатура", ТекущаяСтрока.Номенклатура),,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
        Возврат;
	КонецЕсли;
	
	СписокТоваровВыборКоличестваУпаковокЗавершение(ЕстьПартии, КоличествоУпаковок, МассивНоменклатуры, Упаковка, Элемент);
КонецПроцедуры

&НаКлиенте
Процедура СписокТоваровВыборКоличестваУпаковок(Результат, ДополнительныеПараметры) Экспорт
	
	ЕстьПартии = ДополнительныеПараметры.ЕстьПартии;
	МассивНоменклатуры = ДополнительныеПараметры.МассивНоменклатуры;
	Элемент = ДополнительныеПараметры.Элемент;
	
	АдресПараметров = Результат;
	Попытка 
		ТаблицаПараметров = ПолучитьИзВременногоХранилища(АдресПараметров);
		КоличествоУпаковок = ТаблицаПараметров.Количество;
		Упаковка = ТаблицаПараметров.Упаковка;
	Исключение
		Возврат;
	КонецПопытки;
	
	СписокТоваровВыборКоличестваУпаковокЗавершение(ЕстьПартии, КоличествоУпаковок, МассивНоменклатуры, Упаковка, Элемент);

КонецПроцедуры

&НаКлиенте
Процедура СписокТоваровВыборКоличестваУпаковокЗавершение(Знач ЕстьПартии, Знач КоличествоУпаковок, Знач МассивНоменклатуры, Упаковка, Знач Элемент)
	
	Для Каждого ЭлементМ из МассивНоменклатуры Цикл
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура", ?(ЕстьПартии, Элемент.ТекущиеДанные.Номенклатура, ЭлементМ.Номенклатура));		
		Если Не ЗначениеЗаполнено(Упаковка) Тогда
			Упаковка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктураОтбора.Номенклатура, "УпаковкаПоуМолчанию");
		КонецЕсли; 		
		СтруктураОтбора.Вставить("Упаковка", Упаковка);
		Если ЕстьПартии Тогда
			СтруктураОтбора.Вставить("Партия", ЭлементМ);
		КонецЕсли;
		
		Если ИспользуетсяНДС Тогда 
			СтруктураОтбора.Вставить("СтавкаНДС", ПолучитьСтавкуНДСНоменклатуры(Элемент.ТекущиеДанные.Номенклатура, СтруктурнаяЕдиница)); // Элемент.ТекущиеДанные.СтавкаНДС);
		КонецЕсли;
		
		Строки = ОтобранныеЗапасы.НайтиСтроки(СтруктураОтбора);
		
		Если ПроверитьПрименениеВидовНалов(?(ЕстьПартии, Элемент.ТекущиеДанные.Номенклатура, ЭлементМ.Номенклатура)) Тогда
			Возврат;
		КонецЕсли;
		
		Если Строки.Количество() > 0 Тогда
			Строки[0].КоличествоУпаковок 			= Строки[0].КоличествоУпаковок + КоличествоУпаковок;
			Элементы.ОтобранныеЗапасы.ТекущаяСтрока = Строки[0].ПолучитьИдентификатор();
		Иначе 
			НоваяСтрока 					= ОтобранныеЗапасы.Добавить();
			НоваяСтрока.Номенклатура 		= ?(ЕстьПартии, Элемент.ТекущиеДанные.Номенклатура, ЭлементМ.Номенклатура);
			НоваяСтрока.КоличествоУпаковок	= КоличествоУпаковок;  						    			
			НоваяСтрока.Упаковка			= Упаковка;
			НоваяСтрока.Сотрудник			= СотрудникПоУмолчанию;
			
			Если ЗначениеЗаполнено(Упаковка) Тогда
				НоваяСтрока.Цена = ПолучитьЦенуНоменклатуры(НоваяСтрока);
			Иначе
				НоваяСтрока.Цена = Элемент.ТекущиеДанные.Цена;
			КонецЕсли;
			
			Если ЕстьПартии Тогда
				НоваяСтрока.Партия = ЭлементМ;
			КонецЕсли;	
			НоваяСтрока.ИспользуютсяХарактеристики	= ПроверкаНаличияПартий(НоваяСтрока.Номенклатура);
			НоваяСтрока.ЭтоСертификат              	= (ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(НоваяСтрока.Номенклатура, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат"));
			
			Если ЗначениеЗаполнено(СтавкаНДСПриоритет) Тогда
				НоваяСтрока.СтавкаНДС = СтавкаНДСПриоритет;
			Иначе
				НоваяСтрока.СтавкаНДС = ПолучитьСтавкуНДСНоменклатуры(Элемент.ТекущиеДанные.Номенклатура, СтруктурнаяЕдиница); // Элемент.ТекущиеДанные.СтавкаНДС;
			КонецЕсли;	
			
			Элементы.ОтобранныеЗапасы.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
			НоваяСтрока.Бесплатно = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(НоваяСтрока.Номенклатура, "Бесплатно");
			
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
// Функция, проверяет приминение налогов.
//
Функция ПроверитьПрименениеВидовНалов(Номенклатура)
	
	Отказ = Ложь;
	
	Если ОтобранныеЗапасы.Количество() > 0 Тогда
		ВидНалога = ПолучитьВидНалогаНоменклатуры(ОтобранныеЗапасы[0].Номенклатура, СтруктурнаяЕдиница); // ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОтобранныеЗапасы[0].Номенклатура, "ВидНалога");
		Если НЕ ВидНалога = ПолучитьВидНалогаНоменклатуры(Номенклатура, СтруктурнаяЕдиница) Тогда // ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Номенклатура, "ВидНалога") Тогда
			ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения. Номенклатура '%1' и '%2' используют разные режимы налогообложения";
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ОтобранныеЗапасы[0].Номенклатура, Номенклатура);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Отказ = Истина
		КонецЕсли;	
	КонецЕсли;				
	
	Возврат Отказ;
	
КонецФункции

