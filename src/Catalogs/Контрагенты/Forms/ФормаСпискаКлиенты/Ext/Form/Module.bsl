
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Пользователь = ПараметрыСеанса.ТекущийПользователь;
	АктивироватьПапкуКлиентаПоУмолчанию();	
	РаботаСОтборами.ВосстановитьНастройкиОтборов(ЭтотОбъект, Список,,,,, Ложь);		
	ИмяКлючаОбъекта = СтрЗаменить(ИмяФормы, ".", "");
  	СохраненноеЗначениеЭлектроннаяКарта = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(ИмяКлючаОбъекта, ИмяКлючаОбъекта + "_ОтборЭлектроннаяКарта");	
	Если ЗначениеЗаполнено(СохраненноеЗначениеЭлектроннаяКарта) Тогда 
		ОтборЭлектроннаяКарта = СохраненноеЗначениеЭлектроннаяКарта;
	КонецЕсли;
	
	ПредставлениеДатаРегистрации = РаботаСОтборами.ОбновитьПредставлениеПериода(ОтборДатаРегистрации, "Дата регистрации: ");
	ПредставлениеДатаПриема      = РаботаСОтборами.ОбновитьПредставлениеПериода(ОтборДатаПриема, "Дата приема: ");

	Элементы.ОтборТелефон.СписокВыбора.Добавить("Заполнен телефон"   , "Заполнен телефон");
	Элементы.ОтборТелефон.СписокВыбора.Добавить("Не заполнен телефон", "Не заполнен телефон");	
	ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
		
	ОтборыЗаполнены = (ДанныеМеток.Количество() <> 0
		Или ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала) 
		Или ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания) 
		Или ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастОт)
		Или ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастДо)
		Или ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаНачала)
		Или ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаОкончания)
		Или ЗначениеЗаполнено(ЭтотОбъект.ОтборТелефон)
		Или ЭтотОбъект.ОтборЭлектроннаяКарта = Истина);
		
	УстановитьЗапросДинамическогоСписка(ОтборыЗаполнены);  
	// СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Справочники.Контрагенты, НастройкиЗагрузкиДанных, ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника

КонецПроцедуры

