// Процедура - Установить видимость и заголовки.
//
Процедура УстановитьВидимостьИЗаголовки()
	
	//Элементы.УслугиБезСогласования.Видимость = ЗначениеЗаполнено(Объект.Контрагент) 
	//	И Объект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания; 
	//Элементы.УслугиПоСогласованию.Видимость = Элементы.УслугиБезСогласования.Видимость;
	
	ТипКонтрагента = Объект.Контрагент.ТипКонтрагента;
	
	Элементы.ГруппаСтраховойКомпании.Видимость = (ЗначениеЗаполнено(Объект.Контрагент) 
	И ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания);
	
	Если ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания Тогда
		СтрокаТипКонтрагента = "страховой компанией";
		ЗаголовокЭлементаКонтрагенты = "Страховая компания";
	ИначеЕсли ТипКонтрагента = Перечисления.ТипыКонтрагентов.Поставщик Тогда
		СтрокаТипКонтрагента = "поставщиком";
		ЗаголовокЭлементаКонтрагенты = "Поставщик";
	ИначеЕсли ТипКонтрагента = Перечисления.ТипыКонтрагентов.Лаборатория Тогда
		СтрокаТипКонтрагента = "лабораторией";
		ЗаголовокЭлементаКонтрагенты = "Лаборатория";
	Иначе
		СтрокаТипКонтрагента = "контрагентом";
		ЗаголовокЭлементаКонтрагенты = "Контрагент";
	КонецЕсли;	

	Если ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания И ЗначениеЗаполнено(Объект.Контрагент.КраткоеНаименование) Тогда
		Элементы.ГруппаАльфа.Видимость = Истина;
		ФонМетки = ?(ЗначениеЗаполнено(Объект.Контрагент.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(Объект.Контрагент.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
		Элементы.ДекорацияАльфа.ЦветТекста  = ?(Объект.Контрагент.ЦветТекстаБелый, Новый Цвет(255,255,255), Новый Цвет(77,77,77));
		Элементы.ДекорацияАльфа.Заголовок	= Объект.Контрагент.КраткоеНаименование;
		Элементы.ГруппаАльфа.ЦветФона  = ФонМетки; 
	Иначе
		Элементы.ГруппаАльфа.Видимость = Ложь;
	КонецЕсли;
	
	ЭтаФорма.Заголовок = "Договор с "+ СтрокаТипКонтрагента;
	Элементы.Контрагент.Заголовок = ЗаголовокЭлементаКонтрагенты; 
	
КонецПроцедуры

