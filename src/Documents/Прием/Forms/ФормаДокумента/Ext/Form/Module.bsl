// Функция, Получить комментарий визита
//
// Параметры:
//  ОценкиСотрудника - 	 - 
//  Период			 - 	 - 
//  Визит			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКомментарийСотрудника(ОценкиСотрудника, Период, Сотрудник)
	
	КомментарииПриема = ОценкиСотрудника.НайтиСтроки(Новый Структура("Период, Сотрудник", Период, Сотрудник));
	Комментарий       = "";
	
	Для Каждого СтрокаТ Из КомментарииПриема Цикл 
		
		Если Не ЗначениеЗаполнено(СтрНайти(Комментарий, СтрокаТ.Комментарий)) Тогда 
			
			Комментарий = Комментарий + ?(ЗначениеЗаполнено(Комментарий), ", ", "") + СтрокаТ.Комментарий;   
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Комментарий;
	
КонецФункции

