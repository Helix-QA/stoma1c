#Область ОбработчикиСобытийЭквайринговыхТерминаловИСекций

&НаКлиенте
// Процедура, обработчик команды ОткрытьЭквайринговыйТерминал
//
Процедура ОткрытьЭквайринговыйТерминал(Команда)
	
	Ид = ИдентификаторЭлемента(ТекущийЭлемент.Имя);
	ДанныеЭлемента = Объект.ЭквайринговыеТерминалы.НайтиПоИдентификатору(Ид);
	Если ДанныеЭлемента = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если ДанныеЭлемента.Основной Тогда 
		ПоказатьЗначение(,ДанныеЭлемента.ЭквайринговыйТерминал);
	Иначе 
		СписокВариантов = Новый СписокЗначений;
		СписокВариантов.Добавить(0, Нстр("ru = 'Открыть'; en = 'Open'"));
		СписокВариантов.Добавить(1, Нстр("ru = 'Назначить основным'; en = 'Set as main'"));
		ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВариантаДействияСЭквайрингом", ЭтаФорма, ДанныеЭлемента);
		ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокВариантов, ТекущийЭлемент);
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор варианта действия с кассой
//
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборВариантаДействияСЭквайрингом(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда 
		Возврат;
	ИначеЕсли ВыбранныйЭлемент.Значение = 0 Тогда 	
		ПоказатьЗначение(,ДополнительныеПараметры.ЭквайринговыйТерминал);
	ИначеЕсли ВыбранныйЭлемент.Значение = 1 Тогда
		// Сброс по всем строкам
		Для Каждого СтрокаТ ИЗ Объект.ЭквайринговыеТерминалы Цикл
			
			СтрокаТ.Основной = СтрокаТ.ЭквайринговыйТерминал = ДополнительныеПараметры.ЭквайринговыйТерминал;
			ИД = СтрокаТ.ПолучитьИдентификатор();
			ЭквайрингНаФорме = Элементы.Найти("ЭквайринговыйТерминал_" + ИД);
			
			Если ЭквайрингНаФорме <> Неопределено Тогда 
				  ЭквайрингНаФорме.Шрифт = Новый Шрифт(,,СтрокаТ.Основной,,,,);
			КонецЕсли;
			
		КонецЦикла;
		Объект.ЭквайринговыйТерминал = ДополнительныеПараметры.ЭквайринговыйТерминал;
        Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте  
