// Процедура, Подключаемый удалить строку табличной части.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_УдалитьСтрокуТабличнойЧасти(Элемент) Экспорт
	
	Если Объект.Услуги.Количество() > 1 Тогда
		
		// Получим всю информацию по удаляемой строке
		СтруктураДанныхЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Элемент);
		
		Если СтруктураДанныхЭлемента.ДанныеЭлемента <> Неопределено Тогда
			
			СтароеВремяПриема = 0;
			Для СтрокаУслуги = 1 по Объект.Услуги.Количество() Цикл
				СтароеВремяПриема = СтароеВремяПриема + Объект.Услуги[СтрокаУслуги-1].НормаВремени;	
			КонецЦикла;
			
			УдалитьСтрокуТабличнойЧастиНаСервере(СтруктураДанныхЭлемента.ИндексСтроки);
			ЭтаФорма.Модифицированность = Истина;
			
			// Меняем выделяемые элемент в шкале длительности
			
			// ИзменитьЭлементДлительностиПриема(Число(СтароеВремяПриема - Число(СтруктураДанныхЭлемента.ДанныеЭлемента.НормаВремени)), Число(СтароеВремяПриема));
			
			
			УдалитьЭтуДлительностьПриема("УдалитьСтрокуТЧ");
			
			
		КонецЕсли;
		
	Иначе
		Элементы.ГруппаУслугПолями.Видимость = Ложь;
		Элементы.ГруппаКнопкаДобавитьУслуги.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, Удалить строку табличной части на сервере.
//
// Параметры:
//  ИмяТаблицы	 - 	 - 
//  ИндексСтроки - 	 - 
//
Процедура УдалитьСтрокуТабличнойЧастиНаСервере(ИндексСтроки)
	
	Объект.Услуги.Удалить(ИндексСтроки);
	
	// Если удалили последнюю строчку - сразу добавляем новую
	Если Объект.Услуги.Количество() = 0 Тогда
		Объект.Услуги.Добавить();
	КонецЕсли;
	
	ПредыдущаяСтрока = Неопределено;
	ВремяОжидания = 0;
	Для Каждого СтрокаУслуга Из Объект.Услуги Цикл
		
		Если ПредыдущаяСтрока = Неопределено Тогда
			
			Если СтрокаУслуга.ДатаНачала = Дата(1, 1, 1) ИЛИ СтрокаУслуга.ДатаНачала = НачалоДня(ЭтотОбъект.ДатаНачала) Тогда
				СтрокаУслуга.ДатаНачала = ЭтотОбъект.ДатаНачала;
			ИначеЕсли НЕ НачалоДня(СтрокаУслуга.ДатаНачала) = НачалоДня(ЭтотОбъект.ДатаНачала) Тогда
				ИзмененаДатаВизита = Истина;
				СтрокаУслуга.ДатаНачала = НачалоДня(ЭтотОбъект.ДатаНачала) + Час(СтрокаУслуга.ДатаНачала) * 3600 + Минута(СтрокаУслуга.ДатаНачала) * 60;
			КонецЕсли;
			
		Иначе// Если СтрокаУслуга.Сотрудник = ПредыдущаяСтрока.Сотрудник Тогда
			СтрокаУслуга.ДатаНачала = ПредыдущаяСтрока.ДатаНачала + (ПредыдущаяСтрока.НормаВремени * 60);//?(ПредыдущаяСтрока.ДатаНачала + (ПредыдущаяСтрока.НормаВремени * 60) > СтрокаУслуга.ДатаНачала, ПредыдущаяСтрока.ДатаНачала + (ПредыдущаяСтрока.НормаВремени * 60), СтрокаУслуга.ДатаНачала);
			ВремяОжидания = ВремяОжидания + Цел((СтрокаУслуга.ДатаНачала - ПредыдущаяСтрока.ДатаОкончания) / 60);
		КонецЕсли;

		ПредыдущаяСтрока = СтрокаУслуга;

	КонецЦикла;
	
	Если Объект.Услуги.Количество() > 1 Тогда
		ДатаНачала = Объект.Услуги[0].ДатаНачала;
		ДатаОкончания = Объект.Услуги[Объект.Услуги.Количество() - 1 - 1].ДатаОкончания;	
	КонецЕсли;
	
	СоздатьДинамическиеЭлементыГруппыЗапись();
	
	УстановитьНормуВремени();
	
КонецПроцедуры

