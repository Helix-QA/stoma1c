&НаКлиенте
// Процедура - Подключаемый аккаунт сообщений мессенджера поле при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_АккаунтСообщенийМессенджера_Поле_ПриИзменении(Элемент)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаНастройкиДействийТриггерногоСобытия(ЭтотОбъект, Элемент, , "МоделируемыеНастройкиКаналовУведомлений");
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		УстановитьСвойстваЭлементамАккаунтаСообщения(, СтруктураДанныеЭлемента.ИндексСтроки);
		Если ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.АккаунтВнешнейСистемы) Тогда 
			ТипВнешнейСистемы = Неопределено;
			Для Каждого СтрокаВнешняяСистема Из ТаблицаВнешнихСистем Цикл 
				Если СтрокаВнешняяСистема.Ссылка = СтруктураДанныеЭлемента.ДанныеЭлемента.АккаунтВнешнейСистемы Тогда 
					ТипВнешнейСистемы = СтрокаВнешняяСистема.ТипВнешнейСистемы;
					Прервать;
				КонецЕсли;				
			КонецЦикла;	
			Если НЕ ЗначениеЗаполнено(ТипВнешнейСистемы) Тогда 
				ТипВнешнейСистемы = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктураДанныеЭлемента.ДанныеЭлемента.АккаунтВнешнейСистемы, "ТипВнешнейСистемы");
			КонецЕсли;
			Если ТипВнешнейСистемы = ПредопределенноеЗначение("Перечисление.ТипыВнешнихСистем.Chat2Desk") Тогда 
				ЭлементФормы = Элементы.Найти("КаналСистемыСообщений_Индекс_" + Строка(СтруктураДанныеЭлемента.ИндексСтроки));
				Если НЕ ЭлементФормы = Неопределено Тогда 			
					ЭтаФорма.ТекущийЭлемент = ЭлементФормы;		
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

