// Функция, возвращает секцию номенклатуры.
//
Функция ПолучитьСекциюНоменклатуры(Номенклатура, Касса) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Касса"		, Касса);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КассыСекции.НомерСекции
	|ИЗ
	|	Справочник.Кассы.Секции КАК КассыСекции
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|		ПО КассыСекции.СегментНоменклатуры = НоменклатураСегмента.Сегмент
	|ГДЕ
	|	КассыСекции.Ссылка = &Касса
	|	И НоменклатураСегмента.Номенклатура = &Номенклатура";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.НомерСекции, 1);
	
КонецФункции

// Функция - Вернуть доступные кассы по структурным единицам.
//
// Параметры:
//  МассивСтруктурныхЕдиниц	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьДоступныеКассы(МассивСтруктурныхЕдиниц) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Кассы.Ссылка КАК Касса,
	|	ВЫБОР
	|		КОГДА НЕ Кассы.ПометкаУдаления
	|			ТОГДА 1
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК ИндКартинки
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Кассы.ЭтоГруппа = ЛОЖЬ
	|	И Кассы.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)";
	
	Если ЗначениеЗаполнено(МассивСтруктурныхЕдиниц) Тогда
  		Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиниц);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Кассы.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)", "ЛОЖЬ");
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выбрать();
		
КонецФункции

// Функция - Возвращает доступные кассы к оплате в последовательности убывания приоритета.
//
// Параметры:
//  СтруктурнаяЕдиница 	- 	 Справочник.СтруктурныеЕдиницы
//  Организация 		- 	 Справочник.Организации  
//  Сотрудник 		    - 	 Справочник.Сотрудники
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКассыДляОплаты(СтруктурнаяЕдиница, Организация = Неопределено, Сотрудник = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Сотрудник) Тогда 
		Сотрудник = ПараметрыСеанса.ТекущийСотрудник;
	ИначеЕсли ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник,"ЭтоПользовательИБ") = Ложь Тогда 
		Возврат Новый Массив;		
	КонецЕсли; 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СотрудникиДоступныеКассы.Касса КАК Касса
	|ИЗ
	|	Справочник.Сотрудники.ДоступныеКассы КАК СотрудникиДоступныеКассы
	|ГДЕ
	|	СотрудникиДоступныеКассы.Ссылка = &Сотрудник
	|	И СотрудникиДоступныеКассы.Касса.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И СотрудникиДоступныеКассы.Касса.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА &Организация <> НЕОПРЕДЕЛЕНО
	|				ТОГДА СотрудникиДоступныеКассы.Касса.СтруктурнаяЕдиница.Организация = &Организация
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО                                                                                                     
	|	ВЫБОР
	|		КОГДА СотрудникиДоступныеКассы.Основная = ИСТИНА
	|			ТОГДА 1
	|		КОГДА СотрудникиДоступныеКассы.Касса.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И СотрудникиДоступныеКассы.Касса.СтруктурнаяЕдиница.ОсновнаяКасса = СотрудникиДоступныеКассы.Касса
	|			ТОГДА 2
	|		КОГДА СотрудникиДоступныеКассы.Касса.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ТОГДА 3
	|		КОГДА СотрудникиДоступныеКассы.Касса.СтруктурнаяЕдиница.Организация = &Организация
	|			ТОГДА 4
	|	КОНЕЦ");
			
	Запрос.УстановитьПараметр("Сотрудник"		  , Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Организация"		  , ?(ЗначениеЗаполнено(Организация), Организация, Неопределено));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Новый Массив();
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Касса");
		
КонецФункции 

// Функция - получает все кассы по эквайринговому терминалу
//
// Параметры:
//  ЭквайринговыйТерминал - СправочникСсылка "ЭквайринговыйТерминал" 
// 
// Возвращаемое значение:
//   Массив касс 
//
Функция ПолучитьКассуПоЭквайринговомуТерминалу(ЭквайринговыйТерминал) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КассыЭквайринговыеТерминалы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Кассы.ЭквайринговыеТерминалы КАК КассыЭквайринговыеТерминалы
	|ГДЕ
	|	КассыЭквайринговыеТерминалы.ЭквайринговыйТерминал = &ЭквайринговыйТерминал");
	
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Справочники.Кассы.ПустаяСсылка());
	
КонецФункции

// Функция - Получить кассы ссылок на оплату и сбп
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКассыСсылокНаОплатуИСбп(СтруктурнаяЕдиница) Экспорт
		
	МассивТиповБанка = Новый Массив;
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПАльфаБанк);	
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПТинькофф);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПСбербанк);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПСДМ);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	КассыЭквайринговыеТерминалы.Ссылка КАК Касса,
	|	ЛОЖЬ КАК КассаДоступна,
	|	ЛОЖЬ КАК ФРИспользуется,
	|	ИСТИНА КАК ИспользуетсяОнлайн
	|ИЗ
	|	Справочник.Кассы.ЭквайринговыеТерминалы КАК КассыЭквайринговыеТерминалы
	|ГДЕ
	|	КассыЭквайринговыеТерминалы.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И КассыЭквайринговыеТерминалы.ЭквайринговыйТерминал.ПометкаУдаления = ЛОЖЬ
	|	И КассыЭквайринговыеТерминалы.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И КассыЭквайринговыеТерминалы.ЭквайринговыйТерминал.Организация = КассыЭквайринговыеТерминалы.Ссылка.Организация
	|	И (КассыЭквайринговыеТерминалы.ЭквайринговыйТерминал.ИспользоватьОплатуПоСсылке
	|			ИЛИ КассыЭквайринговыеТерминалы.ЭквайринговыйТерминал.ТипБанка В (&МассивТиповБанка))");
		
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("МассивТиповБанка"		, МассивТиповБанка);

	Возврат Запрос.Выполнить().Выгрузить();
		
КонецФункции

// Функция, возвращает кассу оплаты по эквайринговому терминалу.
//
Функция ПолучитьКассуОплатыИПараметрыФискализации(ЭквайринговыйТерминал, ПараметрыФискализации = Неопределено) Экспорт
	
	Переменная_КассовыйСервер = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭквайринговыйТерминал, "КассовыйСервер");
	ПараметрыКассовогоСервера = Неопределено;
	
	Если ЗначениеЗаполнено(Переменная_КассовыйСервер) Тогда
		ПараметрыКассовогоСервера = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Переменная_КассовыйСервер, "Параметры").Получить();
	КонецЕсли;
	
	ОтправлятьВLifePay 		   = Ложь;
	ОтправлятьВCloudKassir	   = Ложь;
	КассовыйСерверИспользуется = Ложь;
	ОтправлятьВCheckbox 	   = Ложь;
	ОтправлятьВЭвотор    	   = Ложь;
	
	Если ЗначениеЗаполнено(Переменная_КассовыйСервер.ДрайверОборудования)
		И Переменная_КассовыйСервер.ДрайверОборудования.ИмяПредопределенныхДанных = "ДрайверLifePayККТ54ФЗ" Тогда
		
		МассивКассОплаты = Справочники.Кассы.ПолучитьКассуПоТерминалуЭквайринга(ЭквайринговыйТерминал);
		КассаОплаты      = ?(ЗначениеЗаполнено(МассивКассОплаты), МассивКассОплаты[0], Неопределено);
		
		ОтправлятьВLifePay = ЗначениеЗаполнено(КассаОплаты);
		
	ИначеЕсли ЗначениеЗаполнено(Переменная_КассовыйСервер.ДрайверОборудования) 
		И Переменная_КассовыйСервер.ДрайверОборудования.ИмяПредопределенныхДанных  = "ДрайверCloudKassirККТ54ФЗ" Тогда
		
		МассивКассОплаты = Справочники.Кассы.ПолучитьКассуПоТерминалуЭквайринга(ЭквайринговыйТерминал);
		КассаОплаты      = ?(ЗначениеЗаполнено(МассивКассОплаты), МассивКассОплаты[0], Неопределено);
		
		ОтправлятьВCloudKassir = ЗначениеЗаполнено(КассаОплаты);
		
	ИначеЕсли ЗначениеЗаполнено(Переменная_КассовыйСервер.ДрайверОборудования) 
		И Переменная_КассовыйСервер.ДрайверОборудования.ИмяПредопределенныхДанных  = "ДрайверCheckboxККТ" Тогда
		
		МассивКассОплаты = Справочники.Кассы.ПолучитьКассуПоТерминалуЭквайринга(ЭквайринговыйТерминал);
		КассаОплаты      = ?(ЗначениеЗаполнено(МассивКассОплаты), МассивКассОплаты[0], Неопределено);
		
		ОтправлятьВCheckbox = ЗначениеЗаполнено(КассаОплаты);
		
	ИначеЕсли ЗначениеЗаполнено(Переменная_КассовыйСервер.ДрайверОборудования)
		И Переменная_КассовыйСервер.ДрайверОборудования.ИмяПредопределенныхДанных = "ДрайверЭвоторККТ54ФЗ" Тогда
		
		МассивКассОплаты = Справочники.Кассы.ПолучитьКассуПоТерминалуЭквайринга(ЭквайринговыйТерминал);
		КассаОплаты      = ?(ЗначениеЗаполнено(МассивКассОплаты), МассивКассОплаты[0], Неопределено);
		
		ОтправлятьВЭвотор = ЗначениеЗаполнено(КассаОплаты);

	ИначеЕсли ТипЗнч(ПараметрыКассовогоСервера) = Тип("Структура") И ПараметрыКассовогоСервера.Свойство("КассаОплаты") Тогда
		
		КассаОплаты 			   = ПараметрыКассовогоСервера.КассаОплаты;
		КассовыйСерверИспользуется = Истина;
		
	Иначе
		МассивКассОплаты = Справочники.Кассы.ПолучитьКассуПоТерминалуЭквайринга(ЭквайринговыйТерминал);
		КассаОплаты      = ?(ЗначениеЗаполнено(МассивКассОплаты), МассивКассОплаты[0], Неопределено);
	КонецЕсли;
	
	ПараметрыФискализации = Новый Структура("ОтправлятьДанныеВLifePay, ОтправлятьДанныеВCloudKassir, КассовыйСерверИспользуется, ОтправлятьДанныеВCheckbox, ОтправлятьДанныеВЭвотор", 
		ОтправлятьВLifePay, ОтправлятьВCloudKassir, КассовыйСерверИспользуется, ОтправлятьВCheckbox, ОтправлятьВЭвотор);
	Возврат КассаОплаты;
	
КонецФункции

// Функция - получает все кассы по эквайринговому терминалу
//
// Параметры:
//  ЭквайринговыйТерминал - СправочникСсылка "ЭквайринговыйТерминал" 
// 
// Возвращаемое значение:
//   Массив касс 
//
Функция ПолучитьКассуПоТерминалуЭквайринга(ЭквайринговыйТерминал) Экспорт
		
	Если ЗначениеЗаполнено(ЭквайринговыйТерминал) Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ЭквайринговыеТерминалыКассы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Кассы.ЭквайринговыеТерминалы КАК ЭквайринговыеТерминалыКассы
		|ГДЕ
		|	ЭквайринговыеТерминалыКассы.Ссылка.ПометкаУдаления = ЛОЖЬ
		|	И ЭквайринговыеТерминалыКассы.ЭквайринговыйТерминал = &ЭквайринговыйТерминал");
				
		Запрос.УстановитьПараметр("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
		Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	Иначе
		Возврат Новый Массив;
	КонецЕсли;
	   		
КонецФункции

#КонецОбласти