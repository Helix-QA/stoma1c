#Область РегситрацияПродуктаИПоддержка

// Процедура - Зарегистрировать программный продукт
// 
функция ЗарегистрироватьПрограммныйПродукт() Экспорт
	
	Попытка
		
		УИД = ПолучитьУИДИнформационнойБазы();		
		Если НЕ ЗначениеЗаполнено(УИД) Тогда		
			УИД = УстановитьУИДИнформационнойБазы();			
		КонецЕсли;
		
		ДатаПервогоЗапуска = Константы.ДатаПервогоВходаВСистему.Получить();	
		Если НЕ ЗначениеЗаполнено(ДатаПервогоЗапуска) Тогда
			ДатаПервогоЗапуска = ТекущаяДата();
		КонецЕсли;
		
		Артикул                = ПолучитьАртикулПродукта();
		КлючЗащитыИспользуется = КлючЗащитыИспользуется();
		
		ПарамтерыЗапроса = Новый Структура("info_base_uid,date_first_launch,security_key_used,vendor_code",
		УИД,
		ДатаПервогоЗапуска,
		КлючЗащитыИспользуется,
		Артикул);
		
		ТекстЗапроса      = СобратьJson(ПарамтерыЗапроса);	
		РезультатЗапроса  = ВыполнитьPOSTЗапрос("products/installation", ТекстЗапроса); 
	    РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);

		// Запись в журнал регистрации
		Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
			ЗаписатьРеквизитВДанныеРегистрационнойАнкеты("ИдентификацияПрограммногоПродуктаВыполнена", Истина);
		КонецЕсли;
		
	Исключение
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

// Функция - Проверить регистрационный номер
// 
// Параметры:
//  РегистрационныйНомер - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПроверитьРегистрационныйНомер(РегистрационныйНомер) Экспорт
	
	Попытка
		
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("registrationnumber", РегистрационныйНомер);		
		ЗаголовкиHTTP.Вставить("vendorcode"        , ПолучитьАртикулПродукта());
		
		РезультатЗапроса  = ВыполнитьGETЗапрос("registration_number/validate", ЗаголовкиHTTP);		
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
		Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
			
			РезультатаОперции.Вставить("ФорматНомераВерен" , РезультатаОперции.ПараметрыРезультата.number_valid);
			РезультатаОперции.Вставить("ОписаниеРезультата", РезультатаОперции.ПараметрыРезультата.description);
			
		КонецЕсли;
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());

	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

// Отправить запрос на RemoteAccessService для регистрации новой анкеты.
// Результат - код ответа и тектс описания резкльтата
Функция ЗарегистрироватьАнкетуПродукта(ПараметрыРегистрации) Экспорт
	
	РезультатаОперции = Неопределено;
	
	Попытка				
		
		СкринАнкетыBase64 = Base64Строка(ПараметрыРегистрации.ПродуктСкринАнкеты);
		
		contact_person = Новый Структура();
		contact_person.Вставить("name" , ПараметрыРегистрации.КонтактноеЛицоИмя);
		contact_person.Вставить("phone", ПараметрыРегистрации.КонтактноеЛицоТелефон);
		contact_person.Вставить("mail" , ПараметрыРегистрации.КонтактноеЛицоПочта);
		
		clinic = Новый Структура();
		clinic.Вставить("type" , ПараметрыРегистрации.КлиникаТип);
		clinic.Вставить("name" , ПараметрыРегистрации.КлиникаНаименование);
		clinic.Вставить("city" , ПараметрыРегистрации.КлиникаГород);
		clinic.Вставить("area" , ПараметрыРегистрации.КлиникаРазмер);
		
		organization = Новый Структура();
		organization.Вставить("name"                   , ПараметрыРегистрации.ОрганизацияНаименование);
		organization.Вставить("address_string"         , ПараметрыРегистрации.ОрганизацияАдресСтрокой);
		organization.Вставить("address_xml"            , ПараметрыРегистрации.ОрганизацияАдресXML);
		organization.Вставить("phone"                  , ПараметрыРегистрации.ОрганизацияТелефон);
		organization.Вставить("mail"                   , ПараметрыРегистрации.ОрганизацияПочта);
		organization.Вставить("inn"                    , ПараметрыРегистрации.ОрганизацияИНН);
		organization.Вставить("responsible_id"         , ПараметрыРегистрации.ОрганизацияОтправительИД);
		organization.Вставить("responsible_full_name"  , ПараметрыРегистрации.ОрганизацияОтправительПолноеИмя);
		
		product = Новый Структура();
		product.Вставить("registration_number"         , ПараметрыРегистрации.ПродуктРегистрационныйНомер);
		product.Вставить("password_to_access"          , ПараметрыРегистрации.ПродуктПароль);
		product.Вставить("vendor_code"                 , ПараметрыРегистрации.ПродуктАртикул);
		product.Вставить("profile_picture"             , СкринАнкетыBase64);
		product.Вставить("name"                        , ПараметрыРегистрации.ПродуктНаименование);
		product.Вставить("date_first_launch"           , ПараметрыРегистрации.ПродуктДатаПевогоЗапуска);
		product.Вставить("uid_info_base"               , ПараметрыРегистрации.ПродуктУИДБазы);
		product.Вставить("security_key_used"           , ПараметрыРегистрации.ПродуктСЛКиспользуется);
		
		ПарамтерыЗапроса = Новый Структура("contact_person,club,organization,product",
		contact_person,
		clinic,
		organization,
		product);
		
		ТекстЗапроса     = СобратьJson(ПарамтерыЗапроса);		
		РезультатЗапроса = ВыполнитьPOSTЗапрос("products/registration", ТекстЗапроса); 
		
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);	
		
		РезультатаОперции.Вставить("РегистрацияПринята");
		РезультатаОперции.Вставить("ОписаниеРезультата");
		РезультатаОперции.Вставить("СтатусАнкетыКод");
		
		Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
			
			РезультатаОперции.РегистрацияПринята     = РезультатЗапроса.parameters.result;
			РезультатаОперции.ОписаниеРезультата     = РезультатЗапроса.parameters.description;
			РезультатаОперции.СтатусАнкетыКод        = РезультатЗапроса.parameters.state_code;
			
		КонецЕсли;
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		РезультатаОперции.Вставить("ОписаниеРезультата");
		РезультатаОперции.ОписаниеРезультата = "Не удалось зарегистрировать анкету";
		
	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

// Функция, возвращает состояние анкеты из CRM.
//
Функция ДанныеПоСостояниюАнкетыПродукта(РегистрационныйНомер) Экспорт
	
	Попытка
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("registrationnumber", РегистрационныйНомер);
		ЗаголовкиHTTP.Вставить("vendorcode"		   , ПолучитьАртикулПродукта());
		
		РезультатЗапроса  = ВыполнитьGETЗапрос("products/registration", ЗаголовкиHTTP);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
		РезультатаОперции.Вставить("СтатусРегистрацииКод");
		РезультатаОперции.Вставить("СтатусРегистрацииОписание");
		РезультатаОперции.Вставить("РегистрацияПринята", Ложь);
		
		РезультатаОперции.Вставить("ТехническаяПоддержкаРазрешена");
		РезультатаОперции.Вставить("ТехническаяПоддержкаСтатус");
		РезультатаОперции.Вставить("ТехническаяПоддержкаОписание");
			
		Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
			
			РезультатаОперции.СтатусРегистрацииКод      = РезультатаОперции.ПараметрыРезультата.registration.state_code;
			РезультатаОперции.СтатусРегистрацииОписание = РезультатаОперции.ПараметрыРезультата.registration.description;
			РезультатаОперции.РегистрацияПринята        = РезультатаОперции.СтатусРегистрацииКод = 304;
			
			РезультатаОперции.ТехническаяПоддержкаРазрешена  = РезультатаОперции.ПараметрыРезультата.support.allow;
			РезультатаОперции.ТехническаяПоддержкаСтатус     = РезультатаОперции.ПараметрыРезультата.support.state_code;
			РезультатаОперции.ТехническаяПоддержкаОписание   = РезультатаОперции.ПараметрыРезультата.support.description;
			
		КонецЕсли;
		
	Исключение
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатаОперции;

КонецФункции

#КонецОбласти

#Область ЛичныйКабинет

// Функция - Войти в личный кабинет
// 
// Параметры:
//  РегистрационныйНомер - 	 - 
//  ПарольДоступа		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВойтиВЛичныйКабинет(РегистрационныйНомер, ПарольДоступа) Экспорт
		
	РезультатаОперции = Неопределено;
	
	Попытка 
		
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("registrationnumber", РегистрационныйНомер);	
		ЗаголовкиHTTP.Вставить("userpassword"      , ПарольДоступа);
		ЗаголовкиHTTP.Вставить("vendorcode"        , ПолучитьАртикулПродукта());
	
		РезультатЗапроса  = ВыполнитьPOSTЗапрос("account/auth", Неопределено, ЗаголовкиHTTP);	
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
		Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
			
			РезультатаОперции.Вставить("ВходРазрешен"      , РезультатаОперции.ПараметрыРезультата.access_allow);
			РезультатаОперции.Вставить("ОписаниеРезультата", РезультатаОперции.ПараметрыРезультата.description);
			РезультатаОперции.Вставить("УИДСессии"         , РезультатаОперции.ПараметрыРезультата.uid_session);
			
		КонецЕсли;
		
