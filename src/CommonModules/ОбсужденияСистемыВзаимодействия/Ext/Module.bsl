// Функция - Данные для регистрации системы взаимодействия
//
// Параметры:
//  ЭтоОблако	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДанныеДляРегистрацииСистемыВзаимодействия(ЭтоОблако = Ложь) Экспорт

	ДанныеРегистрации = Новый Структура;
	
	Если ЭтоОблако = Истина Тогда
		ИмяИнформационнойБазы = ЛичныйКабинет.ПолучитьНомерОбласти();	
	Иначе
		ИмяИнформационнойБазы = ОбсужденияСистемыВзаимодействия.ИмяИнформационнойБазыДляРегистрации();
	КонецЕсли;	
	
	Сервер 				  = "ws://collab.stoma1c.ru:8081";
	АдресЭлектроннойПочты = ОбсужденияСистемыВзаимодействия.ПолучитьАдресПочтыДляРегистрации();
    КодРегистрации		  = Формат(ТекущаяДата(), "DF=""yyyyMMddHHmmss""");
	
	ДанныеРегистрации.Вставить("Сервер"				  , Сервер);
	ДанныеРегистрации.Вставить("ИмяИнформационнойБазы", ИмяИнформационнойБазы);
	ДанныеРегистрации.Вставить("АдресЭлектроннойПочты", ?(ЗначениеЗаполнено(АдресЭлектроннойПочты), АдресЭлектроннойПочты, ИмяИнформационнойБазы));
	ДанныеРегистрации.Вставить("КодРегистрации"		  , КодРегистрации);
	
	Возврат ДанныеРегистрации;
	
КонецФункции

