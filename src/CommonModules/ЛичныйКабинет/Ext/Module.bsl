// Процедура, отправляет запрос CRM, для отправки push уведомления врачу.
//
Процедура ОтправитьPushУведомлениеMobile(СтруктураPushУведомления) Экспорт
	
	Попытка 
		
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("RegNumber", СтруктураPushУведомления.ПродуктРегистрационныйНомер);
		ЗаголовкиHTTP.Вставить("Apikey"   , СтруктураPushУведомления.КлючПриложения);
		
		ТелоЗапроса = СобратьJson(СтруктураPushУведомления);	
		
		ОписаниеОшибки = "";
		ОтветОтСервера = ВыполнитьPOSTЗапрос("/salonmob_app/push_mobile", ТелоЗапроса, ЗаголовкиHTTP);  
		
		Если НЕ ОтветОтСервера.parameters.result И ЗначениеЗаполнено(ОтветОтСервера.errors.message) Тогда 
			ОписаниеОшибки = "Код ошибки: " + ОтветОтСервера.errors.code + " Описание ошибки: " + ОтветОтСервера.errors.message;
		КонецЕсли;
		
	Исключение	
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
	КонецПопытки;			
	
КонецПроцедуры

