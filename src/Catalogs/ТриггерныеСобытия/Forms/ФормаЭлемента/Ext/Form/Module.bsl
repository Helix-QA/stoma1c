// Функция - Закешировать текущие значения объекта
// 
// Возвращаемое значение:
//   - 
//
Функция ЗакешироватьТекущиеЗначенияОбъекта();
	
	СтруктураРеквизитов = Новый Структура();
	
	РеквизитыОбъекта 			= Объект.Ссылка.Метаданные().Реквизиты;
	РеквизитыОбъектаСтандартные = Объект.Ссылка.Метаданные().СтандартныеРеквизиты;
	Для Каждого РеквизитФормы Из РеквизитыОбъекта Цикл 
		СтруктураРеквизитов.Вставить(РеквизитФормы.Имя, Объект[РеквизитФормы.Имя]);
	КонецЦикла;
	Для Каждого РеквизитФормы Из РеквизитыОбъектаСтандартные Цикл
		Если РеквизитФормы.Имя = "Наименование" Тогда 
			СтруктураРеквизитов.Вставить(РеквизитФормы.Имя, Объект[РеквизитФормы.Имя]);
			Прервать;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

