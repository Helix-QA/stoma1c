			Если МассивТриггеров.Количество() > 0 Тогда 
				ГенерируемыйТриггер = МассивТриггеров[0].Ссылка;
			Иначе 
				ГенерируемыйТриггер = ТаблицаТриггеров[0].Ссылка;
			КонецЕсли;	
		КонецЕсли;
		
		Попытка
			Если ЗначениеЗаполнено(ГенерируемыйТриггер) Тогда 
				ТриггерСменаСтатусаЗаписи 						= ГенерируемыйТриггер.ПолучитьОбъект();
			Иначе 	
				// Генерируем триггер
				ТриггерСменаСтатусаЗаписи 						= СоздатьЭлемент();
			КонецЕсли;
			ТриггерСменаСтатусаЗаписи.Активно 					= Истина;
			ТриггерСменаСтатусаЗаписи.Наименование 				= ?(ЗначениеЗаполнено(ГенерируемыйТриггер), ТриггерСменаСтатусаЗаписи.Наименование, НСтр("ru = 'Смена статуса записи на приём сотрудником клиники';en= 'Changing the status of an appointment with a clinic employee'"));
