#Область appointment

// Функция - Создать визит
//
// Параметры:
//  Сотрудник			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  ДатаНачала			 - 	 - 
//  ДатаОкончания		 - 	 - 
//  ПараметрыJSON		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция appointment(ПараметрыJSON, СтруктурнаяЕдиница, Автор, ВнешняяСистема) Экспорт
	
	Статус			= ?(ПараметрыJSON.Свойство("Статус"), Перечисления.СтатусыСобытия[ПараметрыJSON.Статус], Неопределено);
	УИДПриема		= ?(ПараметрыJSON.Свойство("УИДПриема"), ПараметрыJSON.УИДПриема, Неопределено);
	ДокументСобытие	= ?(ЗначениеЗаполнено(УИДПриема), Документы.Событие.ПолучитьСсылку(Новый УникальныйИдентификатор(УИДПриема)), Неопределено);
	ПереданПрием	= ЗначениеЗаполнено(ДокументСобытие);
	УИДВрача		= ?(ПараметрыJSON.Свойство("УИДВрача"), ПараметрыJSON.УИДВрача, Неопределено);
	Сотрудник		= ?(ЗначениеЗаполнено(УИДВрача), Справочники.Сотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(УИДВрача)), Автор);
	
	#Область ОтменитьВизит
	
	Если ПереданПрием И Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
		
		Если Не ДокументСобытие.Проведен 
			ИЛИ НачалоДня(ДокументСобытие.Дата) <> НачалоДня(ТекущаяДатаСеанса()) 
			ИЛИ ДокументСобытие.Статус = Перечисления.СтатусыСобытия.ПриемОкончен
			ИЛИ ДокументСобытие.Статус = Перечисления.СтатусыСобытия.ПриемНачат Тогда			
			
			Возврат ПолучитьСтруктуруОтвета(, 2038,, Ложь);			
			
		КонецЕсли;
		
		ОбъектСобытие		= ДокументСобытие.ПолучитьОбъект();
		ОбъектСобытие.Статус	= Статус;
		
		Если ПараметрыJSON.Свойство("ПричинаОтменыУИД") Тогда
			ПричинаОтменыЗаписи = Справочники.ПричиныОтменыЗаписи.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыJSON.ПричинаОтменыУИД));
		Иначе
			ПричинаОтменыЗаписи = Справочники.ПричиныОтменыЗаписи.НайтиПоНаименованию("Отмена с мобильного приложения клиники");
		КонецЕсли;
		
		ОбъектСобытие.ПричинаОтмены = ?(ЗначениеЗаполнено(ПричинаОтменыЗаписи), ПричинаОтменыЗаписи, СоздатьПричинуОтменыЗаписи());
		
		//Если Автор = Сотрудник Тогда
		//	ОбъектСобытие.ДополнительныеСвойства.Вставить("НеОтправлятьПушУведомление", Истина);
		//КонецЕсли;
		ОбъектСобытие.ДополнительныеСвойства.Вставить("АвторЗаписи", Автор);
		
		Попытка
			ОбъектСобытие.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Возврат ПолучитьСтруктуруОтвета(, 2036, ОписаниеОшибки(), Ложь);
		КонецПопытки;
		
		СтруктураВозврата = Новый Структура;
		СтруктураВозврата.Вставить("Статус", ПолучитьСтатусСобытия(ОбъектСобытие.Статус));
		
		Возврат ПолучитьСтруктуруОтвета(СтруктураВозврата);
		
	КонецЕсли;
	
	#КонецОбласти
		
	ДатаНачала			=  ?(ПараметрыJSON.Свойство("ДатаНачала"), ПараметрыJSON.ДатаНачала, Неопределено);
	Комментарий			= ?(ПараметрыJSON.Свойство("Комментарий"), ПараметрыJSON.Комментарий, Неопределено);
	УИДПациента			= ?(ПараметрыJSON.Свойство("УИДПациента"), ПараметрыJSON.УИДПациента, Неопределено); 
	Длительность		= ?(ПараметрыJSON.Свойство("Длительность"), ПараметрыJSON.Длительность, Неопределено);
	ПричинаЗаписиУИД	= ?(ПараметрыJSON.Свойство("ПричинаЗаписиУИД"), ПараметрыJSON.ПричинаЗаписиУИД, Неопределено);
	УИДПолиса			= ?(ПараметрыJSON.Свойство("УИДПолиса"), ПараметрыJSON.УИДПолиса, Неопределено);
	ИмяПациента			= ?(ПараметрыJSON.Свойство("ИмяПациента"), ПараметрыJSON.ИмяПациента, Неопределено);
	ТелефонПациента		= ?(ПараметрыJSON.Свойство("ТелефонПациента"), ПараметрыJSON.ТелефонПациента, Неопределено);
	МассивМеток			= ?(ПараметрыJSON.Свойство("МассивМеток"), ПараметрыJSON.МассивМеток,  Неопределено);
	
	Пациент				= ?(ЗначениеЗаполнено(УИДПациента), Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(УИДПациента)), Неопределено);	
	ПричинаЗаписи		= ?(ЗначениеЗаполнено(ПричинаЗаписиУИД), Справочники.ПричиныЗаписи.ПолучитьСсылку(Новый УникальныйИдентификатор(ПричинаЗаписиУИД)), Неопределено);
	ПолисМедСтрахования	= ?(ЗначениеЗаполнено(УИДПолиса), Справочники.ПолисыМедицинскогоСтрахования.ПолучитьСсылку(Новый УникальныйИдентификатор(УИДПолиса)), Неопределено);

	Если Документы.Событие.НаличиеСобытийЗаУказаныйПериод(ДатаНачала, ДатаНачала+Длительность*60, СтруктурнаяЕдиница, Сотрудник,, ДокументСобытие) = Истина Тогда 
		Возврат ПолучитьСтруктуруОтвета(, 1046,, Ложь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяПациента) И ЗначениеЗаполнено(ТелефонПациента) И Не ЗначениеЗаполнено(Пациент) Тогда
		
		НовыйКонтрагент = СоздатьНовогоКлиента(ИмяПациента, ТелефонПациента, Сотрудник);
		
		Попытка
			НовыйКонтрагент.Записать();
			Пациент = НовыйКонтрагент.Ссылка;
		Исключение
			СистемнаяОшибка = ОписаниеОшибки();
			ЗаписьЖурналаРегистрации("Http-сервисы.MobileApp.CreateUpdateVisit", УровеньЖурналаРегистрации.Ошибка,,, "Ошибка при записи клиента: " + СистемнаяОшибка);
			Возврат ПолучитьСтруктуруОтвета(, 2040, СистемнаяОшибка, Ложь);
		КонецПопытки;
		
	КонецЕсли;
	
	Если Пациент.Теги.НайтиСтроки(Новый Структура("Тег", Справочники.Теги.ЗапретитьОбслуживание)).Количество() > 0 Тогда // Клиент.Теги.НайтиСтроки(Новый Структура("Тег", Справочники.Теги.ЗапретитьОнлайнЗапись)).Количество() > 0 ИЛИ 	
		Возврат ПолучитьСтруктуруОтвета(, 2029,, Ложь);
	КонецЕсли;
		
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("Дата", ДатаНачала);
	ПараметрыЗаполнения.Вставить("Контрагент", Пациент);
	ПараметрыЗаполнения.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиница);	
	ПараметрыЗаполнения.Вставить("ДатаОкончания", ДатаНачала+Длительность*60);
	ПараметрыЗаполнения.Вставить("Врач", Сотрудник);
		
	Если ЗначениеЗаполнено(Статус) Тогда
		ПараметрыЗаполнения.Вставить("Статус", Статус);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда
		ПараметрыЗаполнения.Вставить("ПолисМедСтрахования", ПолисМедСтрахования);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Комментарий) Тогда
		ПараметрыЗаполнения.Вставить("Комментарий", Комментарий);
	КонецЕсли; 
	
	Если Не ПереданПрием Тогда
		
		ПараметрыЗаполнения.Вставить("ДатаСоздания", ТекущаяДатаСеанса());
		ПараметрыЗаполнения.Вставить("АвторДокумента", Сотрудник);
		ПараметрыЗаполнения.Вставить("ТипСобытия", Перечисления.ТипыСобытий.ПредварительнаяЗапись);
		ПараметрыЗаполнения.Вставить("ИсточникЗаписи", api_v1.ПолучитьИсточникЗаписи(ВнешняяСистема)); 		
		ВидЦенСотрудника = РегистрыСведений.НастройкиСотрудников.ПолучитьВидЦенСотрудника(СтруктурнаяЕдиница, Сотрудник);
		ВидЦенСотрудника = ?(ЗначениеЗаполнено(ВидЦенСотрудника), ВидЦенСотрудника, Справочники.ВидыЦен.Розничная);		
		ПараметрыЗаполнения.Вставить("ВидЦен", ВидЦенСотрудника);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Комментарий) Тогда
		ПараметрыЗаполнения.Вставить("Комментарий", Комментарий);
	КонецЕсли; 
		
	ТаблицаУслуг = Новый ТаблицаЗначений;
	ТаблицаУслуг.Колонки.Добавить("ДатаНачала");
	ТаблицаУслуг.Колонки.Добавить("ДатаОкончания");
	ТаблицаУслуг.Колонки.Добавить("Номенклатура");
	ТаблицаУслуг.Колонки.Добавить("НормаВремени");
	ТаблицаУслуг.Колонки.Добавить("ПризнакЗаблокированно");
	ТаблицаУслуг.Колонки.Добавить("ПричинаЗаписи");
	ТаблицаУслуг.Колонки.Добавить("Сотрудник");
	ТаблицаУслуг.Колонки.Добавить("Цена");
	
	НоваяСтрока = ТаблицаУслуг.Добавить();
	НоваяСтрока.ДатаНачала = ДатаНачала;
	НоваяСтрока.ДатаОкончания = ДатаНачала+Длительность*60;
	НоваяСтрока.НормаВремени = Длительность;
	НоваяСтрока.ПричинаЗаписи = ПричинаЗаписи;
	НоваяСтрока.Сотрудник = Сотрудник;
	
	ПараметрыЗаполнения.Вставить("Услуги", ТаблицаУслуг);	
		
	ОбъектСобытие = СформироватьИЛИОбновитьВизит(ДокументСобытие, ПараметрыЗаполнения);
	
	Попытка
		
		ОбъектСобытие.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		
		 //Если Автор = Сотрудник Тогда
		 //   ОбъектСобытие.ДополнительныеСвойства.Вставить("НеОтправлятьПушУведомление", Истина);
		 //КонецЕсли; 
		 
		ОбъектСобытие.ДополнительныеСвойства.Вставить("АвторЗаписи", Автор);
		ОбъектСобытие.ДополнительныеСвойства.Вставить("Пользователь", Сотрудник);		
		ПроверкаПройдена = ОбъектСобытие.ПроверитьЗаполнение();			
		ОбъектСобытие.Записать(РежимЗаписиДокумента.Проведение);
		ДокументСобытие = ОбъектСобытие.Ссылка;                                                                                                                                                                              
		
		РегистрыСведений.ВремяРаботыСотрудниковПлан.УстановкаРабочегоВремениСотрудника(СтруктурнаяЕдиница, Сотрудник, Истина, ДокументСобытие.Дата, ДокументСобытие.ДатаОкончания, Перечисления.ТипыРабочегоВремени.Рабочее);	
		
		Если ЗначениеЗаполнено(МассивМеток) Тогда
			
			НаборЗаписей = РегистрыСведений.МеткиКлиентов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Клиент.Установить(ДокументСобытие);
			
			Для Каждого Метка ИЗ МассивМеток Цикл			
				НоваяМетка				= НаборЗаписей.Добавить();
				НоваяМетка.Период       = ТекущаяДатаСеанса();
				НоваяМетка.Клиент       = ДокументСобытие;
				НоваяМетка.Метка        = Справочники.Метки.ПолучитьСсылку(Новый УникальныйИдентификатор(Метка));
				НоваяМетка.Автор        = Сотрудник;
				НоваяМетка.Активна      = Истина;			
			КонецЦикла;
			
			Попытка
				НаборЗаписей.ОбменДанными.Загрузка = Истина;
				НаборЗаписей.Записать(Истина);
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ТекстОшибки = ИзвлечьОписаниеОшибки(ТекстОшибки);		
		Возврат ПолучитьСтруктуруОтвета(, 2036, ТекстОшибки, Ложь);		
	КонецПопытки;
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("УИДПриема", УникальныйИдентификатор(ДокументСобытие));
	СтруктураВозврата.Вставить("Статус"	  , ПолучитьСтатусСобытия(ДокументСобытие.Статус));
	
	Возврат ПолучитьСтруктуруОтвета(СтруктураВозврата);
	
Конецфункции

// Функция - Сформировать визит
//
// Параметры:
//  Клиент							 - 	 - 
//  ТаблицаЗначенийЗаписи			 - 	 - 
//  СтруктурнаяЕдиница				 - 	 - 
//  ТребуетсяПредоплата				 - 	 - 
//  ВнешняяСистема					 - 	 - 
//  ЗаКакоеВремяНапоминатьОЗаписи	 - 	 - 
//  РекламныйИсточник				 - 	 - 
//  КомментарийЗаписи				 - 	 - 
//  ИсточникИнформации				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьИЛИОбновитьВизит(ДокументСобытие, ПараметрыЗаполнения)
	
	 Если ЗначениеЗаполнено(ДокументСобытие) Тогда
		ОбъектСобытие = ДокументСобытие.ПолучитьОбъект();
		ОбъектСобытие.Услуги.Очистить();
	 Иначе
	 	ОбъектСобытие = Документы.Событие.СоздатьДокумент();	
	 КонецЕсли;
	
	 ЗаполнитьЗначенияСвойств(ОбъектСобытие, ПараметрыЗаполнения);
	
	 ОбъектСобытие.Услуги.Загрузить(ПараметрыЗаполнения.Услуги);
		
	Возврат ОбъектСобытие;
	
КонецФункции

#КонецОбласти

#Область sync_appointment

// Функция - Sync document visit
//
// Параметры:
//  Параметры			 - 	 - 
//  Визит				 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция sync_appointment(ПараметрыJSON, СтруктурнаяЕдиница, Автор) Экспорт
	
	УидСобытия = ПараметрыJSON.УИДСобытия;	
	Событие = ?(ЗначениеЗаполнено(УидСобытия), Документы.Событие.ПолучитьСсылку(Новый УникальныйИдентификатор(УидСобытия)), Неопределено);			
	
	Если Не ЗначениеЗаполнено(Событие) Тогда
		Возврат ПолучитьСтруктуруОтвета(, 2037,, Ложь);		
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура("РазрешенаЗапись, ОписаниеЗапрета", Ложь, Неопределено);
	ДатаНачала		= ПараметрыJSON.ДатаНачала;
	ДатаОкончания	= ПараметрыJSON.ДатаОкончания; 
	Сотрудник		= ?(ЗначениеЗаполнено(ПараметрыJSON.Сотрудник), Справочники.Сотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыJSON.Сотрудник)), Неопределено);
	Помещение		= ?(ЗначениеЗаполнено(ПараметрыJSON.Помещение), Справочники.Помещения.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыJSON.Помещение)), Неопределено);
		
	Если Документы.Событие.НаличиеСобытийЗаУказаныйПериод(ДатаНачала, ДатаОкончания, СтруктурнаяЕдиница, Сотрудник, Помещение, Событие) = Ложь Тогда 
		
		УслугиНЕДоступныДляСотрудника = ПроверитьДоступностьУслугСотрудникомПоСобытию(Сотрудник, СтруктурнаяЕдиница, Событие);
		
		Если УслугиНЕДоступныДляСотрудника.Количество() = 0 Тогда		
			ВыполненоУспешно = Ложь;
			ОписаниеОшибки = "";
			Документы.Событие.ПеренестиПредварительнуюЗапись(Событие, Сотрудник, Помещение, ДатаНачала, ДатаОкончания, Истина, СтруктураВозврата.РазрешенаЗапись, СтруктураВозврата.ОписаниеЗапрета, Автор);
			
			Если СтруктураВозврата.РазрешенаЗапись ТОгда 
				РегистрыСведений.ВремяРаботыСотрудниковПлан.УстановкаРабочегоВремениСотрудника(СтруктурнаяЕдиница, Сотрудник, Истина, ДатаНачала, ДатаОкончания, Перечисления.ТипыРабочегоВремени.Рабочее);
			КонецЕсли;	
			
		Иначе
			СтруктураВозврата.ОписаниеЗапрета = "Одна или несколько услуг недоступна для сотрудника";	
		КонецЕсли;
		
	Иначе
		СтруктураВозврата.ОписаниеЗапрета = "Выбранный интервал уже занят";
	КонецЕсли;
	
	Возврат ПолучитьСтруктуруОтвета(СтруктураВозврата);
	
КонецФункции

// Функция - Проверить доступные услуги сотрудника
//
Функция ПроверитьДоступностьУслугСотрудникомПоСобытию(Сотрудник, СтруктурнаяЕдиница, Событие)
	
	МассивНедоступныхУслуг = Новый Массив;
	
	Для Каждого Элемент Из Событие.Услуги Цикл
		ДоступнаяУслуга = РегистрыСведений.УслугиСотрудника.УслугаДоступнаДляСотрудника(Элемент.Номенклатура, Сотрудник, СтруктурнаяЕдиница);
		Если НЕ ДоступнаяУслуга И ЗначениеЗаполнено(Элемент.Номенклатура) Тогда
			МассивНедоступныхУслуг.Добавить(Элемент.Номенклатура.Наименование);	
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивНедоступныхУслуг;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область DELETE_v1
#КонецОбласти

#КонецОбласти

#Область ДополнительныеПроцедурыИФункции

// Функция, возвращает структуру возврата ошибки. 
//
Функция ПолучитьСтруктуруОтвета(СтруктураПараметров = Неопределено, КодОшибки = Неопределено, СистемноеОписаниеОшибки = "", ПолучатьHTTPОтвет = Неопределено) Экспорт
	
	Если ПолучатьHTTPОтвет = Неопределено Тогда 
		ПолучатьHTTPОтвет = СтруктураПараметров = Неопределено;
	КонецЕсли;
	
	СтруктураОтвета = Новый Структура("Parameters, Error, ErrorMessage", СтруктураПараметров, КодОшибки, ПолучитьОписаниеОшибки(КодОшибки, СистемноеОписаниеОшибки));
	
	Если ПолучатьHTTPОтвет Тогда
		Возврат ПолучитьHTTPОтвет(СтруктураОтвета);	
	Иначе		
		Возврат СтруктураОтвета; 
	КонецЕсли;
	
КонецФункции

// Функция, возвращает параметр из строки JSON.
// 
Функция ПолучитьПараметрИзСтрокиJSON(ПараметрыЗапроса, НаименованиеПараметра) Экспорт
	
	ТекстJSON = ПараметрыЗапроса.Получить(НаименованиеПараметра);
	
	Если ЗначениеЗаполнено(ТекстJSON) Тогда
		
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ТекстJSON);
			ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);
			Возврат ПараметрыJSON; 
		Исключение
			Возврат Неопределено; 
		КонецПопытки;
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
