КонецПроцедуры

&НаСервереБезКонтекста
// Функция "КонтрагентПриИзмененииНаСервере".
//
Процедура КонтрагентПриИзмененииНаСервере(Сотрудник, Контрагент)	
	
	Результат = Справочники.Сотрудники.ПолучитьСотрудникаПоКонтагенту(Контрагент); 
	
	Для Каждого СтрокаТЗ Из Результат Цикл 
		
		Если СтрокаТЗ.Сотрудник <> Сотрудник Тогда
			
			ТекстСообщения = СтрШаблон(Нстр("ru='Контрагент: %1, привязан к сотруднику: %2';en='Counterparty: %1 tied to employee: %2'"), Контрагент, СтрокаТЗ.Сотрудник);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

