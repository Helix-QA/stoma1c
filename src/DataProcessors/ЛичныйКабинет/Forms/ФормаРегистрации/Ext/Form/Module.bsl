&НаКлиенте
Перем ПопыткаУстановитьРасширениеРаботыСФайлами;

#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик создания формы на сервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.АвторизацияРегистрационныйНомер = ЛичныйКабинет.ПолучитьРегистрационныйНомерПродукта();
	ЭтотОбъект.РегистрацияОтправитель          = ТекущийПользователь();
	ЭтотОбъект.РежимВходаНоваяРегистрация      = НЕ ЗначениеЗаполнено(ЭтотОбъект.АвторизацияРегистрационныйНомер);
	
	Если Параметры.Свойство("АвторизацияПоЗавершениюСессии") = Ложь Тогда
		
		Элементы.ДекорацияАвторизацияВерх.Заголовок = "";
		
		Если ПроверитьВозможностьЗайтиВКабинетПоОткрытойСессии() = Истина Тогда
			Возврат;
		КонецЕсли;
		
		ПоказатьСообщениеНаФормуСервер(Неопределено);
	
	Иначе
		
		ПоказатьСообщениеНаФормуСервер("Текущая сессия была завершена. Необходимо выполнить авторизацию.", 2);
		Элементы.ДекорацияПереключательРежимаВхода.Видимость = Ложь;
		
	КонецЕсли;
	
	УстановитьСостояниеНачальнойСтраницы();
	
	Элементы.ГруппаКнопки.Видимость = Ложь;
	
	СоздатьГруппуКонтактнаяИнформация();
	
	УправлениеКонтактнойИнформациейСтоматология.ПриСозданииПриЧтенииНаСервере(ЭтаФорма, ЭтотОбъект.Организация);	
	ДонастроитьКонтактнуюИнформацию();
	
	Выборка = Справочники.Организации.Выбрать(,,, "Наименование Убыв");
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ПометкаУдаления = Ложь Тогда
			
			СписокОрганизаций.Добавить(Выборка.Ссылка, Выборка.Наименование);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - При открытии
// 
// Параметры:
//  Отказ	 - 	 - 
// 
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЭтотОбъект.ПерейтиВЛичныйКабинет = Истина Тогда
		
		ПараметрыФормы = Новый Структура("ВходРазрешен,РегистрационныйНомер,УидСессии",
		Истина, ЭтотОбъект.АвторизацияРегистрационныйНомер, ЭтотОбъект.УидОткрытойСессии);
		
		ОткрытьФорму("Обработка.ЛичныйКабинет.Форма", ПараметрыФормы);
		
		ЭтаФорма.Закрыть();	
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Зайти в кабиент по открытой сессии
// 
&НаСервере
Функция  ПроверитьВозможностьЗайтиВКабинетПоОткрытойСессии()
	
	Если ЗначениеЗаполнено(ЛичныйКабинет.УидТекущейСессии())
		И ЗначениеЗаполнено(ЭтотОбъект.АвторизацияРегистрационныйНомер) Тогда
		
		ЭтотОбъект.УидОткрытойСессии = ЛичныйКабинет.УидТекущейСессии();
		
		ОписаниеСессии = ЛичныйКабинет.ПроверитьСостояниеСессии(ЭтотОбъект.УидОткрытойСессии);
		
		Если ОписаниеСессии.ВыполненоУспешно = Истина Тогда
			
			ЭтотОбъект.ПерейтиВЛичныйКабинет = ОписаниеСессии.ВходРазрешен;
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеСессии.ОписаниеОшибки);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ЭтотОбъект.ПерейтиВЛичныйКабинет;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиПереходаПоСтраницам

// Процедура - Далее
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура Далее(Команда)
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаАвторизация Тогда
		
		Если НоваяРегистрацияПроверкаДанныхАвтоизации() Тогда
			
			УстановитьСостояниеДляСтраницыКонтИнформации();
			
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаКонтатнаяИнформация;
		
		КонецЕсли;

	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаКонтатнаяИнформация Тогда
		
		УстановитьСостояниеДляСтраницыОкончанияРегистрации();

		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаРегистрацияОрганизация;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Назад
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура Назад(Команда)
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаРегистрацияОрганизация Тогда
		
		УстановитьСостояниеДляСтраницыКонтИнформации();
		
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаКонтатнаяИнформация;
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаКонтатнаяИнформация Тогда
		
		Элементы.ГруппаКнопки.Видимость         = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаАвторизация;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Установить состояние для страницы конт информации
// 
&НаСервере
Процедура УстановитьСостояниеДляСтраницыКонтИнформации()
	
	Элементы.ГруппаКнопки.Видимость                       = Истина;
	Элементы.ЗарегистрироватьДляПодтверждения.Видимость   = Ложь;
	Элементы.Далее.Видимость                              = Истина;
	
	Если Элементы.Найти("ПозвонитьПоIPТелефонии_0") <> Неопределено Тогда 
		
		Элементы.ПозвонитьПоIPТелефонии_0.Видимость = Ложь;
		
	КонецЕсли;
	
	СохранитьКонтактнуюИнформациюПриСменеСтраницы(Элементы.ГруппаСтраницы.ТекущаяСтраница);
	
	ПереместитьГруппуКонтактнаяИнформацияНаСтрКонтактнаяИнформация();
	
	НастроитьОтображениеКонтактнойИнформации(Элементы.ГруппаКонтатнаяИнформация);
	
	ЗаполнитьКонтактнуюИнформациюПриСменеСтраницы(Элементы.ГруппаКонтатнаяИнформация);
	
КонецПроцедуры

// Процедура - Установить состояние для страницы окончания регистрации
// 
&НаСервере
Процедура УстановитьСостояниеДляСтраницыОкончанияРегистрации()
	
	Элементы.ГруппаКнопки.Видимость                      = Истина;
	Элементы.ЗарегистрироватьДляПодтверждения.Видимость  = Истина;
    Элементы.Далее.Видимость                             = Ложь;
	Элементы.ДекорацияПримерРегАнкеты.Видимость          = Ложь;

	СохранитьКонтактнуюИнформациюПриСменеСтраницы(Элементы.ГруппаСтраницы.ТекущаяСтраница);

	ПереместитьГруппуКонтактнаяИнформацияНаСтрРегОрганизации();
	
	НастроитьОтображениеКонтактнойИнформации(Элементы.ГруппаСтраницаРегистрацияОрганизация);
	
	ЗаполнитьКонтактнуюИнформациюПриСменеСтраницы(Элементы.ГруппаСтраницаРегистрацияОрганизация);
	
КонецПроцедуры

// Процедура - Создать группу контактная информация
// 
&НаСервере
Процедура СоздатьГруппуКонтактнаяИнформация()
	
	ГруппаФормы = Элементы.Вставить("КонтактнаяИнформация", Тип("ГруппаФормы"), Элементы.ГруппаКонтактнаяИнформация, Элементы.ГруппаКлиника);
	ГруппаФормы.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФормы.ОтображатьЗаголовок = Ложь;
	ГруппаФормы.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		
КонецПроцедуры

// Процедура - Донастроить контактную информацию
// 
&НаСервере
Процедура ДонастроитьКонтактнуюИнформацию()
	
	Элемент_КИ_Телефон = Элементы.Найти("ВидКИ_0");
	Если НЕ Элемент_КИ_Телефон = Неопределено Тогда 
		ДекорацияТелефон                          = Элементы.Вставить("ВидКИ_0Декорация", Тип("ДекорацияФормы"), Элементы.ВидКИ_0.Родитель, Элементы.ВидКИ_0);
		ДекорацияТелефон.Заголовок                = "Телефон";
		ДекорацияТелефон.РастягиватьПоГоризонтали = Истина;
		ДекорацияТелефон.Ширина                   = 8;
		
		Элементы.ВидКИ_0.Видимость = Ложь;
		Элементы.ПредставлениеКИ_0.МаксимальнаяШирина = 30;
		Элементы.ДействиеКИ_0.Видимость = Ложь;
	КонецЕсли;

	Элемент_КИ_Мыло = Элементы.Найти("ВидКИ_1");
	Если НЕ Элемент_КИ_Мыло = Неопределено Тогда 	
		ДекорацияМыло                          = Элементы.Вставить("ВидКИ_1Декорация", Тип("ДекорацияФормы"), Элементы.ВидКИ_1.Родитель, Элементы.ВидКИ_1);
		ДекорацияМыло.Заголовок                = "Email";
		ДекорацияМыло.РастягиватьПоГоризонтали = Истина;
		ДекорацияМыло.Ширина                   = 8;
		
		Элементы.ВидКИ_1.Видимость = Ложь;
		Элементы.ПредставлениеКИ_1.МаксимальнаяШирина = 30;
		Элементы.ДействиеКИ_1.Видимость = Ложь;		
	КонецЕсли;

	Элемент_КИ_ЮрЛицо = Элементы.Найти("ВидКИ_2");
	Если НЕ Элемент_КИ_ЮрЛицо = Неопределено Тогда 		
		ДекорацияЮрЛицо                          = Элементы.Вставить("ВидКИ_2Декорация", Тип("ДекорацияФормы"), Элементы.ВидКИ_2.Родитель, Элементы.ВидКИ_2);
		ДекорацияЮрЛицо.Заголовок                = "Юр. адрес";
		ДекорацияЮрЛицо.РастягиватьПоГоризонтали = Истина;
		ДекорацияЮрЛицо.Ширина                   = 8;
		
		Элементы.ВидКИ_2.Видимость = Ложь;
		Элементы.ПредставлениеКИ_2.МаксимальнаяШирина = 30;
		Элементы.ДействиеКИ_2.Видимость = Ложь;		
	КонецЕсли;

	//Элементы.ПредставлениеКИ_0.МаксимальнаяШирина = 30;
	//Элементы.ПредставлениеКИ_1.МаксимальнаяШирина = 30;
	//Элементы.ПредставлениеКИ_2.МаксимальнаяШирина = 30;
	//
	//Элементы.ВидКИ_0.Видимость = Ложь;
	//Элементы.ВидКИ_1.Видимость = Ложь;
	//Элементы.ВидКИ_2.Видимость = Ложь;
	//
	//Элементы.ДействиеКИ_0.Видимость = Ложь;
	//Элементы.ДействиеКИ_1.Видимость = Ложь;
	//Элементы.ДействиеКИ_2.Видимость = Ложь;
	
КонецПроцедуры

// Процедура - Переместить группу контактная информация на стр контактная информация
// 
&НаСервере
Процедура ПереместитьГруппуКонтактнаяИнформацияНаСтрКонтактнаяИнформация()

	Элементы.Переместить(Элементы.КонтактнаяИнформация, Элементы.ГруппаКонтактнаяИнформация, Элементы.ГруппаКлиника);
	
КонецПроцедуры

// Процедура - Переместить группу контактная информация на стр рег организации
// 
&НаСервере
Процедура ПереместитьГруппуКонтактнаяИнформацияНаСтрРегОрганизации()

	Элементы.Переместить(Элементы.КонтактнаяИнформация, Элементы.ГруппаОсновнаяИнформация);
	
КонецПроцедуры

// Процедура - Настроить отображение контактной информации
// 
// Параметры:
//  ТекущаяСтраница	 - 	 - 
// 
&НаСервере
Процедура НастроитьОтображениеКонтактнойИнформации(ТекущаяСтраница)
	
	Элементы.КомментарийКИ_0.Видимость = Ложь;
	Элементы.КомментарийКИ_1.Видимость = Ложь;

	Если ТекущаяСтраница = Элементы.ГруппаКонтатнаяИнформация Тогда
		
		Элементы.КИ_0.Видимость = Истина;
		Элементы.КИ_1.Видимость = Истина;
	    Элементы.КИ_2.Видимость = Ложь;
		Элементы.КИ_3.Видимость = Ложь;
		//Элементы.КИ_4.Видимость = Ложь;
				
		Элементы.ПредставлениеКИ_0.АвтоОтметкаНезаполненного = Истина;
		Элементы.ПредставлениеКИ_1.АвтоОтметкаНезаполненного = Истина;

	Иначе	
		
		Элементы.КИ_0.Видимость = Истина;
		Элементы.КИ_1.Видимость = Истина;
	    Элементы.КИ_2.Видимость = Истина;
		Элементы.КИ_3.Видимость = Ложь;
		//Элементы.КИ_4.Видимость = Ложь;
		
		Элементы.ПредставлениеКИ_0.АвтоОтметкаНезаполненного = Ложь;
		Элементы.ПредставлениеКИ_1.АвтоОтметкаНезаполненного = Ложь;
		Элементы.ПредставлениеКИ_0.ОтметкаНезаполненного     = Ложь;
	    Элементы.ПредставлениеКИ_1.ОтметкаНезаполненного     = Ложь;
		
	КонецЕсли;                    
	
КонецПроцедуры

// Процедура - Сохранить контактную информацию при смене страницы
// 
// Параметры:
//  ТекущаяСтраница	 - 	 - 
// 
&НаСервере
Процедура СохранитьКонтактнуюИнформациюПриСменеСтраницы(ТекущаяСтраница)
	
	Если ТекущаяСтраница = Элементы.ГруппаКонтатнаяИнформация Тогда
		
		ЭтотОбъект.КиТелефон    = ЭтотОбъект.КонтактнаяИнформация[0].Представление;
		ЭтотОбъект.КиТелефонXML = ЭтотОбъект.КонтактнаяИнформация[0].ЗначенияПолей;		
		ЭтотОбъект.КиПочта      = ЭтотОбъект.КонтактнаяИнформация[1].Представление;
		ЭтотОбъект.КиПочтаXML   = ЭтотОбъект.КонтактнаяИнформация[1].ЗначенияПолей;

	ИначеЕсли ТекущаяСтраница = Элементы.ГруппаСтраницаРегистрацияОрганизация Тогда
		
		ЭтотОбъект.ОрганизацияТелефон    = ЭтотОбъект.КонтактнаяИнформация[0].Представление;
		ЭтотОбъект.ОрганизацияТелефонXML = ЭтотОбъект.КонтактнаяИнформация[0].ЗначенияПолей;		
		ЭтотОбъект.ОрганизацияПочта      = ЭтотОбъект.КонтактнаяИнформация[1].Представление;
		ЭтотОбъект.ОрганизацияПочтаXML   = ЭтотОбъект.КонтактнаяИнформация[1].ЗначенияПолей;
        ЭтотОбъект.ОрганизацияАдрес      = ЭтотОбъект.КонтактнаяИнформация[2].Представление;
		ЭтотОбъект.ОрганизацияАдресXML   = ЭтотОбъект.КонтактнаяИнформация[2].ЗначенияПолей;

	КонецЕсли;
 	
КонецПроцедуры

// Процедура - Заполнить контактную информацию при смене страницы
// 
// Параметры:
//  ТекущаяСтраница	 - 	 - 
// 
&НаСервере
Процедура ЗаполнитьКонтактнуюИнформациюПриСменеСтраницы(ТекущаяСтраница)
	
	Если ТекущаяСтраница = Элементы.ГруппаКонтатнаяИнформация Тогда
		
		 ЭтотОбъект.КонтактнаяИнформация[0].Представление = ЭтотОбъект.КиТелефон;
		 ЭтотОбъект.КонтактнаяИнформация[0].ЗначенияПолей = ЭтотОбъект.КиТелефонXML;
         ЭтотОбъект.КонтактнаяИнформация[1].Представление = ЭтотОбъект.КиПочта;
		 ЭтотОбъект.КонтактнаяИнформация[1].ЗначенияПолей = ЭтотОбъект.КиПочтаXML;

	ИначеЕсли ТекущаяСтраница = Элементы.ГруппаСтраницаРегистрацияОрганизация Тогда

		 ЭтотОбъект.КонтактнаяИнформация[0].Представление = ЭтотОбъект.ОрганизацияТелефон ;
		 ЭтотОбъект.КонтактнаяИнформация[0].ЗначенияПолей = ЭтотОбъект.ОрганизацияТелефонXML;		
		 ЭтотОбъект.КонтактнаяИнформация[1].Представление = ЭтотОбъект.ОрганизацияПочта;
		 ЭтотОбъект.КонтактнаяИнформация[1].ЗначенияПолей = ЭтотОбъект.ОрганизацияПочтаXML;
         ЭтотОбъект.КонтактнаяИнформация[2].Представление = ЭтотОбъект.ОрганизацияАдрес;
		 ЭтотОбъект.КонтактнаяИнформация[2].ЗначенияПолей = ЭтотОбъект.ОрганизацияАдресXML;
		
	КонецЕсли;
 	
КонецПроцедуры

#КонецОбласти

#Область СтраницаАвторизацииИлиНовойРегистрации

#Область ОбработчикиКоманд

&НаКлиенте
// Восстановить доступ к анкете
Процедура ВойтиИлиЗарегистрироваться(Команда)
	
	ПоказатьСообщениеНаФорму(Неопределено);
	
	Если РежимВходаНоваяРегистрация = Истина Тогда
		Далее(Команда);
	Иначе
		ВыполнитьВходвЛичныйКабинет();
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Выполнить входв личный кабинет
// 
&НаКлиенте
Процедура ВыполнитьВходвЛичныйКабинет()
		
	Результат = ЛичныйКабинет.ВойтиВЛичныйКабинет(СокрЛП(ЭтотОбъект.АвторизацияРегистрационныйНомер), ЭтотОбъект.АвторизацияПароль);
	
	Если Результат.ВыполненоУспешно = Истина 
		И Результат.ВходРазрешен = Истина Тогда
		
		УстановитьУидОткрытойСессии(Результат.УидСессии);
		
		Если ЛичныйКабинет.ПолучитьРегистрационныйНомерПродукта() <> СокрЛП(ЭтотОбъект.АвторизацияРегистрационныйНомер) Тогда
			ЗаписатьДанныеПослеПервогоВхода(СокрЛП(ЭтотОбъект.АвторизацияРегистрационныйНомер));
		КонецЕсли;
		
		ПараметрыФормы =  Новый Структура("ВходРазрешен,РегистрационныйНомер,УидСессии", Истина, ЭтотОбъект.АвторизацияРегистрационныйНомер, Результат.УидСессии);
		ОткрытьФорму("Обработка.ЛичныйКабинет.Форма", ПараметрыФормы);
		ЭтаФорма.Закрыть(Новый Структура("ВходРазрешен,УидСессии", Истина, Результат.УидСессии));
		
	Иначе	
		
		Если Результат.Свойство("ОписаниеРезультата") Тогда
			ПоказатьСообщениеНаФорму(Результат.ОписаниеРезультата);
		Иначе
			ПоказатьСообщениеНаФорму(Результат.ОписаниеОшибки);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
// Процедура - Установить состояние начальной страницы
// 
Процедура УстановитьСостояниеНачальнойСтраницы()
	
	Если ЭтотОбъект.РежимВходаНоваяРегистрация = Истина Тогда
		
		Элементы.АвторизацияПарольПодтверждения.Видимость    = Истина;
		Элементы.ВойтиИлиЗарегистрироваться.Заголовок        = "Зарегистрироваться";
		Элементы.ДекорацияПереключательРежимаВхода.Заголовок = "Уже зарегистрирован";		
		Элементы.ДекорацияАвторизацияЗаголовок.Заголовок     = "Регистрация";
		
		ЭтаФорма.Заголовок                                   = "Регистрация программного продукта";
	
	Иначе
		
		Элементы.АвторизацияПарольПодтверждения.Видимость    = Ложь;
		Элементы.ВойтиИлиЗарегистрироваться.Заголовок        = "Войти";
		Элементы.ДекорацияПереключательРежимаВхода.Заголовок = "Зарегистрироваться";
		Элементы.ДекорацияАвторизацияЗаголовок.Заголовок     = "Авторизация";

		ЭтаФорма.Заголовок                                   = "Вход в личный кабинет";
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Начало новой регистрации
// 
Функция НоваяРегистрацияПроверкаДанныхАвтоизации()
	
	Если Не ЗначениеЗаполнено(СокрЛП(ЭтотОбъект.АвторизацияРегистрационныйНомер)) Тогда
		
		ПоказатьСообщениеНаФорму("Укажите регистрационный номер продукта!");
		Возврат Ложь;
		
	ИначеЕсли Не ЗначениеЗаполнено(ЭтотОбъект.АвторизацияПароль) Тогда
		
		ПоказатьСообщениеНаФорму("Укажите пароль доступа к личному кабинете!");
		Возврат Ложь;
		
	ИначеЕсли СтрДлина(ЭтотОбъект.АвторизацияПароль) < 4 Тогда
		
		ПоказатьСообщениеНаФорму("Пароль доступа должен быть не короче 4-х символов");
		Возврат Ложь;
		
	ИначеЕсли Не ЗначениеЗаполнено(ЭтотОбъект.АвторизацияПарольПодтверждения) Тогда
		
		ПоказатьСообщениеНаФорму("Укажите пароль повторно!");
		Возврат Ложь;
		
	ИначеЕсли ЭтотОбъект.АвторизацияПарольПодтверждения <> ЭтотОбъект.АвторизацияПароль Тогда
		
		ПоказатьСообщениеНаФорму("Пароль и повторный пароль не совпадают!!");
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Процедура - Авторизация регистрационный номер при изменении
// 
// Параметры:
//  Элемент	 - 	 - 
