// Процедура - Добавить документ оплаты в очередь
//
// Параметры:
//  ДокументОплаты	 - 	 - 
//
Процедура ДобавитьДокументОплатыВОчередь(ДокументОплаты, НеВыполнятьПроверки = Ложь) Экспорт
	
	Если Не НеВыполнятьПроверки Тогда
		
		Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") Тогда
			
			Если КассовыйСерверПовтИсп.КассаКассовогоСервера(ДокументОплаты.Организация) <> ДокументОплаты.Касса Тогда
				ВызватьИсключение "Нельзя добавить в очередь фискализации " + ДокументОплаты + " касса документа отличается от кассы кассового сервера!";
			КонецЕсли;
			
			Если ДокументОплаты.ТипДенежныхСредств <> Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
				ВызватьИсключение "Нельзя добавить в очередь фискализации " + ДокументОплаты + " обрабатываются только оплаты платежной картой или лицевым счетом!";
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.Реализация") Тогда
			
			Если ДокументОплаты.УчтенныеАвансы.Количество() = 0 Тогда			
				ВызватьИсключение "Нельзя добавить в очередь фискализации " + ДокументОплаты + " обрабатываются только оплаты платежной картой или лицевым счетом!";
			КонецЕсли;
			
			Если КассовыйСерверПовтИсп.КассаКассовогоСервера() <> ДокументОплаты.УчтенныеАвансы[0].КассаОплаты Тогда
				ВызватьИсключение "Нельзя добавить в очередь фискализации " + ДокументОплаты + " касса документа отличается от кассы кассового сервера!";
			КонецЕсли;
			
		КонецЕсли;      		
		
		Если ДокументОплаты.Проведен = Ложь Тогда
			ВызватьИсключение "Нельзя добавить в очередь фискализации " + ДокументОплаты + " документ не проведен";
		КонецЕсли;
		
		Если (ТипЗнч(ДокументОплаты) <> Тип("ДокументСсылка.Реализация")
			И ЗначениеЗаполнено(ДокументОплаты.НомерЧекаККМ))
			ИЛИ (ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.Реализация")
			И ДокументОплаты.УчтенныеАвансы.НайтиСтроки(Новый Структура("НомерЧекаККМ, ТипАвансовыхСредств", 0, Перечисления.ТипыДенежныхСредств.ЛицевойСчет)).Количество() = 0) Тогда  	

			ВызватьИсключение "Нельзя добавить в очередь фискализации " + ДокументОплаты + " документ пробит на ФР";
		КонецЕсли;
		
	КонецЕсли;
	
	СчетчикПопыток = 0;
	
	Пока СчетчикПопыток < 5 Цикл
		
		НачатьТранзакцию();
		
		Попытка 
			
			МенеджерЗаписи = РегистрыСведений.ОчередьКассовогоСервера.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.ДатаПоступления  = ТекущаяДата();
			МенеджерЗаписи.ДокументОплаты   = ДокументОплаты;
			МенеджерЗаписи.СуммаОплаты      = ?(ТипЗнч(ДокументОплаты) <> Тип("ДокументСсылка.Реализация"),
												ДокументОплаты.СуммаДокумента, 
												Документы.Реализация.ПолучитьСуммуНеФискализированныхУчтенныхАвансов(ДокументОплаты));
			МенеджерЗаписи.Статус           = Перечисления.СтатусыПробитияЧекаКассовымСервером.Ожидание;
			
			МенеджерЗаписи.Записать();
			
			ЗафиксироватьТранзакцию();
			
			Прервать;
			
		Исключение	
			
			ОтменитьТранзакцию();
			
			ОписаниеОшибки = ОписаниеОшибки();
			
			СчетчикПопыток = СчетчикПопыток + 1;
			
			Если СчетчикПопыток = 5 Тогда
				ВызватьИсключение ОписаниеОшибки;
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

