// Процедура, производит запись данные для оповещения клиента.
//
Процедура ПолучитьПараметрыТекущегоПользователяДляОповещения(ДанныеКлиентаСистемыВзаимодействия) Экспорт
	
	ДанныеКлиентаСистемыВзаимодействия = Новый Структура;
	ДанныеКлиентаСистемыВзаимодействия.Вставить("РабочееМесто"		 			   , ПараметрыСеанса.РабочееМестоКлиента);
	ДанныеКлиентаСистемыВзаимодействия.Вставить("ТекущийПользователь"		       , ПараметрыСеанса.ТекущийПользователь);
	ДанныеКлиентаСистемыВзаимодействия.Вставить("НомерСеанса"		 			   , НомерСеансаИнформационнойБазы()); 
	ДанныеКлиентаСистемыВзаимодействия.Вставить("ТекущаяСтруктурнаяЕдиница"		   , ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница); 
	ДанныеКлиентаСистемыВзаимодействия.Вставить("ДатаНачалаСеанса"				   , НачалоДня(ТекущаяДатаСеанса())); 
	
КонецПроцедуры

// Функция, получает ключ обсуждения в системе взаимодействия для журнала оповещений
//
Функция КлючОбсужденияЖурналаОповещений(Ключ = Неопределено, ОтказСистемыВзаимодействия = Ложь) Экспорт
	
	Обсуждение = Неопределено;  
	
	Попытка
		Если Не ЗначениеЗаполнено(Ключ) Тогда
			ТекущийПользователь = ПараметрыСеанса.ТекущийПользователь;
			Ключ = Строка(ТекущийПользователь.ИдентификаторПользователяИБ);	
		КонецЕсли;
		
		#Если НЕ ВнешнееСоединение Тогда
			
			Если НЕ СистемаВзаимодействия.ИнформационнаяБазаЗарегистрирована() Тогда
				Возврат Обсуждение;
			КонецЕсли;
			
			УстановитьПривилегированныйРежим(Истина);
			Попытка
				Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(Ключ);
			Исключение
            	ОтказСистемыВзаимодействия = Истина;
			КонецПопытки;
			
			ПроверитьВозможностьОтправлятьОповещенияЧерезСВ(ОтказСистемыВзаимодействия);

			УстановитьПривилегированныйРежим(Ложь);
			
		#КонецЕсли
	Исключение 
		Возврат Неопределено;
	КонецПопытки;
	
	Если Обсуждение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Обсуждение.Идентификатор;
	
КонецФункции

// Функция, возвращает обсуждение в системе взаимодействия для текущего пользователя.
//
Функция ПолучитьОбсуждениеСотрудника(Сотрудник = Неопределено, ОтказСистемыВзаимодействия = Ложь) Экспорт
	
	Если Сотрудник = Неопределено Тогда
		Сотрудник = ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;

	КлючОбсуждения = Строка(Сотрудник.ИдентификаторПользователяИБ);
	
	Обсуждение = КлючОбсужденияЖурналаОповещений(КлючОбсуждения, ОтказСистемыВзаимодействия);
	Если Обсуждение <> Неопределено Тогда
		Возврат КлючОбсуждения; 
	КонецЕсли;
	
	Возврат Неопределено; 
	
КонецФункции

// Функция - Получить массив активных сотрудников
//
// Параметры:
//  Сотрудники	 - 	 - 
//  РабочиеМеста - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивАктивныхСотрудников(Сотрудники = Неопределено, 
								          РабочиеМеста = Неопределено, 
										  НомераСеансов = Неопределено,
										  СтруктурнаяЕдиница = Неопределено,
										  РольПользователя = Неопределено) Экспорт
										  
	Если Не ЗначениеЗаполнено(Сотрудники) И Не ЗначениеЗаполнено(РабочиеМеста) И Не ЗначениеЗаполнено(НомераСеансов) И Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		Возврат Новый Массив;
	КонецЕсли;
											  									  									  
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СоединенияИнформационнойБазы.Пользователь КАК Сотрудник
	|ПОМЕСТИТЬ ВтАктивныеСотрудники
	|ИЗ
	|	РегистрСведений.СоединенияИнформационнойБазы КАК СоединенияИнформационнойБазы
	|ГДЕ
	|	СоединенияИнформационнойБазы.Активен = ИСТИНА
	|	И &УсловиеСотрудники
	|	И &УсловиеРабочиеМеста
	|	И &УсловиеНомераСеансов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтАктивныеСотрудники КАК ВтАктивныеСотрудники
	|		ПО (ВтАктивныеСотрудники.Сотрудник = Сотрудники.Ссылка)
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеРоль");
	
	УсловиеСотрудники         = ?(ЗначениеЗаполнено(Сотрудники)  	   , "И СоединенияИнформационнойБазы.Пользователь В(&Сотрудники)"  , "И Истина");
	УсловиеРабочиеМеста       = ?(ЗначениеЗаполнено(РабочиеМеста) 	   , "И СоединенияИнформационнойБазы.РабочееМесто В(&РабочееМесто)", "И Истина");
	УсловиеНомераСеансов      = ?(ЗначениеЗаполнено(НомераСеансов)	   , "И СоединенияИнформационнойБазы.НомерСеанса В(&НомерСеанса)"  , "И Истина");
	УсловиеСтруктурнаяЕдиница = ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), "И Сотрудники.ДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "И Истина");
	УсловиеРольПользователя   = ?(ЗначениеЗаполнено(РольПользователя)  , "И Сотрудники.Роль = &РольПользователя", "И Истина");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеСотрудники"   	    , УсловиеСотрудники);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеРабочиеМеста" 	    , УсловиеРабочиеМеста);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеНомераСеансов"	    , УсловиеНомераСеансов);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеСтруктурнаяЕдиница" , УсловиеСтруктурнаяЕдиница);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеРоль"				, УсловиеРольПользователя);
	
	Запрос.УстановитьПараметр("РабочееМесто"	  , РабочиеМеста);
	Запрос.УстановитьПараметр("Сотрудники"  	  , Сотрудники);
	Запрос.УстановитьПараметр("НомерСеанса" 	  , НомераСеансов);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("РольПользователя"  , РольПользователя);	
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");
	
КонецФункции

