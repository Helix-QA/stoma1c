// Процедура, обработчик оповещения.
//
Процедура ЗавершитьРедактированиеЗаметкиЗвонокНаСервере(ТекстЗаметки, ИдЗвонка)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ИсторияВызовов.ОборудованиеТелефонии КАК ОборудованиеТелефонии,
	|	ИсторияВызовов.IDЗвонка КАК IDЗвонка,
	|	ИсторияВызовов.НаправлениеВызова КАК НаправлениеВызова,
	|	ИсторияВызовов.ИсходящийЗвонок КАК ИсходящийЗвонок,
	|	ИсторияВызовов.НомерТелефона КАК НомерТелефона,
	|	ИсторияВызовов.ПользовательSip КАК ПользовательSip,
	|	ИсторияВызовов.НачалоВызова КАК НачалоВызова,
	|	ИсторияВызовов.НачалоРазговора КАК НачалоРазговора,
	|	ИсторияВызовов.ОкончаниеЗвонка КАК ОкончаниеЗвонка,
	|	ИсторияВызовов.Статус КАК Статус,
	|	ИсторияВызовов.URLЗаписи КАК URLЗаписи,
	|	ИсторияВызовов.ФайлЗаписи КАК ФайлЗаписи,
	|	ИсторияВызовов.ПринятДругимАбонентомГруппы КАК ПринятДругимАбонентомГруппы,
	|	ИсторияВызовов.Заявка КАК Заявка,
	|	ИсторияВызовов.НеОбработан КАК НеОбработан,
	|	ИсторияВызовов.ИдентификаторОбрабатывающего КАК ИдентификаторОбрабатывающего,
	|	ИсторияВызовов.ИсточникЗвонка КАК ИсточникЗвонка,
	|	ИсторияВызовов.Пользователь КАК Пользователь,
	|	ИсторияВызовов.Контрагент КАК Контрагент,
	|	ИсторияВызовов.ПопытокПолученияФайлаЗаписи КАК ПопытокПолученияФайлаЗаписи,
	|	ИсторияВызовов.Заметка КАК Заметка
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.IDЗвонка = &IDЗвонка");
	
	Запрос.УстановитьПараметр("IDЗвонка", ИдЗвонка); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		МенеджерЗаписи = РегистрыСведений.ИсторияВызовов.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);	
		МенеджерЗаписи.Заметка = ТекстЗаметки;
		МенеджерЗаписи.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает фильтр истории взаимодействия на сервере.
//
Процедура УстановитьФильтрИсторииВзаимодействияНаСервере(ИмяЭлемента = Неопределено)
	
	Если ЗначениеЗаполнено(ИмяЭлемента) Тогда
		Фильтр = Элементы[ИмяЭлемента];
		УстановитьФильтр = СтрНайти(Фильтр.Подсказка, "Установить") > 0;
		Фильтр.Картинка  = ?(УстановитьФильтр, БиблиотекаКартинок.ФильтрОчистить, БиблиотекаКартинок.Фильтр);
		Фильтр.Подсказка = ?(УстановитьФильтр, "Очистить фильтр", "Установить фильтр"); 
	КонецЕсли;
	
	Если Не Объект.Ссылка.Пустая() Тогда
		
		Фильтры = Новый Структура();
		// Фильтры.Вставить("Задача"      , ПолучитьЗначениеФильтра("Задача")); 	
		Фильтры.Вставить("Заметка"      , ПолучитьЗначениеФильтра("Заметка")); 	
		Фильтры.Вставить("Прием"      , ПолучитьЗначениеФильтра("Прием")); 	
		Фильтры.Вставить("SMS"        , ПолучитьЗначениеФильтра("SMS"));
		Фильтры.Вставить("Письмо"     , ПолучитьЗначениеФильтра("Письмо"));
		Фильтры.Вставить("ПланЛечения", ПолучитьЗначениеФильтра("ПланЛечения"));
		Фильтры.Вставить("Событие"    , ПолучитьЗначениеФильтра("Событие"));
		
		Если ВсеФильтрыОтключены(Фильтры) Тогда
			Фильтры = Новый Структура();
		КонецЕсли;
		
		ОбновитьИсториюВзаимодействияСКлиентом(Фильтры);
		
	КонецЕсли;
	
КонецПроцедуры

