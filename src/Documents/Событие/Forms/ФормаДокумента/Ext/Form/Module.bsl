// Процедура, обработчик события "Пол_НовыйПациентПриИзменении"
//
Процедура Пол_НовыйПациентПриИзменении(Элемент)
	
	Если ТипЗнч(ПризнакСозданияНовогоПациента) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		// Получим ссылку на нового пациента
		Если ЗначениеЗаполнено(ПризнакСозданияНовогоПациента) Тогда
			Ссылка_НовыйПациент = ?(Ссылка_НовыйПациент <> Неопределено И ЗначениеЗаполнено(Ссылка_НовыйПациент), Ссылка_НовыйПациент, ПолучитьСсылкуНаНовогоПациента());
		КонецЕсли;
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ЗначенияЗаполнения"		, Новый Структура("Родственник", ПризнакСозданияНовогоПациента)); 
		ПараметрыФормы.Вставить("ВернутьСтруктуруСвязи"		, Истина);
		ПараметрыФормы.Вставить("Контрагент"				, Ссылка_НовыйПациент);
        ПараметрыФормы.Вставить("ЭтоНовый"					, Истина);
		ПараметрыФормы.Вставить("ПолКонтрагента"			, Пол_НовыйПациент);

		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьРодственнуюСвязь", ЭтотОбъект, ПараметрыФормы);
	    ОткрытьФорму("РегистрСведений.РодственныеСвязи.Форма.ФормаЗаписиБыстрая", ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
						
	КонецЕсли;
	
КонецПроцедуры

