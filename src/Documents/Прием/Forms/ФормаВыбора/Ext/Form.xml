	ДокументПрием.СуммаДокумента,
	ДокументПрием.СуммаОплачено,
	ДокументПрием.ШаблонОбследования,
	ДокументПрием.ЭтоПервичныйПациентДляВрача,
	ДокументПрием.ПроцентЗаполненияОбследования,
	ДокументПрием.ВидНалога,
	ДокументПрием.Сделка,
