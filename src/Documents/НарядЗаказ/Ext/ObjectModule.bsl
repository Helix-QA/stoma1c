// Процедура, обработчик события "ПриКопировании"
//
Процедура ПриКопировании(ОбъектКопирования)

	ЭтотОбъект.Статус 		= Ложь;
	ЭтотОбъект.СуммаПродажи = 0;
	Для Каждого СтрокаТЧ Из ЭтотОбъект.Запасы Цикл
		СтрокаТЧ.НомерЗаказа 	= "";
		СтрокаТЧ.Статус 		= Перечисления.СтатусыНарядЗаказа.Заказано;
		СтрокаТЧ.ДатаЗаказа 	= Неопределено;
		СтрокаТЧ.ДатаВыполнения = Неопределено;
		СтрокаТЧ.Прием 			= Документы.Прием.ПустаяСсылка();
		СтрокаТЧ.ПланЛечения 	= Неопределено;		
	КонецЦикла;
	ЭтотОбъект.Договор = Неопределено;
	СуммаОплаченоПродажи = 0;
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	
КонецПроцедуры

// Обработчик проведения документа
//
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	 // Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);	
    // Инициализация данных документа.	
	Документы.НарядЗаказ.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);	
    // Движения по регистрам		
	ДвиженияДокументовСервер.ВзаиморасчетыСКонтрагентами(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.УстановкаЦен(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.НарядЗаказы(ДополнительныеСвойства, Движения, Отказ); 
	ДвиженияДокументовСервер.ПланыЛечения(ДополнительныеСвойства, Движения, Отказ);   		
	// Запись наборов записей.                                                     	
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);		

КонецПроцедуры

// Обработчик перед записью документа
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	СуммаДокумента = Запасы.Итог("Всего");
	СуммаПродажи   = Запасы.Итог("ВсегоПродажи");
	
	// ПостОбработка Планов лечения
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда 
		ПостОбработкаДокументовАванса(РежимЗаписи, Отказ);
	КонецЕсли;
	
	Перем_РежимЗаписи = РежимЗаписи;
	
КонецПроцедуры

// Процедура, обработчик события "ПриЗаписи"
//
Процедура ПриЗаписи(Отказ)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
		
	МаксИдентификаторСтроки = 0;
	Перезаписать = Ложь;
	Для Каждого СтрокаТЧ из Запасы Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.НомерЗаказа) Тогда
			Ключ = Сред(СтрокаТЧ.НомерЗаказа, Найти(СтрокаТЧ.НомерЗаказа, "-")+1);			
			Если Число(Ключ) > МаксИдентификаторСтроки Тогда
				МаксИдентификаторСтроки = Число(Ключ);
			КонецЕсли;
		КонецЕсли;		
	КонецЦикла;
	Для Каждого СтрокаТЧ из Запасы Цикл
		Если Не ЗначениеЗаполнено(СтрокаТЧ.НомерЗаказа) или Найти(СтрокаТЧ.НомерЗаказа, "-") = 1 Тогда
			МаксИдентификаторСтроки = МаксИдентификаторСтроки + 1;
			СтрокаТЧ.НомерЗаказа = СтрЗаменить(ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Номер, "", Ложь),"-","") + "-"+ МаксИдентификаторСтроки;
			Перезаписать = Истина;
		КонецЕсли;
	КонецЦикла;  
	
	Если Перезаписать Тогда
		Если Перем_РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
			ЭтотОбъект.Записать(РежимЗаписиДокумента.Запись);
			Перем_РежимЗаписи = РежимЗаписиДокумента.Проведение
		Иначе
			ЭтотОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;	
	КонецЕсли;
	
	// Пост-обработка документов аванса
	ПостОбработкаДокументовАванса(, Отказ);
	
	// Автоматическая генерация/синхронизация документов Поступления
	Создать_Синхронизировать_ДокументыПоступления();
	
КонецПроцедуры

// Процедура - обработчик события ОбработкаУдаленияПроведения объекта.
//
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	// Удаляем цены из регистра по документу
	ДвиженияДокументовСервер.УдалениеЦен(Ссылка, Движения, Отказ);
	
КонецПроцедуры

// Процедура, обработчик события "ОбработкаПроверкиЗаполнения"
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Проверка табличной части на разрешения по значениям 
	Если ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьНулевуюСумму, Ложь) Тогда
		УдаляемыйЭлемент = ПроверяемыеРеквизиты.Найти("Запасы.Сумма");
	
		Если УдаляемыйЭлемент <> Неопределено Тогда
			ПроверяемыеРеквизиты.Удалить(УдаляемыйЭлемент);
		КонецЕсли;
	КонецЕсли;
	
	// 1. Определяем вид налога если он не заполнен, для старых документов.	
	Если Запасы.Количество() > 0 Тогда
		ВидНалога    = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Запасы[0].Номенклатура, СтруктурнаяЕдиница);// Запасы[0].Номенклатура.ВидНалога;
		Номенклатура = Запасы[0].Номенклатура;
	Иначе
		Возврат;
	КонецЕсли;
	
	ЕстьРазличия = Ложь;
	Для Каждого СтрокаТЧ Из Запасы Цикл
		Если НЕ Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(СтрокаТЧ.Номенклатура, СтруктурнаяЕдиница) = ВидНалога Тогда
			ЕстьРазличия = Истина;	
			мНоменклатура = СтрокаТЧ.Номенклатура;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьРазличия Тогда
		Отказ = Истина;
		ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения. Номенклатура '%1' и '%2' используют разные режимы налогообложения";
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Номенклатура, мНоменклатура);	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;

КонецПроцедуры

