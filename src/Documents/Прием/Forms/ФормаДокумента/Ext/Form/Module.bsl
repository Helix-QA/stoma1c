#Область ОценкиИОтзывы

&НаСервере
// Процедура, Обновить элементы статус оценки
//
Процедура СформироватьОценкиИОтзывы()
	
	ОценкиПриема = РегистрыСведений.ОценкиПриемов.ПолучитьОценкиСотрудниковПриема(Объект.Ссылка);
	
	Если ЗначениеЗаполнено(ОценкиПриема) Тогда 
		
		ОценкаПриема      = Неопределено;
		КомментарийОценки = "";
		
		Если ОценкиПриема.Количество() = 1 Тогда 
			
			ОценкаПриема      = ОценкиПриема[0].Оценка;
			КомментарийОценки = ОценкиПриема[0].Комментарий; 
		Иначе 	
			Оценка           = 0;
			КоличествоОценок = 0;
			
			Для Каждого СтрокаТ Из ОценкиПриема Цикл
				
				Если ЗначениеЗаполнено(СтрокаТ.Оценка) Тогда 
					
					Если Не СтрНайти(КомментарийОценки, СтрокаТ.Комментарий) > 0 Тогда  
						КомментарийОценки = КомментарийОценки + Символы.ПС + СтрокаТ.Комментарий; 
					КонецЕсли;
					
					Оценка            = Оценка + СтрокаТ.Оценка; 
					КоличествоОценок  = КоличествоОценок + 1;
				КонецЕсли;
				
			КонецЦикла;	
			
			Если Оценка <> 0 Тогда 
				ОценкаПриема = Оценка/КоличествоОценок;	
			КонецЕсли;	
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ОценкаПриема) Тогда 
			Возврат;
		КонецЕсли;	
	Иначе
		Возврат;
	КонецЕсли;		
	
	ЭтотОбъект.ОтображатьОценкиИОтзывы        = Истина;
	ЭтаФорма.Элементы.ГруппаРейтинг.Видимость = Истина;			
	
	Для а = 1 по 5 Цикл
		
		Если ОценкаПриема = 0.5 Тогда
			Картинка = БиблиотекаКартинок.РейтингЗвездаПоловина;
		ИначеЕсли ОценкаПриема > 0.5 Тогда
			
			Картинка = БиблиотекаКартинок.РейтингЗвездаЗаполненная;
		Иначе
			Картинка = БиблиотекаКартинок.РейтингЗвездаПустая;
		КонецЕсли;				
		
		ДекорацияЗвезда                      = ЭтаФорма.Элементы["Рейтинг" + а];
		ДекорацияЗвезда.Картинка             = Картинка;
		ДекорацияЗвезда.Подсказка            = КомментарийОценки;
		ДекорацияЗвезда.ОтображениеПодсказки = ОтображениеПодсказки.Всплывающая; 
		
		ОценкаПриема = ОценкаПриема - 1;
		
	КонецЦикла;	
	
	СформироватьБлокОценкиИОтзывы(ОценкиПриема);	
	
КонецПроцедуры  

&НаСервере
// Процедура, выполянет создание блока история визитов
//
Процедура СформироватьБлокОценкиИОтзывы(ОценкиПриема)
	
	ИдСтроки          = 1;
	ДатаОценки        = Неопределено;
	
	СоздатьЭлементДекорация("ДекорацияРазделениеДаты_0", Элементы.ГруппаОценкиИОтзывы, "", 127,, Истина,, Истина);
	
	// Сформировать таблицу оценок
	Для Каждого СтрокаОценка Из ОценкиПриема Цикл 
		
		Если СтрокаОценка.Период <> ДатаОценки Тогда  
			
			Сотрудник = Неопределено;
			
			// Дата оценивания
			ДатаОценки = СтрокаОценка.Период;
			Дата       = ПолучитьПредставлениеДатыОценивания(ДатаОценки);
			
			ГруппаВыравнивание = СоздатьЭлементГруппа(
			"ГруппаВыравнивание_" + ИдСтроки, 
			Элементы.ГруппаОценкиИОтзывы, 
			ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
			127);
			
			СоздатьЭлементДекорация("ДекорацияДатаОценки_" + ИдСтроки, ГруппаВыравнивание, Дата, 10, ВертикальноеПоложениеЭлемента.Верх); 
			
			ГруппаДанныеОценкиСотрудникаВертикальная = СоздатьЭлементГруппа(
			"ГруппаДанныеОценкиСотрудникаВертикальная" + ИдСтроки, 
			ГруппаВыравнивание, 
			ГруппировкаПодчиненныхЭлементовФормы.Вертикальная, 
			117);
			
			СоздатьЭлементДекорация("ДекорацияРазделениеДаты_" + ИдСтроки, Элементы.ГруппаОценкиИОтзывы, "", 127,, Истина,, Истина);
			
		КонецЕсли;
		
		Если Сотрудник <> СтрокаОценка.Сотрудник Тогда 
			
			// Разделение сотрудников
			Если Сотрудник <> Неопределено Тогда 
				СоздатьЭлементДекорация("ДекорацияРазделениеСотрудника_" + ИдСтроки, ГруппаДанныеОценкиСотрудникаВертикальная, "", 117,, Истина,, Истина); 
			КонецЕсли;
			
			Сотрудник = СтрокаОценка.Сотрудник;
			
			// Данные оценок сотрудника			
			ГруппаДанныеОценкиСотрудникаГоризонтальная = СоздатьЭлементГруппа(
			"ГруппаДанныеОценкиСотрудникаГоризонтальная" + ИдСтроки, 
			ГруппаДанныеОценкиСотрудникаВертикальная, 
			ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
			117);
			
			// Оценки сотрудника			
			ГруппаОценкаСотрудникаВертикальная = СоздатьЭлементГруппа(
			"ГруппаОценкаСотрудникаВертикальная" + ИдСтроки, 
			ГруппаДанныеОценкиСотрудникаГоризонтальная, 
			ГруппировкаПодчиненныхЭлементовФормы.Вертикальная, 
			28);
			
			// Сотрудник
			СоздатьЭлементКнопка(
			ИдСтроки, 
			СтрокаОценка.Сотрудник.Наименование, 
			ГруппаДанныеОценкиСотрудникаГоризонтальная, 
			"Сотрудник",, 
			Строка(СтрокаОценка.Сотрудник), 
			28);
			
			// Услуги
			УслугиСотрудника = ПолучитьУслугиСотрудника(СтрокаОценка.Сотрудник, Объект.Лечение);
			
			СоздатьЭлементДекорация("Состав_" + ИдСтроки, ГруппаДанныеОценкиСотрудникаГоризонтальная, УслугиСотрудника, 18); 
			
			Комментарий = ПолучитьКомментарийСотрудника(ОценкиПриема, СтрокаОценка.Период, СтрокаОценка.Сотрудник);
			
			СоздатьЭлементДекорация("Комментарий_" + ИдСтроки, ГруппаДанныеОценкиСотрудникаГоризонтальная, Комментарий, 35,,, Комментарий); 			
			
		КонецЕсли;
		
		// Оценка сотрудника
		ГруппаОценкаИПараметрСотрудникаГоризонтальная = СоздатьЭлементГруппа(
		"ГруппаОценкаИПараметрСотрудникаГоризонтальная" + ИдСтроки, 
		ГруппаОценкаСотрудникаВертикальная, 
		ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
		28);
		
		Если СтрокаОценка.Оценка > 0 Тогда
			
			ГруппаОценкаСотрудникаГоризонтальная = СоздатьЭлементГруппа(
			"ГруппаОценкаСотрудникаГоризонтальная" + ИдСтроки, 
			ГруппаОценкаИПараметрСотрудникаГоризонтальная, 
			ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
			14);
			
			ОценкаСотрудника = СтрокаОценка.Оценка;
			
			// Пятибальная
			ИдСтрокиОценкаСотрудника = 1;
			Для а = 1 по 5 Цикл
				
				Декорация = Элементы.Вставить("ОценкаСотрудника" + ИдСтроки + "_" + ИдСтрокиОценкаСотрудника, Тип("ДекорацияФормы"), ГруппаОценкаСотрудникаГоризонтальная);
				
				Декорация.Вид                  = ВидДекорацииФормы.Картинка;
				Декорация.Картинка             = ?(ОценкаСотрудника > 0, БиблиотекаКартинок.РейтингЗвездаЗаполненная, БиблиотекаКартинок.РейтингЗвездаПустая);
				Декорация.Подсказка            = СтрокаОценка.Комментарий;
				Декорация.ОтображениеПодсказки = ОтображениеПодсказки.Всплывающая; 
				ОценкаСотрудника 		       = ОценкаСотрудника - 1;
				
				ИдСтрокиОценкаСотрудника = ИдСтрокиОценкаСотрудника + 1;
				
			КонецЦикла;	
			
		Иначе
			СоздатьЭлементДекорация("ОценкаСотрудника" + ИдСтроки, ГруппаОценкаИПараметрСотрудникаГоризонтальная, "", 14); 
		КонецЕсли;
		
		СоздатьЭлементДекорация("ПараметрОценки_" + ИдСтроки, ГруппаОценкаИПараметрСотрудникаГоризонтальная, СтрокаОценка.ПараметрОценки, 14); 
		
		СтрокаТЧ                = ЭтотОбъект.ТаблицаОценок.Добавить();
		СтрокаТЧ.Дата           = Дата;
		СтрокаТЧ.Оценка         = СтрокаОценка.Оценка;	
		СтрокаТЧ.ПараметрОценки = СтрокаОценка.ПараметрОценки;	
		СтрокаТЧ.Сотрудник      = СтрокаОценка.Сотрудник;
		СтрокаТЧ.Состав         = УслугиСотрудника;	
		СтрокаТЧ.Комментарий    = СтрокаОценка.Комментарий;
		
		ИдСтроки = ИдСтроки + 1;
		
	КонецЦикла;	
	
	ОценкиПриема.Свернуть("Сотрудник");
