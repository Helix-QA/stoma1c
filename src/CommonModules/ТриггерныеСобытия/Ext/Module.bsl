	// --------------Выключаем регламент пока обновляем настройки------------

	ТаблицаТриггеров = ТаблицаНастроекКаналовУведомлений.Скопировать(, "ТриггерСсылка");
	ТаблицаТриггеров.Свернуть("ТриггерСсылка");
	
	Для Каждого СтрокаТриггер Из ТаблицаТриггеров Цикл
		Триггер_Объект = СтрокаТриггер.ТриггерСсылка.ПолучитьОбъект();
		Триггер_Объект.НастройкиКаналовУведомлений.Очистить();
		МассивСтрокНастроек = ТаблицаНастроекКаналовУведомлений.НайтиСтроки(Новый Структура("ТриггерСсылка", СтрокаТриггер.ТриггерСсылка));
		Для Каждого СтрокаНастройкаКанала Из МассивСтрокНастроек Цикл
			// Актуализируем пуши
			ОтправкаPush 								= СтрокаНастройкаКанала.ОтправкаPush;
			СтрокаНастройкаКанала.ОтправкаPush 			= Ложь;
			ОтправкаPushWallet 							= СтрокаНастройкаКанала.ОтправкаPushWallet;
			СтрокаНастройкаКанала.ОтправкаPushWallet 	= Ложь;
			Для Каждого СтрокаВнешняяСистема Из ТаблицаВнешнихСистем Цикл
				Если ОтправкаPush Тогда 
					СтрокаНастройкаКанала.ОтправкаPush 			= Макс(СтрокаНастройкаКанала.ОтправкаPush		, (СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.МобильноеПриложениеКлиента И (СтрокаНастройкаКанала.СтруктурнаяЕдиница = СтрокаВнешняяСистема.СтруктурнаяЕдиница ИЛИ НЕ ЗначениеЗаполнено(СтрокаВнешняяСистема.СтруктурнаяЕдиница))));
				Иначе 
					СтрокаНастройкаКанала.ОтправкаPush 			= Мин(СтрокаНастройкаКанала.ОтправкаPush		, (СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.МобильноеПриложениеКлиента И (СтрокаНастройкаКанала.СтруктурнаяЕдиница = СтрокаВнешняяСистема.СтруктурнаяЕдиница ИЛИ НЕ ЗначениеЗаполнено(СтрокаВнешняяСистема.СтруктурнаяЕдиница))));
				КонецЕсли;
				Если ОтправкаPushWallet Тогда 
					СтрокаНастройкаКанала.ОтправкаPushWallet 	= Макс(СтрокаНастройкаКанала.ОтправкаPushWallet	, (СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet И (СтрокаНастройкаКанала.СтруктурнаяЕдиница = СтрокаВнешняяСистема.СтруктурнаяЕдиница ИЛИ НЕ ЗначениеЗаполнено(СтрокаВнешняяСистема.СтруктурнаяЕдиница))));
				Иначе 
					СтрокаНастройкаКанала.ОтправкаPushWallet 	= Мин(СтрокаНастройкаКанала.ОтправкаPushWallet	, (СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet И (СтрокаНастройкаКанала.СтруктурнаяЕдиница = СтрокаВнешняяСистема.СтруктурнаяЕдиница ИЛИ НЕ ЗначениеЗаполнено(СтрокаВнешняяСистема.СтруктурнаяЕдиница))));
				КонецЕсли;
				
				Если НЕ СтрокаНастройкаКанала.ОтправкаMessenger Тогда 
					АккаунтВнешнейСистемы = Справочники.ВнешниеСистемы.ПустаяСсылка();
					КаналСистемыСообщений = "";
					Продолжить;
				КонецЕсли;	
			КонецЦикла;
			// Актуализируем мессенджеры
			Если НЕ ЗначениеЗаполнено(СтрокаНастройкаКанала.АккаунтВнешнейСистемы) Тогда 
				СтрокаНастройкаКанала.ОтправкаMessenger = Ложь;
