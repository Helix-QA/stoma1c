&НаКлиенте
// Процедура, удаляет динамический элемент.
//
Процедура УдалитьДинамическийЭлемент(Элемент, СтрокаСЭ = Истина)
	
	Индекс                = ПолучитьИндексНаименования(Элемент.Имя);
	КлючСтроки            = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(Индекс)].КлючСтроки;
	ЭквайринговыйТерминал = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(Индекс)].ЭквайринговыйТерминал; 
	
	НайденныеСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки));
	Если СтрокаСЭ Тогда	
		Для Каждого СтрокаНС Из НайденныеСтроки Цикл
			ИндексСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Индекс(СтрокаНС);
			ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Удалить(ИндексСтроки);
		КонецЦикла;		
	Иначе
		
		ИндексСтрокиСЕ = ПолучитьИндексНаименования(Элемент.Родитель.Родитель.Имя);
		Элементы["ГруппаЭквайринговыеТерминалыВсплывающая_" + Число(ИндексСтрокиСЕ)].Скрыть();
		
		Если НайденныеСтроки.Количество() = 1 Тогда
			ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(Индекс)].ЭквайринговыйТерминал = Неопределено;
		Иначе	
			Для Каждого СтрокаНС Из НайденныеСтроки Цикл
				Если СтрокаНС.ЭквайринговыйТерминал = ЭквайринговыйТерминал Тогда
					ИндексСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Индекс(СтрокаНС);
					ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Удалить(ИндексСтроки);
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	УдалитьДинамическиеЭлементыИПерезаполнитьСписок();	
	
КонецПроцедуры	

&НаСервере
// Процедура, удаляет перезаполняет список СЭС динамически на сервере.
//
Процедура УдалитьДинамическиеЭлементыИПерезаполнитьСписок()
	
	УправлениеИнтерфейсамиСервер.УдалитьПодчиненныеЭлементыГруппы(ЭтаФорма, Элементы.ГруппаОбщаяДляСтруктурныхЕдиниц, Неопределено);
	ЗаполнитьСтруктурноЭкайринговыеСоответствия();
	
КонецПроцедуры

&НаСервере
// Процедура, заполняе структурно эквайринговые соответствия.
//
Процедура ЗаполнитьСтруктурноЭкайринговыеСоответствия()
	
	МассивПроверреныхСЕ = Новый Массив;
	ТекущаяСЕ           = Неопределено;
	ИндексГруппы        = -1;
	ИндексТЧ            = 0;
	
	ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Сортировать("СтруктурнаяЕдиница");
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.СтруктурноЭквайринговыеСоответствия Цикл
		
		Если ТекущаяСЕ <> СтрокаТЧ.СтруктурнаяЕдиница ИЛИ ТекущаяСЕ = Неопределено Тогда
			
			ТекущаяСЕ = СтрокаТЧ.СтруктурнаяЕдиница;
			
			Если Не ЗначениеЗаполнено(ТекущаяСЕ) ИЛИ МассивПроверреныхСЕ.Найти(ТекущаяСЕ) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			МассивПроверреныхСЕ.Добавить(ТекущаяСЕ);
			
			ИндексГруппы = ИндексГруппы + 1;
			ДобавитьСтруктурнуюЕдиницуНаФорму(ИндексГруппы, ИндексТЧ, Истина);
			
			НайденныеСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ТекущаяСЕ));
			
			Для Каждого НайденнаяСтрока ИЗ НайденныеСтроки Цикл
				
				ДобавитьЭквайринговыйТерминалНаФорму(ИндексГруппы, ИндексТЧ, Истина);
				
				// Организация эквайрингового тиерминала:
				Организация = ПолучитьЗначенияРеквизитовПоСсылке(НайденнаяСтрока.ЭквайринговыйТерминал, "Организация");
				Элементы["ДекорацияОрганизация_" + ИндексТЧ].Заголовок = Строка(Организация);
				
				ИндексТЧ = ИндексТЧ + 1;
				
			КонецЦикла;	
			
			// Количество эквайринговых терминалов:
			НайденныеСтрокиЭТ = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ТекущаяСЕ));
			КоличествоЭТ      = 0;
			Для Каждого СтрокаНС Из НайденныеСтрокиЭТ Цикл
				Если ЗначениеЗаполнено(СтрокаНС.ЭквайринговыйТерминал) Тогда
					КоличествоЭТ = КоличествоЭТ + 1;	
				КонецЕсли;
			КонецЦикла;		
			УстановитьЗаголовЭТНаСервере(ИндексГруппы, КоличествоЭТ);
			
			// Продолжаем с текущеей позиции
			ИндексГруппы = ИндексТЧ - 1;
			
		КонецЕсли;
		
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
// Процедура - Установить заголов ЭТНа сервере
//
// Параметры:
//  ИндексСтрокиСЕ	 - 	 - 
//  КоличествоЭТ	 - 	 - 
//
Процедура УстановитьЗаголовЭТНаСервере(ИндексСтрокиСЕ, КоличествоЭТ)
	
	ДекорацияНажатие = Элементы.Найти("ДекорацияНажатиеЭквайриговыеТерминалы_" + ИндексСтрокиСЕ);
	ДекорацияНажатие.Заголовок = Нстр("ru = 'Эквайринговые терминалы('; en = 'Acquiring terminals('") + КоличествоЭТ + ")";
	
КонецПроцедуры

&НаКлиенте
