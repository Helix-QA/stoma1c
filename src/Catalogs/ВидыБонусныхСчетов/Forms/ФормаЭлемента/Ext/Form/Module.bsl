&НаСервере
// Удалить элементы формы связанные с удаляемым временем занятия
//
Процедура УдалитьЭлементыФормыСоставУслуг(ИДСтрокиДанных)
	
	// При удалении выбранного времени занятия проводим удаление элементов
	// формы и строки в таблице данных т.к. индексы в таблице данных
	// смещаются, необходимо переопределить путь к данным для элементов
	// следующих после удаленных. Сделать это невозможно, поэтому мы вынуждены 
	// создать их заново.
	
	// Ищем строку в данных по ИД
	СтрокаДанных = Объект.ПакетУслугСоставУслуг.НайтиПоИдентификатору(ИДСтрокиДанных);	
	Если СтрокаДанных <> Неопределено Тогда
		
		// Удаляем элементы
		Для Каждого СтрокаТЗ Из Объект.ПакетУслугСоставУслуг Цикл
			Элементы.Удалить(Элементы[ПараметрыСозданияЭлементовФормы.СоставУслугКнопкаУдалить				 + СтрокаТЗ.ПолучитьИдентификатор()]);
			Элементы.Удалить(Элементы[ПараметрыСозданияЭлементовФормы.СоставУслугВидЦены					 + СтрокаТЗ.ПолучитьИдентификатор()]);
			Элементы.Удалить(Элементы[ПараметрыСозданияЭлементовФормы.СоставУслугУслугаСегмент				 + СтрокаТЗ.ПолучитьИдентификатор()]);
			Элементы.Удалить(Элементы[ПараметрыСозданияЭлементовФормы.СоставУслугПереключательУслугаСегмент	 + СтрокаТЗ.ПолучитьИдентификатор()]);
			Элементы.Удалить(Элементы[ПараметрыСозданияЭлементовФормы.СоставУслугГруппаЭлементов			 + СтрокаТЗ.ПолучитьИдентификатор()]);
		КонецЦикла;
		
		// Удалить строку из данных
		Объект.ПакетУслугСоставУслуг.Удалить(СтрокаДанных);
		
		// Создаем элементы взамен удаленных на пред. этапе	  
		Для Каждого СтрокаТЗ Из Объект.ПакетУслугСоставУслуг Цикл
			ДобавитьЭлементыФормыСоставаУслуг(СтрокаТЗ.ПолучитьИдентификатор());				
		КонецЦикла;
		
		УстановитьВидимостьЭлементов();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция вернет идентификатор строки данных по имени элемента
//
Функция ИдентификаторСтрокиДанныхПоИмениЭлемента(ИмяЭлемента)
	
	НомерСимвола = Найти(ИмяЭлемента,"_");
	Возврат Число(Прав(ИмяЭлемента,СтрДлина(ИмяЭлемента) - НомерСимвола)); 
	
КонецФункции

&НаСервере
// Процедура, устанавливает видимость элементов формы.
//
// Параметры:
//  Нет.
//
Процедура УстановитьВидимостьЭлементов()
	
	// -----------------------------------Ограничение процента списания---------------------------------------	
	
	Если Объект.НеОграниченПроцентомСписания Тогда		
		Элементы.ОграничениеСписанияПроцент.Видимость 	= Ложь;
		Элементы.ДекорацияПроцент.Видимость 			= Ложь;		
	Иначе		
		Элементы.ОграничениеСписанияПроцент.Видимость 	= Истина;
		Элементы.ДекорацияПроцент.Видимость 			= Истина;		
	КонецЕсли;	
	
	// -----------------------------Ограничение срока действия бонусного счета--------------------------------
	
	// Бессрочный
	Если Объект.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный  Тогда 
		
		Элементы.ГруппаПараметрыСрокаДействия.Видимость 			= Ложь;
		Элементы.ГруппаПараметрыСрокаДействияДата_С_По.Видимость 	= Ложь;
		
	// Срок действия с.. по..
	ИначеЕсли Объект.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокДействия_С_По Тогда	
		
		Если Объект.СрокДействияДатойС = Дата(1,1,1) Тогда 
			Объект.СрокДействияДатойС = ТекущаяДата();
		КонецЕсли;	
		
		Элементы.ГруппаПараметрыСрокаДействия.Видимость 			= Ложь;
		Элементы.ГруппаПараметрыСрокаДействияДата_С_По.Видимость 	= Истина;
		
	// Срок ограничен периодом	
	ИначеЕсли Объект.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокОграниченПериодом Тогда
		
		Элементы.ГруппаПараметрыСрокаДействия.Видимость 			= Истина;
		Элементы.ГруппаПараметрыСрокаДействияДата_С_По.Видимость 	= Ложь;
		
	Иначе 
		
		Элементы.ГруппаПараметрыСрокаДействия.Видимость 			= Ложь;
		Элементы.ГруппаПараметрыСрокаДействияДата_С_По.Видимость 	= Ложь;
		
	КонецЕсли;
	
	// -----------------------Ограничение срока действия начислений бонусного счета--------------------------
	
	// Бессрочный
	Если Объект.ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный  Тогда 
		
		Элементы.ГруппаПараметрыСрокаДействияНачислений.Видимость = Ложь;
		
	// Срок ограничен периодом	
	ИначеЕсли Объект.ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокОграниченПериодом Тогда
		
		Элементы.ГруппаПараметрыСрокаДействияНачислений.Видимость = Истина;
		
	Иначе
		
		Элементы.ГруппаПараметрыСрокаДействияНачислений.Видимость = Ложь;
		
	КонецЕсли;
			
КонецПроцедуры

#КонецОбласти
