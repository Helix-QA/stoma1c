		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Взаимодействие.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	Взаимодействие.АвторДокумента КАК Пользователь,
	Взаимодействие.ИсточникИнформации КАК ИсточникИнформации,
	Взаимодействие.Дата КАК Дата,
	Взаимодействие.ЗадачаПредмет КАК Пациент,
	Взаимодействие.Задача КАК Тема,
	Взаимодействие.ЗадачаОписание КАК Описание,
	Взаимодействие.ПредварительнаяЗаписьНаСледующийПрием КАК ЗаписьНаПрием,
	1 КАК Количество
ИЗ
	Документ.Взаимодействие КАК Взаимодействие
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL 
					И &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА Взаимодействие.Дата &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL 
					И &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА Взаимодействие.Дата &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}</query>
