// Обработчик при начале выбора банковского счета списания средств
Процедура БанковскийСчетСписанияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	РеквизитВладельца = Неопределено;
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
	    РеквизитВладельца = Объект.Контрагент;
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеИзБанка") Тогда
		РеквизитВладельца = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.СтруктурнаяЕдиница, "Организация");
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(РеквизитВладельца) Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ОткрытьФорму("Справочник.БанковскиеСчета.ФормаВыбора", 
		Новый Структура("Владелец", РеквизитВладельца),,,,, 
		Новый ОписаниеОповещения("БанковскийСчетСписанияНачалоВыбораЗавершение", ЭтотОбъект), 
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	КонецЕсли;
	
