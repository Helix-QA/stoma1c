
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.МаксимальноеКоличествоЗаявокВКолонке = 15;
	
	ЭтотОбъект.ТекущийСотрудник				 = ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница	 = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ЭтотОбъект.ЭтоПолноправныйПользователь	 = РольДоступна(Метаданные.Роли.ПолныеПрава);
	
	Если Параметры.Свойство("ПараметрыОтбора") И ЗначениеЗаполнено(Параметры.ПараметрыОтбора) Тогда
		ОбновитьМеханизмФильтрацииДанных(Параметры.ПараметрыОтбора, Истина);
	Иначе
		ИнициализироватьМеханизмФильтрацииДанных(, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	// Запускаем обновление канбана раз в 10 минут.
	ПодключитьОбработчикОжидания("ОбновитьПредставлениеКанбана", 600, Ложь);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если Источник = ЭтотОбъект Тогда
		// Не обрабатываем оповещения из этой же формы.
		Возврат;
	КонецЕсли;
	
	Если ИмяСобытия = "ЗаписанаНоваяЗаявка" Тогда
		
		// Запись из карточки заявки.
		ОбработатьИзменениеЗаявки(Параметр);
		
	ИначеЕсли ИмяСобытия = "ОповещениеОНовыхЗаявках" Тогда
		
		// Создание новой или изменение существующей заявки в другом сеансе.
		ОбработатьОповещениеОНовойЗаявке(Параметр);
		
	ИначеЕсли ИмяСобытия = "ОбновленСтатусЗаявки" Тогда
		
		// Изменение статуса заявки в другом сеансе.
		ОбработатьОповещениеОНовойЗаявке(Параметр);
		
	ИначеЕсли ИмяСобытия = "ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ" Тогда
		
		// Записана сделка, обновляем данные в блоке заявки.
		ОбработатьИзменениеСделки(Параметр);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОткрытьСписок(Команда)
	
	ПерейтиВСписок();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОбновитьКанбан(Команда)
	
	ОбновитьПредставлениеКанбана();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриНажатии".
//
Процедура КанбанПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	                             
	Если ДанныеСобытия.Element.id = "eventSender" Тогда
		
		ОбработатьВызовСобытия(ДанныеСобытия.Element.dataset.eventName);
		
	ИначеЕсли ДанныеСобытия.Element.className = "phone-number" Тогда
		
		Если Не ЭтотОбъект.ТелефонияДоступна Тогда
			// Если не доступна телефония - ничего не делаем при нажатии на номер.
			Возврат;
		КонецЕсли;
		
		ИдентификаторЗаявки = ДанныеСобытия.Element.closest(".item-col").id;
		ПредставлениеНомера = ДанныеСобытия.Element.innerText;
		СовершитьЗвонок(ИдентификаторЗаявки, ПредставлениеНомера);
			
	ИначеЕсли ДанныеСобытия.Element.className = "ico-chat" Тогда
		
		ИдентификаторЗаявки = ДанныеСобытия.Element.closest(".item-col").id;
		ПерейтиКДиалогу(ИдентификаторЗаявки);
			
	ИначеЕсли ДанныеСобытия.Element.className = "manager" Тогда
		
		ИдентификаторСотрудника = ДанныеСобытия.Element.id;
		ОткрытьСотрудника(ИдентификаторСотрудника);
		
	ИначеЕсли ДанныеСобытия.Element.className = "title-col" Тогда
		
		ИдентификаторЗаявки = ДанныеСобытия.Element.dataset.requestId;
		ОткрытьЗаявку(ИдентификаторЗаявки);
		
	ИначеЕсли ДанныеСобытия.Element.className = "client-name" Тогда
		
		ИдентификаторКлиента = ДанныеСобытия.Element.id;
		ОткрытьКлиента(ИдентификаторКлиента);
		
	ИначеЕсли ДанныеСобытия.Element.className = "button-create" Тогда
		
		СоздатьЗаявку();
		
	ИначеЕсли ДанныеСобытия.Element.className = "deal" Тогда
		
		ИдентификаторСделки = ДанныеСобытия.Element.id;
		ОткрытьСделку(ИдентификаторСделки);
		
	ИначеЕсли СтрЧислоВхождений(ДанныеСобытия.Element.className, "show-all") Тогда
		
		Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок." + ДанныеСобытия.Element.dataset.status);
		ПерейтиВСписок(Статус);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура, устанавливает отбор по статусу.
//
Процедура УстановитьОтбор(ПараметрыОтбора) Экспорт
	
	// Используется для установки фильтра из формы канбана.
	// См. ФормаСписка.ОткрытьКанбан.
	ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора, Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет канбан.
//
Процедура ОбновитьПредставлениеКанбана() Экспорт
	
	СформироватьКанбан();
	ЭтотОбъект.ТекущийЭлемент = Элементы.Канбан;
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет переход на форму списка с установкой фильтра по статусу.
//
Процедура ПерейтиВСписок(Статус = Неопределено)
	
	ФормаСписка = ПолучитьОткрытуюФорму("Справочник.Заявки.Форма.ФормаСписка");
	
	ПараметрыОтбора = ПараметрыВыбранныхФильтровКлиент();
	
	Если ЗначениеЗаполнено(Статус) Тогда

		МассивСтатусов				 = Новый_Массив(Статус);
		МассивСтатусов_ВариантОтбора = Истина;

		ПараметрыОтбора.Вставить("МассивСтатусов"				, МассивСтатусов);
		ПараметрыОтбора.Вставить("МассивСтатусов_ВариантОтбора"	, МассивСтатусов_ВариантОтбора);
		
	КонецЕсли;
	
	Если ФормаСписка = Неопределено Тогда
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ПараметрыОтбора", ПараметрыОтбора);
		
		ОткрытьФормуСписка(ПараметрыОткрытия);
		
	Иначе
		ФормаСписка.Активизировать();
		ФормаСписка.УстановитьОтбор(ПараметрыОтбора);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, открывает форму списка заявок.
//
Процедура ОткрытьФормуСписка(ПараметрыОткрытия = Неопределено)
	
	ОткрытьФорму("Справочник.Заявки.Форма.ФормаСписка", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обрабатывает вызов события из HTML-документа.
//
Процедура ОбработатьВызовСобытия(ИмяСобытия)
	
	Если ИмяСобытия = "drop" Тогда
		ИзменитьСтатусЗаявки();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, изменяет статус заявки.
//
Процедура ИзменитьСтатусЗаявки()
	
	Документ = Элементы.Канбан.Документ;
	
	Если Документ.defaultView.dropElement.parentElement = Документ.defaultView.dropSource Тогда
		// Заявка осталась в том же блоке.
		Возврат;
	КонецЕсли;
	
	НовыйСтатус			 = Документ.defaultView.dropTarget.parentElement.dataset.id;
	ИдентификаторЗаявки	 = Документ.defaultView.dropElement.querySelector(".item-col").id;
	
	КоличествоЗаявокВИсточникеВсего		 = Число(Документ.defaultView.dropSource.parentElement.querySelector(".item-count").dataset.count);
	КоличествоЗаявокВИсточникеТекущее	 = Документ.defaultView.dropSource.querySelectorAll(".kanban-item").length;
	ТребуетсяПолучитьЗаявкуИзОчереди	 = КоличествоЗаявокВИсточникеВсего > Макс(ЭтотОбъект.МаксимальноеКоличествоЗаявокВКолонке, КоличествоЗаявокВИсточникеТекущее + 1);
	
	Если ТребуетсяПолучитьЗаявкуИзОчереди Тогда
		
		ИдентификаторыИсключаемыхЗаявок = Новый Массив;
		
		Для Каждого БлокЗаявки Из Документ.defaultView.dropSource.children Цикл
			
			Если БлокЗаявки.className = "show-all" Тогда
				Продолжить;
			КонецЕсли;
			
			ИдентификаторыИсключаемыхЗаявок.Добавить(БлокЗаявки.children[0].id);
			
		КонецЦикла;
		
		СтатусДоИзменения = Документ.defaultView.dropSource.parentElement.dataset.id;
		
		ПараметрыПолученияЗаявкиИзОчереди = Новый Структура;
		ПараметрыПолученияЗаявкиИзОчереди.Вставить("Статус"							, СтатусДоИзменения);
		ПараметрыПолученияЗаявкиИзОчереди.Вставить("ИдентификаторыИсключаемыхЗаявок", ИдентификаторыИсключаемыхЗаявок);
		
	КонецЕсли;
	
	Если НовыйСтатус = "Принята" Тогда
		ОбработатьКачественнуюЗаявки(ИдентификаторЗаявки, ПараметрыПолученияЗаявкиИзОчереди);
	ИначеЕсли НовыйСтатус = "Отклонена" Тогда
		ОбработатьНекачественнуюЗаявку(ИдентификаторЗаявки, ПараметрыПолученияЗаявкиИзОчереди);
	Иначе
		ОбработатьЗаявкуВРаботе(ИдентификаторЗаявки, НовыйСтатус, ПараметрыПолученияЗаявкиИзОчереди);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет представление сделки в блоках заявок.
//
Процедура ОбработатьИзменениеСделки(Сделка)
	
	Если Не ЗначениеЗаполнено(Сделка) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОбновленияСделок = ПолучитьПараметрыОбновленияСделок(Сделка);
	
	Если Не ЗначениеЗаполнено(ПараметрыОбновленияСделок) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСделки		 = ПараметрыОбновленияСделок.ДанныеСделки;
	ИдентификаторКлиента = Строка(ПараметрыОбновленияСделок.Контрагент.УникальныйИдентификатор());
	
	Документ = Элементы.Канбан.Документ;
	Селектор = "#" + Документ.CSS.escape(ИдентификаторКлиента) + ".client-name";
	
	// Нужно обновить блоки всех заявок, привязанных к этому клиенту.
	БлокиКлиентаОбновляемыхЗаявок = Документ.querySelectorAll(Селектор);
	
	Для Каждого БлокКлиента Из БлокиКлиентаОбновляемыхЗаявок Цикл
		
		БлокСделки			 = БлокКлиента.parentElement.querySelector(".deal");
		БлокСделки.id		 = ДанныеСделки.ИдентификаторСделки;
		БлокСделки.title	 = ДанныеСделки.ПредставлениеСделки;
		БлокСделки.innerText = ДанныеСделки.ПредставлениеСделки;
		БлокСделки.style	 = ДанныеСделки.СтилиСделки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает параметры обновления сделок в блоках заявок.
//
Функция ПолучитьПараметрыОбновленияСделок(Сделка)
	
	// Выбираем актуальную сделку клиента, сделку которого изменили.
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Сделки.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ КонтрагентТекущейСделки
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.Ссылка = &Сделка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КонтрагентыСведенияДляСписка.Контрагент КАК Контрагент,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК Ссылка,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка.НаименованиеСокращенное КАК НаименованиеСокращенное,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.Наименование КАК НаименованиеЭтапа,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.ЦветЭтапа КАК ЦветЭтапа
	|ИЗ
	|	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КонтрагентТекущейСделки КАК КонтрагентТекущейСделки
	|		ПО КонтрагентыСведенияДляСписка.Контрагент = КонтрагентТекущейСделки.Контрагент");
	
	Запрос.УстановитьПараметр("Сделка", Сделка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда
		Возврат Неопределено;   
	ИначеЕсли НЕ ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеСделки = Новый Структура;
	ДанныеСделки.Вставить("Ссылка"					, Выборка.Ссылка);
	ДанныеСделки.Вставить("НаименованиеСокращенное"	, Выборка.НаименованиеСокращенное);
	
	ДанныеЭтапа = Новый Структура;
	ДанныеЭтапа.Вставить("ЦветЭтапа"	, Выборка.ЦветЭтапа);
	ДанныеЭтапа.Вставить("Наименование"	, Выборка.НаименованиеЭтапа);
	
	ДанныеСделкиДляОбновленияБлока = ПолучитьДанныеСделкиДляОбновленияБлока(ДанныеСделки, ДанныеЭтапа);
	
	ПараметрыОбновленияСделок = Новый Структура;
	ПараметрыОбновленияСделок.Вставить("Контрагент"		, Выборка.Контрагент);
	ПараметрыОбновленияСделок.Вставить("ДанныеСделки"	, ДанныеСделкиДляОбновленияБлока);
	
	Возврат ПараметрыОбновленияСделок;
	
КонецФункции

&НаКлиенте
// Процедура, обрабатывает оповещение о новой заявке.
//
Процедура ОбработатьОповещениеОНовойЗаявке(Параметр)
	
	// Не переданы данные заявки для обработки.
	Если Не ЗначениеЗаполнено(Параметр) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Параметр) = Тип("СправочникСсылка.Заявки") Тогда
		Параметр = Новый Структура("Заявка", Параметр);
	КонецЕсли;
	
	Если Параметр.Свойство("Заявка") Тогда
		ОбработатьИзменениеЗаявки(Параметр.Заявка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, удаляет блок заявки.
//
Процедура УдалитьБлокЗаявки(ИдентификаторЗаявки)
	
	Документ = Элементы.Канбан.Документ;
	
	БлокЗаявки = Документ.getElementById(ИдентификаторЗаявки);
	
	// Блока нет на форме, действий не требуется.
	Если БлокЗаявки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	БлокЗаявки.parentElement.remove();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обрабатывает оповещение об изменении заявки.
//
Процедура ОбработатьИзменениеЗаявки(Заявка)
	
	Документ = Элементы.Канбан.Документ;
	
	ИдентификаторЗаявки	 = Строка(Заявка.УникальныйИдентификатор());
	СелекторЗаявки		 = "#" + Документ.CSS.escape(ИдентификаторЗаявки) + ".item-col";
	
	УдаляемыйБлокЗаявки = Документ.querySelector(СелекторЗаявки);
	
	Если УдаляемыйБлокЗаявки <> Неопределено Тогда
		
		// При необходимости подгрузить следующую заявку для этоой колонки.
		КолонкаУдаляемойЗаявки = УдаляемыйБлокЗаявки.closest(".kanban-board");
		
		КоличествоЗаявокВКолонкеВсего	 = Число(КолонкаУдаляемойЗаявки.querySelector(".item-count").dataset.count);
		КоличествоЗаявокВКолонкеТекущее	 = КолонкаУдаляемойЗаявки.querySelectorAll(".kanban-item").length;
		ТребуетсяПолучитьЗаявкуИзОчереди = КоличествоЗаявокВКолонкеВсего > Макс(ЭтотОбъект.МаксимальноеКоличествоЗаявокВКолонке, КоличествоЗаявокВКолонкеТекущее);
		
		Если ТребуетсяПолучитьЗаявкуИзОчереди Тогда
			
			ИдентификаторыИсключаемыхЗаявок = Новый Массив;
			
			Для Каждого БлокЗаявки Из КолонкаУдаляемойЗаявки.querySelector(".kanban-drag").children Цикл
				
				Если БлокЗаявки.className = "show-all" Тогда
					Продолжить;
				КонецЕсли;
				
				ИдентификаторыИсключаемыхЗаявок.Добавить(БлокЗаявки.children[0].id);
				
			КонецЦикла;
			
			СтатусДоИзменения = КолонкаУдаляемойЗаявки.dataset.id;
			
			ПараметрыПолученияЗаявкиИзОчереди = Новый Структура;
			ПараметрыПолученияЗаявкиИзОчереди.Вставить("Статус"							, СтатусДоИзменения);
			ПараметрыПолученияЗаявкиИзОчереди.Вставить("ИдентификаторыИсключаемыхЗаявок", ИдентификаторыИсключаемыхЗаявок);
			
		КонецЕсли;
		
		// Удаляем существующий неактуальный блок заявки.
		УдаляемыйБлокЗаявки.parentElement.remove();
		
	КонецЕсли;
	
	СтруктураОтбора	 = ПолучитьСтруктуруЗначенийОтбораКлиент();
	ДанныеБлока		 = ПолучитьДанныеБлокаЗаявки(Заявка, СтруктураОтбора, ПараметрыПолученияЗаявкиИзОчереди);
	
	Если Не ЗначениеЗаполнено(ДанныеБлока) Тогда
		Возврат;
	КонецЕсли;
	
	КолонкаДанныхКанбана = Документ.querySelector(".kanban-board[data-id=" + ДанныеБлока.ПредставлениеКолонки + "] .kanban-drag");
	
	// Добавляем новый блок в начало колонки.
	НовыйБлокЗаявки				 = Документ.createElement("div");
	НовыйБлокЗаявки.innerHTML	 = ДанныеБлока.БлокЗаявки;
	НовыйБлокЗаявки.className	 = "kanban-item";
	
	КолонкаДанныхКанбана.prepend(НовыйБлокЗаявки);
	
	ОбновитьКоличествоЗаявокВБлоках(ДанныеБлока.ДанныеКоличества);
	ВывестиЗаявкуИзОчереди(ДанныеБлока.ДанныеВыводимойЗаявки);
	
КонецПроцедуры

&НаКлиенте
