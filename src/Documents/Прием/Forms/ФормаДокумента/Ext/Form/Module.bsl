		ЭтотОбъект.СкидкаНаценкаОплатаБонусами.Удалить(ЭлементМ);
	КонецЦикла;
	
	ПересчитатьАвтоматическиеСкидки();
	
	ОтобразитьИнформациюПоОплате();
			
