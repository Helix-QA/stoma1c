	// Актуализируем параметры отрисовки
	Если ПараметрыОтображенияЭлементов = Неопределено Тогда 
		ПараметрыОтображенияЭлементов 	= ИнициализироватьСтруктуруПараметровОтрисовки(Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение);
		МассивАктуальныхСтрок 			= Объект.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь));		
