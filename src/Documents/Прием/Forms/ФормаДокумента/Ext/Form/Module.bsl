// Процедура - Проверка на ограничение по договору номенклатура начало выбора завершение.
//
Процедура ПроверкаНаОграничениеПоДоговору_НоменклатураНачалоВыбораЗавершение(Знач ПодборДанные)
	
	МассивНоменклатуры = Новый Массив();
	МассивНоменклатуры.Добавить(ПодборДанные.Номенклатура); 
	
	МассивЗубов = Новый Массив();
	Если Элементы.ТаблицаЛечение.ТекущиеДанные <> Неопределено
		И ЗначениеЗаполнено(Элементы.ТаблицаЛечение.ТекущиеДанные.Зуб) Тогда
		МассивЗубов.Добавить(Элементы.ТаблицаЛечение.ТекущиеДанные.Зуб);
	Иначе
		МассивЗубов = МассивВыделенныхЗубов.ВыгрузитьЗначения();
		Если МассивЗубов.Количество() = 0 Тогда 
			МассивЗубов.Добавить(ОбщиеПараметры.Перечисление_Зубы_ВсяПолость);
		КонецЕсли;	
	КонецЕсли;
	
	МассивСтруктурСКоличествомПоПолису = ПолучитьКоличествоПоПолису(Объект.ПолисМедСтрахования, Объект.Ссылка);
	КоличествоЗубовВсего = 0;
	КоличествоВсего = 0;
	ОписаниеОшибки = "";
	
	Для каждого СтрокаМассива Из МассивСтруктурСКоличествомПоПолису Цикл
		Если СтрокаМассива.Номенклатура = ПодборДанные.Номенклатура Тогда
			
			КоличествоЗубовВсего = СтрокаМассива.КоличествоЗубов;
			КоличествоВсего = СтрокаМассива.Количество;
			
		КонецЕсли;
	КонецЦикла;
	
	СтруктураПараметровПоПолису = Новый Структура();
	СтруктураПараметровПоПолису.Вставить("ЭлементМЗуб", 		МассивЗубов[0]);
	СтруктураПараметровПоПолису.Вставить("КоличествоНоменклатурыВТЧ", ВернутьКоличествоНоменклатурыВТЧЛечение(ПодборДанные.Номенклатура));
	СтруктураПараметровПоПолису.Вставить("КоличествоЗубовСНомненклатуройВТЧ", ПолучитьКоличествоЗубовСНомненклатурой(ПодборДанные.Номенклатура));
	
	СтруктураПараметровПоПолису.Вставить("КоличествоЗубов", 	ПодборДанные.КоличествоЗубов);
	СтруктураПараметровПоПолису.Вставить("КоличествоВПриеме", 	ПодборДанные.КоличествоВПриеме);
	СтруктураПараметровПоПолису.Вставить("Номенклатура", 		ПодборДанные.Номенклатура);
	СтруктураПараметровПоПолису.Вставить("ПолисНеограничено", 	ПодборДанные.ПолисНеограничено);
	СтруктураПараметровПоПолису.Вставить("ПолисКоличество", 	ПодборДанные.ПолисКоличество);
	СтруктураПараметровПоПолису.Вставить("КоличествоЗубовВсего",КоличествоЗубовВсего);
	СтруктураПараметровПоПолису.Вставить("КоличествоВсего", 	КоличествоВсего);
	
	ПроверитьУслугуНаСогласованностьПоПолису(СтруктураПараметровПоПолису, ОписаниеОшибки);
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ПоказатьПредупреждение(,ОписаниеОшибки);	 
	Иначе		
		СтруктураДанныеПолиса = ПолучитьСтруктуруДанныхПолиса(ПодборДанные, СтруктураПараметровПоПолису);							
		ТаблицаУслугиНоменклатураНачалоВыбораЗавершение_ДобавлениеПослеСогласования(ПодборДанные.Номенклатура, СтруктураДанныеПолиса);		
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить структуру данных полиса.
//
Функция ПолучитьСтруктуруДанныхПолиса(Знач ПодборДанные, Знач СтруктураПараметровПоПолису)
		
	Если ПодборДанные.ПолисСогласование <> Перечисления.ТипыСогласованийУслугСтраховойКомпании.НеТребуется
		И СтруктураПараметровПоПолису.КоличествоНоменклатурыВТЧ + СтруктураПараметровПоПолису.КоличествоВсего >= ПодборДанные.ПолисКоличествоПриПревышении Тогда
		
		СтруктураДанныеПолиса = Новый Структура();
		СтруктураДанныеПолиса.Вставить("Результат"					, Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования);
		СтруктураДанныеПолиса.Вставить("ПолисСогласование"			, ПодборДанные.ПолисСогласование);
		СтруктураДанныеПолиса.Вставить("СогласованиеПриПревышении"	, ПодборДанные.ПолисКоличествоПриПревышении <> 0 ИЛИ ПодборДанные.ПолисСогласование = Перечисления.ТипыСогласованийУслугСтраховойКомпании.Всегда);
		
	Иначе 				
		СтруктураДанныеПолиса = Неопределено;
	КонецЕсли;
	
	Возврат СтруктураДанныеПолиса;

КонецФункции

