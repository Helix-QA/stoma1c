&НаКлиенте
// Процедура рассчитывает сумму в строке табличной части.
//
Процедура РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти = Неопределено)
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	КонецЕсли;
	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, Новый Структура("ЕстьКолонкаПроцентСкидкиНаценки, ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки", ложь, ложь));
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры // РассчитатьСуммуВСтрокеТабличнойЧасти()

&НаКлиенте
// Процедура рассчитывает сумму в строке табличной части.
//
Процедура РассчитатьСуммуПродажиВСтрокеТабличнойЧасти(СтрокаТЧ = Неопределено)
	
	Если СтрокаТЧ = Неопределено Тогда
		СтрокаТЧ = Элементы.Запасы.ТекущиеДанные;
	КонецЕсли;
		
	Сумма                 = СтрокаТЧ.ЦенаПродажи * ?(СтрокаТЧ.Свойство("КоличествоУпаковок"),СтрокаТЧ.КоличествоУпаковок,СтрокаТЧ.Количество);
	СуммаСкидки           = 0;
	СуммаСкидки           = СуммаСкидки + Сумма * СтрокаТЧ.ПроцентСкидкиНаценки / 100;
	СуммаСкидки           = СуммаСкидки + СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки;
	СтрокаТЧ.СуммаПродажи = Сумма - СуммаСкидки;	
	СтрокаТЧ.ВсегоПродажи = СтрокаТЧ.СуммаПродажи;                      
	
КонецПроцедуры

&НаСервере
// Функция получает список товаров из временного хранилища
//
Процедура ПолучитьЗапасыИзХранилища(АдресЗапасовВХранилище, ИмяТабличнойЧасти, ЕстьПартии)
	
	ТаблицаДляЗагрузки = ПолучитьИзВременногоХранилища(АдресЗапасовВХранилище);	
	Для каждого СтрокаЗагрузки Из ТаблицаДляЗагрузки Цикл
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура", СтрокаЗагрузки.Номенклатура);
		СтруктураОтбора.Вставить("Упаковка", СтрокаЗагрузки.Упаковка);
		Если ЕстьПартии Тогда
			СтруктураОтбора.Вставить("Партия", СтрокаЗагрузки.Партия);
		КонецЕсли;
		
		Строки = Объект[ИмяТабличнойЧасти].НайтиСтроки(СтруктураОтбора);
		Если Строки.Количество() > 0 Тогда
			СтрокаТабличнойЧасти = Строки[0];
		Иначе
			СтрокаТабличнойЧасти = Объект[ИмяТабличнойЧасти].Добавить();
		КонецЕсли;
		
		СтрокаТабличнойЧасти.Зуб                  = ОбщиеПараметры.Перечисление_Зубы_ВсяПолость;
		СтрокаТабличнойЧасти.Номенклатура         = СтрокаЗагрузки.Номенклатура;
		СтрокаТабличнойЧасти.Партия               = СтрокаЗагрузки.Партия;
		СтрокаТабличнойЧасти.КоличествоУпаковок   = СтрокаЗагрузки.КоличествоУпаковок;
		СтрокаТабличнойЧасти.Количество           = СтрокаЗагрузки.Количество;
		СтрокаТабличнойЧасти.ЦенаПродажи          = СтрокаЗагрузки.Цена;
		СтрокаТабличнойЧасти.Лаборатория          = Объект.Лаборатория;
		СтрокаТабличнойЧасти.ВидЦен               = Объект.ВидЦен;
		СтрокаТабличнойЧасти.ВидЦенПродажи        = Объект.ВидЦенПродажи;
		СтрокаТабличнойЧасти.Упаковка             = СтрокаЗагрузки.Упаковка;
		СтрокаТабличнойЧасти.СтавкаНДС            = ?(ЗначениеЗаполнено(СтрокаЗагрузки.СтавкаНДС), СтрокаЗагрузки.СтавкаНДС, Перечисления.СтавкиНДС.БезНДС);
		СтрокаТабличнойЧасти.СуммаПродажи         = СтрокаТабличнойЧасти.ЦенаПродажи * СтрокаТабличнойЧасти.КоличествоУпаковок;	
		СтрокаТабличнойЧасти.ВсегоПродажи         = СтрокаТабличнойЧасти.СуммаПродажи;
		
		// Получаем закупочную цену
		СтруктураДанные = Новый Структура;
		СтруктураДанные.Вставить("СтруктурнаяЕдиница",  Объект.СтруктурнаяЕдиница);
		СтруктураДанные.Вставить("ДатаОбработки",	 	Объект.Дата);
		СтруктураДанные.Вставить("ВидЦен", 				?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидЦен), СтрокаТабличнойЧасти.ВидЦен, Справочники.ВидыЦен.Закупочная));	
		СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
		СтруктураДанные.Вставить("Упаковка", 			СтрокаТабличнойЧасти.Упаковка);
		
		СтруктураДанныеЗакупки    = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные); 			
		СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;		
		
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, Новый Структура("ЕстьКолонкаПроцентСкидкиНаценки, ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки", ложь, ложь));
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);			
		
		СтрокаТабличнойЧасти.Статус = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.Статус), СтрокаТабличнойЧасти.Статус, Перечисления.СтатусыНарядЗаказа.Заказано);
		
	КонецЦикла;
	
КонецПроцедуры // ПолучитьЗапасыИзХранилища()

