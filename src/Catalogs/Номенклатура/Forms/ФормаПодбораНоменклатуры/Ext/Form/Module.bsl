// Обработчик окончания ввода текста поиска
//
Процедура БыстрыйПоискОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка)

	ИдентификаторПоследнейНайденнойСтроки = ?(БыстрыйПоиск <> Текст,-1,ИдентификаторПоследнейНайденнойСтроки);
	БыстрыйПоиск = Текст;
	
    Поиск(Неопределено);
	
КонецПроцедуры

&НаСервере
// Рекусивная фкнция поиска в дереве значений
//
Функция БыстрыйПоиск(Знач ЭлементыДерева = Неопределено,ПоискВПеред,СтрокаПоиска)

	ИндексСтартовый = 0;
	// Оптимизация по границам поиска
	Если ЭлементыДерева = Неопределено Тогда	
				
		ЭлементыДерева  = Список.ПолучитьЭлементы();
		КоличествоЭл    = ЭлементыДерева.Количество() - 1;

		Если ПоискВПеред Тогда
			ИндексСтартовый = ИндексВерхнейГруппы; 
		Иначе
			КоличествоЭл    = ИндексВерхнейГруппы + 1; 
		КонецЕсли;

	Иначе
		КоличествоЭл = ЭлементыДерева.Количество() - 1;
	КонецЕсли;
	
	// Основной цикл поиска
	Для А = ИндексСтартовый  По КоличествоЭл Цикл
		
		ЭлементДерева =?(ПоискВПеред, ЭлементыДерева[А], ?(ЭлементыДерева.Количество() < КоличествоЭл - А, ЭлементыДерева[КоличествоЭл - А],ЭлементыДерева[А]));
		
		Если  ЭлементДерева.Номенклатура.ЭтоГруппа  Тогда
			
			// Рекурсивный вызов
			Результат = БыстрыйПоиск(ЭлементДерева.ПолучитьЭлементы(),ПоискВПеред,СтрокаПоиска);
			Если  Результат <> Неопределено Тогда
				
				ИндексПредВерхнейГруппы = А;
				Возврат Результат
				
			КонецЕсли;	
		Иначе
			// Проверка совпадения подстроки
			Если Найти(НРег(Строка(ЭлементДерева.Номенклатура)),НРег(СтрокаПоиска)) > 0 Тогда			
				
				ИД = ЭлементДерева.ПолучитьИдентификатор();
				Если  ИдентификаторПоследнейНайденнойСтроки = -1 ИЛИ (ПоискВПеред И ИД > ИдентификаторПоследнейНайденнойСтроки) ИЛИ (НЕ ПоискВПеред И ИД < ИдентификаторПоследнейНайденнойСтроки)  Тогда				
					Возврат ИД;			
				КонецЕсли;	
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
					
	Возврат Неопределено;
	
КонецФункции	

&НаКлиенте
// Процедура вызова поиска
//
Процедура ИскатьВДереве(ПоискДалее)
	
	Результат = БыстрыйПоиск(,ПоискДалее,БыстрыйПоиск);
	Если Результат <> Неопределено Тогда
		
		 Элементы.Список.ТекущаяСтрока         = Результат;
		 ИдентификаторПоследнейНайденнойСтроки = Результат;                                   

	 Иначе
		 
		ИндексПредВерхнейГруппы               = 0;
		ИдентификаторПоследнейНайденнойСтроки = -1;
		ПоказатьПредупреждение(,"Поиск не дал результата!"); 
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик копки поиска
//
Процедура Поиск(Команда)
	
	ИндексПредВерхнейГруппы               = 0;
	ИдентификаторПоследнейНайденнойСтроки = -1;
	ИскатьВДереве(Истина);
	
КонецПроцедуры

&НаКлиенте
// Обработчик поиск Далее
//
Процедура ПоискДалее(Команда)
	
	ИскатьВДереве(Истина);
	
КонецПроцедуры

&НаКлиенте
// Обработчик поиск Предыдущее
//
Процедура ПоискПредыдущие(Команда)
	
