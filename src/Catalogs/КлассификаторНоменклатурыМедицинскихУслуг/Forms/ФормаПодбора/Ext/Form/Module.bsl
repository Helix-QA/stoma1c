// Процедура, выполняет заполнение строки таблицы.
//
Процедура ЗаполнитьСтрокуТаблицыНоменклатуры(СтрокаДерева)
	
	Если СтрокаДерева["Выбран"] Тогда
		НоваяСтрока				 = ТаблицаКлассификаторУслуг.Добавить();
		НоваяСтрока.Услуга       = СтрокаДерева.Услуга;
	КонецЕсли;
	
КонецПроцедуры

