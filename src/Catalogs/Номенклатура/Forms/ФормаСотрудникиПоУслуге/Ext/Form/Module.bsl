
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Номенклатура", Номенклатура);
		
	СоздатьДеревоУслуг();
	УстановитьУсловноеОформление(); 
	
	Если НЕ ПравоДоступа("Изменение", Метаданные.РегистрыСведений.УслугиСотрудника) Тогда
		
		Элементы.ГруппаДеревоСотрудников.ТолькоПросмотр = Истина;
		Элементы.ГруппаФильтрКнопки.Доступность	 		= Ложь;

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УстановитьФильтр();
	ПослеЗаполненияСпискаПодбораСотрудников();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ФильтрПриИзменении(Элемент)
	
	УстановитьФильтр();
	Если Фильтр = 1 Тогда
		ИдТекЭлемент = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭтаФорма._ПодборСотрудников, Истина);		
		Если ИдТекЭлемент <> Неопределено Тогда
			Элементы._ПодборСотрудников.ТекущаяСтрока = ИдТекЭлемент;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура Подключаемый_ПодборСотрудниковПриИзменении(Элемент)
	
	ИмяКолонки 	  = Элемент.Имя;
	ТекущиеДанные = Элементы._ПодборСотрудников.ТекущиеДанные;
	
	Если ТекущиеДанные.ЭтоГруппа Тогда                      		
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли; 
		УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонки);
		УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, Истина);
	Иначе
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли;		
		УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки);			
	КонецЕсли;
	
	Если Фильтр = 1 Тогда
		ИдТекЭлемент = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭтаФорма._ПодборСотрудников, Истина);		
		Если ИдТекЭлемент <> Неопределено Тогда
			Элементы._ПодборСотрудников.ТекущаяСтрока = ИдТекЭлемент;
		КонецЕсли;
	КонецЕсли;
	
	ТаблицаСотрудников.Очистить();
	ДанныеДерева = ЭтаФорма._ПодборСотрудников.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ Из ДанныеДерева Цикл
		Если СтрокаТЧ.ЭтоГруппа Тогда
			ЗаполнитьТаблицуСотрудников(СтрокаТЧ);
		Иначе
			ЗаполнитьСтрокуТаблицыСотрудников(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
	СохранитьЗначения(ТаблицаСотрудников, ЭтотОбъект.Номенклатура);
	
КонецПроцедуры  

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура Подключаемый_НормаВремениПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы._ПодборСотрудников.ТекущиеДанные;
	ТекущиеДанные.НормаВремениСотрудника = НЕ ТекущиеДанные.НормаВремени = ТекущиеДанные.БазоваяНормаВремени;
	
	ТаблицаСотрудников.Очистить();
	ДанныеДерева = ЭтаФорма._ПодборСотрудников.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ Из ДанныеДерева Цикл
		Если СтрокаТЧ.ЭтоГруппа Тогда
			ЗаполнитьТаблицуСотрудников(СтрокаТЧ);
		Иначе
			ЗаполнитьСтрокуТаблицыСотрудников(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
	СохранитьЗначения(ТаблицаСотрудников, ЭтотОбъект.Номенклатура);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередНачаломДобавления".
//
Процедура Подключаемый_ПодборСотрудниковПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередУдалением".
//
Процедура Подключаемый_ПодборСотрудниковПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик события команды.
//
Процедура СкопироватьНастройки(Команда)
	
	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбора",,,,,,Новый ОписаниеОповещения("СкопироватьНастройкиЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения команды.
//
Процедура СкопироватьНастройкиЗавершение(Источник, Параметры) Экспорт
	
	Если Не Источник = Неопределено И Не Источник = Номенклатура Тогда
		СкопироватьНастройкиСотрудника(Источник);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
// Функция - Получить места работы сотрудников
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМестаРаботыСотрудников()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	НастройкиСотрудников.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников");
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница");
	
КонецФункции

&НаСервере
// Процедура, выполянет создание дерева услуг.
//
Процедура СоздатьДеревоУслуг()
	
	МассивСтруктурныхЕдиниц = ПолучитьМестаРаботыСотрудников();
 	
	Индекс = 1;
	Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл
		НоваяСтрока = МестаРаботы.Добавить();
		НоваяСтрока.НомерСтроки = Индекс;
		НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
		Индекс = Индекс + 1;
	КонецЦикла;
	
	ИмяЭлементаДляРазмещения = "ГруппаДеревоСотрудников";
	масРеквизитов = Новый Массив;		
	
	ИмяДерева = "_ПодборСотрудников";
	
	МассивДопустимыхТипов = Новый Массив;
	МассивДопустимыхТипов.Добавить(Тип("СправочникСсылка.Сотрудники"));
	МассивДопустимыхТипов.Добавить(Тип("Строка"));
	
	МассивДопустимыхТиповДолжности = Новый Массив;
	МассивДопустимыхТиповДолжности.Добавить(Тип("СправочникСсылка.Должности"));
	МассивДопустимыхТиповДолжности.Добавить(Тип("Строка"));
		
	масРеквизитов.Добавить(Новый РеквизитФормы(ИмяДерева		       , Новый ОписаниеТипов("ДеревоЗначений"), , "Подбор номенклатур", Ложь));
	масРеквизитов.Добавить(Новый РеквизитФормы("Сотрудник"	      	   , Новый ОписаниеТипов(МассивДопустимыхТипов), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Должность"	      	   , Новый ОписаниеТипов(МассивДопустимыхТиповДолжности), ИмяДерева));	
	масРеквизитов.Добавить(Новый РеквизитФормы("ЭтоГруппа"		       , Новый ОписаниеТипов("Булево"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ИндКартинки"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("НормаВремени"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("БазоваяНормаВремени"   , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("НормаВремениСотрудника", Новый ОписаниеТипов("Булево"), ИмяДерева));
	
	Для Каждого СтрокаТЧ Из МестаРаботы Цикл
		масРеквизитов.Добавить(Новый РеквизитФормы("СтруктурнаяЕдиница" + СтрокаТЧ.НомерСтроки, Новый ОписаниеТипов("Число", , Новый КвалификаторыЧисла(1,0)), ИмяДерева));
	КонецЦикла;
	
	масРеквизитов.Добавить(Новый РеквизитФормы("_ПодборСотрудниковИсточникГрупп", Новый ОписаниеТипов("ДеревоЗначений"), , "Услгуи подбор список", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"), "_ПодборСотрудниковИсточникГрупп"));
	
	ИмяДерева = "_ПодборСотрудниковИсточникЭлементов";
	масРеквизитов.Добавить(Новый РеквизитФормы(ИмяДерева		       , Новый ОписаниеТипов("ТаблицаЗначений"), , "Услгуи подбор список", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Сотрудник"	       	   , Новый ОписаниеТипов("СправочникСсылка.Сотрудники"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Должность"	       	   , Новый ОписаниеТипов("СправочникСсылка.Должности"), ИмяДерева)); 
	масРеквизитов.Добавить(Новый РеквизитФормы("ЭтоГруппа"		       , Новый ОписаниеТипов("Булево"), ИмяДерева));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Родитель"		       , Новый ОписаниеТипов("СправочникСсылка.Сотрудники"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ИндКартинки"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Наименование"	       , Новый ОписаниеТипов("Строка"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("НормаВремени"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("БазоваяНормаВремени"   , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("НормаВремениСотрудника", Новый ОписаниеТипов("Булево"), ИмяДерева));
	
	Для Каждого СтрокаТЧ Из МестаРаботы Цикл
		масРеквизитов.Добавить(Новый РеквизитФормы("СтруктурнаяЕдиница" + СтрокаТЧ.НомерСтроки,  Новый ОписаниеТипов("Число", , Новый КвалификаторыЧисла(1,0)), ИмяДерева));
	КонецЦикла;
	
	ИзменитьРеквизиты(масРеквизитов);	
	
	ЭлементДерево = Элементы.Добавить("_ПодборСотрудников", Тип("ТаблицаФормы"), Элементы[ИмяЭлементаДляРазмещения]);
	ЭлементДерево.ПутьКДанным 				 = "_ПодборСотрудников";
	ЭлементДерево.Отображение 				 = ОтображениеТаблицы.Дерево;
	ЭлементДерево.КартинкаСтрок 			 = БиблиотекаКартинок.ТерминалПодбор;
	ЭлементДерево.ПутьКДаннымКартинкиСтроки  = "_ПодборСотрудников.ИндКартинки";
	ЭлементДерево.КоманднаяПанель.Видимость  = Ложь;
	ЭлементДерево.КонтекстноеМеню.Видимость  = Ложь;
	ЭлементДерево.ПоложениеКоманднойПанели   = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	//ЭлементДерево.АвтоМаксимальнаяШирина  	 = Ложь;
	//ЭлементДерево.МаксимальнаяШирина 	 	 = 120;
	ЭлементДерево.РастягиватьПоГоризонтали   = Истина;
	ЭлементДерево.НачальноеОтображениеДерева = НачальноеОтображениеДерева.РаскрыватьВсеУровни;
	ЭлементДерево.УстановитьДействие("ПередНачаломДобавления", "Подключаемый_ПодборСотрудниковПередНачаломДобавления");
	ЭлементДерево.УстановитьДействие("ПередУдалением", "Подключаемый_ПодборСотрудниковПередУдалением");
	
	НовыйЭлемент = ЭтаФорма.Элементы.Добавить("Сотрудник", Тип("ПолеФормы"), ЭлементДерево);	
	НовыйЭлемент.Вид 		 			  	 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.АвтоМаксимальнаяШирина    	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 	 	 = 60;
	НовыйЭлемент.ТолькоПросмотр 		 	 = Истина;
	НовыйЭлемент.ЦветФонаЗаголовка			 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.ПутьКДанным 			 	 = "_ПодборСотрудников.Сотрудник";
	
	НовыйЭлемент = ЭтаФорма.Элементы.Добавить("Должность", Тип("ПолеФормы"), ЭлементДерево);	
	НовыйЭлемент.Вид 		 			  	 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.АвтоМаксимальнаяШирина    	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 	 	 = 60;
	НовыйЭлемент.ТолькоПросмотр 		 	 = Истина;
	НовыйЭлемент.ЦветФонаЗаголовка			 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.ПутьКДанным 			 	 = "_ПодборСотрудников.Должность";

	НовыйЭлемент = Элементы.Добавить("НормаВремени", Тип("ПолеФормы"), ЭлементДерево);
	НовыйЭлемент.Вид		 			 	 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 			 	 = "_ПодборСотрудников.НормаВремени";
	НовыйЭлемент.Ширина 	 			 	 = 12;
	НовыйЭлемент.АвтоМаксимальнаяШирина  	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 	 	 = 12;
	НовыйЭлемент.РастягиватьПоГоризонтали	 = Ложь;	
	НовыйЭлемент.Заголовок 				 	 = "Норма времени";
	НовыйЭлемент.ЦветФонаЗаголовка			 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_НормаВремениПриИзменении");
	
	УстановитьПривилегированныйРежим(Истина);
	
	Для Каждого СтрокаТЧ Из МестаРаботы Цикл
		
		НовыйЭлемент = Элементы.Добавить("СтруктурнаяЕдиница" + СтрокаТЧ.НомерСтроки, Тип("ПолеФормы"), ЭлементДерево);
		НовыйЭлемент.Вид					 = ВидПоляФормы.ПолеФлажка;
		НовыйЭлемент.ПутьКДанным			 = "_ПодборСотрудников.СтруктурнаяЕдиница" + СтрокаТЧ.НомерСтроки;
		НовыйЭлемент.Заголовок				 = СтрокаТЧ.СтруктурнаяЕдиница.Наименование;		
		НовыйЭлемент.ТриСостояния 			 = Истина;
		НовыйЭлемент.ЦветФонаЗаголовка		 = Новый Цвет(255, 255, 255);
		НовыйЭлемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
		НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ПодборСотрудниковПриИзменении");
		
	КонецЦикла;	
	
	НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ПодборСотрудниковПриИзменении");

	УстановитьПривилегированныйРежим(Ложь);
	
	ОбновитьДеревоПодборовСотрудников();		
	
	// Проставялем флаги на группах дерева.
	УстановитьНачальныеФлагиНаГруппы();
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет установку условного оформления.
//
Процедура УстановитьУсловноеОформление()
	
	ЭлементУФ = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
	
	ГруппаОтбора		   = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	
	Для Каждого МестоРаботы Из МестаРаботы Цикл
		
		ЭлементОтбора				 = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("_ПодборСотрудников.СтруктурнаяЕдиница" + МестоРаботы.НомерСтроки); // имя поля
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = 0;                                              
		ЭлементОтбора.Использование  = Истина;
		
	КонецЦикла;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Видимость"), Ложь);
	
	ПолеОформления				 = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("Сотрудник");
	ПолеОформления.Использование = Истина;  
	ПолеОформления				 = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("Должность");
	ПолеОформления.Использование = Истина; 
	ПолеОформления				 = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("НормаВремени");
	ПолеОформления.Использование = Истина;
	
	Для Каждого СтрокаТЧ Из МестаРаботы Цикл
		ПолеОформления				 = ЭлементУФ.Поля.Элементы.Добавить();	
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("СтруктурнаяЕдиница" + СтрокаТЧ.НомерСтроки);
		ПолеОформления.Использование = Истина;		
	КонецЦикла;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Доступность"), Ложь);
	
	ПолеОформления				 = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("НормаВремени");
	ПолеОформления.Использование = Истина; 
	
	ЭлементУФ = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
	
	ЭлементОтбора				 = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("_ПодборСотрудников.ЭтоГруппа"); // имя поля	
	ЭлементОтбора.ВидСравнения 	 = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Истина;                                              
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ЦветФона"), Новый Цвет(245, 245, 245));
	
	ПолеОформления				 = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("_ПодборСотрудников");
	ПолеОформления.Использование = Истина; 
	
	ЭлементУФ = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
	
	ЭлементОтбора				 = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("_ПодборСотрудников.НормаВремениСотрудника"); // имя поля
	ЭлементОтбора.ВидСравнения 	 = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Истина;
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ЦветТекста"), WebЦвета.Зеленый);
	
	ПолеОформления				 = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле			 = Новый ПолеКомпоновкиДанных("НормаВремени");
	ПолеОформления.Использование = Истина;	
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет заполнение подбора номенклатуры 
//
Процедура ЗаполнитьДеревоПодбораСотрудников()
		
	ЭтаФорма._ПодборСотрудниковИсточникГрупп.ПолучитьЭлементы().Очистить();
	ЭтаФорма._ПодборСотрудниковИсточникЭлементов.Очистить();
	ЭтаФорма._ПодборСотрудников.ПолучитьЭлементы().Очистить();

	ЗапросГрупп = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ЭтоГруппа = ИСТИНА
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка ИЕРАРХИЯ,
	|	Сотрудники.Наименование");	
	
	ВыборкаГрупп = ЗапросГрупп.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);	
	ЭтаФорма._ПодборСотрудниковИсточникГрупп.ПолучитьЭлементы().Очистить();	
	
	ЗаполнитьИсточникГрупп(ВыборкаГрупп, ЭтаФорма._ПодборСотрудниковИсточникГрупп.ПолучитьЭлементы());	
	ПустаяГруппа = ЭтаФорма._ПодборСотрудниковИсточникГрупп.ПолучитьЭлементы().Добавить();
	
	ЗапросСотрудников = Новый Запрос( 
	"ВЫБРАТЬ
	|	УслугиСотрудника.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	УслугиСотрудника.Сотрудник КАК Сотрудник,
	|	УслугиСотрудника.НормаВремени КАК НормаВремениСотрудника,
	|	Номенклатуры.НормаВремени КАК НормаВремени,
	|	Номенклатуры.НормаВремени КАК БазоваяНормаВремени
	|ПОМЕСТИТЬ УслугиСотрудника
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатуры
	|		ПО УслугиСотрудника.Номенклатура = Номенклатуры.Ссылка
	|ГДЕ
	|	УслугиСотрудника.Номенклатура = &Номенклатура
	|	И УслугиСотрудника.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СпрСотрудники.Ссылка КАК Сотрудник,
	|	СпрСотрудники.ЭтоГруппа КАК ЭтоГруппа,
	|	ВЫБОР
	|		КОГДА СпрСотрудники.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндКартинки,
	|	СпрСотрудники.Родитель КАК Родитель,
	|	СпрСотрудники.Наименование КАК Наименование,
	|	УслугиСотрудника.НормаВремениСотрудника КАК НормаВремениСотрудника,
	|	УслугиСотрудника.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СпрСотрудники.Должность КАК Должность
	|ИЗ
	|	Справочник.Сотрудники КАК СпрСотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ УслугиСотрудника КАК УслугиСотрудника
	|		ПО СпрСотрудники.Ссылка = УслугиСотрудника.Сотрудник
	|ГДЕ
	|	НЕ СпрСотрудники.ПометкаУдаления
	|	И НЕ СпрСотрудники.ЭтоГруппа
    |   И СпрСотрудники.Служебный = ЛОЖЬ
	|   И &ОтборПоСотруднику
	|   И &ОтборПоДолжности
	|   И &ОтборПоРоли
	|УПОРЯДОЧИТЬ ПО
	|	Должность,
	|	Наименование
	|ИТОГИ
	|	МАКСИМУМ(ЭтоГруппа),
	|	МАКСИМУМ(ИндКартинки),
	|	МАКСИМУМ(Родитель),
	|	МАКСИМУМ(Наименование)
	|ПО
	|	Сотрудник");
	
	ЗапросСотрудников.УстановитьПараметр("Номенклатура"			  , ЭтотОбъект.Номенклатура);
	ЗапросСотрудников.УстановитьПараметр("МассивСтруктурныхЕдиниц", МестаРаботы.Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница"));
	
	Если ЗначениеЗаполнено(ОтборСотрудник) И ТипЗнч(ОтборСотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда
		ЗапросСотрудников.Текст = СтрЗаменить(ЗапросСотрудников.Текст,"И &ОтборПоСотруднику","И СпрСотрудники.Ссылка = &Сотрудник"); 
		ЗапросСотрудников.УстановитьПараметр("Сотрудник",ОтборСотрудник);
	Иначе
		ЗапросСотрудников.Текст = СтрЗаменить(ЗапросСотрудников.Текст,"И &ОтборПоСотруднику",""); 
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ОтборСотрудникДолжность) И ТипЗнч(ОтборСотрудникДолжность) = Тип("СправочникСсылка.Должности") Тогда
		ЗапросСотрудников.Текст = СтрЗаменить(ЗапросСотрудников.Текст,"И &ОтборПоДолжности","И СпрСотрудники.Должность = &Должность"); 
		ЗапросСотрудников.УстановитьПараметр("Должность",ОтборСотрудникДолжность);
	Иначе
		ЗапросСотрудников.Текст = СтрЗаменить(ЗапросСотрудников.Текст,"И &ОтборПоДолжности",""); 
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ОтборСотрудникРоль) И ТипЗнч(ОтборСотрудникРоль) = Тип("ПеречислениеСсылка.РольПользователя") Тогда
		ЗапросСотрудников.Текст = СтрЗаменить(ЗапросСотрудников.Текст,"И &ОтборПоРоли","И СпрСотрудники.Роль = &Роль"); 
		ЗапросСотрудников.УстановитьПараметр("Роль",ОтборСотрудникРоль);
	Иначе
		ЗапросСотрудников.Текст = СтрЗаменить(ЗапросСотрудников.Текст,"И &ОтборПоРоли",""); 
	КонецЕсли;

	ВыборкаСотрудников = ЗапросСотрудников.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	НомераСтруктурныхЕдиниц = Новый Соответствие;
	
	Для Каждого СтрокаТЧ Из МестаРаботы Цикл
		НомераСтруктурныхЕдиниц.Вставить(СтрокаТЧ.СтруктурнаяЕдиница, СтрокаТЧ.НомерСтроки);
	КонецЦикла;
	
	Пока ВыборкаСотрудников.Следующий() Цикл
		
		СтрокаТЧ = ЭтаФорма._ПодборСотрудниковИсточникЭлементов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ВыборкаСотрудников);
		СтрокаТЧ.НормаВремени = ?(СтрокаТЧ.НормаВремени = 0, ЭтотОбъект.Номенклатура.НормаВремени, СтрокаТЧ.НормаВремени);
		
		ВыборкаЗначений = ВыборкаСотрудников.Выбрать(ОбходРезультатаЗапроса.Прямой); 
		
		Пока ВыборкаЗначений.Следующий() Цикл 
			Если ЗначениеЗаполнено(ВыборкаЗначений.СтруктурнаяЕдиница) Тогда
				СтрокаТЧ["СтруктурнаяЕдиница" + НомераСтруктурныхЕдиниц[ВыборкаЗначений.СтруктурнаяЕдиница]] = Истина;
				Если ЗначениеЗаполнено(ВыборкаЗначений.НормаВремениСотрудника) Тогда
					СтрокаТЧ.НормаВремени = ВыборкаЗначений.НормаВремениСотрудника;
					Если Не СтрокаТЧ.БазоваяНормаВремени = СтрокаТЧ.НормаВремени Тогда
						СтрокаТЧ.НормаВремениСотрудника = Истина;
					КонецЕсли; 				
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
// Процедура, заполняет источник групп
//
Процедура ЗаполнитьИсточникГрупп(ВыборкаГрупп,УровеньЗаполнения)
	
	Для Каждого УровеньОбхода ИЗ ВыборкаГрупп.Строки Цикл
		НоваяСтрока = УровеньЗаполнения.Добавить();
		ЗаполнитьИсточникГрупп(УровеньОбхода,НоваяСтрока.ПолучитьЭлементы());
		НоваяСтрока.Сотрудник = УровеньОбхода.Ссылка;                          
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура рекурсивного заолнения дерева подбора номенклатур
//
Процедура ЗаполнитьСписокПодбораРекурсивноСервер(ИсточникГрупп, ИсточникСотрудников, ЭлементЗаполнения, Форма)
		
	Для Каждого УровеньЗаполнения ИЗ ИсточникГрупп Цикл
		Если ЗначениеЗаполнено(УровеньЗаполнения.Сотрудник) Тогда
			НоваяСтрокаГруппы           = ЭлементЗаполнения.ПолучитьЭлементы().Добавить();
			НоваяСтрокаГруппы.Сотрудник = УровеньЗаполнения.Сотрудник;
			НоваяСтрокаГруппы.ЭтоГруппа = Истина;
		Иначе
			НоваяСтрокаГруппы = Форма._ПодборСотрудников;
		КонецЕсли;
		
		ЗаполнитьСписокПодбораРекурсивноСервер(УровеньЗаполнения.ПолучитьЭлементы(), ИсточникСотрудников, НоваяСтрокаГруппы, Форма);						
		СотрудникПоРодителю = Форма._ПодборСотрудниковИсточникЭлементов.НайтиСтроки(Новый Структура("Родитель", УровеньЗаполнения.Сотрудник));	
		
		// Заполняем номенклатуры
		Для Каждого СтрокаН ИЗ СотрудникПоРодителю Цикл
			НоваяСтрока = НоваяСтрокаГруппы.ПолучитьЭлементы().Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаН);
		КонецЦикла;
		
		// Удаляем узел группы если он не содержит элементы
		Если НоваяСтрокаГруппы.ПолучитьЭлементы().Количество() = 0 И Не ТипЗнч(НоваяСтрокаГруппы) = Тип("ДанныеФормыДерево") Тогда
			ЭлементЗаполнения.ПолучитьЭлементы().Удалить(НоваяСтрокаГруппы);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Процедура рекурсивного заолнения дерева подбора номенклатур
//
Процедура ЗаполнитьСписокПодбораРекурсивно(ИсточникГрупп, ИсточникСотрудников, ЭлементЗаполнения, Форма)
	
	Для Каждого УровеньЗаполнения ИЗ ИсточникГрупп Цикл
		
		Если ЗначениеЗаполнено(УровеньЗаполнения.Номенклатура) Тогда
			НоваяСтрокаГруппы              = ЭлементЗаполнения.ПолучитьЭлементы().Добавить();
			НоваяСтрокаГруппы.Номенклатура = УровеньЗаполнения.Номенклатура;		
			НоваяСтрокаГруппы.ЭтоГруппа    = Истина;
		Иначе
			НоваяСтрокаГруппы = ЭтаФорма._ПодборСотрудников;
		КонецЕсли;
		
		ЗаполнитьСписокПодбораРекурсивно(УровеньЗаполнения.ПолучитьЭлементы(), ИсточникСотрудников,НоваяСтрокаГруппы, Форма);			
		СотрудникПоРодителю = ЭтаФорма._ПодборСотрудниковИсточникЭлементов.НайтиСтроки(Новый Структура("Родитель", УровеньЗаполнения.Номенклатура));
		
		// Заполняем номенклатуры
		Для Каждого СтрокаН ИЗ СотрудникПоРодителю Цикл
			НоваяСтрока = НоваяСтрокаГруппы.ПолучитьЭлементы().Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаН);
		КонецЦикла;
		
		// Удаляем узел группы если он не содержит элементы
		Если НоваяСтрокаГруппы.ПолучитьЭлементы().Количество() = 0 И Не ТипЗнч(НоваяСтрокаГруппы) = Тип("ДанныеФормыДерево") Тогда
			ЭлементЗаполнения.ПолучитьЭлементы().Удалить(НоваяСтрокаГруппы);
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
// Выполняется после заполнения дерева подобра. Разворачивается дерево, установка тек. элемента
//
Процедура ПослеЗаполненияСпискаПодбораСотрудников()
	
	ОбщегоНазначенияКлиентСтоматология.РазвернутьДерево(Элементы._ПодборСотрудников, ЭтаФорма._ПодборСотрудников);
	
	ИдТекЭлемент = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭтаФорма._ПодборСотрудников);
	
	Если ИдТекЭлемент <> Неопределено Тогда
		Элементы._ПодборСотрудников.ТекущаяСтрока = ИдТекЭлемент;
	КонецЕсли;
	
	Для Каждого ПунктКонтекстногоМеню Из Элементы._ПодборСотрудников.КонтекстноеМеню.ПодчиненныеЭлементы Цикл
		ПунктКонтекстногоМеню.Видимость=Ложь;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
// Функция вернет идентификатор строки элемента или группы
//
Функция ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ТаблицаПодбора, ВернутьГруппу = Ложь)
	
	ВерхнийУровень = ТаблицаПодбора.ПолучитьЭлементы();
	Для Каждого ЭлементУровня ИЗ ВерхнийУровень Цикл 		
		Для НомерСЕ = 1 По МестаРаботы.Количество() Цикл 
			Если ЭлементУровня.ЭтоГруппа И ЭлементУровня["СтруктурнаяЕдиница" + НомерСЕ] Тогда
				Если ВернутьГруппу Тогда
					Возврат ЭлементУровня.ПолучитьИдентификатор();
				Иначе
					Рез = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭлементУровня); 
					Если Рез <> Неопределено Тогда
						Возврат Рез;
					КонецЕсли;				
				КонецЕсли;
			ИначеЕсли ЭлементУровня["СтруктурнаяЕдиница" + НомерСЕ] Тогда
				Возврат ЭлементУровня.ПолучитьИдентификатор();
			КонецЕсли;		
		КонецЦикла;
	КонецЦикла;
	Возврат Неопределено; 
	
КонецФункции

