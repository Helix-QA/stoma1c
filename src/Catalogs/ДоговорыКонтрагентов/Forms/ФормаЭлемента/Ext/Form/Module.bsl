// Функция - Получить список номенклатуры из папки.
//
Функция ПолучитьСписокНоменклатурыИзПапки(Папка)
	
	Если НЕ Папка.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
		Возврат Новый Массив;	
	КонецЕсли;
	
	Таблица = Справочники.Номенклатура.ПолучитьНоменклатуруПоГруппе(Папка);
	Возврат ?(ЗначениеЗаполнено(Таблица), Таблица.ВыгрузитьКолонку("Ссылка"), Новый Массив);
	
КонецФункции

&НаСервере
// Процедура - заполняет дерево значений формы из данных.
//
Процедура ЗаполнитьДерево(Договор = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДоговорыКонтрагентовОграничениеЗубов.КлючСтроки КАК КлючСтроки,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.КоличествоЗубов, 0) КАК КоличествоЗубов,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.КоличествоВПриеме, 0) КАК КоличествоВПриеме,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.НаименованиеОграничения, """") КАК НаименованиеОграничения,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Номенклатура КАК Номенклатура,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Согласование КАК Согласование,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Количество КАК Количество,
	|	ДоговорыКонтрагентовУслугиПоДоговору.КоличествоПриПревышении КАК КоличествоПриПревышении
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов.ОграничениеЗубов КАК ДоговорыКонтрагентовОграничениеЗубов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов.УслугиПоДоговору КАК ДоговорыКонтрагентовУслугиПоДоговору
	|		ПО ДоговорыКонтрагентовОграничениеЗубов.Ссылка = ДоговорыКонтрагентовУслугиПоДоговору.Ссылка
	|			И ДоговорыКонтрагентовОграничениеЗубов.КлючСтроки = ДоговорыКонтрагентовУслугиПоДоговору.КлючСтроки
	|ГДЕ
	|	ДоговорыКонтрагентовОграничениеЗубов.Ссылка = &Ссылка
	|ИТОГИ ПО
	|	КлючСтроки ИЕРАРХИЯ";
	Запрос.УстановитьПараметр("Ссылка", ?(ЗначениеЗаполнено(Договор), Договор, Объект.Ссылка));
	//Запрос.УстановитьПараметр("КлючСтроки", Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
	
	ВыборкаКлючСтроки = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Дерево = РеквизитФормыВЗначение("ДеревоУслуг");
	Дерево.Строки.Очистить();
	
	Пока ВыборкаКлючСтроки.Следующий() Цикл
		
		Если ЗначениеЗаполнено(ВыборкаКлючСтроки.КлючСтроки) Тогда
			НоваяСтрЗубы = Дерево.Строки.Добавить(); 
			НоваяСтрЗубы.КлючСтрокиОграничениеЗубов = ВыборкаКлючСтроки.КлючСтроки;	
		КонецЕсли;
		
		Детали = ВыборкаКлючСтроки.Выбрать();
		
		Пока Детали.Следующий() Цикл
			
			Если ЗначениеЗаполнено(Детали.Номенклатура) Тогда
				
				НовСтрДетали = НоваяСтрЗубы.Строки.Добавить();
				
				ЗаполнитьЗначенияСвойств(НовСтрДетали, Детали);
				НовСтрДетали.КлючСтрокиУслугиПоДоговору = Детали.КлючСтроки; 
				НовСтрДетали.Картинка = БиблиотекаКартинок.ИконкаЭлементДляСписка;
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ВыборкаКлючСтроки.КлючСтроки) Тогда
				// Заполняем главную группировку, т.к. данные тянутся позже.	
				НоваяСтрЗубы.КоличествоЗубов	 = Детали.КоличествоЗубов;
				НоваяСтрЗубы.КоличествоВПриеме	 = Детали.КоличествоВПриеме;	
				НоваяСтрЗубы.Номенклатура		 = Детали.НаименованиеОграничения; //ПолучитьПредставленеОграниченияЗуба(Детали.НаименованиеОграничения, Детали.КоличествоВПриеме, Детали.КоличествоЗубов);
				НоваяСтрЗубы.Картинка			 = БиблиотекаКартинок.ИконкаПапкиДляСписка;
				НоваяСтрЗубы.НаименованиеОграничения = Детали.НаименованиеОграничения;
				НоваяСтрЗубы.ПредставлениеОграничение = ПолучитьПредставлениеОграниченияЗуба(Детали.КоличествоВПриеме, Детали.КоличествоЗубов);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;		
	
	ЗначениеВРеквизитФормы(Дерево, "ДеревоУслуг");
	
КонецПроцедуры

&НаСервере
// Функция - возвращает наименование ограничения зубов в приеме.
//
Функция ПолучитьПредставлениеОграниченияЗуба(КоличествоВПриеме, КоличествоЗубов)
	
	СтрокаСЧисломЗубов = СтрокаСЧислом(";%1 зуб;;%1 зуба;%1 зубов;%1 зуба", КоличествоЗубов, ВидЧисловогоЗначения.Количественное, "L=ru"); 
	
	Если КоличествоВПриеме > 0 Тогда    
		СтрокаСЧисломПриемы	= СтрШаблон(", но не более %1 в приеме", КоличествоВПриеме);
	Иначе
		СтрокаСЧисломПриемы = "";
	КонецЕсли;

	Если КоличествоЗубов > 0 Тогда		
		Возврат СтрШаблон("На %1%2", СтрокаСЧисломЗубов, СтрокаСЧисломПриемы);
	Иначе		
		Возврат "";
	КонецЕсли; 
	
КонецФункции

&НаСервере
// Процедура - Дерево в таблицу.
//
Процедура ДеревоВТаблицу(ТекущийОбъект)
	
	Дерево = РеквизитФормыВЗначение("ДеревоУслуг");
	
	ТекущийОбъект.ОграничениеЗубов.Очистить();
	ТекущийОбъект.УслугиПоДоговору.Очистить();
	
	ПреобразоватьДеревоВТаблицуРекурсивно(Дерево, ТекущийОбъект); 
	
	МассивВыбранныхНоменклатур = ПолучитьМассивВыбранныхНоменклатур();
	
	Для каждого ЭлементМассива Из МассивВыбранныхНоменклатур Цикл 
		СтрокаТабличнойЧасти = ТекущийОбъект.УслугиПоДоговору.Добавить();
		СтрокаТабличнойЧасти.Номенклатура = ЭлементМассива;
		СтрокаТабличнойЧасти.Согласование = Перечисления.ТипыСогласованийУслугСтраховойКомпании.НеТребуется;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - преобрзует дерево значений формы в табличную часть объекта рекурсивно.
//
Процедура ПреобразоватьДеревоВТаблицуРекурсивно(КоллекцияСтрок, ТекущийОбъект)
	
	Для каждого СтрокаДерева Из КоллекцияСтрок.Строки Цикл
		
		Если ТипЗнч(СтрокаДерева.Номенклатура) = Тип("Строка") Тогда
			
			СтрокаТабличнойЧасти = ТекущийОбъект.ОграничениеЗубов.Добавить();  
			СтрокаТабличнойЧасти.НаименованиеОграничения = СтрокаДерева.НаименованиеОграничения;
			СтрокаТабличнойЧасти.КлючСтроки				 = СтрокаДерева.КлючСтрокиОграничениеЗубов;
			СтрокаТабличнойЧасти.КоличествоЗубов	 	 = СтрокаДерева.КоличествоЗубов;
			СтрокаТабличнойЧасти.КоличествоВПриеме	 	 = СтрокаДерева.КоличествоВПриеме;
			
		Иначе
			
			СтрокаТабличнойЧасти = ТекущийОбъект.УслугиПоДоговору.Добавить();
			СтрокаТабличнойЧасти.КлючСтроки				 = СтрокаДерева.КлючСтрокиУслугиПоДоговору;
			СтрокаТабличнойЧасти.Номенклатура			 = СтрокаДерева.Номенклатура;
			СтрокаТабличнойЧасти.Согласование			 = СтрокаДерева.Согласование;
			СтрокаТабличнойЧасти.Количество				 = СтрокаДерева.Количество;			  
			СтрокаТабличнойЧасти.КоличествоПриПревышении = СтрокаДерева.КоличествоПриПревышении; 
			
		КонецЕсли; 
		
		ПреобразоватьДеревоВТаблицуРекурсивно(СтрокаДерева, ТекущийОбъект);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить ограничение зубов на сервере завершение.
//
Процедура ДобавитьОграничениеЗубовНаСервереЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено
		И ТипЗнч(Результат) = Тип("Структура") Тогда
		
		ИзменитьДеревоУслуг(Результат);
		РазвернутьДеревоЗначений();
		ЭтаФорма.Модифицированность = Истина; 
		УстановитьДоступностьДобавленияУслугНаКлиенте();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Изменить дерево услуг.
//
Процедура ИзменитьДеревоУслуг(СтруктураПараметров = Неопределено)
	
	Если СтруктураПараметров <> Неопределено Тогда
		
		Дерево = РеквизитФормыВЗначение("ДеревоУслуг");
		
		ПредставлениеОграниченияЗуба = ПолучитьПредставлениеОграниченияЗуба(СтруктураПараметров.КоличествоВПриеме, СтруктураПараметров.КоличествоЗубов);
		
		// Помним, что для Общих итогов задан свой УИД.
		// Для групп тоже задан УИД
		// Без УИДа могут быть только номенклатуры без групп. 
		НайденнаяСтрока = Дерево.Строки.Найти(СтруктураПараметров.КлючСтроки, "КлючСтрокиОграничениеЗубов"); // Ищем в общих итогах.
		Если НайденнаяСтрока <> Неопределено Тогда  
			
			ЗаполнитьЗначенияСвойств(НайденнаяСтрока, СтруктураПараметров); 
			НайденнаяСтрока.Номенклатура = СтруктураПараметров.НаименованиеОграничения; 
			НайденнаяСтрока.ПредставлениеОграничение = ПредставлениеОграниченияЗуба; 
			//НайденнаяСтрока.Номенклатура = НаименованиеОграниченияЗуба; 
			
		Иначе
			
			НовСтрДетали = Дерево.Строки.Добавить(); 
			ЗаполнитьЗначенияСвойств(НовСтрДетали, СтруктураПараметров); 
			НовСтрДетали.Номенклатура = СтруктураПараметров.НаименованиеОграничения; 
			НовСтрДетали.ПредставлениеОграничение = ПредставлениеОграниченияЗуба; 
			НовСтрДетали.КлючСтрокиОграничениеЗубов = СтруктураПараметров.КлючСтроки;
			НовСтрДетали.Картинка = БиблиотекаКартинок.ИконкаПапкиДляСписка;
			НовСтрДетали.Согласование = СтруктураПараметров.Согласование; 
			
		КонецЕсли;
		
		ЗначениеВРеквизитФормы(Дерево, "ДеревоУслуг"); 
		
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура - Дерево услуги номенклатура начало выбора завершение.
//
Процедура ДеревоУслугиНоменклатураНачалоВыбораЗавершение(Значение, Параметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Значение) Тогда 
		Возврат;
	КонецЕсли; 
	
	ДобавитьМассивНоменклатурНаСервере(Значение, Параметры);
	
	РазвернутьДеревоЗначений();
	
КонецПроцедуры

&НаКлиенте
// Процедура - разворачивает дерево значений на клиенте.
//
Процедура РазвернутьДеревоЗначений()
	
	тЭлементы = ДеревоУслуг.ПолучитьЭлементы();
	Для Каждого тСтр Из тЭлементы Цикл
		Элементы.ДеревоУслуг.Развернуть(тСтр.ПолучитьИдентификатор(), Истина);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - добавляет массив номенклатур в дерево услуг на сервере.
//
Процедура ДобавитьМассивНоменклатурНаСервере(МассивНоменклатур, МассивВыбранныхНоменклатур)
	
	ТекущаяСтрока = ДеревоУслуг.НайтиПоИдентификатору(Элементы.ДеревоУслуг.ТекущаяСтрока);
	СтрокаРодитель = ТекущаяСтрока.ПолучитьРодителя();
	
	Если ТекущаяСтрока.Номенклатура = Неопределено
		ИЛИ ТипЗнч(ТекущаяСтрока.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
		
		СтрокаРодитель = ТекущаяСтрока.ПолучитьРодителя();
		
	Иначе
		СтрокаРодитель = ТекущаяСтрока;	
	КонецЕсли;
	
	Дерево = РеквизитФормыВЗначение("ДеревоУслуг"); 
	
	НайденнаяСтрокаРодитель = Дерево.Строки.Найти(СтрокаРодитель.КлючСтрокиОграничениеЗубов, "КлючСтрокиОграничениеЗубов", Истина); // Ищем в общих итогах.	
	
	Если НайденнаяСтрокаРодитель <> Неопределено Тогда
		Для каждого ЭлементМассива Из МассивНоменклатур Цикл 
			
			ДобавитьНоменклатуруРекурсивно(Дерево, НайденнаяСтрокаРодитель, ЭлементМассива, МассивВыбранныхНоменклатур);
			
		КонецЦикла;	
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(Дерево, "ДеревоУслуг"); 
	
	ЭтаФорма.Модифицированность = Истина;

КонецПроцедуры

&НаСервере
// Процедура - Добавить номенклатуру рекурсивно.
//
// Параметры:
//  Дерево					 - 	 - 
//  НайденнаяСтрокаРодитель	 - 	 - 
//  НоменклатураСсылка		 - 	 - 
//
Процедура ДобавитьНоменклатуруРекурсивно(Дерево, НайденнаяСтрокаРодитель, НоменклатураСсылка, МассивВыбранныхНоменклатур)
		
	// Добавляем группу.
	Если НоменклатураСсылка.ЭтоГруппа Тогда 
		
		ТаблицаНоменклатуры = Справочники.Номенклатура.ПолучитьНоменклатуруПоГруппе(НоменклатураСсылка);
		
		Для каждого СтрокаТаблицы Из ТаблицаНоменклатуры Цикл
			ДобавитьНоменклатуруРекурсивно(Дерево, НайденнаяСтрокаРодитель, СтрокаТаблицы.Ссылка, МассивВыбранныхНоменклатур);
		КонецЦикла;
		
	Иначе
		
		Если ЗначениеЗаполнено(МассивВыбранныхНоменклатур) Тогда 
			// Исключаем не выбранные услуги.
			ИндексНайденнойСтроки = МассивВыбранныхНоменклатур.Найти(НоменклатураСсылка);
			
			Если ИндексНайденнойСтроки <> Неопределено Тогда
				
				// Добавляем элемент.
				НайденнаяСтрока = Дерево.Строки.Найти(НоменклатураСсылка, "Номенклатура", Истина);	
				Если НайденнаяСтрока = Неопределено Тогда
					
					НоваяСтрока = НайденнаяСтрокаРодитель.Строки.Добавить();
					НоваяСтрока.Номенклатура = НоменклатураСсылка;
					НоваяСтрока.Согласование = ?(ЗначениеЗаполнено(НайденнаяСтрокаРодитель.Согласование), НайденнаяСтрокаРодитель.Согласование, ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.НеТребуется")); 
					НоваяСтрока.Картинка	 = БиблиотекаКартинок.ИконкаЭлементДляСписка;
					НоваяСтрока.КлючСтрокиУслугиПоДоговору = НайденнаяСтрокаРодитель.КлючСтрокиОграничениеЗубов; 
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Заполнить дерево номенклатур.
//
Процедура ЗаполнитьДеревоНоменклатур(Договор = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДоговорыКонтрагентовУслугиПоДоговору.КлючСтроки КАК КлючСтроки,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВтДоговоров
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов.УслугиПоДоговору КАК ДоговорыКонтрагентовУслугиПоДоговору
	|ГДЕ
	|	ДоговорыКонтрагентовУслугиПоДоговору.Ссылка = &Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СпрНоменклатура.Ссылка КАК Номенклатура,
	|	НЕ ВтДоговоров.КлючСтроки ЕСТЬ NULL КАК Выбран,
	|	ВЫБОР
	|		КОГДА СпрНоменклатура.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндексКартинки,
	|	СпрНоменклатура.ЭтоГруппа КАК ЭтоГруппа
	|ИЗ
	|	Справочник.Номенклатура КАК СпрНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтДоговоров КАК ВтДоговоров
	|		ПО СпрНоменклатура.Ссылка = ВтДоговоров.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&ДатаСреза, ) КАК СтатусыНоменклатурыСрезПоследних
	|		ПО СпрНоменклатура.Ссылка = СтатусыНоменклатурыСрезПоследних.Номенклатура
	|ГДЕ
	|	СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И НЕ СпрНоменклатура.ПометкаУдаления
	|	И ЕСТЬNULL(СтатусыНоменклатурыСрезПоследних.ВПродаже, ИСТИНА)
	|	И НЕ СпрНоменклатура.Ссылка В (&НеиспользуемыеГруппы)
	|
	|УПОРЯДОЧИТЬ ПО
	|	СпрНоменклатура.Ссылка ИЕРАРХИЯ
	|АВТОУПОРЯДОЧИВАНИЕ";
	МассивТипов = Новый Массив();
	МассивТипов.Добавить(Перечисления.ТипыНоменклатуры.Услуга);
	Запрос.УстановитьПараметр("ДатаСреза", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Договор", ?(ЗначениеЗаполнено(Договор), Договор, Объект.Ссылка));
	Запрос.УстановитьПараметр("УИД", Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000")); 
	Запрос.УстановитьПараметр("НеиспользуемыеГруппы", 
	Справочники.Номенклатура.ПолучитьНеиспользуемыеГруппы(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, ТекущаяДатаСеанса(), МассивТипов));
	
	ДеревоЗнч = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);	
	
	ЗначениеВРеквизитФормы(ДеревоЗнч, "ДеревоНоменклатур");                                    

КонецПроцедуры

&НаКлиенте
// Процедура, выполняет установку флагов на элменеты.
//
Процедура УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонки, МассивИсключений = Неопределено)
	
	МассивИсключений = ?(МассивИсключений = Неопределено, Новый Массив(), МассивИсключений);
	Флаг 		 = ТекущиеДанные[ИмяКолонки];
	ДанныеДерева = ТекущиеДанные.ПолучитьЭлементы();
	
	Для Каждого СтрокаДерева из ДанныеДерева Цикл
		
		НайденнаяСтрока = МассивИсключений.Найти(СтрокаДерева.Номенклатура);
		Если НайденнаяСтрока = Неопределено Тогда
			СтрокаДерева[ИмяКолонки] = Флаг;
			
			Если СтрокаДерева.ЭтоГруппа Тогда
				УстановитьФлагиНаЭлементы(СтрокаДерева, ИмяКолонки, МассивИсключений);
			КонецЕсли;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Удалите услугу: %1 из дерева ограничений", СтрокаДерева.Номенклатура));	
		КонецЕсли;
		
	КонецЦикла;		
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает флаги на группы.
//
Процедура УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, ЭтоРодитель = Ложь)
	
	Если ЭтоРодитель Тогда
		Родитель = ТекущиеДанные;
	Иначе
		Родитель = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	
	Если Родитель = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДерева = Родитель.ПолучитьЭлементы();
	
	КоличествоВыбранных = 0;
	Для Каждого СтрокаДерева из ДанныеДерева Цикл
		
		Если СтрокаДерева[ИмяКолонки] = 1 Тогда
			КоличествоВыбранных = КоличествоВыбранных + 1;
		ИначеЕсли СтрокаДерева[ИмяКолонки] = 2 Тогда
			КоличествоВыбранных = -1;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если КоличествоВыбранных = ДанныеДерева.Количество() Тогда
		Родитель[ИмяКолонки] = 1;
	ИначеЕсли КоличествоВыбранных = 0 Тогда
		Родитель[ИмяКолонки] = 0;
	Иначе
		Родитель[ИмяКолонки] = 2;
	КонецЕсли;		
	
	УстановитьФлагиНаГруппы(Родитель, ИмяКолонки);
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает флаги на группы при первоночальном построение дерева.
//
Процедура УстановитьНачальныеФлагиНаГруппы()
	
	// Проставялем флаги на группах дерева.
	ДанныеДерева = ЭтаФорма.ДеревоНоменклатур.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ Из ДанныеДерева Цикл
		Если СтрокаТЧ.ЭтоГруппа Тогда
			ОбработкаТабличныхЧастейКлиент.УстановитьНачальныеФлагиНаГруппы(СтрокаТЧ, "Выбран");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
