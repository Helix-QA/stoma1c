	Запрос.УстановитьПараметр("ЭтапПотенциальныйПрием"	, СоответствиеЭтаповСделок.Получить(1));
	Запрос.УстановитьПараметр("ЭтапПредложениеОзвучено"	, СоответствиеЭтаповСделок.Получить(2));
	Запрос.УстановитьПараметр("ЭтапПациентЗаписан"		, СоответствиеЭтаповСделок.Получить(3));
    Запрос.УстановитьПараметр("ЭтапПациентПодтвердил"	, СоответствиеЭтаповСделок.Получить(4)); 	
	Запрос.УстановитьПараметр("ДатаНачала"				, ПериодРасчетаНачало);
	Запрос.УстановитьПараметр("ДатаОкончания"			, ПериодРасчетаОкончание);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
		
	Результат = ПолучитьРезультатыПакетногоЗапроса(Новый_Массив(5, 6, 12, 13, 14, 15, 16, 17), Запрос.ВыполнитьПакетСПромежуточнымиДанными());  
			
	ПоместитьВоВременноеХранилище(Результат, ВременноеХранилищеРезультата);
		
КонецФункции  

// Функция возвращает этапы сделок по виду сделки.
//
Функция ПолучитьЭтапыСделок(ПредопределенныйВидСделки)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.НомерЭтапа КАК НомерЭтапа
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ВидСделки = &ВидСделки
	|	И ЭтапыСделок.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерЭтапа"; 
	
	Запрос.УстановитьПараметр("ВидСделки", ПредопределенныйВидСделки); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	СоответствиеРезультат = Новый Соответствие; 
	
	Пока Выборка.Следующий() Цикл
		
		СоответствиеРезультат.Вставить(Выборка.НомерЭтапа, Выборка.Ссылка); 
		
	КонецЦикла;	
		
	Возврат СоответствиеРезультат;
	
КонецФункции

// Функция - Получить результаты пакетного запроса.
//
// Параметры:
//  ИндексыРезультатов	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьРезультатыПакетногоЗапроса(МассивИндексовРезультатов, МассивРезультатовЗапроса)
	
	Результат = Новый Соответствие();
	
	Для Каждого Индекс Из МассивИндексовРезультатов Цикл
		
		Выборка = МассивРезультатовЗапроса[Индекс].Выбрать(); 	
		
		Пока Выборка.Следующий() Цикл 
			Для Каждого Колонка Из МассивРезультатовЗапроса[Индекс].Колонки Цикл		
				Результат.Вставить(Колонка.Имя, Выборка[Колонка.Имя]);
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

