						СтрокаСкидкиДерева.ЗначениеСкидкиНаценки 				= ЗначениеСкидкиНаценкиПроцент - (ЗначениеСкидкиНаценкиПроцент * СтрокаРодитель.НакапливаемоеЗначениеСкидкиНаценки - СтрокаРодитель.МаксимальноеЗначениеСкидкиНаценки);
						СтрокаСкидкиДерева.ЗначениеСкидкиНаценки 				= ?(СтрокаСкидкиДерева.ЗначениеСкидкиНаценки < 0, 0, СтрокаСкидкиДерева.ЗначениеСкидкиНаценки);
