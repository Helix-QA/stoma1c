// Процедура - Установить вид оплаты СБП
//
Процедура УстановитьВидОплатыСБП_И_СсылокНаОплату()
	
	ВнешняяСистема			= Неопределено;
	ЭтоВозврат				= ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Возврат;
	
	Если ЭтоВозврат Тогда
		
		Если ЗначениеЗаполнено(ДокументыЗадолженности) И ТипЗнч(ДокументыЗадолженности[0].Значение) = Тип("ДокументСсылка.ВозвратОтПокупателя")Тогда
			ТаблицаЭТ = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьТаблицуСЭквайрингомДляВозврата(ДокументыЗадолженности[0].Значение);
		Иначе
			ТаблицаЭТ = Новый ТаблицаЗначений;	
		КонецЕсли;
		
	Иначе
		ТаблицаЭТ = Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыеТерминалыСБП_И_СсылокНаОплату(ЭтотОбъект.ТекущаяКасса, ЭтотОбъект.СтруктурнаяЕдиница);			
	КонецЕсли;

	Если ТаблицаЭТ.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	СущВидыОплатВерхУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей,,,,,,,,,,, Справочники.ЭквайринговыеТерминалы.ПустаяСсылка());
	
	Если НЕ ЗначениеЗаполнено(СущВидыОплатВерхУр) Тогда
		
		ЭлементДереваЭТ                    = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Добавить();
		ЭлементДереваЭТ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей; 
		ЭлементДереваЭТ.Представление      = НСтр("ru = 'Система быстрых платежей и ссылки на оплату'; en = 'Fast payment system and payment links'");  
		
	Иначе
		ЭлементДереваЭТ = СущВидыОплатВерхУр[0];
	КонецЕсли;
		
	Для Каждого СтрокаТ ИЗ ТаблицаЭТ Цикл
				
		СущВидыОплатНижнУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей,,,,,,,,,,, СтрокаТ.ЭквайринговыйТерминал);
		
		НоваяСтрока = ?(ЗначениеЗаполнено(СущВидыОплатНижнУр), СущВидыОплатНижнУр[0], ЭлементДереваЭТ.ПолучитьЭлементы().Добавить());
		
		НоваяСтрока.ЭквайринговыйТерминал  = СтрокаТ.ЭквайринговыйТерминал;
		НоваяСтрока.Контрагент	           = ЭтотОбъект.Контрагент;
		НоваяСтрока.КассаОплаты            = ЭтотОбъект.ТекущаяКасса;
		НоваяСтрока.ТипДенежныхСредств     = Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей;
		НоваяСтрока.МаксСуммаСписания      = ?(ЭтоВозврат, СтрокаТ.Сумма, -1);
		НоваяСтрока.НаименованиеВидаОплаты = СтрокаТ.Наименование;
		НоваяСтрока.Представление		   = СтрокаТ.Наименование;
				
	КонецЦикла;
				
КонецПроцедуры

#КонецОбласти

#Область КонструкторДинамическойТаблицыДоступныхВидовОплат

// Процедура - Построить динаимческую таблицу задолженностей
// 
&НаСервере
Процедура СоздатьДинамическуюТаблицуДоступныхВидовОплат()
	
	УдалитьДинамическиеЭлементыТаблицыДоступныхВидовОплат();
			
	ОсновнаяГруппа = ВидыОплатРодительскаяГруппаФормы();

	Для Каждого ВидОплатыВрУр ИЗ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл
		
		НомерСтрокиВрУр = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Индекс(ВидОплатыВрУр);	
			
		Если ВидОплатыВрУр.ПолучитьЭлементы().Количество() = 0 Тогда
			
			Если НомерСтрокиВрУр = 0 Тогда
				
				Если ВидОплатыВрУр.Представление = "Заглушка" Тогда
					
					Элементы.ГруппаВидыОплатЗаголовокГруппировки_0.Видимость = Ложь;
                    Продолжить;
					
				Иначе
					
					Элементы.ГруппаВидыОплатЗаголовокГруппировки_0.Видимость = Истина;
					 
				 КонецЕсли;
				
				Если ВидОплатыВрУр.Внесено = 0 Тогда
					
					Элементы.ДекорацияНаименованиеГруппировкиВидовОплат_0.Видимость = Ложь;
					Элементы.КнопкаВидыОплатаНаименованиеСтрока_0.Заголовок         = ВидОплатыВрУр.Представление;
					Элементы.ПолеВидыОплатВводСуммыСтрока_0.Видимость               = Ложь;
					Элементы.КнопкаВидыОплатПредставлениеСуммыСтрока_0.Видимость    = Ложь;
					Элементы.КнопкаВидыОплатПрименитьСуммуСтрока_0.Видимость       = Ложь;
					Элементы.КнопкаВидыОплатУдалитьСуммуСтрока_0.Видимость          = Ложь;
					Элементы.ПолеВводаСерииСертификата_0.Видимость                  = Ложь;
					Элементы.ПолеВыбораВидаЛицевогоСчета_0.Видимость                = Ложь;

				КонецЕсли;
				
			Иначе
				
				СоздатьСтрокуДинамическойТаблицыДоступныхВидовОплат(
				ОсновнаяГруппа,
				ВидОплатыВрУр.ПолучитьИдентификатор(),
				НомерСтрокиВрУр, 
				-1,
				ВидОплатыВрУр.Представление,
				Неопределено,
				ВидОплатыВрУр.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПустаяСсылка(),
				Ложь);
		
			КонецЕсли;
			
		Иначе
					
			ГруппаГруппировкиСтрок = СоздатьГруппировкуВидовОплат(ОсновнаяГруппа, НомерСтрокиВрУр, ВидОплатыВрУр.Представление);
	
			Для Каждого ВидОплатыНижУр ИЗ ВидОплатыВрУр.ПолучитьЭлементы() Цикл
				
				НомерСтрокиНижУр = ВидОплатыВрУр.ПолучитьЭлементы().Индекс(ВидОплатыНижУр);	
				
				Картинка = ?(ЗначениеЗаполнено(ВидОплатыНижУр.ЭквайринговыйТерминал), ПолучитьКартинкуСоответствияТипуШлюза(ВидОплатыНижУр.ЭквайринговыйТерминал), Неопределено);				
				
				СоздатьСтрокуДинамическойТаблицыДоступныхВидовОплат(
				ГруппаГруппировкиСтрок,
				ВидОплатыНижУр.ПолучитьИдентификатор(),
				"" + НомерСтрокиВрУр,
				НомерСтрокиНижУр,
				ВидОплатыНижУр.Представление,
				ВидОплатыВрУр.Представление,,,
				Картинка);
												
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Удалить динаимеческие элементы состав занятия
// 
// Параметры:
//  ИндексПервогоЭлемента	 - 	 - 
// 
Процедура УдалитьДинамическиеЭлементыТаблицыДоступныхВидовОплат()
	
	ОсновнаяГруппа = ВидыОплатРодительскаяГруппаФормы();
	
	// Все оставльные
	Индекс = ОсновнаяГруппа.ПодчиненныеЭлементы.Количество() - 1;
	Пока Индекс > 0  Цикл
		
		Элементы.Удалить(ОсновнаяГруппа.ПодчиненныеЭлементы[Индекс]);		
		Индекс = Индекс - 1;
		
	КонецЦикла;	
	
КонецПроцедуры

// Функция - Создать группировку видов оплат
// 
// Возвращаемое значение:
//   - 
// 
&НаСервере
Функция СоздатьГруппировкуВидовОплат(ОсновнаяГруппа, НомерСтрокиДан, ЗаголовокГруппы)
	
	ГруппаГруппировкиВерхняя = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатЗаголовокГруппировки_0,
	НомерСтрокиДан,
	ОсновнаяГруппа);
	
	ДекорацияЗаголовка =  УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ДекорацияНаименованиеГруппировкиВидовОплат_0, 
	НомерСтрокиДан,
	Тип("ДекорацияФормы"),
	ГруппаГруппировкиВерхняя);
	
	ДекорацияЗаголовка.Заголовок = ЗаголовокГруппы;
	ДекорацияЗаголовка.Видимость = Истина;
	
	ГруппаГруппировкиНижняя = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатГруппировка_0,
	НомерСтрокиДан,
	ГруппаГруппировкиВерхняя);

	Возврат ГруппаГруппировкиНижняя;
	
КонецФункции

// Процедура - Построить строку динаимческой таблицы задолженностей
// 
// Параметры:
//  СтрокаТ	 - 	 - 
// 
&НаСервере
Процедура СоздатьСтрокуДинамическойТаблицыДоступныхВидовОплат(ОсновнаяГруппа, ИдСтрокиДанных, НомерСтрокиДанВерхУр, НомерСтрокиДанНижУр, Заголовок, ЗаголовокГруппы, ВыводитьЗаглушку = Ложь, ФлагДоступность = Неопределено, Картинка = Неопределено)

	НомерСтрокиДан = "" + НомерСтрокиДанВерхУр + ?(НомерСтрокиДанНижУр > -1, "x" + НомерСтрокиДанНижУр, "");
		    
	ПодгруппаСтрокиВертикальная = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатГруппировкаВертикальная_0,
	НомерСтрокиДан,
	ОсновнаяГруппа);
	
	ПодгруппаСтрокиВертикальная.Доступность = ?(ФлагДоступность <> Неопределено И ФлагДоступность, Ложь, ПодгруппаСтрокиВертикальная.Доступность);
	
	ПодгруппаСтроки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатСтрока_0,
	НомерСтрокиДан,
	ПодгруппаСтрокиВертикальная);
	
	Если ВыводитьЗаглушку Тогда
		
		Заглушка = УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
		ЭтаФорма,
		Элементы.ДекорацияЗаглушка_0, 
		НомерСтрокиДан,
		ТипЗнч(Элементы.ДекорацияЗаглушка_0),
		ПодгруппаСтроки);
		
		Заглушка.Видимость = Истина;
		
	КонецЕсли;
	
	УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатаНаименованиеСтрока_0, 
	НомерСтрокиДан,
	ПодгруппаСтроки,
	"ОбработчикНажатияВидыОплатВыбор",
	Заголовок,,,
	Картинка);
	
	ПодгруппаРедактированияСуммы = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатСуммаСтрока_0,
	НомерСтрокиДан,
	ПодгруппаСтроки);
	
	ПодгруппаРедактированияДатыОплаты = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатДатаОплатыСтрока_0,
	НомерСтрокиДан,
	ПодгруппаСтроки);
	
	// Сумма оплаты
    СоздатьГруппуСуммыВнесеннойОплаты(ПодгруппаРедактированияСуммы, ИдСтрокиДанных, НомерСтрокиДанВерхУр, НомерСтрокиДанНижУр, Заглушка);
	
КонецПроцедуры

// Процедура - Построить группу суммы внесенной оплаты
// 
// Параметры:
//  РодительскаяГруппа	 - 	 - 
//  НомерСтрокиДанВерхУр - 	 - 
//  НомерСтрокиДанНижУр	 - 	 - 
// 
&НаСервере
Процедура СоздатьГруппуСуммыВнесеннойОплаты(РодительскаяГруппа, ИдСтрокиДанных, НомерСтрокиДанВерхУр, НомерСтрокиДанНижУр, ДекорацияЗаглушка = Неопределено)
	
	НомерСтрокиДан = "" + НомерСтрокиДанВерхУр + ?(НомерСтрокиДанНижУр > -1, "x" + НомерСтрокиДанНижУр, "");
	СтрокаДанных   = ЭтотОбъект.ВидыОплат.НайтиПоИдентификатору(ИдСтрокиДанных);
	
	Если СтрокаДанных.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
		
		ПолеВводаСерииСертификатаИлиВидаЛС = УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
		ЭтаФорма,
		Элементы.ПолеВводаСерииСертификата_0, 
		НомерСтрокиДан,
		Тип("ПолеФормы"), 
		РодительскаяГруппа,
		"ВидыОплат[" + НомерСтрокиДанВерхУр +"]" + ?(НомерСтрокиДанНижУр > -1, "[" + НомерСтрокиДанНижУр + "]", "") + ".ВводСерииСертификата");
		
		ПолеВводаСерииСертификатаИлиВидаЛС.Видимость = Истина;
		
	Иначе
		
		ПолеВводаСерииСертификатаИлиВидаЛС = УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
		ЭтаФорма,
		Элементы.ПолеВыбораВидаЛицевогоСчета_0, 
		НомерСтрокиДан,
		Тип("ПолеФормы"), 
		РодительскаяГруппа,
		"ВидыОплат[" + НомерСтрокиДанВерхУр +"]" + ?(НомерСтрокиДанНижУр > -1, "[" + НомерСтрокиДанНижУр + "]", "") + ".ВыборВидаЛицевогоСчета");

		ПолеВводаСерииСертификатаИлиВидаЛС.Видимость = Истина;
		
	КонецЕсли;

	ПолеВводаСерииСертификатаИлиВидаЛС.Видимость = Ложь;
		
	ПолеВводаОплаты = УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ПолеВидыОплатВводСуммыСтрока_0, 
	НомерСтрокиДан,
	Тип("ПолеФормы"), 
	РодительскаяГруппа,
	"ВидыОплат[" + НомерСтрокиДанВерхУр +"]" + ?(НомерСтрокиДанНижУр > -1, "[" + НомерСтрокиДанНижУр + "]", "") + ".Внесено");
	
	ПолеВводаОплаты.Видимость = Ложь;
	ПолеВводаОплаты.ТолькоПросмотр = СтрокаДанных.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПустаяСсылка();
	
	КнопкаПредставления =  УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатПредставлениеСуммыСтрока_0, 
	НомерСтрокиДан,
	РодительскаяГруппа);
	
	КнопкаПрименить =  УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатПрименитьСуммуСтрока_0, 
	НомерСтрокиДан,
	РодительскаяГруппа);
	
	КнопкаУдалить =  УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатУдалитьСуммуСтрока_0, 
	НомерСтрокиДан,
	РодительскаяГруппа);
	
	СтрокаДанных = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы()[Число(НомерСтрокиДанВерхУр)];
	Если Число(НомерСтрокиДанНижУр) > -1 Тогда
		СтрокаДанных = СтрокаДанных.ПолучитьЭлементы()[Число(НомерСтрокиДанНижУр)];
	КонецЕсли;
	
	Если СтрокаДанных.Внесено > 0 Тогда
		
		КнопкаПредставления.Заголовок = Формат(СтрокаДанных.Внесено,"ЧДЦ=2");
		КнопкаПредставления.Видимость = Истина;
		КнопкаПрименить.Видимость     = Ложь;
		КнопкаУдалить.Видимость       = Истина;
		
	Иначе
		
	    КнопкаПредставления.Заголовок =  "0,00";
		КнопкаПредставления.Видимость = Ложь;
		КнопкаПрименить.Видимость     = Ложь;
		КнопкаУдалить.Видимость       = Ложь;
		
		Если ДекорацияЗаглушка <> Неопределено Тогда
			ДекорацияЗаглушка.Видимость = Ложь;
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

// Функция - Виды оплат родительская группа формы
// 
// Возвращаемое значение:
//   - 
// 
&НаСервере
Функция ВидыОплатРодительскаяГруппаФормы()
	
	Возврат Элементы.ГруппаДинамическаяТабДоступныхВидовОплат;
	
КонецФункции

// Функция - Виды оплат строка кнопка наименования вида оплат
// 
// Параметры:
//  ПрефиксИмени - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
&НаКлиенте
Функция ВидыОплатСтрокаКнопкаНаименованияВидаОплат(ПрефиксИмени)
	
   ИмяПоляРодителя = "КнопкаВидыОплатаНаименованиеСтрока_";
   
