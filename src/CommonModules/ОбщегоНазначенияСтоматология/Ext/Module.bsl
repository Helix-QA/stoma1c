		Возврат "КартаКонтрагента";
	ИначеЕсли ЕстьРеквизитДокумента("КартаИсточник", МетаданныеДокумента) Тогда
		Возврат "КартаИсточник";
	ИначеЕсли ЕстьРеквизитДокумента("КартаКлиента", МетаданныеДокумента) Тогда
		Возврат "КартаКлиента";		
	Иначе
