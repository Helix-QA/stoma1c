						Исключение
						КонецПопытки; 
					КонецЕсли;	
					СтрПакетыУслуг.Количество = КоличествоУслуг; 
					СтрПакетыУслуг.КлючСтроки = НоваяСтрока.КлючСтроки;
				КонецЕсли;                                                                

				НоваяСтрока.ВидЦен = Справочники.ВидыЦен.Розничная;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ЗаписьЖурналаРегистрации(Нстр("ru='Загрузка данных'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Документы.ВводНачальныхОстатков, , Нстр("ru ='Запасы: '") + ОписаниеОшибки());
