
#Область ОписаниеПеременных

&НаКлиенте
Перем ТекЭлементВвода;  
&НаКлиенте
Перем ТаблицаЛечениеИзмененаСуммаСтроки;
&НаКлиенте
Перем ТаблицаЗапасыИзмененаСуммаСтроки;
&НаКлиенте
Перем ПерваяСсылкаВСпикеПодбораНоменклатуры;	
&НаКлиенте
Перем ФильтрУслугИспользован;
&НаКлиенте
Перем ФильтрТоваровИспользован;
&НаКлиенте
Перем ИскомыйКлиент;
&НаКлиенте
// Флаг указывает на необходимость блокировки отработки события
Перем HTMLДокументОбследованиеБлокироватьСобытиеСформирован;
&НаКлиенте
// В переменной содержится таблица подбора, которую необходимо обновить принудительно
Перем ПринудительноеОбновлениеТаблицыПодбора;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЦветАктивногоЭлемента = ЦветаСтиля.ЦветНавигации;
	СброситьРазмерыИПоложениеОкна();
	
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);
	
	// Создаем уникальный идентификатор доступа для данного документа
	УникальныйИдентификаторДоступа = Новый УникальныйИдентификатор;
	
	ИспользуетсяРасширениеМессенджер = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер");	

	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		
		// Открывает доступ к приемам для рекламаторов
		ИнициализацияДоступаРекламаторам("Открыть",,,ПолучитьМассивРекламацийСервер(),
			Объект.Контрагент,
			Объект.АвторДокумента,
			Объект.СтруктурнаяЕдиница,
			УникальныйИдентификаторДоступа);  
			
			Если Не Объект.Ссылка.Пустая() Тогда
				ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Объект.Контрагент, Объект.СтруктурнаяЕдиница);
			КонецЕсли;	  
			
	КонецЕсли;
	
	ЭтотОбъект.ОтображатьОценкиИОтзывы = Ложь;
	
	// Открывает доступ к колонке %ручной скидки
	ИнициализацияДоступаКРучнойСкидке();
	// Устанавливает видимость колонки "Рекламация"
	Элементы.ТаблицаЛечениеРекламация.Видимость = ИнициализацияВидимостиКолонкиРекламация(Объект.Лечение);	
	
	ВсяПолость = Перечисления.Зубы.ВсяПолость;
	
	РежимРаботыЕдинаяСеть = Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть; 	
	ОбщиеПараметры        = Новый Структура;
	ОбщиеПараметры.Вставить("Перечисление_Зубы_ВсяПолость"                   , ВсяПолость);
	ОбщиеПараметры.Вставить("ТипыПараметровШаблоновОбследований_Статический" , Перечисления.ТипыПараметровШаблоновОбследований.Статический);
	ОбщиеПараметры.Вставить("ТипыПараметровШаблоновОбследований_Динамический", Перечисления.ТипыПараметровШаблоновОбследований.Динамический);
	
	// Формирует переключатель закладок
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("ЗубнаяФормула"	, "ЗубнаяФормула");
	СтруктураМеню.Вставить("Обследование"	, "ГруппаОбследование");
	СтруктураМеню.Вставить("Лечение"		, "ГруппаЛечение");
	СтруктураМеню.Вставить("Товары"			, "ГруппаЗапасы");
	СтруктураМеню.Вставить("СкидкиНаценки"	, "ГруппаСкидкиНаценки");
	СтруктураМеню.Вставить("Подарки"		, "ГруппаПодарки");
	СтруктураМеню.Вставить("Авансы"			, "ГруппаАвансы");
	СтруктураМеню.Вставить("Дополнительно"	, "ГруппаДополнительно");
	
	ПрименятьСкидкиПоПланамЛечения = ОбщегоНазначенияСтоматология.ПолучитьЗначениеКонстанты("ПрименятьСкидкиПоПланамЛечения");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	// Получаем вид цены
	Если Объект.Ссылка.Пустая() Тогда
		Если Объект.ВремяНачалаПриема = Дата(1,1,1) Тогда 
			Объект.ВремяНачалаПриема    = ТекущаяДатаСеанса();
		КонецЕсли; 
		
		Если Не ЗначениеЗаполнено(Объект.ВидЦен) Тогда
			Объект.ВидЦен = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
		КонецЕсли;
	
		// Устанавливаем заголовок формы если это создание доумента
		Этаформа.АвтоЗаголовок = Ложь;
		Этаформа.Заголовок = "Прием начат";
	КонецЕсли;  
	
	ПредВыбранныйКонтрагент         = Объект.Контрагент;
	ПредВыбранныйСтраховойПолис     = Объект.ПолисМедСтрахования;
	УстановитьОтборСегментНоменклатуры(Объект.ПолисМедСтрахования, Объект.СтруктурнаяЕдиница, Объект.Сотрудник);
	ЭтотОбъект._ПодборДоговорПолиса = ?(ЗначениеЗаполнено(Объект.ПолисМедСтрахования), Объект.ПолисМедСтрахования.Договор, Неопределено); // Справочники.ДоговорыКонтрагентов.ПустаяСсылка()	
	ВидЦеныПред                     = Объект.ВидЦен;
    СотрудникПред                   = Объект.Сотрудник;
    ЭтоСтоматологическиеУслуги      = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(Объект.Сотрудник);
	Объект.Ассистент                = ?(Не ЗначениеЗаполнено(Объект.Ассистент),РегистрыСведений.НастройкиСотрудников.ПолучитьАссистентаСотрудника(Объект.Сотрудник, Объект.СтруктурнаяЕдиница), Объект.Ассистент);
	МаксимальнаяРучнаяСкидка	    = РегистрыСведений.НастройкиСотрудников.ПолучитьМаксимальнуюСкидкуСотрудника(ПараметрыСеанса.АвторизованныйПользователь.Сотрудник, Объект.СтруктурнаяЕдиница);

	ИспользоватьУЕТ = Константы.ИспользоватьУЕТ.Получить();
	Элементы.ТаблицаЛечениеУЕТ.Видимость = ИспользоватьУЕТ;	

	// Сформируем надпись
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);	
	
	// Сформируем надпись
	СтруктураНадписи = Новый Структура("ВидЦен", Объект.ВидЦен);
	ВидЦенНадпись = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи, Ложь);
	
	HTML = ПолучитьОбщийМакет("HTMLДокумент").ПолучитьТекст();
	НастройкаФормыСервер("ПРИ_ЗАПУСКЕ");                      	
	SVGВыделенныйЗуб         = "var selectzub"; 
	SVGМассивВыделенныхЗубов = "var SelectedTeeth = [];";
	SVGМассивЛечащихсяЗубов  = "var mas='';";	
	
	ОткрыватьПодбор = Истина; 
	ФлагВыгрузиКэш  = Истина;	
	
	Если Объект.Ссылка.Пустая() Тогда
		Если ИспользоватьНесколькоВрачейВОдномПриеме() Тогда 
			Если Объект.Лечение.Количество() > 0 Тогда 
				Для Каждого СтрокаТЧЛечение Из Объект.Лечение Цикл 
					Если НЕ ЗначениеЗаполнено(СтрокаТЧЛечение.Сотрудник) Тогда 
						СтрокаТЧЛечение.Сотрудник = Объект.Сотрудник;
					КонецЕсли;	
				КонецЦикла;
				Врач = Объект.Сотрудник;
			КонецЕсли;
		КонецЕсли;	
		Для Каждого СтрокаТЧ Из Объект.Запасы Цикл		
			Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ВидЦен) Тогда 			
				СтрокаТч.ВидЦен = Объект.ВидЦен;
			КонецЕсли;		
		КонецЦикла;	
	КонецЕсли;
	
	// Если документ заполнен на основании, 
	// необходимо завершить подготовку его ТЧ
	Если Объект.Ссылка.Пустая() И (Объект.Запасы.Количество() <> 0 Или Объект.Лечение.Количество() <> 0) Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Ложь;
		ПересчетТабличныхЧастейФормы();
    КонецЕсли;

	// Если документ открыт на основании документа аванса
	// сохраняем этот документ для последующего подбора услуг
	Если Параметры.Свойство("Основание") И (ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.НарядЗаказ")
			ИЛИ ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.ПланЛечения")) Тогда
	     ОснованиеЗаполнения = Параметры.Основание;	
	КонецЕсли;
	
	Если Не Элементы.Найти("ФормаДокументОплатить") = Неопределено Тогда
		Элементы.ФормаДокументОплатить.Доступность = Не ЗначениеЗаполнено(Объект.ПолисМедСтрахования);
	КонецЕсли;

	РассчитатьСуммуСкидки();	
	
	ЗаполнитьПараметрыВыбораВыбораВрачей();
	
	ЗаполнитьПараметрыВыбораСтруктурныхЕдиниц();
	
	ЗаполнитьПараметрыВыбораОрганизаций();
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаполнитьВозвращенныеУслугиЗапасы();
	КонецЕсли;
	
	СистемнаяИнформация = Новый СистемнаяИнформация;
	ЭтотОбъект.ЭтоWindows = СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86 
		Или СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86_64;
		
	УправлениеИнтерфейсамиСервер.ОбновитьВиджетСделки(ЭтаФорма, Объект.Контрагент, Объект.Сделка); 
		
	// Настройки сортировки подбора.	
	ЗаполнитьНастройкиПодбораНоменклатуры();
	
	ОтборМассивРазрешенныхТипов     = Новый Массив;	
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Услуга);
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Набор);
	ОбработкаТабличныхЧастейКлиент.СоздатьДинамическийСписокПодбораНоменклатур(ЭтаФорма, Объект, "ГруппаПодборУслуги", 
		ОтборМассивРазрешенныхТипов, Ложь, ОтображатьЦену, Истина, , ОтображатьАртикул, ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса));  // Остаток - ложь
		
	ТаблицаПодборУслуг = Элементы.Найти("_ПодборНоменклатурУслуги");	
	Если НЕ ТаблицаПодборУслуг = Неопределено Тогда	
		
		ТаблицаПодборУслуг.ПоложениеСтрокиПоиска = ПоложениеСтрокиПоиска.Нет;
		Элементы.КнопкаНастройкиПодбораУслуг.Видимость = Истина;
		Элементы.ГруппаЛечениеНастройкиПодбора.Видимость = Истина;
		Элементы.СтрокаПоискаПодборУслуг.Видимость = Истина;
		
	КонецЕсли;
		
	ОтборМассивРазрешенныхТипов = Новый Массив;
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Материал);
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.ПодарочныйСертификат);
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Запас);
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Имущество);
	ОбработкаТабличныхЧастейКлиент.СоздатьДинамическийСписокПодбораНоменклатур(ЭтаФорма, Объект, "ГруппаПодборТовары", 
		ОтборМассивРазрешенныхТипов, ОтображатьОстаток, ОтображатьЦену, Истина, , ОтображатьАртикул);//, ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса)); // Остаток - Истина
		
	ТаблицаПодборЗапасов = Элементы.Найти("_ПодборНоменклатур");	
	Если НЕ ТаблицаПодборЗапасов = Неопределено Тогда	
		
		ТаблицаПодборЗапасов.ПоложениеСтрокиПоиска = ПоложениеСтрокиПоиска.Нет;
		Элементы.КнопкаНастройкиПодбораЗапасов.Видимость = Истина;	
		Элементы.ГруппаЗапасыНастройкиПодбора.Видимость = Истина;
		Элементы.СтрокаПоискаПодборЗапасов.Видимость = Истина;
		
	КонецЕсли;
				
	Если Элементы.ГруппаПодборУслуги.Видимость Тогда
		ОтображатьПодбор = ?(НЕ Объект.РезультатПриема = 0, Ложь, ОбщегоНазначения.ПолучитьНастройкуПользователяИзХранилищаСистемныхНастроек("ОтображатьПодборУслугиВПриеме", Истина));  
		СкрытьПодборНаСервере("Услуги", ОтображатьПодбор);
	КонецЕсли;

	Если Элементы.ГруппаПодборТовары.Видимость Тогда
		ОтображатьПодбор = ?(НЕ Объект.РезультатПриема = 0, Ложь, ОбщегоНазначения.ПолучитьНастройкуПользователяИзХранилищаСистемныхНастроек("ОтображатьПодборТоварыВПриеме", Истина));
		СкрытьПодборНаСервере("Товары", ОтображатьПодбор);
	КонецЕсли;

	ПолучитьВысотуSVGПодпора();
	
	ЭтотОбъект.ПробитПоФР = ДокументПробитПоФР();
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма
	, Объект.ПометкаУдаления
	, Объект.Проведен
	, ЭтотОбъект.ПробитПоФР
	, Объект.ИзмененПослеОплаты);
	
	Элементы.СостояниеОбъектаРазблокировать.Видимость = ЭтотОбъект.ПробитПоФР И РольДоступна("ПолныеПрава");
	
	Если Не Объект.Ссылка.Пустая() Тогда 
		ПроставитьТипСкидкиНаценки();
		ЗаполнитьВирутальныеРеквизитыПодарков();
		ЗаполнитьТЧДоступныеОплатыБонусами(); 
		ЗаполнитьДополнительныеРеквизитыТаблицыЛечения();		  
		СформироватьОценкиИОтзывы();
	КонецЕсли;   
	УстановитьВидимостьЭлементов();
	Если Не Объект.Ссылка.Пустая() И ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		ОтобразитьИнформациюПоОплате();
	КонецЕсли;
	
	ЗаполнитьПредставленияМатериалов();
		
	// Если Объект.ПометкаУдаления = Истина Тогда
	//	Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
	//	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	// КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда 
		ОбновитьМетки();
	КонецЕсли;
		
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ПодключаемыеКоманды;
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	 
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ИнформированияПоДнюРожденияКонтрагента = ПроверитьНеобходимостьИнформированияПоДнюРожденияКонтрагента(Объект.Контрагент); 
		СформироватьБлокСДолгомИОстаткомНаЛСПациента();
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из Объект.Лечение Цикл					
		СтрокаТЧ.Бесплатно = СтрокаТЧ.Номенклатура.Бесплатно;
	КонецЦикла;
	
	Для Каждого СтрокаТЧ Из Объект.Запасы Цикл					
		СтрокаТЧ.Бесплатно = СтрокаТЧ.Номенклатура.Бесплатно;
	КонецЦикла;
		
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
	Если НачалоДня(Объект.Дата) <> НачалоДня(Объект.ВремяНачалаПриема) Тогда
		Элементы.ВремяНачалаПриема.Заголовок               = "Дата начала";
		Элементы.ВремяНачалаПриема.ФорматРедактирования    = "ДФ=dd.MM.yyyy HH:mm";
		Элементы.ВремяОкончанияПриема.Заголовок            = "Дата окончания";
		Элементы.ВремяОкончанияПриема.ФорматРедактирования = "ДФ=dd.MM.yyyy HH:mm"; 
		Элементы.ВремяНачалаПриема.МаксимальнаяШирина      = 10; 
		Элементы.ВремяОкончанияПриема.МаксимальнаяШирина   = 10;
		Элементы.Номер.МаксимальнаяШирина                  = 10;
	Иначе
		Элементы.ВремяНачалаПриема.Заголовок               = "Время начала";
		Элементы.ВремяНачалаПриема.ФорматРедактирования    = "ДФ=HH:mm"; 
		Элементы.ВремяОкончанияПриема.Заголовок            = "Время окончания";
		Элементы.ВремяОкончанияПриема.ФорматРедактирования = "ДФ=HH:mm"; 
		Элементы.ВремяНачалаПриема.МаксимальнаяШирина      = 6; 
		Элементы.ВремяОкончанияПриема.МаксимальнаяШирина   = 6;  
		Элементы.Номер.МаксимальнаяШирина                  = 16;
	КонецЕсли;  
	
	//Если Не Объект.Ссылка.Пустая() Тогда
	ОбновитьСписокНаправленийНаКонсультацию();
	//КонецЕсли;  
	
	ЭтотОбъект.ДокументРазблокированПослеОплаты = Ложь;
	
	СсылкиНаОплатуИСБП.ОбновитьИнформациюПоИспользованиюСсылкиНаОплату(ЭтаФорма);
	
КонецПроцедуры                                                                       

