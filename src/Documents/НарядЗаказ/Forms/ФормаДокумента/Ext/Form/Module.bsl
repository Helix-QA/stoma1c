// Процедура, обработчик события "ПриИзменении"
//
Процедура КонтрагентПриИзменении(Элемент)
	
	Элементы.Договор.Видимость = ЗначениеЗаполнено(Объект.Лаборатория);
	
	Если ЗначениеЗаполнено(Объект.Лаборатория) Тогда
		
		Для Каждого СтрокаТЧ из Объект.Запасы Цикл
			
			СтрокаТЧ.Лаборатория = Объект.Лаборатория;
			
		КонецЦикла;
		
		ДанныеДоговораПоЛаборатории = ПолучитьДанныеДоговораПоЛаборатории(Объект.Лаборатория,Объект.Дата);
		
		Элементы.Договор.СписокВыбора.Очистить();
		Элементы.Договор.СписокВыбора.ЗагрузитьЗначения(ДанныеДоговораПоЛаборатории.МассивЗначенийВыбора);
		ДанныеДоговора = ДанныеДоговораПоЛаборатории.ДанныеДоговора;
		
		Если Не ДанныеДоговора = Неопределено Тогда
			
			Объект.Договор = ДанныеДоговора.Договор;
			
			Если ЗначениеЗаполнено(ДанныеДоговора.ВидЦен) И НЕ Объект.ВидЦен = ДанныеДоговора.ВидЦен Тогда
				
				Объект.ВидЦен = ДанныеДоговора.ВидЦен; 
				
				ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(Ложь, Истина);
				
			КонецЕсли;
			
		КонецЕсли;
		
		// Получим сегмент номенклатуры
		СегментНоменклатуры = ВернутьСегментНоменклатуры(Объект.Договор, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
		
	КонецЕсли;
	
КонецПроцедуры 

