|ИЗ
|	ТаблицаТоварыПодарки КАК ТаблицаТоварыПодарки";
	
КонецФункции

// Функция получает массиов видов бонусных счетов, не начисляемых при оплате бонусами
//
Функция ПолучитьМассивВидовБонусныхСчетовНеНачисляемыхПриОплатеБонусами(ТаблицаОплатыБонусами)
	
	МассивВидовБонусныхСчетов = Новый Массив;
	
	Если ТаблицаОплатыБонусами = Неопределено Тогда
		Возврат МассивВидовБонусныхСчетов;
	КонецЕсли;  
		
	Для Каждого СтрокаОплатыБонусами Из ТаблицаОплатыБонусами Цикл
		Если СтрокаОплатыБонусами.Сумма > 0 
			И ЗначениеЗаполнено(СтрокаОплатыБонусами.БонусныйСчет)
			И СтрокаОплатыБонусами.БонусныйСчет.НеНачислятьПриОплатеБонусами Тогда 				
			
			МассивВидовБонусныхСчетов.Добавить(СтрокаОплатыБонусами.БонусныйСчет.ВидБонусногоСчета);
			
		КонецЕсли;    		
	КонецЦикла;  
	
	Возврат МассивВидовБонусныхСчетов;
	
КонецФункции          

// Рассчитывает сумму скидки суммой или процентом
//
// Параметры
//  МассивСкидок  - Массив скидок, по которым выполнилось условие
//  СтрокаТоваров - Строка таблицы значений с данными из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором рассчитывается скидка
//  ДатаДокумента - Дата документа необходима для расчета скидки по цене
//
// Возвращаемое значение:
//  Сумма скидки
//
Процедура РасчитатьСуммуСкидкиИНовыеЦеныНоменклатурыНаСкидкиПоВидуЦен(ТаблицаСкидок, СтруктураПараметров)
	
	Для Каждого СтрокаТаблицыСкидок Из ТаблицаСкидок Цикл
		
		Если СтрокаТаблицыСкидок.СпособПредоставленияСкидки <> Перечисления.СпособПредоставленияСкидки.ВидЦен Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураПолученияЦены = Новый Структура();
		СтруктураПолученияЦены.Вставить("СтруктурнаяЕдиница",		СтруктураПараметров.СтруктурнаяЕдиница);
		СтруктураПолученияЦены.Вставить("Номенклатура", 			СтрокаТаблицыСкидок.Номенклатура);
		СтруктураПолученияЦены.Вставить("Упаковка",					СтрокаТаблицыСкидок.Упаковка);
		СтруктураПолученияЦены.Вставить("ДатаОбработки",			СтруктураПараметров.ДатаСкидок);
		СтруктураПолученияЦены.Вставить("ВидЦен", 					?(СтруктураПараметров.Свойство("ВидЦен"), СтруктураПараметров.ВидЦен, Справочники.ВидыЦен.Розничная));
		ЦенаНоменклатурыПоВидуЦенШапки = Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураПолученияЦены);
		
		СтруктураПолученияЦены.Вставить("ВидЦен", 					СтрокаТаблицыСкидок.ЗначениеСкидкиНаценкиОбъектом);
		ЦенаНоменклатурыПоНовомуВидуЦенСкидки = Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураПолученияЦены);
		
		СтрокаТаблицыСкидок.Цена		= ЦенаНоменклатурыПоНовомуВидуЦенСкидки;
		СтрокаТаблицыСкидок.Сумма		= ЦенаНоменклатурыПоНовомуВидуЦенСкидки * СтрокаТаблицыСкидок.КоличествоУпаковок;
		СтрокаТаблицыСкидок.СуммаСкидки = (ЦенаНоменклатурыПоВидуЦенШапки - ЦенаНоменклатурыПоНовомуВидуЦенСкидки);
		
	КонецЦикла; 
	
КонецПроцедуры

// Рассчитывает сумму скидки суммой или процентом
//
// Параметры
//  МассивСкидок  - Массив скидок, по которым выполнилось условие
//  СтрокаТоваров - Строка таблицы значений с данными из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором рассчитывается скидка
//  ДатаДокумента - Дата документа необходима для расчета скидки по цене
//
// Возвращаемое значение:
//  Сумма скидки
//
Процедура РаспределитьСкидкуСуммойПроцентомПоНоменклатуре(ТаблицаСкидок, СтруктураПараметров)
	
	Для каждого СтрокаТаблицыСкидок Из ТаблицаСкидок Цикл
		
		Если СтрокаТаблицыСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма Тогда
			СтрокаТаблицыСкидок.СуммаСкидки = СтрокаТаблицыСкидок.ЗначениеСкидкиНаценки;
		ИначеЕсли СтрокаТаблицыСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
			СтрокаТаблицыСкидок.СуммаСкидки = СтрокаТаблицыСкидок.Сумма * СтрокаТаблицыСкидок.ЗначениеСкидкиНаценки / 100;
		КонецЕсли;
		
		Если СтрокаТаблицыСкидок.Сумма < СтрокаТаблицыСкидок.СуммаСкидки
			И СтрокаТаблицыСкидок.НачислениеБонусами = Ложь Тогда
			
			СтрокаТаблицыСкидок.СуммаСкидки = СтрокаТаблицыСкидок.Сумма;
		КонецЕсли;			
		
	КонецЦикла; 
	
КонецПроцедуры

// Разбивает сумму скидки на документ по позициям номенклатуры
//
// Параметры
//  МассивСкидок  - Массив скидок, по которым выполнилось условие
//  СтрокаТоваров - Строка таблицы значений с данными из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором рассчитывается скидка
//  ДатаДокумента - Дата документа необходима для расчета скидки по цене
//
// Возвращаемое значение:
//  Сумма скидки
//
Процедура РаспределитьСкидкуНаДокументПоНоменклатуре(
	ТаблицаСкидок, 
	ТаблицаЗапасы	= Неопределено, 
	ТаблицаЛечение	= Неопределено, 
	ТаблицаУслуги	= Неопределено,
	СтруктураПараметров)
	
	МассивУникальныхСкидокНаДокумент = Новый Массив;
	Для каждого СтрокаТЧСкидки Из ТаблицаСкидок Цикл
		Если СтрокаТЧСкидки.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.СуммаНаДокумент
			И МассивУникальныхСкидокНаДокумент.Найти(СтрокаТЧСкидки.СкидкаНаценка) = Неопределено Тогда
			
			МассивУникальныхСкидокНаДокумент.Добавить(СтрокаТЧСкидки.СкидкаНаценка);
		КонецЕсли; 
	КонецЦикла;
	
	Для Каждого ЭлементСкидки Из МассивУникальныхСкидокНаДокумент Цикл
		
		СуммаСтрокСкидкиНаДокумент = 0;
		Для Каждого СтрокаТЧ Из ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", ЭлементСкидки)) Цикл
			СуммаСтрокСкидкиНаДокумент = СуммаСтрокСкидкиНаДокумент + СтрокаТЧ.Сумма;
		КонецЦикла;
		
		СуммаРаспределения = ЭлементСкидки.ЗначениеСкидкиНаценки;
		СуммаФактическогоРаспределения = 0;
		Если СуммаСтрокСкидкиНаДокумент < СуммаРаспределения Тогда
			СуммаРаспределения = СуммаСтрокСкидкиНаДокумент;
		КонецЕсли;	
		
		КоэффициентРаспределения = ?(СуммаСтрокСкидкиНаДокумент <> 0, 1 - СуммаРаспределения / СуммаСтрокСкидкиНаДокумент, 0);
		
		Если ТаблицаЗапасы <> Неопределено Тогда 
			Для Каждого СтрокаСкидки Из ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", ЭлементСкидки)) Цикл
				ИскомаСтрока = ТаблицаЗапасы.Найти(СтрокаСкидки.КлючСтроки, "КлючСтроки");
				Если ИскомаСтрока = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				СуммаНоменклатуры = ИскомаСтрока.Сумма;
				СтрокаСкидки.СуммаСкидки = Окр(СуммаНоменклатуры - СуммаНоменклатуры * КоэффициентРаспределения, 2, 1);
				СуммаФактическогоРаспределения = СуммаФактическогоРаспределения + СтрокаСкидки.СуммаСкидки;
			КонецЦикла;
		КонецЕсли;
		
		Если ТаблицаЛечение <> Неопределено Тогда 
			Для Каждого СтрокаСкидки Из ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", ЭлементСкидки)) Цикл
				ИскомаСтрока = ТаблицаЛечение.Найти(СтрокаСкидки.КлючСтроки, "КлючСтроки");
				Если ИскомаСтрока = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				СуммаНоменклатуры = ИскомаСтрока.Сумма;
				СтрокаСкидки.СуммаСкидки = Окр(СуммаНоменклатуры - СуммаНоменклатуры * КоэффициентРаспределения, 2, 1);
				СуммаФактическогоРаспределения = СуммаФактическогоРаспределения + СтрокаСкидки.СуммаСкидки;
			КонецЦикла;
		КонецЕсли;

		Если ТаблицаУслуги <> Неопределено Тогда 
			Для Каждого СтрокаСкидки Из ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", ЭлементСкидки)) Цикл
				ИскомаСтрока = ТаблицаУслуги.Найти(СтрокаСкидки.КлючСтроки, "КлючСтроки");
				Если ИскомаСтрока = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				СуммаНоменклатуры = ИскомаСтрока.Сумма;
				СтрокаСкидки.СуммаСкидки = Окр(СуммаНоменклатуры - СуммаНоменклатуры * КоэффициентРаспределения, 2, 1);
				СуммаФактическогоРаспределения = СуммаФактическогоРаспределения + СтрокаСкидки.СуммаСкидки;
			КонецЦикла;
		КонецЕсли;
		
		ОшибкаОкругления = СуммаРаспределения - СуммаФактическогоРаспределения;
		Если ОшибкаОкругления <> 0 Тогда
			МассивСтрокСкидок = ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", ЭлементСкидки));
			МассивСтрокСкидок[0].СуммаСкидки = МассивСтрокСкидок[0].СуммаСкидки + ОшибкаОкругления;
		КонецЕсли;		
		
	КонецЦикла; 
	
КонецПроцедуры

// Определяет по таблице скидок подарков количество подарков
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//  ТаблицаНеПрименяемыхПодарков - Таблица значений, служит для возврата не используемых подарков
//
Процедура ОпределитьКоличествоСтоимостьПодарков(
	ТаблицаСкидок, 
	ТаблицаЗапасов,
	ТаблицаЛечения,
	ТаблицаУслуг, 
	СтруктураПараметров,
	ДокументОбъект)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Если ТаблицаЗапасов <> Неопределено Тогда Запрос.УстановитьПараметр("ТаблицаЗапасы"	, ТаблицаЗапасов) КонецЕсли;
	Если ТаблицаЛечения <> Неопределено Тогда Запрос.УстановитьПараметр("ТаблицаЛечения", ТаблицаЛечения) КонецЕсли;
	Если ТаблицаУслуг   <> Неопределено	Тогда Запрос.УстановитьПараметр("ТаблицаУслуг"	, ТаблицаУслуг)	  КонецЕсли;
	
	ЕстьКолонкаКоличествоУпаковокТЧЛечение = Ложь;
	Если ТаблицаЛечения <> Неопределено Тогда 
		ЕстьКолонкаКоличествоУпаковокТЧЛечение = ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("КоличествоУпаковок") <> Неопределено;
