// Процедура - Установить даты.
//
Процедура УстановитьДаты()
	
	Если Объект.Услуги.Количество() <> 0 Тогда
		ТаблицаУслуги = Объект.Услуги.Выгрузить();
		ТаблицаУслуги.Сортировать("ДатаНачала");
		ДатаНачала = ТаблицаУслуги[0].ДатаНачала;
		ТаблицаУслуги.Сортировать("ДатаОкончания УБЫВ");
		ДатаОкончания = ТаблицаУслуги[0].ДатаОкончания;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Устанавливает списки выбора для элементов выбора времени начала и окончания услуг
// Это вынужденная мера, т.к. в платформе 8.3.4 есть косяк со списками выбора
//
Процедура ПроинициализироватьЭлементыВыбораВремени()

	МассивИнициализируемыхЭлементов = Новый Массив;
	МассивИнициализируемыхЭлементов.Добавить("УслугиДатаНачала");
	
	МассивПериодов = Новый Массив;
	МассивПериодов.Добавить(ПериодРаботыСЕ);
	СписокВремени = ВернутьСписокВремени(МассивПериодов, Истина, ОпределнениеИнтервалаВремени(ИнтервалГрафика));
	
	Для Каждого ИмяЭлемента Из МассивИнициализируемыхЭлементов Цикл
		
		Элементы[ИмяЭлемента].СписокВыбора.Очистить();
		Для Каждого ПредставлениеВремени Из СписокВремени Цикл
			Элементы[ИмяЭлемента].СписокВыбора.Добавить(ПредставлениеВремени.Значение, ПредставлениеВремени.Представление);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры // ПроинициализироватьЭлементыВыбораВремени()

&НаКлиенте
// Функция возвращает интервалы времени
// 
//  Параметры
//   МассивПериодов - структура, периоды, между которыми необходимо возвратить интервалы
//   Интервал - число, интервал в минутах
//   Формат - строка, представление интервала
//
// Возвращаемое значение:
//   СписокЗначений, список времени с интервалом.
//
Функция ВернутьСписокВремени(МассивПериодов, ДатаНачала, Интервал = 15, Формат = "ДФ=ЧЧ:мм")

	СписокВремени = Новый СписокЗначений;
	
	Для Каждого Период Из МассивПериодов Цикл
		Если ДатаНачала Тогда
			Индекс = 0;
		Иначе
			Индекс = 1;
		КонецЕсли;
		Период.ДатаНачала = НачалоЧаса(Период.ДатаНачала) + Цел (Минута(Период.ДатаНачала) / 15) * 15 * 60;
		Пока Период.ДатаНачала + Интервал * 60 * Индекс <= Период.ДатаОкончания Цикл
			Время = Период.ДатаНачала + Интервал * 60 * Индекс;
			Если СписокВремени.НайтиПоЗначению(Время) = Неопределено Тогда
				Если не ЗначениеЗаполнено(Время) Тогда
					СписокВремени.Добавить(Время, "00:00");
				Иначе
					СписокВремени.Добавить(Время, Формат(Время, Формат));
				КонецЕсли;
			КонецЕсли;			
			Индекс = Индекс + 1;
		КонецЦикла;
		Если Период.ДатаОкончания = Дата(01,01,01,23,59,59) и не ДатаНачала Тогда
			СписокВремени.Добавить(Период.ДатаНачала + Интервал * 60 * Индекс, "24:00");
		КонецЕсли;
	КонецЦикла;

	Возврат СписокВремени; 
	
КонецФункции

&НаСервере
// Процедура устанавливает видимость у надписи
// с гиперсылками "Открыть" и "ДобавитьУслуги"
//
Процедура ВывестиНезавершенныеНарядЗаказы()
	
	// Почистим группу перед добавлением в нее элементов
	Индекс = 0;
	КоличествоЭлементов = Элементы.НарядЗаказыВРаботе.ПодчиненныеЭлементы.Количество();	
	Пока Индекс < КоличествоЭлементов Цикл		
		ЭтаФорма.Элементы.Удалить(Элементы.НарядЗаказыВРаботе.ПодчиненныеЭлементы[0]);
		Индекс = Индекс + 1;
	КонецЦикла;            
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		МассивКонтрагентов 		= Новый Массив;
		МассивСтруктурныхЕдиниц = Новый Массив;
		МассивКонтрагентов.Добавить(Объект.Контрагент);
		МассивСтруктурныхЕдиниц.Добавить(Объект.СтруктурнаяЕдиница);
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ВложенныйЗапрос.Ссылка КАК НарядЗаказ,
		               |	ВложенныйЗапрос.Ссылка.Контрагент КАК Контрагент,
		               |	ВложенныйЗапрос.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ВложенныйЗапрос.Ссылка.Дата КАК Дата,
		               |	"""" КАК СтрокаКлюч
		               |ИЗ
		               |	(ВЫБРАТЬ
		               |		НарядЗаказЗапасы.Ссылка КАК Ссылка
		               |	ИЗ
		               |		Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
		               |	ГДЕ
		               |		НарядЗаказЗапасы.Ссылка.Проведен
		               |		И НЕ НарядЗаказЗапасы.Ссылка.ПометкаУдаления
		               |		И (НарядЗаказЗапасы.Прием = ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
		               |				ИЛИ НарядЗаказЗапасы.Прием = НЕОПРЕДЕЛЕНО
		               |				ИЛИ НарядЗаказЗапасы.Прием = NULL)
		               |		И НарядЗаказЗапасы.Ссылка.Контрагент В(&МассивКонтрагентов)
		               |		И НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)
		               |	
		               |	СГРУППИРОВАТЬ ПО
		               |		НарядЗаказЗапасы.Ссылка) КАК ВложенныйЗапрос
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Дата";
					   
		Запрос.УстановитьПараметр("МассивКонтрагентов"		, МассивКонтрагентов);
		Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц"	, МассивСтруктурныхЕдиниц);		
		
		// Для того, чтобы о наряд-заказах были прочитаны независимо от прав пользователя
		УстановитьПривилегированныйРежим(Истина);
		ТаблицаНезавершенныхНарядЗаказов.Загрузить(Запрос.Выполнить().Выгрузить());
		УстановитьПривилегированныйРежим(Ложь);
		
		Счетчик = 0;
		
		Для Каждого НарядЗаказ Из ТаблицаНезавершенныхНарядЗаказов Цикл
			НарядЗаказ.СтрокаКлюч = Строка(Счетчик);
			// Добавим группу   
			ЭлементГруппа                     = ЭтаФорма.Элементы.Добавить("ГруппаНарядЗаказа_" + НарядЗаказ.СтрокаКлюч, Тип("ГруппаФормы"), Элементы.НарядЗаказыВРаботе);
			ЭлементГруппа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
			ЭлементГруппа.ОтображатьЗаголовок = Ложь;
			ЭлементГруппа.Отображение         = ОтображениеОбычнойГруппы.Нет;
			ЭлементГруппа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;		   
			
			// Добавим элементы в эту группу
			ЭлементДекорация                           = ЭтаФорма.Элементы.Добавить("Декорация_Картинка_" + НарядЗаказ.СтрокаКлюч, Тип("ДекорацияФормы"), ЭлементГруппа);
			ЭлементДекорация.Вид                       = ВидДекорацииФормы.Картинка;
			
			// Определим стадию выполнеия наряд-заказа
			СтатусНарядЗакза = ВернутьСтатусНарядЗаказа(НарядЗаказ.НарядЗаказ);
			Если СтатусНарядЗакза 		= Перечисления.СтатусыНарядЗаказа.Заказано Тогда 
				ЭлементДекорация.Картинка 				   = БиблиотекаКартинок.СтатусЗаказано;
			ИначеЕсли СтатусНарядЗакза 	= Перечисления.СтатусыНарядЗаказа.ВРаботе Тогда 
			    ЭлементДекорация.Картинка 				   = БиблиотекаКартинок.СтатусВРаботе;
			ИначеЕсли СтатусНарядЗакза 	= Перечисления.СтатусыНарядЗаказа.Выполнено Тогда
			    ЭлементДекорация.Картинка 				   = БиблиотекаКартинок.СтатусВыполнено;
			КонецЕсли;
			ЭлементДекорация.Ширина = 2;
			ЭлементДекорация.Высота = 1;
			// -------------------------------
			ЭлементДекорация                          = ЭтаФорма.Элементы.Добавить("Декорация_НезавершенныйНарядЗаказ_" + НарядЗаказ.СтрокаКлюч, Тип("ДекорацияФормы"), ЭлементГруппа);
			ЭлементДекорация.Вид                      = ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение  = ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.Гиперссылка              = Истина;
			ЭлементДекорация.АвтоМаксимальнаяШирина   = Ложь;
			// ЭлементДекорация.Шрифт                    = Новый Шрифт( , , Истина, );
			ЭлементДекорация.Заголовок = "Наряд-заказ № " + Формат(ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(НарядЗаказ.НарядЗаказ.Номер, Истина, Истина),"ЧГ=0") + " от " + Сред(Формат(НарядЗаказ.Дата, "ДЛФ=DD"), 1, ?(СтрДлина(Формат(НарядЗаказ.Дата, "ДЛФ=DD")) > 0, СтрДлина(Формат(НарядЗаказ.Дата, "ДЛФ=DD")) - 1, 0)) + ", " + НарядЗаказ.НарядЗаказ.Сотрудник;
			ЭлементДекорация.УстановитьДействие("Нажатие", "ДекорацияНезавершенныйНарядЗаказНажатие");
			
			Счетчик = Счетчик + 1;
			
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Функция - Вернуть статус наряд заказа.
//
// Параметры:
//  НарядЗаказ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
Функция ВернутьСтатусНарядЗаказа(НарядЗаказ)
	
	ТаблицаЗапасыНЗ = НарядЗаказ.Запасы.ВыгрузитьКолонки();	
	Для Каждого СтрокаТабличнойЧасти Из НарядЗаказ.Запасы Цикл 
		Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.Прием) Тогда 
			НоваяСтрока = ТаблицаЗапасыНЗ.Добавить();
	        ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТабличнойЧасти);
		КонецЕсли;	
	КонецЦикла;
	
	МассивСтрок_ЗАКАЗАНО 	= ТаблицаЗапасыНЗ.НайтиСтроки(Новый Структура("Статус", Перечисления.СтатусыНарядЗаказа.Заказано)); 
	МассивСтрок_ВРАБОТЕ 	= ТаблицаЗапасыНЗ.НайтиСтроки(Новый Структура("Статус", Перечисления.СтатусыНарядЗаказа.ВРаботе)); 
	МассивСтрок_ВЫПОЛНЕНО 	= ТаблицаЗапасыНЗ.НайтиСтроки(Новый Структура("Статус", Перечисления.СтатусыНарядЗаказа.Выполнено)); 
	
	Если МассивСтрок_ЗАКАЗАНО.Количество() = ТаблицаЗапасыНЗ.Количество() Тогда 
		Статус = Перечисления.СтатусыНарядЗаказа.Заказано;
	ИначеЕсли МассивСтрок_ВРАБОТЕ.Количество() > 0 Тогда 
		Статус = Перечисления.СтатусыНарядЗаказа.ВРаботе;
	ИначеЕсли МассивСтрок_ВЫПОЛНЕНО.Количество() = ТаблицаЗапасыНЗ.Количество() Тогда
		Статус = Перечисления.СтатусыНарядЗаказа.Выполнено;
	Иначе 
		Статус = Перечисления.СтатусыНарядЗаказа.ВРаботе;
	КонецЕсли;
	
	Возврат Статус;
	
КонецФункции

&НаСервере
// Процедура - Обновить надписи.
//
Процедура ОбновитьНадписи()
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Долг 					= РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокПоВзаиморасчетамСконтрагентом(Объект.Контрагент,, Объект.СтруктурнаяЕдиница);	
		ОстатокЛицевогоСчета 	= РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент, ТекущаяДатаСеанса(),, Объект.СтруктурнаяЕдиница,,Истина);
		ЗапланированныеОплаты	= ОбщегоНазначенияСтоматология.ВернутьЗапланированныеОплаты(Объект.Контрагент);
	Иначе
		Долг = 0;
		ОстатокЛицевогоСчета = 0;
		ЗапланированныеОплаты = 0;
	КонецЕсли;

	// Декорация планируемых оплат контрагента
	Элементы.ДекорацияЗапланированныеОплаты.Заголовок = "Запланированные оплаты:";
	// Элементы.ДекорацияСуммаПланируемыхОплат.Заголовок = Формат(ЗапланированныеОплаты, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
	Элементы.ДекорацияСуммаПланируемыхОплат.Заголовок = Формат(ЗапланированныеОплаты, "ЧЦ=15; ЧДЦ=2; ЧН=");
	Если ЗапланированныеОплаты > 0 Тогда 
		Элементы.ДекорацияЗапланированныеОплаты.ЦветТекста = Новый Цвет(220,140,0); // Новый Цвет(150, 95, 9);
		Элементы.ДекорацияСуммаПланируемыхОплат.ЦветТекста = Новый Цвет(220,140,0); // Новый Цвет(150, 95, 9);
	Иначе 
		Элементы.ДекорацияЗапланированныеОплаты.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		Элементы.ДекорацияСуммаПланируемыхОплат.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
	КонецЕсли;
	
	// Декорация задолженности контрагента
	Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
	Если Долг > 0 Тогда
		Элементы.ДекорацияЗадолженностьСумма.Заголовок = "Долг пациента:";
		// Элементы.ДекорацияДолг.Заголовок = Формат(Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		Элементы.ДекорацияДолг.Заголовок = Формат(Долг, "ЧЦ=15; ЧДЦ=2; ЧН=");
		Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = WebЦвета.Красный;
		Элементы.ДекорацияДолг.ЦветТекста = WebЦвета.Красный;			
	Иначе
		Элементы.ДекорацияЗадолженностьСумма.Заголовок = "Наш долг перед пациентом:";
		// Элементы.ДекорацияДолг.Заголовок = Формат(-Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		Элементы.ДекорацияДолг.Заголовок = Формат(-Долг, "ЧЦ=15; ЧДЦ=2; ЧН=");
		Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		Элементы.ДекорацияДолг.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;				
	КонецЕсли;
	
	// Декорация остатка лицевого счета
	Элементы.ДекорацияОстаткиНаЛицевыхсчетах.Заголовок = "На лицевом счете пациента:";
	// Элементы.ДекорацияОстатокЛицевогоСчета.Заголовок = Формат(ОстатокЛицевогоСчета, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
	Элементы.ДекорацияОстатокЛицевогоСчета.Заголовок = Формат(ОстатокЛицевогоСчета, "ЧЦ=15; ЧДЦ=2; ЧН=");
	Если ОстатокЛицевогоСчета < 0 Тогда
		Элементы.ДекорацияОстаткиНаЛицевыхсчетах.ЦветТекста = WebЦвета.Красный;
		Элементы.ДекорацияОстатокЛицевогоСчета.ЦветТекста = WebЦвета.Красный;
	Иначе
		Элементы.ДекорацияОстаткиНаЛицевыхсчетах.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		Элементы.ДекорацияОстатокЛицевогоСчета.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
	КонецЕсли;
	ДатаСозданияОбращения = Формат(Объект.ДатаСоздания,"ДЛФ=DD");

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Элементы.ДекорацияАвторДатаВремяСоздания.Видимость = Истина;
		Элементы.ДекорацияАвторДатаВремяСоздания.Заголовок = "Создана " + Лев(ДатаСозданияОбращения, СтрДлина(ДатаСозданияОбращения) - 2) + " в " 
															+ Формат(Объект.ДатаСоздания, "ДФ=HH:mm")+ ", " 
															+ ПользователиСлужебныйКлиентСервер.ПолучитьКраткоеИмяПользователяИБНовый(Объект.АвторДокумента); 
	Иначе
		Элементы.ДекорацияАвторДатаВремяСоздания.Видимость = Ложь;
	КонецЕсли;
	Элементы.ДекорацияКартинкаНаправления.Видимость = Элементы.ДекорацияАвторДатаВремяСоздания.Видимость;
	
КонецПроцедуры

&НаСервере
// Процедура обновляет полисы медицинского страхования пациента.
//
Процедура ОбновитьПолисыМедицинскогоСтрахования(ПриСоздании = Ложь)
	
    МассивПолисовВсе = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(Объект.Контрагент, Объект.Дата);
	
	Если МассивПолисовВсе.Количество() > 0 Или ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда
		Элементы.ГруппаПолисМедСтрахования.Видимость = Истина;  
		Элементы.ПолисМедСтрахования.СписокВыбора.Очистить();
		
		Если МассивПолисовВсе.Количество() > 0 Тогда
			Элементы.ПолисМедСтрахования.СписокВыбора.ЗагрузитьЗначения(МассивПолисовВсе); 
			
			Если ПриСоздании = Ложь ИЛИ (ПриСоздании = Истина И Объект.Ссылка.Пустая() И НЕ ЗначениеЗаполнено(Объект.ПолисМедСтрахования)) Тогда
				МассивПолисовДействующие = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(Объект.Контрагент, Объект.Дата,,Ложь);
				Если МассивПолисовДействующие.Количество() > 0 Тогда
					Объект.ПолисМедСтрахования = МассивПолисовДействующие[0];	
				Иначе
					Объект.ПолисМедСтрахования = Неопределено;	
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;	
		
		ОтобразитьМеткуПолиса();
	Иначе
		Элементы.ГруппаПолисМедСтрахования.Видимость = Ложь;		
	КонецЕсли;	
	
КонецПроцедуры

