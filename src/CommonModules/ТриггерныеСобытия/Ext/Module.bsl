// Функция - Вернуть таблицу контактов
//
// Параметры:
//  СтрокаТаблицыДанных				 - 	 - 
//  СтрокаПланДействий				 - 	 - 
//  СтруктураКонтактнойИнформации	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьТаблицуКонтактов(СтрокаТаблицыДанных, СтрокаПланДействий, СтруктураКонтактнойИнформации, РассылкаЗапрещена = Ложь, РассылкаЗапрещенаДляУслуги = Ложь)
	   
	ТаблицаКонтактов 		= Новый ТаблицаЗначений;
	МассивТиповПолучателей 	= Новый Массив;
	МассивТиповПолучателей.Добавить(Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	МассивТиповПолучателей.Добавить(Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	
	МассивСервисРассылки 	= Новый Массив;
	МассивСервисРассылки.Добавить(Новый ОписаниеТипов("СправочникСсылка.СервисыРассылки"));
	МассивСервисРассылки.Добавить(Новый ОписаниеТипов("СправочникСсылка.ВнешниеСистемы"));

	ТаблицаКонтактов.Колонки.Добавить("Получатель"				, Новый ОписаниеТипов(МассивТиповПолучателей));
	ТаблицаКонтактов.Колонки.Добавить("НомерТелефона"			, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));
	ТаблицаКонтактов.Колонки.Добавить("Адрес"					, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	ТаблицаКонтактов.Колонки.Добавить("СервисРассылки"			, Новый ОписаниеТипов(МассивСервисРассылки));
	ТаблицаКонтактов.Колонки.Добавить("КаналСистемыСообщений"	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(32)));
	
	АккаунтОтправки 				= Неопределено;
	МассивСтрокДляОтправки 			= Неопределено;
	НеУчаствоватьВРассылкеСообщений = Ложь;
	Если СтрокаПланДействий.ВидАдресата = Перечисления.ВидыАдресатов.КонтрагентСобытия Тогда
		Если СтрокаПланДействий.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение И СтруктураКонтактнойИнформации.Свойство("ТаблицаКлиентовСНомерамиТелефонов") Тогда 
			Если СтрокаПланДействий.ТаблицаЗначенийПараметров <> Неопределено И НЕ СтрокаПланДействий.ТаблицаЗначенийПараметров.Колонки.Найти("СсылкаНаИнформациюОЗаписиНаЗанятие") = Неопределено Тогда 
				Если ТипЗнч(СтрокаТаблицыДанных.ОбъектСобытия) = Тип("ДокументСсылка.Занятие") Тогда 
					НеУчаствоватьВРассылкеСообщений = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТаблицыДанных.ОбъектСобытия, "Номенклатура"), "НеУчаствоватьВРассылкеСообщений");
					Если НеУчаствоватьВРассылкеСообщений = Истина Тогда 
						РассылкаЗапрещенаДляУслуги = Истина;
						Возврат ТаблицаКонтактов;
					КонецЕсли;	
			    КонецЕсли;
			КонецЕсли;
			Если МассивСтрокДляОтправки = Неопределено Тогда  
				МассивСтрокСНомерами = СтруктураКонтактнойИнформации.ТаблицаКлиентовСНомерамиТелефонов.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница, Контрагент, ОтправкаPush", СтрокаПланДействий.ИдентификаторДействия, СтрокаТаблицыДанных.СтруктурнаяЕдиница, СтрокаТаблицыДанных.Контрагент, Истина));			
				Если МассивСтрокСНомерами.Количество() > 0 Тогда
					МассивСтрокДляОтправки = МассивСтрокСНомерами;
				КонецЕсли;
			КонецЕсли;
			Если МассивСтрокДляОтправки = Неопределено Тогда 
				МассивСтрокСНомерами = СтруктураКонтактнойИнформации.ТаблицаКлиентовСНомерамиТелефонов.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница, Контрагент, ОтправкаPushWallet", СтрокаПланДействий.ИдентификаторДействия, СтрокаТаблицыДанных.СтруктурнаяЕдиница, СтрокаТаблицыДанных.Контрагент, Истина));			
				Если МассивСтрокСНомерами.Количество() > 0 Тогда
					МассивСтрокДляОтправки = МассивСтрокСНомерами;
				КонецЕсли;
			КонецЕсли;			
			Если МассивСтрокДляОтправки = Неопределено Тогда 
				МассивСтрокСНомерами = СтруктураКонтактнойИнформации.ТаблицаКлиентовСНомерамиТелефонов.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница, Контрагент, ОтправкаMessenger", СтрокаПланДействий.ИдентификаторДействия, СтрокаТаблицыДанных.СтруктурнаяЕдиница, СтрокаТаблицыДанных.Контрагент, Истина));			
				Если МассивСтрокСНомерами.Количество() > 0 Тогда
					МассивСтрокДляОтправки 	= МассивСтрокСНомерами;
					// АккаунтОтправки 		= СтрокаПланДействий.АккаунтВнешнейСистемы;
				КонецЕсли;
			КонецЕсли;
			Если МассивСтрокДляОтправки = Неопределено Тогда 
				МассивСтрокСНомерами = СтруктураКонтактнойИнформации.ТаблицаКлиентовСНомерамиТелефонов.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница, Контрагент, ОтправкаSMS", СтрокаПланДействий.ИдентификаторДействия, СтрокаТаблицыДанных.СтруктурнаяЕдиница, СтрокаТаблицыДанных.Контрагент, Истина));			
				Если МассивСтрокСНомерами.Количество() > 0 Тогда
					МассивСтрокДляОтправки 	= МассивСтрокСНомерами;
					// АккаунтОтправки 		= СтрокаПланДействий.АккаунтSMS;					
				КонецЕсли;
			КонецЕсли;
			Если МассивСтрокДляОтправки <> Неопределено Тогда 
				ПолучитьПриведенныеНомера(СтрокаТаблицыДанных.Контрагент, МассивСтрокДляОтправки, ТаблицаКонтактов, Истина, АккаунтОтправки, РассылкаЗапрещена); 			
			КонецЕсли;	
		ИначеЕсли СтрокаПланДействий.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо И СтруктураКонтактнойИнформации.Свойство("ТаблицаКлиентовСУказаннымиEmail") Тогда 	 
			МассивСтрокСЭлектроннымиАдресами = СтруктураКонтактнойИнформации.ТаблицаКлиентовСУказаннымиEmail.НайтиСтроки(Новый Структура("Контрагент", СтрокаТаблицыДанных.Контрагент));			
			ПолучитьКорректныеЭлектронныеАдреса(СтрокаТаблицыДанных.Контрагент, МассивСтрокСЭлектроннымиАдресами, ТаблицаКонтактов, РассылкаЗапрещена); 			
		ИначеЕсли СтрокаПланДействий.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота И СтруктураКонтактнойИнформации.Свойство("ТаблицаКлиентовСНомерамиТелефонов") Тогда 
			Если МассивСтрокДляОтправки = Неопределено Тогда 
				МассивСтрокСНомерами = СтруктураКонтактнойИнформации.ТаблицаКлиентовСНомерамиТелефонов.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница, Контрагент, ОтправкаMessenger", СтрокаПланДействий.ИдентификаторДействия, СтрокаТаблицыДанных.СтруктурнаяЕдиница, СтрокаТаблицыДанных.Контрагент, Истина));			
				Если МассивСтрокСНомерами.Количество() > 0 Тогда
					МассивСтрокДляОтправки 	= МассивСтрокСНомерами;
					// АккаунтОтправки 		= СтрокаПланДействий.АккаунтВнешнейСистемы;
				КонецЕсли;
			КонецЕсли;
			Если МассивСтрокДляОтправки <> Неопределено Тогда 
				ПолучитьПриведенныеНомера(СтрокаТаблицыДанных.Контрагент, МассивСтрокДляОтправки, ТаблицаКонтактов, Истина, АккаунтОтправки, РассылкаЗапрещена); 			
			КонецЕсли;	
		КонецЕсли;
	ИначеЕсли СтрокаПланДействий.ВидАдресата = Перечисления.ВидыАдресатов.Куратор Тогда	
		Если СтруктураКонтактнойИнформации.Свойство("ТаблицаОсновныхМенеджеров") Тогда 
			МассивСтрокСМенеджерами = СтруктураКонтактнойИнформации.ТаблицаОсновныхМенеджеров.НайтиСтроки(Новый Структура("Контрагент", СтрокаТаблицыДанных.Контрагент));
			Если МассивСтрокСМенеджерами.Количество() <> 0 Тогда
				Если ЗначениеЗаполнено(МассивСтрокСМенеджерами[0].Менеджер) И СтрокаПланДействий.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение Тогда
					Если МассивСтрокДляОтправки = Неопределено Тогда 
						МассивСтрокСНомерами = СтруктураКонтактнойИнформации.ТаблицаСотрудниковСНомерамиТелефонов.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница, Сотрудник, ОтправкаMessenger", СтрокаПланДействий.ИдентификаторДействия, СтрокаТаблицыДанных.СтруктурнаяЕдиница, МассивСтрокСМенеджерами[0].Менеджер, Истина));			
						Если МассивСтрокСНомерами.Количество() > 0 Тогда
							МассивСтрокДляОтправки 	= МассивСтрокСНомерами;
							// АккаунтОтправки 		= СтрокаПланДействий.АккаунтВнешнейСистемы;							
