
#Область СлужебныйПрограммныйИнтерфейс

// Функция - Создать подписку на Webhook.
//
Функция СоздатьПодпискуНаWebhook(ВнешняяСистема, ОписаниеОшибки = Неопределено) Экспорт
	
	ВыполненоУспешно = Ложь;
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	Если ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		
		АдресПодключения = "https://cloud.stoma1c.ru/api/hs/messenger/chatapi/v1/" + ВнешняяСистема.КлючПриложения;
		ВыполненоУспешно = GreenApi_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения, ОписаниеОшибки);
		
	ИначеЕсли ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.VkontakteApi Тогда
		
		АдресПодключения = "https://cloud.stoma1c.ru/api/hs/messenger/vkontakte/v1/" + ВнешняяСистема.КлючПриложения;
		ВыполненоУспешно = VkApi_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения);
		
	ИначеЕсли ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Telegram Тогда
		
		АдресПодключения = "https://cloud.stoma1c.ru/api/hs/messenger/telegram/v1/" + ВнешняяСистема.КлючПриложения;
		ВыполненоУспешно = Telegram_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения);
		
	ИначеЕсли ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Viber Тогда
		
		АдресПодключения = "https://cloud.stoma1c.ru/api/hs/messenger/viber/v1/" + ВнешняяСистема.КлючПриложения;
		ВыполненоУспешно = Viber_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения);
		
	// ИначеЕсли ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Instagram Тогда
	//	
	//	ВыполненоУспешно = Истина;
		
	КонецЕсли;
	
	Возврат ВыполненоУспешно;
	
КонецФункции

// Функция - Отправить сообщение клиенту
//
// Параметры:
//  ТекстСообщения	 - 	               - Обязательный
//  Клиент			 -                 - Обязательный
//  ВнешняяСистема	 - Сервис рассылки - Обязательный 
//  НомерТелефона	 - Номер телефона нового контакта WhatsApp (если не заполнен возьмется из КИ) - Необязательный 
//  ИдКанала		 - ID канала (если не заполнен возьмется первый канал из сервиса) - Необязательный 
// 
// Возвращаемое значение:
//   - 
//
Функция ОтправитьСообщениеКлиенту(ТекстСообщения
								, Клиент
								, ВнешняяСистема
								, НомерТелефона = Неопределено
								, ИдКанала = ""
								, ДополнительныеПараметры = Неопределено
								, ПараметрыКлиента = Неопределено) Экспорт

	Если ТипЗнч(ВнешняяСистема) = Тип("СправочникСсылка.ВнешниеСистемы") Тогда 
		ТипВнешнейСистемы = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВнешняяСистема, "ТипВнешнейСистемы");
	Иначе 	
		ТипВнешнейСистемы = ВнешняяСистема.ТипВнешнейСистемы;
	КонецЕсли;	
	
	Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		
		Возврат ОтправитьСообщениеКлиентуGreenApi(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона, ДополнительныеПараметры, ПараметрыКлиента);
		
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.VkontakteApi Тогда
		
		Возврат ОтправитьСообщениеКлиентуVkApi(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона, ИдКанала);
		
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Viber Тогда
		
		Возврат ОтправитьСообщениеКлиентуViber(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона, ИдКанала);
		
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Telegram Тогда
		
		Возврат ОтправитьСообщениеКлиентуTelegram(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона, ИдКанала, ДополнительныеПараметры);
		
	// ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Instagram Тогда
	//	
	//	Возврат ОтправитьСообщениеКлиентуInstagram(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона, ИдКанала);
		
	КонецЕсли;

	РезультатОтправки = Новый Структура;
	РезультатОтправки.Вставить("ВыполненоУспешно", Ложь);
	РезультатОтправки.Вставить("ОписаниеОшибки"  , Нстр("ru = 'Не удалось отправить сообщение. Сервисы рассылки недоступны.'; en = 'There are no message services available.'"));
	
	Возврат РезультатОтправки;
	
КонецФункции

// Функция - Создать клиента мессенджера.
//
Функция СоздатьКлиентаМессенджера(ВнешняяСистема, Контрагент, Знач НомерТелефона) Экспорт
	
	Если ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		
		НомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Ложь);
		НомерТелефона = ?(СтрДлина(НомерТелефона) > 10 И Лев(НомерТелефона, 1) = "8", "7" + Сред(НомерТелефона, 2), НомерТелефона);
		
		ИдКлиента = НомерТелефона + "@c.us";
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдКлиента) Тогда
		РегистрыСведений.КонтактыМессенджеров.ЗаписатьИдентификаторМессенджера(
			ИдКлиента,
			Контрагент,
			НомерТелефона,,
			ВнешняяСистема,
			Контрагент.Наименование
		);
		
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
			ИдКлиента,
			Строка(Новый УникальныйИдентификатор()),,
			"",
			"",
			Истина,
			Перечисления.Мессенджеры.whatsapp,
			Ложь,
			ТекущаяДатаСеанса(),
			ВнешняяСистема,,,,,,,
			Истина
		);
		
	КонецЕсли;
	
	Возврат ИдКлиента;	
	
КонецФункции

#Область Обработчики_GreenApi

Функция ОтправитьСообщениеКлиентуGreenApi(ТекстСообщения
										, Клиент
										, ВнешняяСистема
										, НомерТелефона = Неопределено
										, ДополнительныеПараметры = Неопределено
										, ПараметрыКлиента = Неопределено)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ВыполненоУспешно"			, Ложь);
	СтруктураВозврата.Вставить("ОписаниеОшибки"  			, "");
	СтруктураВозврата.Вставить("ИдСообщения"     			, "");
	СтруктураВозврата.Вставить("ОписаниеВторичнойОшибки"  	, "");
	
	ОписаниеОшибки    = "";
	// Если Не ЗначениеЗаполнено(Клиент) Тогда
	//	СтруктураВозврата.ОписаниеОшибки = "Не заполнено поле ""Клиент"".";
	//	Возврат СтруктураВозврата;
	// ИначеЕсли Не ЗначениеЗаполнено(ТекстСообщения) Тогда
	//	СтруктураВозврата.ОписаниеОшибки = "Не заполнено поле ""Текст сообщения"".";
	//	Возврат СтруктураВозврата;
	// ИначеЕсли Не ЗначениеЗаполнено(ВнешняяСистема) Тогда	
	//	СтруктураВозврата.ОписаниеОшибки = "Не заполнена внешняя система Мессенджеров.";
	//	Возврат СтруктураВозврата;
	// КонецЕсли;
	
	ПараметрыВнешнейСистемы = Неопределено;	
	Если НЕ ИнициализированыПараметрыВнешнейСистемы(ВнешняяСистема, ПараметрыВнешнейСистемы) Тогда 
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не заполнены параметры внешней системы."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПараметрыКлиента) Тогда		
		ПараметрыКлиента = ?(ЗначениеЗаполнено(Клиент), ПолучитьПараметрыОбъектаИдентификации(Клиент, ВнешняяСистема), Неопределено);
	КонецЕсли;
	
	// Если клиента нет среди контактов мессенджера - попробуем отправить ему сообщение (при наличии аккаунта WhatsApp).
	Если Не ЗначениеЗаполнено(ПараметрыКлиента) Тогда
		
		// Если не передан номер телефона - возьмем первый попавшийся.
		Если Не ЗначениеЗаполнено(НомерТелефона) Тогда
			
			НомерТелефона = Справочники.Контрагенты.ПолучитьНомерТелефонаДляРассылки(Клиент, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
			
			Если Не ЗначениеЗаполнено(НомерТелефона) Тогда
				СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Контакт не найден. Для создания контакта заполните номер телефона клиента."; 	
				Возврат СтруктураВозврата;
			КонецЕсли;
			
		КонецЕсли;
		
		НомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Ложь);
		НомерТелефона = ?(СтрДлина(НомерТелефона) > 10 И Лев(НомерТелефона, 1) = "8", "7" + Сред(НомерТелефона, 2), НомерТелефона);
		
		ПараметрыКлиента = Новый Структура;
		ПараметрыКлиента.Вставить("ИдКлиента"	, НомерТелефона + "@c.us");
		ПараметрыКлиента.Вставить("НовыйКонтакт", Истина);
		Если НЕ ПараметрыКлиента.Свойство("НомерТелефона") Тогда 
			ПараметрыКлиента.Вставить("НомерТелефона", НомерТелефона);		
		КонецЕсли;	
	КонецЕсли;
	
	Если Не ПараметрыКлиента.Свойство("ИдКлиента") Или Не ЗначениеЗаполнено(ПараметрыКлиента.ИдКлиента) Тогда
		ПараметрыКлиента.Вставить("ИдКлиента"	, НомерТелефона + "@c.us");
		ПараметрыКлиента.Вставить("НовыйКонтакт", Истина);
		Если НЕ ПараметрыКлиента.Свойство("НомерТелефона") Тогда 
			ПараметрыКлиента.Вставить("НомерТелефона", НомерТелефона);		
		КонецЕсли;			
	КонецЕсли;
	
	РезультатОперации = GreenApi_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы,, ОписаниеОшибки);
	
	// Если сообщение отправлено.
	Если РезультатОперации.ВыполненоУспешно Тогда
		
		СтруктураВозврата.ВыполненоУспешно = Истина;
		СтруктураВозврата.ИдСообщения      = РезультатОперации.ИдСообщения;
		
		// Если новый клиент записываем его в регистр сведений контакты мессенджеров.
		Если ТипЗнч(ПараметрыКлиента) = Тип("Структура") И ПараметрыКлиента.Свойство("НовыйКонтакт") Тогда		
			Попытка
				ДобавитьКонтактМессенджера(ВнешняяСистема, Клиент, ПараметрыКлиента);
			Исключение
				СтруктураВозврата.ОписаниеВторичнойОшибки = "WhatsApp: Ошибка при создании контакта мессенджера. " + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());				
			КонецПопытки;
		КонецЕсли;
		
		ОператорСообщения 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ОператорСообщения"	, Неопределено);
		Триггер 			= ?(ТипЗнч(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ПараметрыРегистрацииТриггера", Ложь)) = Тип("Структура"), Истина, Ложь);
		СтартСценария 		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "СтартСценария"		, Ложь);
		
		Попытка
			// Добавляем отправленное сообщенте в регистр.
			РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(ПараметрыКлиента.ИдКлиента
																			, РезультатОперации.ИдСообщения
																			,, РезультатОперации.ИдКанала
																			, ТекстСообщения
																			, Истина
																			, Перечисления.Мессенджеры.whatsapp
																			, Ложь
																			, ТекущаяДатаСеанса()
																			, ВнешняяСистема
																			, ОператорСообщения,,,
																			, Триггер,,,,,
																			, ДополнительныеПараметры);		
			
			// Оповещаем сотрудников о новом отправленном сообщении.
			ОповеститьСотрудниковОНовомСообщении(РезультатОперации.ИдСообщения,, ПараметрыКлиента.ИдКлиента,, ВнешняяСистема);				
		Исключение
			СтруктураВозврата.ОписаниеВторичнойОшибки = "WhatsApp: Ошибка при добавлении записи в журнал сообщений." + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());				
		КонецПопытки;
		
	ИначеЕсли ТипЗнч(ПараметрыКлиента) = Тип("Структура") И ПараметрыКлиента.Свойство("НовыйКонтакт") Тогда		
		СтруктураВозврата.ОписаниеОшибки = "WhatsApp: Не удалось отправить сообщение. Ошибка при создании контакта. " + ОписаниеОшибки;
	Иначе
		СтруктураВозврата.ОписаниеОшибки = "WhatsApp: Не удалось отправить сообщение. Ошибка при отправке." + ОписаниеОшибки; 		
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Создать контакт мессенджера GreenApi.
//
Функция СоздатьКонтактМессенджераGreenApi(Клиент, ВнешняяСистема, ПараметрыВнешнейСистемы, НомерТелефона = Неопределено) Экспорт
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ВыполненоУспешно", Ложь);
	СтруктураВозврата.Вставить("ОписаниеОшибки"  , "");
	СтруктураВозврата.Вставить("ИдКлиента"       , "");
	СтруктураВозврата.Вставить("ИдСообщения"     , "");
	
	// Если не передан номер телефона - возьмем первый попавшийся.
	Если Не ЗначениеЗаполнено(НомерТелефона) Тогда
		
		НомерТелефона = Справочники.Контрагенты.ПолучитьНомерТелефонаДляРассылки(Клиент, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
		
		Если Не ЗначениеЗаполнено(НомерТелефона) Тогда
			СтруктураВозврата.ОписаниеОшибки = "Контакт не найден. Для создания контакта заполните номер телефона клиента."; 	
			Возврат СтруктураВозврата;
		КонецЕсли;
		
	КонецЕсли;
	
	НомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Ложь);
	ИдКлиента     = НомерТелефона + "@c.us";
	ИдКанала      = ПараметрыВнешнейСистемы.ChannelId;
	ИдСообщения   = Строка(Новый УникальныйИдентификатор);
	
	СтруктураВозврата.ВыполненоУспешно = Истина;
	СтруктураВозврата.ИдКлиента        = ИдКлиента;
	СтруктураВозврата.ИдСообщения      = ИдСообщения;
	
	// Создаем запись о контакте. 
	РегистрыСведений.КонтактыМессенджеров.ЗаписатьИдентификаторМессенджера(
		ИдКлиента,
		Клиент,
		НомерТелефона,
		"",
		ВнешняяСистема,
		Клиент.Наименование
	);
	
	// Добавляем пустое сообщение там будет храниться канал связи.	
	РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
		ИдКлиента,
		ИдСообщения,, 
		ИдКанала,
		"Создан клиент (Служебное сообщение)",
		Истина,
		Перечисления.Мессенджеры.whatsapp,
		Ложь,
		ТекущаяДатаСеанса() - 1,
		ВнешняяСистема,,
		Неопределено,
		Неопределено,
		Неопределено
	);
	
	Возврат СтруктураВозврата;

КонецФункции

// Процедура - Добавить контакт мессенджера
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  Клиент			 - 	 - 
//  ПараметрыКлиента - 	 - 
//
Процедура ДобавитьКонтактМессенджера(ВнешняяСистема, Клиент, ПараметрыКлиента)
	
	Если ТипЗнч(Клиент) = Тип("СправочникСсылка.Контрагенты") Тогда 
		НаименованиеКлиента = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Клиент, "Наименование");
	Иначе 
		НаименованиеКлиента = Клиент.Наименование;
	КонецЕсли;
	
	РегистрыСведений.КонтактыМессенджеров.ЗаписатьИдентификаторМессенджера(ПараметрыКлиента.ИдКлиента
																		, Клиент
																		, ПараметрыКлиента.НомерТелефона
																		, ""
																		, ВнешняяСистема
																		, ?(ЗначениеЗаполнено(Клиент), НаименованиеКлиента, ПараметрыКлиента.НомерТелефона));
	
	РезультатЗапроса = GreenApi_ПолучитьДанныеДиалога(ПараметрыКлиента.ИдКлиента,, ВнешняяСистема);		
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		РегистрыСведений.КонтактыМессенджеров.ЗаполнитьФотоИНаименованиеКлиента(РезультатЗапроса, ВнешняяСистема);	
	КонецЕсли;
	
КонецПроцедуры

