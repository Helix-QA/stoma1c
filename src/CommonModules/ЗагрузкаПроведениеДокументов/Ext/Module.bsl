		КонецЦикла; // ВыборкаПоЧекам
		Если СообщилиПрогресс = Ложь Тогда
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеРеализации			= "";
			Прогресс 						= Цел(100 * СозданоРеализаций / ОбщееКоличествоРеализаций);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по реализациям...';en='Saving data by realizations...'") + Символы.Таб + " Осталось: " + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеРеализации, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;
	КонецЦикла; // ВыборкаПоКлиентам
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
	ТаблицаВидовЛицевыхСчетовВБазе.Очистить();				ТаблицаВидовЛицевыхСчетовВБазе 	= Неопределено;
	ТаблицаЛицевыхСчетовВБазе.Очистить();					ТаблицаЛицевыхСчетовВБазе 		= Неопределено;
	ВыборкаПоКлиентам 										= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить занятия в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьЗанятияВФонеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	ТипКонтрагента_Клиенты						 		= Перечисления.ТипыКонтрагентов.Клиенты;
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	СтатусЗанятия_Проведено								= Перечисления.СтатусыЗанятия.Проведено;	
	ТипЗанятия_ПерсональноеЗанятие 						= Перечисления.ТипыЗанятий.ПерсональноеЗанятие;
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Занятия 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Занятия;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Занятия, "Таблица_Занятия");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Занятия.Исполнитель КАК Тренер,
	               |	Таблица_Занятия.ИсполнительГруппа КАК ТренерГруппа
	               |ИЗ
	               |	Таблица_Занятия КАК Таблица_Занятия
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Занятия.ИсполнительГруппа,
	               |	Таблица_Занятия.Исполнитель
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Занятия.АвторДокумента КАК МенеджерПоПродажам
	               |ИЗ
	               |	Таблица_Занятия КАК Таблица_Занятия
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Занятия.АвторДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование,
	               |	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Занятия.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Занятия.ИДКонтракта КАК ИДКонтракта,
	               |	Таблица_Занятия.ИДУслуги КАК ИДУслуги,
	               |	Таблица_Занятия.ИДЗанятия КАК ИДЗанятия,
	               |	Таблица_Занятия.АвторДокумента КАК АвторДокумента,
	               |	Таблица_Занятия.ДатаДокумента КАК ДатаДокумента,
	               |	Таблица_Занятия.ДатаЗанятия КАК ДатаЗанятия,
	               |	Таблица_Занятия.ВремяЗанятия КАК ВремяЗанятия,
	               |	Таблица_Занятия.ДлительностьЗанятия КАК ДлительностьЗанятия,
	               |	Таблица_Занятия.Исполнитель КАК Исполнитель,
	               |	Таблица_Занятия.ИсполнительГруппа КАК ИсполнительГруппа,
	               |	ЧленствоПакетУслуг.Ссылка КАК ЧленствоПакетУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.Контрагент
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК КонтрагентЧленстваПакетаУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.СтруктурнаяЕдиница
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК СтруктурнаяЕдиницаЧленстваПакетаУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.ТипЧленстваПакетаУслуг
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК ТипЧленстваПакетаУслуг,
	               |	Услуга.Ссылка КАК Услуга,
	               |	ВЫБОР
	               |		КОГДА НЕ Услуга.Ссылка ЕСТЬ NULL
	               |			ТОГДА Услуга.УслугаТипСписанияЗанятием
	               |		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВариантыКогдаЗанятиеСчитаетсяОказанным.ВсегдаКромеРаннейОтмены)
	               |	КОНЕЦ КАК ТипСписанияУслуги,
	               |	Занятие.Ссылка КАК ЗанятиеСсылка
	               |ИЗ
	               |	Таблица_Занятия КАК Таблица_Занятия
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг
	               |		ПО Таблица_Занятия.ИДКонтракта = ЧленствоПакетУслуг.КодСинхронизации
	               |			И Таблица_Занятия.ПрефиксСинхронизации = ЧленствоПакетУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Занятия.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Услуга
	               |		ПО Таблица_Занятия.ИДУслуги = Услуга.КодСинхронизации
	               |			И Таблица_Занятия.ПрефиксСинхронизации = Услуга.ПрефиксСинхронизации
	               |			И (Услуга.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга))
	               |			И (Таблица_Занятия.ИДУслуги > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Занятие КАК Занятие
	               |		ПО Таблица_Занятия.ИДЗанятия = Занятие.КодСинхронизации
	               |			И Таблица_Занятия.ПрефиксСинхронизации = Занятие.ПрефиксСинхронизации
	               |			И (Таблица_Занятия.ИДЗанятия > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИДКонтракта,
	               |	ДатаЗанятия,
	               |	ИДЗанятия
	               |ИТОГИ
	               |	МАКСИМУМ(ПрефиксСинхронизации),
	               |	МАКСИМУМ(АвторДокумента),
	               |	МАКСИМУМ(ДатаДокумента),
	               |	МИНИМУМ(ВремяЗанятия),
	               |	СУММА(ДлительностьЗанятия),
	               |	МАКСИМУМ(Исполнитель),
	               |	МАКСИМУМ(ИсполнительГруппа),
	               |	МАКСИМУМ(ЧленствоПакетУслуг),
	               |	МАКСИМУМ(СтруктурнаяЕдиницаЧленстваПакетаУслуг),
	               |	МАКСИМУМ(ТипЧленстваПакетаУслуг),
	               |	МАКСИМУМ(Услуга),
	               |	МАКСИМУМ(ЗанятиеСсылка)
	               |ПО
	               |	ИДКонтракта,
	               |	ДатаЗанятия,
	               |	ИДУслуги,
	               |	ИДЗанятия";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ТаблицаТренеров	 							= РезультатПакетаЗапросов[0].Выгрузить();	
	ТаблицаМенеджеровПоПродажам					= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[2].Выгрузить();
	ВыборкаПоКонтрактамБлокам 					= РезультатПакетаЗапросов[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Получим должность для менеджеров по продажам	
	ДолжностьМенеджер 	= ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	// Получим должность для тренера	
	ДолжностьТренер 	= ПолучитьДолжностьПоНаименованию("Тренер");
	
	// Создаем необходимых тренеров на текущем этапе
	Для Каждого СтрокаТренер Из ТаблицаТренеров Цикл
		Если НЕ СокрЛП(СтрокаТренер.Тренер) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.Тренер), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				ГруппаСотрудника = Неопределено;
				Если НЕ СокрЛП(СтрокаТренер.ТренерГруппа) = "" Тогда
					МассивСтрокГруппСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.ТренерГруппа), Истина));
					Если МассивСтрокГруппСотрудников.Количество() = 0 Тогда
						ГруппаСотрудника = СоздатьГруппуСотрудникаПоНаименованию(СтрокаТренер.ТренерГруппа, ТекстовыйНакопитель);
						ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ГруппаСотрудника);
					Иначе 
						ГруппаСотрудника = МассивСтрокГруппСотрудников[0].Ссылка;
					КонецЕсли;
				КонецЕсли;
				ТренерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаТренер.Тренер, ДолжностьТренер, ГруппаСотрудника, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ТренерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);									
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаТренер.Тренер, 0, ""));		
	КонецЦикла;
	
	// Создаем необходимых менеджеров на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеровПоПродажам Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.МенеджерПоПродажам) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаМенеджер.МенеджерПоПродажам), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.МенеджерПоПродажам, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.МенеджерПоПродажам, 0, ""));		
	КонецЦикла;
	
	Помещение = Справочники.Помещения.НайтиПоНаименованию("Помещение", Истина);
	Если Помещение = Неопределено Тогда
		Помещение = Справочники.Помещения.СоздатьЭлемент();
		Помещение.Наименование 							= "Помещение";
		Помещение.ИспользоватьВРасписанииЗанятий 		= Истина;
		Помещение.НеКонтролироватьЗанятостьСотрудника 	= Истина;
		Помещение.НеКонтролироватьЗанятостьПомещения 	= Истина;
		Помещение.СтруктурнаяЕдиница 					= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
		Помещение.УстановитьНовыйКод();		
		Помещение.ОбменДанными.Загрузка 				= Истина;
		Помещение.Записать();
		Помещение 										= Помещение.Ссылка;
	КонецЕсли;	
	
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по занятиям...';en='Saving data by class...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоЗанятий	 	= ВыборкаПоКонтрактамБлокам.Количество();
	ОбщееКоличествоЗанятий		= ?(ОбщееКоличествоЗанятий < 1, 1, ОбщееКоличествоЗанятий);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоЗанятий				= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеЗанятия		= "";
	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКонтрактамБлокам.Следующий() Цикл
		СообщилиПрогресс = Ложь;		
		СозданоЗанятий = СозданоЗанятий + 1;
		Если ЗначениеЗаполнено(ВыборкаПоКонтрактамБлокам.ЧленствоПакетУслуг) Тогда
			ВыборкаПоДатамЗанятия = ВыборкаПоКонтрактамБлокам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоДатамЗанятия.Следующий() Цикл
				ВыборкаПоУслугам = ВыборкаПоДатамЗанятия.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПоУслугам.Следующий() Цикл					
					Если ЗначениеЗаполнено(ВыборкаПоУслугам.Услуга) Тогда
						ВыборкаПоЗанятиям = ВыборкаПоУслугам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						КоличествоУслуг = ВыборкаПоЗанятиям.Количество();
						Если ВыборкаПоЗанятиям.Следующий() Тогда
							ВыборкаЗанятие = ВыборкаПоЗанятиям.Выбрать();
							ВыборкаЗанятие.Следующий();
							
							// Если ЗначениеЗаполнено(ВыборкаЗанятие.ЗанятиеСсылка) Тогда
								Занятие = ВыборкаЗанятие.ЗанятиеСсылка.ПолучитьОбъект();
							// Иначе
								// Занятие = Документы.Занятие.СоздатьДокумент();
							// КонецЕсли;	
							
							// Получим автора документа Занятие
							АвторДокументаСтрокой 	= СокрЛП(ВыборкаЗанятие.АвторДокумента);
							АвторДокумента 			= Сотрудник_ПустаяСсылка;
							Если АвторДокументаСтрокой <> "" Тогда
								СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", АвторДокументаСтрокой, Ложь));
								Если НЕ СтрокаМенеджерСотрудник.Количество() = 0 Тогда
									АвторДокумента 	= СтрокаМенеджерСотрудник[0].Ссылка;
								КонецЕсли;
							КонецЕсли;	
							
							// Получим исполнтеля услуги
							ИсполнительСтрокой 		= СокрЛП(ВыборкаЗанятие.Исполнитель);
							Исполнитель 			= Сотрудник_ПустаяСсылка;							
							Если ИсполнительСтрокой <> "" Тогда
								СтрокаИсполнтельУслуги = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", ИсполнительСтрокой, Ложь));
								Если НЕ СтрокаИсполнтельУслуги.Количество() = 0 Тогда
									Исполнитель 	= СтрокаИсполнтельУслуги[0].Ссылка;
								КонецЕсли;
							КонецЕсли;	
							
							ДатаВремяНачала 	= НачалоДня(ВыборкаЗанятие.ДатаЗанятия) + (ВыборкаЗанятие.ВремяЗанятия - НачалоДня(ВыборкаЗанятие.ВремяЗанятия));
							ДатаВремяОкончания 	= ДатаВремяНачала + ?(ВыборкаЗанятие.ДлительностьЗанятия > 1, ВыборкаЗанятие.ДлительностьЗанятия*60, КоличествоУслуг*60);
							
							СтруктураЗаполнения = Новый Структура();
							СтруктураЗаполнения.Вставить("ТипЗанятия"			, ТипЗанятия_ПерсональноеЗанятие);
							СтруктураЗаполнения.Вставить("Номенклатура"			, ВыборкаЗанятие.Услуга);
							// СтруктураЗаполнения.Вставить("Помещение"			, Помещение);	Не передаем. Пусть попробует заполнить из услуги.						
							СтруктураЗаполнения.Вставить("Сотрудник"			, Исполнитель);
							СтруктураЗаполнения.Вставить("АвторДокумента"		, АвторДокумента);
							СтруктураЗаполнения.Вставить("ДатаВремяНачала"		, ДатаВремяНачала);
							СтруктураЗаполнения.Вставить("ДатаВремяОкончания"	, ДатаВремяОкончания);
							СтруктураЗаполнения.Вставить("Контрагент"			, ВыборкаЗанятие.КонтрагентЧленстваПакетаУслуг);							
							СтруктураЗаполнения.Вставить("ОснованиеОплаты"		, ВыборкаПоКонтрактамБлокам.ЧленствоПакетУслуг);
							СтруктураЗаполнения.Вставить("СтруктурнаяЕдиница"	, ?(ВыборкаПоКонтрактамБлокам.СтруктурнаяЕдиницаЧленстваПакетаУслуг = Неопределено, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ВыборкаПоКонтрактамБлокам.СтруктурнаяЕдиницаЧленстваПакетаУслуг));
							
							Занятие.ОбменДанными.Загрузка = Истина;
							Занятие.Заполнить(СтруктураЗаполнения);
							
							Занятие.КодСинхронизации 					= ВыборкаЗанятие.ИДЗанятия;
							Занятие.ПрефиксСинхронизации 				= ВыборкаЗанятие.ПрефиксСинхронизации;
							Занятие.Комментарий 						= ВыборкаЗанятие.ПрефиксСинхронизации + " - " + ВыборкаЗанятие.ИДЗанятия;
							Занятие.СтатусЗанятия 						= СтатусЗанятия_Проведено;
							Занятие.ТипСписания 						= ВыборкаЗанятие.ТипСписанияУслуги;
							Занятие.КоличествоОказываемыхУслуг 			= КоличествоУслуг;
							Если НЕ ЗначениеЗаполнено(Занятие.Помещение) ИЛИ Занятие.Помещение = Помещение Тогда
								Занятие.Помещение = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВыборкаЗанятие.Услуга, "УслугаПомещениеПоУмолчанию");
								Если НЕ ЗначениеЗаполнено(Занятие.Помещение) Тогда 
									Занятие.Помещение 					= Помещение; // Заполняем помещением по умолчанию
								КонецЕсли;	
							КонецЕсли;	
							Занятие.АвторДокумента 						= СтруктураЗаполнения.АвторДокумента;
							Занятие.СоставЗанятия[0].Количество 		= КоличествоУслуг;
							Занятие.СоставЗанятия[0].СтатусПрибытия 	= Истина;
							Занятие.СоставЗанятия[0].КонтрагентСписания = СтруктураЗаполнения.Контрагент;
							
							// Получаем сумму документа
							Занятие.СуммаДокумента = Занятие.СоставЗанятия.Итог("СуммаСписания");
							
							// Запишем документ
							Попытка
								ЗаписатьДокумент(Занятие);		
							Исключение
								// Запись в лог
								ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка сохранения док-та Занятие ""%2"" Код синхронизации: %3 %1 %4';en='%1 Mistake save dock Class ""%2"" Sync code: %3 %1 %4'"), Символы.ПС, Строка(ВыборкаЗанятие.КонтрагентЧленстваПакетаУслуг), СокрЛП(ВыборкаЗанятие.ИДЗанятия), ОписаниеОшибки()));						
							КонецПопытки;	
							
							// Накапливаем и выводим статисические данные и оповещаем клиент
							ПредставлениеЗанятия			= ?(Занятие = Неопределено, "", Строка(Занятие.Ссылка));
							Прогресс 						= Цел(100 * СозданоЗанятий / ОбщееКоличествоЗанятий);
							ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
							ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
							ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по занятиям...';en='Saving data by class...'") + Символы.Таб + НСтр("ru= ' Осталось: ';en= ' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеЗанятия, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
							СообщилиПрогресс = Истина;

						КонецЕсли;
					Иначе
						// Запись в лог...
						ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Услуга не найдена! Код синхронизации: ';en='Service not found! Code sync: '") + Строка(ВыборкаПоУслугам.ИДУслуги));						
					КонецЕсли;
				КонецЦикла;	
			КонецЦикла;
		Иначе
			// Запись в лог...
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Членство/Пакет услуг не найден! Код синхронизации: ';en='Membership Services package not found! Code sync: '") + Строка(ВыборкаПоКонтрактамБлокам.ИДКонтракта));			
		КонецЕсли;
		Если СообщилиПрогресс = Ложь Тогда
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеЗанятия			= "";
			Прогресс 						= Цел(100 * СозданоЗанятий / ОбщееКоличествоЗанятий);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по занятиям...';en='Saving data by class...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеЗанятия, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;
	КонецЦикла;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаТренеров.Очистить();	 							ТаблицаТренеров 				= Неопределено;	
	ТаблицаМенеджеровПоПродажам.Очистить();					ТаблицаМенеджеровПоПродажам 	= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
	ВыборкаПоКонтрактамБлокам 										= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить занятия в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьЗанятияВФонеAccessМногопоточно(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Занятия 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Занятия;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Занятия, "Таблица_Занятия");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Занятия.Исполнитель КАК Тренер,
	               |	Таблица_Занятия.ИсполнительГруппа КАК ТренерГруппа
	               |ИЗ
	               |	Таблица_Занятия КАК Таблица_Занятия
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Занятия.ИсполнительГруппа,
	               |	Таблица_Занятия.Исполнитель
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Занятия.АвторДокумента КАК МенеджерПоПродажам
	               |ИЗ
	               |	Таблица_Занятия КАК Таблица_Занятия
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Занятия.АвторДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование,
	               |	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ТаблицаТренеров	 							= РезультатПакетаЗапросов[0].Выгрузить();	
	ТаблицаМенеджеровПоПродажам					= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[2].Выгрузить();
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Получим должность для менеджеров по продажам	
	ДолжностьМенеджер 	= ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	// Получим должность для тренера	
	ДолжностьТренер 	= ПолучитьДолжностьПоНаименованию("Тренер");
	
	// Создаем необходимых тренеров на текущем этапе
	Для Каждого СтрокаТренер Из ТаблицаТренеров Цикл
		Если НЕ СокрЛП(СтрокаТренер.Тренер) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.Тренер), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				ГруппаСотрудника = Неопределено;
				Если НЕ СокрЛП(СтрокаТренер.ТренерГруппа) = "" Тогда
					МассивСтрокГруппСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.ТренерГруппа), Истина));
					Если МассивСтрокГруппСотрудников.Количество() = 0 Тогда
						ГруппаСотрудника = СоздатьГруппуСотрудникаПоНаименованию(СтрокаТренер.ТренерГруппа, ТекстовыйНакопитель);
						ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ГруппаСотрудника);
					Иначе 
						ГруппаСотрудника = МассивСтрокГруппСотрудников[0].Ссылка;
					КонецЕсли;
				КонецЕсли;
				ТренерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаТренер.Тренер, ДолжностьТренер, ГруппаСотрудника, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ТренерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаТренер.Тренер, 0, ""));		
	КонецЦикла;
	
	// Создаем необходимых менеджеров на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеровПоПродажам Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.МенеджерПоПродажам) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаМенеджер.МенеджерПоПродажам), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.МенеджерПоПродажам, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);													
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.МенеджерПоПродажам, 0, ""));		
	КонецЦикла;
	
	Помещение = Справочники.Помещения.НайтиПоНаименованию("Помещение", Истина);
	Если Помещение = Неопределено Тогда
		Помещение = Справочники.Помещения.СоздатьЭлемент();
		Помещение.Наименование 							= "Помещение";
		Помещение.ИспользоватьВРасписанииЗанятий 		= Истина;
		Помещение.НеКонтролироватьЗанятостьСотрудника 	= Истина;
		Помещение.НеКонтролироватьЗанятостьПомещения 	= Истина;
		Помещение.СтруктурнаяЕдиница 					= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
		Помещение.УстановитьНовыйКод();		
		Помещение.ОбменДанными.Загрузка 				= Истина;
		Помещение.Записать();
		Помещение 										= Помещение.Ссылка;
	КонецЕсли;	
	
	#КонецОбласти
	
	КоличествоПотоков 				= ПараметрыЗадания.ПараметрыЗагрузки.КоличествоПотоковДляЭтапаЗанятия;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	МассивТаблиц 					= Новый Массив;
	РазбитьТаблицуОбъектовПоКлючевомуПолю(Таблица_Занятия, "ИДКонтракта", КоличествоПотоков, МассивТаблиц);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Генерация фоновых заданий...';en='Generation of background works...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Генерируем фоновые задания
	МассивФоновыхЗаданий 				= Новый Массив;
	МассивИдентификаторовФоновыхЗаданий = Новый Массив;
	Для Каждого ТаблицаОбъектов Из МассивТаблиц Цикл 
		УникальныйИдентификаторЗадания 	= Новый УникальныйИдентификатор();
		ПараметрыПроцедуры = ПараметрыЗадания;
		ПараметрыПроцедуры.СписокТаблиц[0].Значение.Таблица_Занятия 			= ТаблицаОбъектов;
		ПараметрыПроцедуры.СписокТаблиц[0].Значение.КоличествоПолученныхСтрок 	= ТаблицаОбъектов.Количество();
		ПараметрыПроцедуры.Вставить("ТаблицаСотрудниковВБазе"		, ТаблицаСотрудниковВБазе);
		ПараметрыПроцедуры.ПараметрыЗагрузки.Вставить("Помещение"	, Помещение);
		
		Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторЗадания,
		"ЗагрузкаПроведениеДокументов.ЗагрузитьЗанятияВПотокеAccess",
		ПараметрыПроцедуры,
		НСтр("ru = 'Генерация док-ов Занятие. Поток № " + Строка(МассивТаблиц.Найти(ТаблицаОбъектов)) + "'"));
		
		Если НЕ Результат = Неопределено Тогда 
			Задание = ДлительныеОперации.НайтиЗаданиеПоИдентификатору(Результат.ИдентификаторЗадания);
			Если НЕ Задание = Неопределено Тогда 
				МассивФоновыхЗаданий.Добавить(Задание);
				МассивИдентификаторовФоновыхЗаданий.Добавить(Результат.ИдентификаторЗадания);
			КонецЕсли;
		Иначе 
			ОшибкаИнициацииФоновогоЗадания = Истина;
		КонецЕсли;
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Передача идентификаторов фоновых заданий...';en='Broadcast background assignments ids...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, МассивИдентификаторовФоновыхЗаданий", "", 0, "", МассивИдентификаторовФоновыхЗаданий));
	
	// Ожидаем выполнения фоновых заданий 
	Если МассивФоновыхЗаданий.Количество() > 0 Тогда 
		Попытка 
			ФоновыеЗадания.ОжидатьЗавершения(МассивФоновыхЗаданий); 
		Исключение
			ОшибкаИнициацииФоновогоЗадания = Истина;			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка проведения!");
		КонецПопытки; 
	КонецЕсли;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));	
		КонецЕсли;	
	КонецЦикла;	
	
	// ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаТренеров.Очистить();	 							ТаблицаТренеров 				= Неопределено;	
	ТаблицаМенеджеровПоПродажам.Очистить();					ТаблицаМенеджеровПоПродажам 	= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить занятия в потоке access
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьЗанятияВПотокеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	ТипКонтрагента_Клиенты						 		= Перечисления.ТипыКонтрагентов.Клиенты;
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	СтатусЗанятия_Проведено								= Перечисления.СтатусыЗанятия.Проведено;	
	ТипЗанятия_ПерсональноеЗанятие 						= Перечисления.ТипыЗанятий.ПерсональноеЗанятие;
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Помещение 											= ПараметрыЗадания.ПараметрыЗагрузки.Помещение;
	ТаблицаСотрудниковВБазе 							= ПараметрыЗадания.ТаблицаСотрудниковВБазе;
	Таблица_Занятия 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Занятия;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Занятия, "Таблица_Занятия");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Занятия.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Занятия.ИДКонтракта КАК ИДКонтракта,
	               |	Таблица_Занятия.ИДУслуги КАК ИДУслуги,
	               |	Таблица_Занятия.ИДЗанятия КАК ИДЗанятия,
	               |	Таблица_Занятия.АвторДокумента КАК АвторДокумента,
	               |	Таблица_Занятия.ДатаДокумента КАК ДатаДокумента,
	               |	Таблица_Занятия.ДатаЗанятия КАК ДатаЗанятия,
	               |	Таблица_Занятия.ВремяЗанятия КАК ВремяЗанятия,
	               |	Таблица_Занятия.ДлительностьЗанятия КАК ДлительностьЗанятия,
	               |	Таблица_Занятия.Исполнитель КАК Исполнитель,
	               |	Таблица_Занятия.ИсполнительГруппа КАК ИсполнительГруппа,
	               |	ЧленствоПакетУслуг.Ссылка КАК ЧленствоПакетУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.Контрагент
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК КонтрагентЧленстваПакетаУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.СтруктурнаяЕдиница
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК СтруктурнаяЕдиницаЧленстваПакетаУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.ТипЧленстваПакетаУслуг
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК ТипЧленстваПакетаУслуг,
	               |	Услуга.Ссылка КАК Услуга,
	               |	ВЫБОР
	               |		КОГДА НЕ Услуга.Ссылка ЕСТЬ NULL
	               |			ТОГДА Услуга.УслугаТипСписанияЗанятием
	               |		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВариантыКогдаЗанятиеСчитаетсяОказанным.ВсегдаКромеРаннейОтмены)
	               |	КОНЕЦ КАК ТипСписанияУслуги,
	               |	Занятие.Ссылка КАК ЗанятиеСсылка
	               |ИЗ
	               |	Таблица_Занятия КАК Таблица_Занятия
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг
	               |		ПО Таблица_Занятия.ИДКонтракта = ЧленствоПакетУслуг.КодСинхронизации
	               |			И Таблица_Занятия.ПрефиксСинхронизации = ЧленствоПакетУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Занятия.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Услуга
	               |		ПО Таблица_Занятия.ИДУслуги = Услуга.КодСинхронизации
	               |			И Таблица_Занятия.ПрефиксСинхронизации = Услуга.ПрефиксСинхронизации
	               |			И (Услуга.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга))
	               |			И (Таблица_Занятия.ИДУслуги > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Занятие КАК Занятие
	               |		ПО Таблица_Занятия.ИДЗанятия = Занятие.КодСинхронизации
	               |			И Таблица_Занятия.ПрефиксСинхронизации = Занятие.ПрефиксСинхронизации
	               |			И (Таблица_Занятия.ИДЗанятия > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИДКонтракта,
	               |	ДатаЗанятия,
	               |	ИДЗанятия
	               |ИТОГИ
	               |	МАКСИМУМ(ПрефиксСинхронизации),
	               |	МАКСИМУМ(АвторДокумента),
	               |	МАКСИМУМ(ДатаДокумента),
	               |	МИНИМУМ(ВремяЗанятия),
	               |	СУММА(ДлительностьЗанятия),
	               |	МАКСИМУМ(Исполнитель),
	               |	МАКСИМУМ(ИсполнительГруппа),
	               |	МАКСИМУМ(ЧленствоПакетУслуг),
	               |	МАКСИМУМ(СтруктурнаяЕдиницаЧленстваПакетаУслуг),
	               |	МАКСИМУМ(ТипЧленстваПакетаУслуг),
	               |	МАКСИМУМ(Услуга),
	               |	МАКСИМУМ(ЗанятиеСсылка)
	               |ПО
	               |	ИДКонтракта,
	               |	ДатаЗанятия,
	               |	ИДУслуги,
	               |	ИДЗанятия";
	
	#КонецОбласти
	                                        
	ВыборкаПоКонтрактамБлокам 					= Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	      	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по занятиям...';en='Saving data by class...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоЗанятий	 	= ВыборкаПоКонтрактамБлокам.Количество();
	ОбщееКоличествоЗанятий		= ?(ОбщееКоличествоЗанятий < 1, 1, ОбщееКоличествоЗанятий);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоЗанятий				= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеЗанятия		= "";
	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКонтрактамБлокам.Следующий() Цикл
		СообщилиПрогресс = Ложь;		
		СозданоЗанятий = СозданоЗанятий + 1;
		Если ЗначениеЗаполнено(ВыборкаПоКонтрактамБлокам.ЧленствоПакетУслуг) Тогда
			ВыборкаПоДатамЗанятия = ВыборкаПоКонтрактамБлокам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоДатамЗанятия.Следующий() Цикл
				ВыборкаПоУслугам = ВыборкаПоДатамЗанятия.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПоУслугам.Следующий() Цикл					
					Если ЗначениеЗаполнено(ВыборкаПоУслугам.Услуга) Тогда
						ВыборкаПоЗанятиям = ВыборкаПоУслугам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						КоличествоУслуг = ВыборкаПоЗанятиям.Количество();
						Если ВыборкаПоЗанятиям.Следующий() Тогда
							ВыборкаЗанятие = ВыборкаПоЗанятиям.Выбрать();
							ВыборкаЗанятие.Следующий();
							
							// Если ЗначениеЗаполнено(ВыборкаЗанятие.ЗанятиеСсылка) Тогда
								Занятие = ВыборкаЗанятие.ЗанятиеСсылка.ПолучитьОбъект();
							// Иначе
							//	Занятие = Документы.Занятие.СоздатьДокумент();
							// КонецЕсли;	
							
							// Получим автора документа Занятие
							АвторДокументаСтрокой 	= СокрЛП(ВыборкаЗанятие.АвторДокумента);
							АвторДокумента 			= Сотрудник_ПустаяСсылка;
							Если АвторДокументаСтрокой <> "" Тогда
								СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", АвторДокументаСтрокой, Ложь));
								Если НЕ СтрокаМенеджерСотрудник.Количество() = 0 Тогда
									АвторДокумента 	= СтрокаМенеджерСотрудник[0].Ссылка;
								КонецЕсли;
							КонецЕсли;	
							
							// Получим исполнтеля услуги
							ИсполнительСтрокой 		= СокрЛП(ВыборкаЗанятие.Исполнитель);
							Исполнитель 			= Сотрудник_ПустаяСсылка;							
							Если ИсполнительСтрокой <> "" Тогда
								СтрокаИсполнтельУслуги = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", ИсполнительСтрокой, Ложь));
								Если НЕ СтрокаИсполнтельУслуги.Количество() = 0 Тогда
									Исполнитель 	= СтрокаИсполнтельУслуги[0].Ссылка;
								КонецЕсли;
							КонецЕсли;	
							
							ДатаВремяНачала 	= НачалоДня(ВыборкаЗанятие.ДатаЗанятия) + (ВыборкаЗанятие.ВремяЗанятия - НачалоДня(ВыборкаЗанятие.ВремяЗанятия));
							ДатаВремяОкончания 	= ДатаВремяНачала + ?(ВыборкаЗанятие.ДлительностьЗанятия > 1, ВыборкаЗанятие.ДлительностьЗанятия*60, КоличествоУслуг*60);
							
							СтруктураЗаполнения = Новый Структура();
							СтруктураЗаполнения.Вставить("ТипЗанятия"			, ТипЗанятия_ПерсональноеЗанятие);
							СтруктураЗаполнения.Вставить("Номенклатура"			, ВыборкаЗанятие.Услуга);
							// СтруктураЗаполнения.Вставить("Помещение"			, Помещение);	Не передаем. Пусть попробует заполнить из услуги.						
							СтруктураЗаполнения.Вставить("Сотрудник"			, Исполнитель);
							СтруктураЗаполнения.Вставить("АвторДокумента"		, АвторДокумента);
							СтруктураЗаполнения.Вставить("ДатаВремяНачала"		, ДатаВремяНачала);
							СтруктураЗаполнения.Вставить("ДатаВремяОкончания"	, ДатаВремяОкончания);
							СтруктураЗаполнения.Вставить("Контрагент"			, ВыборкаЗанятие.КонтрагентЧленстваПакетаУслуг);							
							СтруктураЗаполнения.Вставить("ОснованиеОплаты"		, ВыборкаПоКонтрактамБлокам.ЧленствоПакетУслуг);
							СтруктураЗаполнения.Вставить("СтруктурнаяЕдиница"	, ?(ВыборкаПоКонтрактамБлокам.СтруктурнаяЕдиницаЧленстваПакетаУслуг = Неопределено, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ВыборкаПоКонтрактамБлокам.СтруктурнаяЕдиницаЧленстваПакетаУслуг));
							
							Занятие.ОбменДанными.Загрузка = Истина;
							Занятие.Заполнить(СтруктураЗаполнения);
							
							Занятие.КодСинхронизации 					= ВыборкаЗанятие.ИДЗанятия;
							Занятие.ПрефиксСинхронизации 				= ВыборкаЗанятие.ПрефиксСинхронизации;
							Занятие.Комментарий 						= ВыборкаЗанятие.ПрефиксСинхронизации + " - " + ВыборкаЗанятие.ИДЗанятия;
							Занятие.СтатусЗанятия 						= СтатусЗанятия_Проведено;
							Занятие.ТипСписания 						= ВыборкаЗанятие.ТипСписанияУслуги;
							Занятие.КоличествоОказываемыхУслуг 			= КоличествоУслуг;
							Если НЕ ЗначениеЗаполнено(Занятие.Помещение) ИЛИ Занятие.Помещение = Помещение Тогда
								Занятие.Помещение = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВыборкаЗанятие.Услуга, "УслугаПомещениеПоУмолчанию");
								Если НЕ ЗначениеЗаполнено(Занятие.Помещение) Тогда 
									Занятие.Помещение 					= Помещение; // Заполняем помещением по умолчанию
								КонецЕсли;	
							КонецЕсли;	
							Занятие.АвторДокумента 						= СтруктураЗаполнения.АвторДокумента;
							Занятие.СоставЗанятия[0].Количество 		= КоличествоУслуг;
							Занятие.СоставЗанятия[0].СтатусПрибытия 	= Истина;
							Занятие.СоставЗанятия[0].КонтрагентСписания = СтруктураЗаполнения.Контрагент;
							
							// Получаем сумму документа
							Занятие.СуммаДокумента = Занятие.СоставЗанятия.Итог("СуммаСписания");
							
							// Запишем документ
							Попытка
								ЗаписатьДокумент(Занятие);		
							Исключение
								// Запись в лог
								ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка сохранения док-та Занятие ""%2"" Код синхронизации: %3 %1 %4';en='%1 Mistake save dock Class ""%2"" Sync code: %3 %1 %4'"), Символы.ПС, Строка(ВыборкаЗанятие.КонтрагентЧленстваПакетаУслуг), СокрЛП(ВыборкаЗанятие.ИДЗанятия), ОписаниеОшибки()));						
							КонецПопытки;	
							
							// Накапливаем и выводим статисические данные и оповещаем клиент
							ПредставлениеЗанятия			= ?(Занятие = Неопределено, "", Строка(Занятие.Ссылка));
							Прогресс 						= Цел(100 * СозданоЗанятий / ОбщееКоличествоЗанятий);
							ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
							ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
							ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по занятиям...';en='Saving data by class...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеЗанятия, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
							СообщилиПрогресс = Истина;

						КонецЕсли;
					Иначе
						// Запись в лог...
						ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Услуга не найдена! Код синхронизации: ';en='Service not found! Code sync:'") + Строка(ВыборкаПоУслугам.ИДУслуги));							
					КонецЕсли;
				КонецЦикла;	
			КонецЦикла;
		Иначе
			// Запись в лог...
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Членство/Пакет услуг не найден! Код синхронизации: ';en='Membership Services package not found! Code sync: '") + Строка(ВыборкаПоКонтрактамБлокам.ИДКонтракта));			
		КонецЕсли;
		Если СообщилиПрогресс = Ложь Тогда
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеЗанятия			= "";
			Прогресс 						= Цел(100 * СозданоЗанятий / ОбщееКоличествоЗанятий);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по занятиям...';en='Saving data by class...'") + Символы.Таб + НСтр("ru= ' Осталось: ';en= ' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеЗанятия, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;
	КонецЦикла;
	
	// При сообщение на клиент больших текстовых данных (более 1000 строк), при этом в цикле (цикл используется как гарантия того что мы на клиенте 100% словим пересылаемые данные)
	// заметно уменьшается производительность. Ниже описанный механизм позволяет уменьшить количество итерации в цикле при больших текстовых данных. 
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	КоличествоСтрокВЛоге = СтрЧислоСтрок(ЛогГенерации);
	Если КоличествоСтрокВЛоге < 100 Тогда
		КоличествоИтераций = (100 - КоличествоСтрокВЛоге) * 100;
	ИначеЕсли КоличествоСтрокВЛоге > 99 И КоличествоСтрокВЛоге < 999 Тогда 
		КолСимволов = СтрДлина(Формат(КоличествоСтрокВЛоге, "ЧГ=0"));
		ВерхнийРубеж = "1";
		Для К = 0 По КолСимволов - 1 Цикл 
			ВерхнийРубеж = ВерхнийРубеж + "0";
		КонецЦикла;
		ВерхнийРубеж = Число(ВерхнийРубеж);
		КоличествоИтераций = ВерхнийРубеж - КоличествоСтрокВЛоге;
	ИначеЕсли КоличествоСтрокВЛоге > 999 Тогда
		КоличествоИтераций = КоличествоСтрокВЛоге;
	КонецЕсли;
	
	Для К = 0 По КоличествоИтераций Цикл 	
		ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
	ВыборкаПоКонтрактамБлокам 										= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить посещения в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьПосещенияВФонеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	ТипКонтрагента_Клиенты						 		= Перечисления.ТипыКонтрагентов.Клиенты;
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Посещения 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Посещения;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Посещения, "Таблица_Посещения");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Посещения.Оператор КАК Менеджер
	               |ИЗ
	               |	Таблица_Посещения КАК Таблица_Посещения
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Посещения.Оператор
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Посещения.ОператорЗоны КАК Исполнитель
	               |ИЗ
	               |	Таблица_Посещения КАК Таблица_Посещения
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Посещения.ОператорЗоны
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование,
	               |	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Посещения.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Посещения.ИДПосещения КАК ИДПосещения,
	               |	Таблица_Посещения.ИДКонтракта КАК ИДКонтракта,
	               |	Таблица_Посещения.ДатаДокумента КАК ДатаДокумента,
	               |	Таблица_Посещения.Оператор КАК Оператор,
	               |	Таблица_Посещения.Оператор КАК ОператорЗоны,
	               |	Таблица_Посещения.ДатаПрихода КАК ДатаПрихода,
	               |	Таблица_Посещения.ДатаУхода КАК ДатаУхода,
	               |	Таблица_Посещения.КартаВхода КАК КартаВхода,
	               |	Таблица_Посещения.КартаВыхода КАК КартаВыхода,
	               |	Таблица_Посещения.НомерБокса КАК НомерБокса,
	               |	Таблица_Посещения.Тип КАК Тип,
	               |	Таблица_Посещения.Комментарий КАК Комментарий,
	               |	ЧленствоПакетУслуг.Ссылка КАК ЧленствоПакетУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.Контрагент
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК КонтрагентЧленстваПакетаУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.СтруктурнаяЕдиница
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК СтруктурнаяЕдиницаЧленстваПакетаУслуг,
	               |	Посещение.Ссылка КАК ПосещениеСсылка
	               |ИЗ
	               |	Таблица_Посещения КАК Таблица_Посещения
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг
	               |		ПО Таблица_Посещения.ИДКонтракта = ЧленствоПакетУслуг.КодСинхронизации
	               |			И Таблица_Посещения.ПрефиксСинхронизации = ЧленствоПакетУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Посещения.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Посещение КАК Посещение
	               |		ПО Таблица_Посещения.ИДПосещения = Посещение.КодСинхронизации
	               |			И Таблица_Посещения.ПрефиксСинхронизации = Посещение.ПрефиксСинхронизации
	               |			И (Таблица_Посещения.ИДПосещения > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаПрихода,
	               |	ИДПосещения
	               |ИТОГИ
	               |	МАКСИМУМ(ПрефиксСинхронизации),
	               |	МАКСИМУМ(ДатаДокумента),
	               |	МАКСИМУМ(Оператор),
	               |	МАКСИМУМ(ОператорЗоны),
	               |	МИНИМУМ(ДатаПрихода),
	               |	МАКСИМУМ(ДатаУхода),
	               |	МАКСИМУМ(КартаВхода),
	               |	МАКСИМУМ(КартаВыхода),
	               |	МАКСИМУМ(НомерБокса),
	               |	МАКСИМУМ(Тип),
	               |	МАКСИМУМ(ЧленствоПакетУслуг),
	               |	МАКСИМУМ(КонтрагентЧленстваПакетаУслуг),
	               |	МАКСИМУМ(СтруктурнаяЕдиницаЧленстваПакетаУслуг),
	               |	МАКСИМУМ(ПосещениеСсылка)
	               |ПО
	               |	ИДКонтракта,
	               |	ИДПосещения";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ТаблицаМенеджеров			 				= РезультатПакетаЗапросов[0].Выгрузить();	
	ТаблицаИсполнителей							= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[2].Выгрузить();
	ВыборкаПоКонтрактам		 					= РезультатПакетаЗапросов[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимых сотрудников и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Получим должность для менеджеров по продажам	
	ДолжностьМенеджер 	= ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	// Получим должность для тренера	
	ДолжностьТренер 	= ПолучитьДолжностьПоНаименованию("Тренер");
	
	// Создаем необходимых менеджеров на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеров Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.Менеджер) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаМенеджер.Менеджер), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.Менеджер, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.Менеджер, 0, ""));		
	КонецЦикла;
	
	// Создаем необходимых исполнителей на текущем этапе
	Для Каждого СтрокаИсполнитель Из ТаблицаИсполнителей Цикл
		Если НЕ СокрЛП(СтрокаИсполнитель.Исполнитель) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаИсполнитель.Исполнитель), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаИсполнитель.Исполнитель, ДолжностьТренер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаИсполнитель.Исполнитель, 0, ""));		
	КонецЦикла;
	
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по посещениям...';en='Saving data by visits...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоПосещений	 = ВыборкаПоКонтрактам.Количество();
	ОбщееКоличествоПосещений	= ?(ОбщееКоличествоПосещений < 1, 1, ОбщееКоличествоПосещений);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоПосещений			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеПосещения		= "";
	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКонтрактам.Следующий() Цикл
		СообщилиПрогресс = Ложь;		
		Если ЗначениеЗаполнено(ВыборкаПоКонтрактам.ЧленствоПакетУслуг) Тогда
			ВыборкаПоПосещениям = ВыборкаПоКонтрактам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоПосещениям.Следующий() Цикл
				СозданоПосещений = СозданоПосещений + 1;							
				ВыборкаПосещение = ВыборкаПоПосещениям.Выбрать();
				ВыборкаПосещение.Следующий();
				
				Если ЗначениеЗаполнено(ВыборкаПосещение.ПосещениеСсылка) Тогда
					Посещение = ВыборкаПосещение.ПосещениеСсылка.ПолучитьОбъект();
				Иначе
					Посещение = Документы.Посещение.СоздатьДокумент();
				КонецЕсли;	
				
				// Получим автора документа Посещение
				АвторДокументаСтрокой 	= СокрЛП(ВыборкаПосещение.Оператор);
				АвторДокумента 			= Сотрудник_ПустаяСсылка;
				Если АвторДокументаСтрокой <> "" Тогда
					СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", АвторДокументаСтрокой, Ложь));
					Если НЕ СтрокаМенеджерСотрудник.Количество() = 0 Тогда
						АвторДокумента 	= СтрокаМенеджерСотрудник[0].Ссылка;
					КонецЕсли;
				КонецЕсли;	
				
				// Получим исполнтеля (в данном случае пока не нужен)
				ИсполнительСтрокой 		= СокрЛП(ВыборкаПосещение.ОператорЗоны);
				Исполнитель 			= Сотрудник_ПустаяСсылка;							
				Если ИсполнительСтрокой <> "" Тогда
					СтрокаИсполнтельУслуги = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", ИсполнительСтрокой, Ложь));
					Если НЕ СтрокаИсполнтельУслуги.Количество() = 0 Тогда
						Исполнитель 	= СтрокаИсполнтельУслуги[0].Ссылка;
					КонецЕсли;
				КонецЕсли;	
				
				Посещение.Дата 									= ВыборкаПосещение.ДатаПрихода;
				Посещение.СтруктурнаяЕдиница					= ?(ВыборкаПосещение.СтруктурнаяЕдиницаЧленстваПакетаУслуг = Неопределено, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ВыборкаПосещение.СтруктурнаяЕдиницаЧленстваПакетаУслуг);
				Посещение.Контрагент							= ВыборкаПосещение.КонтрагентЧленстваПакетаУслуг;
				Посещение.Основание								= ВыборкаПосещение.ЧленствоПакетУслуг;
				Посещение.ДатаПрихода 							= ВыборкаПосещение.ДатаПрихода;
				Посещение.ДатаУхода 							= ВыборкаПосещение.ДатаУхода;
				Посещение.ВремяПосещения 						= ВыборкаПосещение.ДатаУхода - ВыборкаПосещение.ДатаПрихода;
				Посещение.ПосещениеЗакрыто 						= ИСТИНА;
				Посещение.Комментарий 							= ВыборкаПосещение.ПрефиксСинхронизации + " - " + ВыборкаПосещение.ИДПосещения + Символы.ПС + СокрЛП(ВыборкаПосещение.Комментарий);
				Посещение.АвторДокумента 						= АвторДокумента;
				Посещение.КодСинхронизации 						= ВыборкаПосещение.ИДПосещения;
				Посещение.ПрефиксСинхронизации					= ВыборкаПосещение.ПрефиксСинхронизации;

				Посещение.ОбменДанными.Загрузка 				= Истина;
				
				// Запишем документ
				Попытка
					ЗаписатьДокумент(Посещение);		
				Исключение
					// Запись в лог
					ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка сохранения док-та Посещение %2  Код синхронизации: %3 %1 %4';en='%1 Mistake save doc Visit Visit 2 synchronization code: %3 %1 %4'"), Символы.ПС, Строка(ВыборкаПосещение.КонтрагентЧленстваПакетаУслуг), СокрЛП(ВыборкаПосещение.ИДПосещения), ОписаниеОшибки()));						
				КонецПопытки;	
				
				// Накапливаем и выводим статисические данные и оповещаем клиент
				ПредставлениеПосещения			= ?(Посещение = Неопределено, "", Строка(Посещение.Ссылка));
				Прогресс 						= Цел(100 * СозданоПосещений / ОбщееКоличествоПосещений);
				ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
				ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
				ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по посещениям...';en='Saving data by visits...'") + Символы.Таб + НСтр("ru=' Осталось: ';en='Left:'") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеПосещения, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
				СообщилиПрогресс = Истина;
				
			КонецЦикла;	
		Иначе
			// Запись в лог...
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Членство/Пакет услуг не найден! Код синхронизации: ';en='Membership Services package not found! Code sync:'") + Строка(ВыборкаПоКонтрактам.ИДКонтракта));			
		КонецЕсли;
		Если СообщилиПрогресс = Ложь Тогда
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеПосещения			= "";
			Прогресс 						= Цел(100 * СозданоПосещений / ОбщееКоличествоПосещений);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по посещениям...';en='Saving data by visits...'") + Символы.Таб + НСтр("ru=' Осталось: ';en='Left:'") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеПосещения, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;
	КонецЦикла;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаМенеджеров.Очистить();	 							ТаблицаМенеджеров 				= Неопределено;	
	ТаблицаИсполнителей.Очистить();								ТаблицаИсполнителей 			= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 						ТаблицаСотрудниковВБазе 		= Неопределено;
	ВыборкаПоКонтрактам 										= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить посещения в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьПосещенияВФонеAccessМногопоточно(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Посещения 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Посещения;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Посещения, "Таблица_Посещения");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Посещения.Оператор КАК Менеджер
	               |ИЗ
	               |	Таблица_Посещения КАК Таблица_Посещения
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Посещения.Оператор
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Посещения.ОператорЗоны КАК Исполнитель
	               |ИЗ
	               |	Таблица_Посещения КАК Таблица_Посещения
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Посещения.ОператорЗоны
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование,
	               |	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ТаблицаМенеджеров			 				= РезультатПакетаЗапросов[0].Выгрузить();	
	ТаблицаИсполнителей							= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[2].Выгрузить();
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимых сотрудников и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Получим должность для менеджеров по продажам	
	ДолжностьМенеджер 	= ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	// Получим должность для тренера	
	ДолжностьТренер 	= ПолучитьДолжностьПоНаименованию("Тренер");
	
	// Создаем необходимых менеджеров на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеров Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.Менеджер) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаМенеджер.Менеджер), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.Менеджер, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.Менеджер, 0, ""));		
	КонецЦикла;
	
	// Создаем необходимых исполнителей на текущем этапе
	Для Каждого СтрокаИсполнитель Из ТаблицаИсполнителей Цикл
		Если НЕ СокрЛП(СтрокаИсполнитель.Исполнитель) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаИсполнитель.Исполнитель), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаИсполнитель.Исполнитель, ДолжностьТренер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаИсполнитель.Исполнитель, 0, ""));		
	КонецЦикла;
	
	#КонецОбласти
	
	КоличествоПотоков 				= ПараметрыЗадания.ПараметрыЗагрузки.КоличествоПотоковДляЭтапаЗанятия;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	МассивТаблиц 					= Новый Массив;
	РазбитьТаблицуОбъектовПоКлючевомуПолю(Таблица_Посещения, "ИДКонтракта", КоличествоПотоков, МассивТаблиц);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Генерация фоновых заданий...';en='Generation of background works...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Генерируем фоновые задания
	МассивФоновыхЗаданий 				= Новый Массив;
	МассивИдентификаторовФоновыхЗаданий = Новый Массив;
	Для Каждого ТаблицаОбъектов Из МассивТаблиц Цикл 
		УникальныйИдентификаторЗадания 	= Новый УникальныйИдентификатор();
		ПараметрыПроцедуры = ПараметрыЗадания;
		ПараметрыПроцедуры.СписокТаблиц[0].Значение.Таблица_Посещения 			= ТаблицаОбъектов;
		ПараметрыПроцедуры.СписокТаблиц[0].Значение.КоличествоПолученныхСтрок 	= ТаблицаОбъектов.Количество();
		ПараметрыПроцедуры.Вставить("ТаблицаСотрудниковВБазе"		, ТаблицаСотрудниковВБазе);
		
		Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторЗадания,
		"ЗагрузкаПроведениеДокументов.ЗагрузитьПосещенияВПотокеAccess",
		ПараметрыПроцедуры,
		НСтр("ru = 'Генерация док-ов Посещение. Поток № " + Строка(МассивТаблиц.Найти(ТаблицаОбъектов)) + "'"));
		
		Если НЕ Результат = Неопределено Тогда 
			Задание = ДлительныеОперации.НайтиЗаданиеПоИдентификатору(Результат.ИдентификаторЗадания);
			Если НЕ Задание = Неопределено Тогда 
				МассивФоновыхЗаданий.Добавить(Задание);
				МассивИдентификаторовФоновыхЗаданий.Добавить(Результат.ИдентификаторЗадания);
			КонецЕсли;
		Иначе 
			ОшибкаИнициацииФоновогоЗадания = Истина;
		КонецЕсли;
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Передача идентификаторов фоновых заданий...';en='Broadcast background assignments ids...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, МассивИдентификаторовФоновыхЗаданий", "", 0, "", МассивИдентификаторовФоновыхЗаданий));
	
	// Ожидаем выполнения фоновых заданий 
	Если МассивФоновыхЗаданий.Количество() > 0 Тогда 
		Попытка 
			ФоновыеЗадания.ОжидатьЗавершения(МассивФоновыхЗаданий); 
		Исключение
			ОшибкаИнициацииФоновогоЗадания = Истина;			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка проведения!");
		КонецПопытки; 
	КонецЕсли;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	// ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаМенеджеров.Очистить();	 						ТаблицаМенеджеров 				= Неопределено;	
	ТаблицаИсполнителей.Очистить();							ТаблицаИсполнителей 			= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить посещения в потоке access
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьПосещенияВПотокеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	ТаблицаСотрудниковВБазе 							= ПараметрыЗадания.ТаблицаСотрудниковВБазе;
	Таблица_Посещения 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Посещения;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Посещения, "Таблица_Посещения");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Посещения.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Посещения.ИДПосещения КАК ИДПосещения,
	               |	Таблица_Посещения.ИДКонтракта КАК ИДКонтракта,
	               |	Таблица_Посещения.ДатаДокумента КАК ДатаДокумента,
	               |	Таблица_Посещения.Оператор КАК Оператор,
	               |	Таблица_Посещения.Оператор КАК ОператорЗоны,
	               |	Таблица_Посещения.ДатаПрихода КАК ДатаПрихода,
	               |	Таблица_Посещения.ДатаУхода КАК ДатаУхода,
	               |	Таблица_Посещения.КартаВхода КАК КартаВхода,
	               |	Таблица_Посещения.КартаВыхода КАК КартаВыхода,
	               |	Таблица_Посещения.НомерБокса КАК НомерБокса,
	               |	Таблица_Посещения.Тип КАК Тип,
	               |	Таблица_Посещения.Комментарий КАК Комментарий,
	               |	ЧленствоПакетУслуг.Ссылка КАК ЧленствоПакетУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.Контрагент
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК КонтрагентЧленстваПакетаУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ ЧленствоПакетУслуг.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЧленствоПакетУслуг.СтруктурнаяЕдиница
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК СтруктурнаяЕдиницаЧленстваПакетаУслуг,
	               |	Посещение.Ссылка КАК ПосещениеСсылка
	               |ИЗ
	               |	Таблица_Посещения КАК Таблица_Посещения
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг
	               |		ПО Таблица_Посещения.ИДКонтракта = ЧленствоПакетУслуг.КодСинхронизации
	               |			И Таблица_Посещения.ПрефиксСинхронизации = ЧленствоПакетУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Посещения.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Посещение КАК Посещение
	               |		ПО Таблица_Посещения.ИДПосещения = Посещение.КодСинхронизации
	               |			И Таблица_Посещения.ПрефиксСинхронизации = Посещение.ПрефиксСинхронизации
	               |			И (Таблица_Посещения.ИДПосещения > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаПрихода,
	               |	ИДПосещения
	               |ИТОГИ
	               |	МАКСИМУМ(ПрефиксСинхронизации),
	               |	МАКСИМУМ(ДатаДокумента),
	               |	МАКСИМУМ(Оператор),
	               |	МАКСИМУМ(ОператорЗоны),
	               |	МИНИМУМ(ДатаПрихода),
	               |	МАКСИМУМ(ДатаУхода),
	               |	МАКСИМУМ(КартаВхода),
	               |	МАКСИМУМ(КартаВыхода),
	               |	МАКСИМУМ(НомерБокса),
	               |	МАКСИМУМ(Тип),
	               |	МАКСИМУМ(ЧленствоПакетУслуг),
	               |	МАКСИМУМ(КонтрагентЧленстваПакетаУслуг),
	               |	МАКСИМУМ(СтруктурнаяЕдиницаЧленстваПакетаУслуг),
	               |	МАКСИМУМ(ПосещениеСсылка)
	               |ПО
	               |	ИДКонтракта,
	               |	ИДПосещения";
	
	#КонецОбласти
	                                        
	ВыборкаПоКонтрактам 					= Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	      	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по посещениям...';en='Saving data by visits...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоПосещений	 = ВыборкаПоКонтрактам.Количество();
	ОбщееКоличествоПосещений	= ?(ОбщееКоличествоПосещений < 1, 1, ОбщееКоличествоПосещений);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоПосещений			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеПосещения		= "";

	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКонтрактам.Следующий() Цикл
		СообщилиПрогресс = Ложь;		
		Если ЗначениеЗаполнено(ВыборкаПоКонтрактам.ЧленствоПакетУслуг) Тогда
			ВыборкаПоПосещениям = ВыборкаПоКонтрактам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоПосещениям.Следующий() Цикл
				СозданоПосещений = СозданоПосещений + 1;							
				ВыборкаПосещение = ВыборкаПоПосещениям.Выбрать();
				ВыборкаПосещение.Следующий();
				
				Если ЗначениеЗаполнено(ВыборкаПосещение.ПосещениеСсылка) Тогда
					Посещение = ВыборкаПосещение.ПосещениеСсылка.ПолучитьОбъект();
				Иначе
					Посещение = Документы.Посещение.СоздатьДокумент();
				КонецЕсли;	
				
				// Получим автора документа Посещение
				АвторДокументаСтрокой 	= СокрЛП(ВыборкаПосещение.Оператор);
				АвторДокумента 			= Сотрудник_ПустаяСсылка;
				Если АвторДокументаСтрокой <> "" Тогда
					СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", АвторДокументаСтрокой, Ложь));
					Если НЕ СтрокаМенеджерСотрудник.Количество() = 0 Тогда
						АвторДокумента 	= СтрокаМенеджерСотрудник[0].Ссылка;
					КонецЕсли;
				КонецЕсли;	
				
				// Получим исполнтеля (в данном случае пока не нужен)
				ИсполнительСтрокой 		= СокрЛП(ВыборкаПосещение.ОператорЗоны);
				Исполнитель 			= Сотрудник_ПустаяСсылка;							
				Если ИсполнительСтрокой <> "" Тогда
					СтрокаИсполнтельУслуги = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", ИсполнительСтрокой, Ложь));
					Если НЕ СтрокаИсполнтельУслуги.Количество() = 0 Тогда
						Исполнитель 	= СтрокаИсполнтельУслуги[0].Ссылка;
					КонецЕсли;
				КонецЕсли;	
				
				Посещение.Дата 									= ВыборкаПосещение.ДатаПрихода;
				Посещение.СтруктурнаяЕдиница					= ?(ВыборкаПосещение.СтруктурнаяЕдиницаЧленстваПакетаУслуг = Неопределено, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ВыборкаПосещение.СтруктурнаяЕдиницаЧленстваПакетаУслуг);
				Посещение.Контрагент							= ВыборкаПосещение.КонтрагентЧленстваПакетаУслуг;
				Посещение.Основание								= ВыборкаПосещение.ЧленствоПакетУслуг;
				Посещение.ДатаПрихода 							= ВыборкаПосещение.ДатаПрихода;
				Посещение.ДатаУхода 							= ВыборкаПосещение.ДатаУхода;
				Посещение.ВремяПосещения 						= ВыборкаПосещение.ДатаУхода - ВыборкаПосещение.ДатаПрихода;
				Посещение.ПосещениеЗакрыто 						= ИСТИНА;
				Посещение.Комментарий 							= ВыборкаПосещение.ПрефиксСинхронизации + " - " + ВыборкаПосещение.ИДПосещения + Символы.ПС + СокрЛП(ВыборкаПосещение.Комментарий);				
				Посещение.АвторДокумента 						= АвторДокумента;
				Посещение.КодСинхронизации 						= ВыборкаПосещение.ИДПосещения;
				Посещение.ПрефиксСинхронизации					= ВыборкаПосещение.ПрефиксСинхронизации;
				
				Посещение.ОбменДанными.Загрузка 				= Истина;
				
				// Запишем документ
				Попытка
					ЗаписатьДокумент(Посещение);		
				Исключение
					// Запись в лог
					ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка сохранения док-та Посещение: %2 Код синхронизации: %3 %1 %4';en='%1 Mistake save Doc Visit: %2 Sync Code: %3 %1 %4'"), Символы.ПС, Строка(ВыборкаПосещение.КонтрагентЧленстваПакетаУслуг), СокрЛП(ВыборкаПосещение.ИДПосещения), ОписаниеОшибки()));						
				КонецПопытки;	
				
				// Накапливаем и выводим статисические данные и оповещаем клиент
				ПредставлениеПосещения			= ?(Посещение = Неопределено, "", Строка(Посещение.Ссылка));
				Прогресс 						= Цел(100 * СозданоПосещений / ОбщееКоличествоПосещений);
				ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
				ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
				ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по посещениям...';en='Saving data by visits...'") + Символы.Таб + " Осталось: " + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеПосещения, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
				СообщилиПрогресс = Истина;
				
			КонецЦикла;	
		Иначе
			// Запись в лог...
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Членство/Пакет услуг не найден! Код синхронизации: ';en='Membership Services package not found! Code sync:'") + Строка(ВыборкаПоКонтрактам.ИДКонтракта));			
		КонецЕсли;
		Если СообщилиПрогресс = Ложь Тогда
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеПосещения			= "";
			Прогресс 						= Цел(100 * СозданоПосещений / ОбщееКоличествоПосещений);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по посещениям...';en='Saving data by visits...'") + Символы.Таб + НСтр("ru=' Осталось: ';en='Left:'") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеПосещения, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;
	КонецЦикла;
	
	// При сообщение на клиент больших текстовых данных (более 1000 строк), при этом в цикле (цикл используется как гарантия того что мы на клиенте 100% словим пересылаемые данные)
	// заметно уменьшается производительность. Ниже описанный механизм позволяет уменьшить количество итерации в цикле при больших текстовых данных. 
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	КоличествоСтрокВЛоге = СтрЧислоСтрок(ЛогГенерации);
	Если КоличествоСтрокВЛоге < 100 Тогда
		КоличествоИтераций = (100 - КоличествоСтрокВЛоге) * 100;
	ИначеЕсли КоличествоСтрокВЛоге > 99 И КоличествоСтрокВЛоге < 999 Тогда 
		КолСимволов = СтрДлина(Формат(КоличествоСтрокВЛоге, "ЧГ=0"));
		ВерхнийРубеж = "1";
		Для К = 0 По КолСимволов - 1 Цикл 
			ВерхнийРубеж = ВерхнийРубеж + "0";
		КонецЦикла;
		ВерхнийРубеж = Число(ВерхнийРубеж);
		КоличествоИтераций = ВерхнийРубеж - КоличествоСтрокВЛоге;
	ИначеЕсли КоличествоСтрокВЛоге > 999 Тогда
		КоличествоИтераций = КоличествоСтрокВЛоге;
	КонецЕсли;
	
	Для К = 0 По КоличествоИтераций Цикл 	
		ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
	ВыборкаПоКонтрактам 										= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить заморозки в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьЗаморозкиВФонеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	ТипКонтрагента_Клиенты						 		= Перечисления.ТипыКонтрагентов.Клиенты;
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	СтатусЗанятия_Проведено								= Перечисления.СтатусыЗанятия.Проведено;	
	ТипЗанятия_ПерсональноеЗанятие 						= Перечисления.ТипыЗанятий.ПерсональноеЗанятие;
	ВидОперации_Заморозка 								= Неопределено;
	ВидОперации_Блокировка 								= Неопределено;
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Заморозок 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Заморозок;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Заморозок, "Таблица_Заморозок");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Заморозок.АвторДокумента КАК МенеджерПоПродажам
	               |ИЗ
	               |	Таблица_Заморозок КАК Таблица_Заморозок
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Заморозок.АвторДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование,
	               |	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Заморозок.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Заморозок.ИД КАК ИД,
	               |	Таблица_Заморозок.ИДКонтракта КАК ИДКонтракта,
	               |	Таблица_Заморозок.Статус КАК Статус,
	               |	Таблица_Заморозок.АвторДокумента КАК АвторДокумента,
	               |	Таблица_Заморозок.ДатаДокумента КАК ДатаДокумента,
	               |	Таблица_Заморозок.ДатаНачала КАК ДатаНачала,
	               |	Таблица_Заморозок.ДатаОкончания КАК ДатаОкончания,
	               |	Таблица_Заморозок.Дней КАК Дней,
	               |	Таблица_Заморозок.НачалоКонтракта КАК НачалоКонтракта,
	               |	Таблица_Заморозок.ОкончаниеКонтракта КАК ОкончаниеКонтракта,
	               |	Таблица_Заморозок.КоличествоДнейЗаморозки КАК КоличествоДнейЗаморозки,
	               |	Таблица_Заморозок.Операция КАК Операция,
	               |	Таблица_Заморозок.Комментарий КАК Комментарий,
	               |	Членство.Ссылка КАК ЧленствоПакетУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ Членство.Ссылка ЕСТЬ NULL
	               |			ТОГДА Членство.Контрагент
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК КонтрагентЧленства,
	               |	ВЫБОР
	               |		КОГДА НЕ Членство.Ссылка ЕСТЬ NULL
	               |			ТОГДА Членство.Номенклатура
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК НоменклатураЧленства,
	               |	ОперацииСЧленствомПакетомУслуг.Ссылка КАК ОперацияСсылка,
	               |	ОперацииСЧленствомПакетомУслугУдалить.Ссылка КАК ОперацияСсылкаУдалить
	               |ИЗ
	               |	Таблица_Заморозок КАК Таблица_Заморозок
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК Членство
	               |		ПО Таблица_Заморозок.ИДКонтракта = Членство.КодСинхронизации
	               |			И Таблица_Заморозок.ПрефиксСинхронизации = Членство.ПрефиксСинхронизации
	               |			И (Таблица_Заморозок.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииСЧленствомПакетомУслуг КАК ОперацииСЧленствомПакетомУслуг
	               |		ПО Таблица_Заморозок.ИД = ОперацииСЧленствомПакетомУслуг.КодСинхронизации
	               |			И Таблица_Заморозок.ПрефиксСинхронизации = ОперацииСЧленствомПакетомУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Заморозок.ИД > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииСЧленствомПакетомУслуг КАК ОперацииСЧленствомПакетомУслугУдалить
	               |		ПО Таблица_Заморозок.ИДКонтракта = ОперацииСЧленствомПакетомУслугУдалить.КодСинхронизации
	               |			И Таблица_Заморозок.ПрефиксСинхронизации = ОперацииСЧленствомПакетомУслугУдалить.ПрефиксСинхронизации
	               |			И (Таблица_Заморозок.ИДКонтракта > 0)
	               |ГДЕ
	               |	Таблица_Заморозок.Актуальная = ЛОЖЬ
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаДокумента,
	               |	ИДКонтракта
	               |ИТОГИ
	               |	МАКСИМУМ(ПрефиксСинхронизации),
	               |	МАКСИМУМ(НачалоКонтракта),
	               |	МАКСИМУМ(ОкончаниеКонтракта),
	               |	МАКСИМУМ(КоличествоДнейЗаморозки),
	               |	МАКСИМУМ(ЧленствоПакетУслуг),
	               |	МАКСИМУМ(ОперацияСсылкаУдалить)
	               |ПО
	               |	ИДКонтракта
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Заморозок.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Заморозок.ИД КАК ИД,
	               |	Таблица_Заморозок.ИДКонтракта КАК ИДКонтракта,
	               |	Таблица_Заморозок.Статус КАК Статус,
	               |	Таблица_Заморозок.АвторДокумента КАК АвторДокумента,
	               |	Таблица_Заморозок.ДатаДокумента КАК ДатаДокумента,
	               |	Таблица_Заморозок.ДатаНачала КАК ДатаНачала,
	               |	Таблица_Заморозок.ДатаОкончания КАК ДатаОкончания,
	               |	Таблица_Заморозок.Дней КАК Дней,
	               |	Таблица_Заморозок.Операция КАК Операция,
	               |	Таблица_Заморозок.Комментарий КАК Комментарий,
	               |	Членство.Ссылка КАК ЧленствоПакетУслуг,
	               |	ВЫБОР
	               |		КОГДА НЕ Членство.Ссылка ЕСТЬ NULL
	               |			ТОГДА Членство.Контрагент
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК КонтрагентЧленства,
	               |	ВЫБОР
	               |		КОГДА НЕ Членство.Ссылка ЕСТЬ NULL
	               |			ТОГДА Членство.Номенклатура
	               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
	               |	КОНЕЦ КАК НоменклатураЧленства,
	               |	ОперацииСЧленствомПакетомУслуг.Ссылка КАК ОперацияСсылка
	               |ИЗ
	               |	Таблица_Заморозок КАК Таблица_Заморозок
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК Членство
	               |		ПО Таблица_Заморозок.ИДКонтракта = Членство.КодСинхронизации
	               |			И Таблица_Заморозок.ПрефиксСинхронизации = Членство.ПрефиксСинхронизации
	               |			И (Таблица_Заморозок.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацииСЧленствомПакетомУслуг КАК ОперацииСЧленствомПакетомУслуг
	               |		ПО Таблица_Заморозок.ИД = ОперацииСЧленствомПакетомУслуг.КодСинхронизации
	               |			И Таблица_Заморозок.ПрефиксСинхронизации = ОперацииСЧленствомПакетомУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Заморозок.ИД > 0)
	               |ГДЕ
	               |	Таблица_Заморозок.Актуальная = ИСТИНА
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаДокумента,
	               |	ИДКонтракта";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ТаблицаМенеджеровПоПродажам					= РезультатПакетаЗапросов[0].Выгрузить();
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[1].Выгрузить();
	ВыборкаПоКонтрактам		 					= РезультатПакетаЗапросов[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ТаблицаАктуальныхОперации 					= РезультатПакетаЗапросов[3].Выгрузить();
	
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Получим должность для менеджеров по продажам	
	ДолжностьМенеджер 	= ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	
	// Создаем необходимых менеджеров на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеровПоПродажам Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.МенеджерПоПродажам) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаМенеджер.МенеджерПоПродажам), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.МенеджерПоПродажам, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.МенеджерПоПродажам, 0, ""));		
	КонецЦикла;
		
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по завершенным заморозкам...';en='Saving data on completed frosts...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоЗаморозок 	= ВыборкаПоКонтрактам.Количество();
	ОбщееКоличествоЗаморозок	= ?(ОбщееКоличествоЗаморозок < 1, 1, ОбщееКоличествоЗаморозок);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоЗаморозок			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеЗаморозки		= "";
	
	МассивБессрочныхЧПУ = ПолучитьМассивБессрочныхЧПУ(ПараметрыЗадания.ПараметрыЗагрузки.СегментБессрочныхЧПУ);
	ПараметрыЗадания.ПараметрыЗагрузки.Вставить("МассивБессрочных", МассивБессрочныхЧПУ);
	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКонтрактам.Следующий() Цикл
		СообщилиПрогресс = Ложь;
		СозданоЗаморозок = СозданоЗаморозок + 1;
		Если ЗначениеЗаполнено(ВыборкаПоКонтрактам.ЧленствоПакетУслуг) Тогда
			ВыборкаПоОперациям = ВыборкаПоКонтрактам.Выбрать();
			
			НачалоКонтракта 				= ВыборкаПоКонтрактам.НачалоКонтракта;			
			ОкончаниеКонтракта 				= ВыборкаПоКонтрактам.ОкончаниеКонтракта;
			ОкончаниеКонтрактаСЗаморозками 	= ВыборкаПоКонтрактам.ОкончаниеКонтракта + ВыборкаПоКонтрактам.КоличествоДнейЗаморозки * 86400;
			
			Пока ВыборкаПоОперациям.Следующий() Цикл
				// Если ВыборкаПоОперациям.Статус = 2 Тогда // закрыт контракт - заморозки не грузим
				//	Продолжить;
				// КонецЕсли;	
