	Возврат ОбщегоНазначенияКлиентСервер.ПолучитьЗначениеИзСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию);
	
КонецФункции

&НаСервере
// Процедура, обновляет внешнюю систему в crm.
//
Процедура ОбновитьВнешнююСистему()
	
	РезультатЗапроса = ЛичныйКабинет.ОбновитьВнешнююСистемуВ_CRM(Объект.Ссылка, Истина, ЛичныйКабинет.УидТекущейСессии());
	
	Если НЕ РезультатЗапроса.ВыполненоУспешно Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатЗапроса.ОписаниеОшибки + "(" + РезультатЗапроса.КодОшибки + ")");
		
		Если Объект.Ссылка.Пустая() Тогда
			Объект.Используется = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

