
#Область СлужебныеПроцедурыИФункции

&НаКлиенте 
// Процедура - Создать элемент
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СоздатьЭлемент(Команда)
	
	СписокЗнач = Новый СписокЗначений;
	
	СписокЗнач.Добавить(1,"Исходящее письмо" ,,БиблиотекаКартинок.ПисьмоПереслатьНовая);
	// СписокЗнач.Добавить(2,"Входящее письмо",,БиблиотекаКартинок.ПисьмоОтветитьНовая);
	
	ПоказатьВыборИзМеню(Новый ОписаниеОповещения("СоздатьЭлементПродолжение",ЭтотОбъект),СписокЗнач,Элементы.СоздатьЭлемент);

КонецПроцедуры

&НаКлиенте
// Процедура - Создать элемент продолжение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СоздатьЭлементПродолжение(Результат,ДополнительныеПараметры) Экспорт
	
	Если  Результат = Неопределено Тогда 
		Возврат; 
	КонецЕсли; 
	
	Если Результат.Значение = 1 Тогда
		ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.ФормаОбъекта");
	//ИначеЕсли Результат.Значение = 2 Тогда
    //	ОткрытьФорму("Документ.ЭлектронноеПисьмоВходящее.ФормаОбъекта");	
	Конецесли; 
	
КонецПроцедуры

#КонецОбласти
