
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, при создании на сервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Операторы = IPТелефония.ITOOLABS_ДоступныеАТС();
	
	
	Для каждого ОписаниеОператора Из Операторы Цикл
		НоваяСтрока = СписокОператоров.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ОписаниеОператора, "Представление,Идентификатор,Ссылка");
		Если Параметры.Свойство("ВыбранныйОператор") И ТипЗнч(Параметры.ВыбранныйОператор) = Тип("Структура") И Параметры.ВыбранныйОператор.Свойство("Идентификатор") Тогда
			НоваяСтрока.Используется = (ОписаниеОператора.Идентификатор = Параметры.ВыбранныйОператор.Идентификатор);
		КонецЕсли;
	КонецЦикла;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
	//СписокОператоров.Сортировать("Представление Возр");
	
	//	Элементы.ВыполнитьПоиск.СочетаниеКлавиш = ОбщегоНазначения.УстановитьСочетаниеКлавиш(13,,);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура, список операторов используетя при изменении.
//
Процедура СписокОператоровИспользуетяПриИзменении(Элемент)
	
	ВыбранныйОператор = Новый Структура("Представление,Идентификатор,Ссылка");
	ЗаполнитьЗначенияСвойств(ВыбранныйОператор, Элементы.СписокОператоров.ТекущиеДанные, "Представление,Идентификатор,Ссылка");
	ОповеститьОВыборе(ВыбранныйОператор);
	
	
КонецПроцедуры

&НаКлиенте
// Процедура, список операторов выбор.
//
Процедура СписокОператоровВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПерейтиПоНавигационнойСсылке(Элемент.ТекущиеДанные.Ссылка);
	
КонецПроцедуры

&НаКлиенте
// Процедура, поле поиска очистка.
//
Процедура ПолеПоискаОчистка(Элемент, СтандартнаяОбработка)
	Элементы.СписокОператоров.ОтборСтрок = Неопределено;
КонецПроцедуры

&НаКлиенте
// Процедура, поле поиска авто подбор.
//
Процедура ПолеПоискаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	Если СтрДлина(Текст) >= 1 Тогда
		Элементы.СписокОператоров.ОтборСтрок = Новый ФиксированнаяСтруктура(Новый Структура("Представление", Текст));
	Иначе
		Элементы.СписокОператоров.ОтборСтрок = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#КонецОбласти