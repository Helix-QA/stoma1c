
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если  ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	Если Не РольДоступна("ПолныеПрава") Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Активный", Истина, Истина);
		Элементы.ФормаВклРекламныеИсточники.Видимость = Ложь;
		Элементы.ФормаВыклРекламныеИсточники.Видимость = Ложь; 
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды формы "ВклРекламныеИсточники".
//
Процедура ВклРекламныеИсточники(Команда)
	УстановитьСтатусРекламныхИсточниковНаСервере(Ложь);	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды формы "ВыклРекламныеИсточники".
//
Процедура ВыклРекламныеИсточники(Команда)
	УстановитьСтатусРекламныхИсточниковНаСервере(Истина);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, устанавливает статус рекламного источника.
//
Процедура УстановитьСтатусРекламныхИсточниковНаСервере(Статус)
	
	Для Каждого РекламныйИсточник Из Элементы.Список.ВыделенныеСтроки Цикл
		РекламныйИсточникОбъект = РекламныйИсточник.ПолучитьОбъект();
		РекламныйИсточникОбъект.Активный = Статус;
		
		Попытка
			РекламныйИсточникОбъект.Записать();
		Исключение
			
		КонецПопытки;
	КонецЦикла;
	
	Элементы.Список.Обновить();
	
КонецПроцедуры

#КонецОбласти
