			Элемент.ТекущиеДанные.ПробиватьНефискальныйЧек = Ложь; 		
			ПоказатьПредупреждение(,"Для данного вида оплаты невозможно использование не фискального чека!");
		КонецЕсли; 	
	КонецЕсли;
	
КонецПроцедуры

