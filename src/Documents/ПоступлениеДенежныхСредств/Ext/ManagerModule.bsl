		Если ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные  Тогда
		     УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчетКонтрагента",,ЛОжь); 
		 КонецЕсли;
		 УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Ложь);
	 ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВозвратЗаработнойПлаты Тогда
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчетКонтрагента",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Контрагент",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа",,Истина);
        УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.Сотрудник",,Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаВыплатаЗП",Тип("ГруппаФормы"),Истина);	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаИнформация",Тип("ГруппаФормы"),Ложь);
        УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.ДокументАванса",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Истина);
		
	КонецЕсли;
	
	Если ОбъектФормы.СтатьяВТаблице Тогда
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.Статья");
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Статья",,,Ложь);
 	КонецЕсли;
	
	Возврат МассивРеквизитов;
	
КонецФункции // ПолучитьМассивыРеквизитов()

// Получить массив обязательных для заполнения реквизитов реквизитов
Процедура ПолучитьМассивыОбязательныхРеквизитов(ДокументОбъект,МассивОбязательныхРеквизитов) Экспорт
	
	МассивОбязательныхРеквизитов.Добавить("ТипДенежныхСредств");
	МассивОбязательныхРеквизитов.Добавить("ВидОперации");
	МассивОбязательныхРеквизитов.Добавить("СуммаДокумента");

	// Состояние реквизитов в зависимости от типа денежных средств
	Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
		МассивОбязательныхРеквизитов.Добавить("Касса");
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда		 
		МассивОбязательныхРеквизитов.Добавить("БанковскийСчет");  
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда		
		МассивОбязательныхРеквизитов.Добавить("ЭквайрингТерминал");
		МассивОбязательныхРеквизитов.Добавить("ЭквайрингВидПлатежнойКарты");		
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда	
		МассивОбязательныхРеквизитов.Добавить("ЛицевойСчетКонтрагента");
	КонецЕсли;

	// Состояние реквизитов в зависимости от вида операции
	Если ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента Тогда			
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа");	
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ДокументОснования");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сумма");
		Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда
		   МассивОбязательныхРеквизитов.Добавить("БанковскийСчетКонтрагента");
	    КонецЕсли;
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет Тогда				
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
		МассивОбязательныхРеквизитов.Добавить("ЛицевойСчетКонтрагента");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОтПодотчетника Тогда	
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа");	
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ДокументОснования");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сумма");	
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзБанка Тогда		
		МассивОбязательныхРеквизитов.Добавить("БанковскийСчетКонтрагента");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыОтПоставщика 
		ИЛИ ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратЗайма Тогда			
		МассивОбязательныхРеквизитов.Добавить("Контрагент");		
		Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда			
			МассивОбязательныхРеквизитов.Добавить("БанковскийСчетКонтрагента");			
		КонецЕсли;		
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда		
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа");	
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ДокументОснования");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сумма");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратНалога Тогда
        МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ВидНалога");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеОтЭквайера Тогда
        МассивОбязательныхРеквизитов.Добавить("ЭквайрингТерминал"); // ЭквайрингДоговор.
    ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ПрочееПоступление Тогда
         Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
			МассивОбязательныхРеквизитов.Добавить("Контрагент");
		КонецЕсли;
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратЗаработнойПлаты Тогда		
		МассивОбязательныхРеквизитов.Добавить("ВозвратВыплатыЗПДокументОснования");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа");	
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ДокументОснования");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сотрудник");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сумма");

	КонецЕсли;
	
КонецПроцедуры

