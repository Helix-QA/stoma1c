// Процедура - Пробить чек выполнить после выбора устройства
//
// Параметры:
//  ИдентификаторУстройства	 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПробитьЧекВыполнитьПослеВыбораУстройства(ИдентификаторУстройства, ЧекКоррекции) Экспорт
	
	ОписаниеОшибки = "";
	
	Если НЕ ИдентификаторУстройства = Неопределено Тогда
		
		ПараметрывККТ    = МенеджерОборудованияКлиентПовтИсп.ПолучитьПараметрыУстройства(ИдентификаторУстройства);					
		Результат = МенеджерОборудованияКлиент.ПодключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства, ОписаниеОшибки);
		
		Если Результат Тогда 			
			
			ОбщиеПараметры = ПодготовитьДанныеДляПробитияЧека(ЧекКоррекции);
			
			ВходныеПараметры  = Новый Массив;
			ВходныеПараметры.Добавить(ОбщиеПараметры.ФискальныйЧек);
			ВыходныеПараметры = Новый Массив; 	
			
			Если ОбщиеПараметры.Результат Тогда 												
				// Печать фискального чека
				Результат = МенеджерОборудованияКлиент.ВыполнитьКоманду(ИдентификаторУстройства, "PrintReceipt", ВходныеПараметры, ВыходныеПараметры);
			КонецЕсли;
			
			Если Результат Тогда	
				ПробитьЧекВыполнитьЗавершение(ВыходныеПараметры);
				// ЧекКоррекции.НомерЧекаККМ        = ?(Не ЗначениеЗаполнено(ВыходныеПараметры[1]), 1, ВыходныеПараметры[1]);			
			Иначе					
				ОписаниеОшибки      = ВыходныеПараметры[1];
				ПроизошлоИсключение = Истина;							
			КонецЕсли;					
			// Отключаем ФР
			МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(УникальныйИдентификатор, ИдентификаторУстройства);
			
		Иначе
			ТекстСтандартногоСообщения = НСтр("ru = 'При подключении устройства произошла ошибка.
			|Чек не напечатан на фискальном регистраторе.
			|Дополнительное описание:
			|%ДополнительноеОписание%'");
			ПроизошлоИсключение = Истина;
		КонецЕсли;
		
	КонецЕсли;		
	
КонецПроцедуры

