// Функция - Получить таблицу клиник.
//
Функция ПолучитьТаблицуКлиник()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	//"ВЫБРАТЬ 
	//|	СотрудникиМестаРаботы.СтруктурнаяЕдиница КАК Салон
	//|ИЗ
	//|	Справочник.Сотрудники.МестаРаботы КАК СотрудникиМестаРаботы
	//|ГДЕ
	//|	СотрудникиМестаРаботы.Ссылка = &Пользователь
	//|	И СотрудникиМестаРаботы.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ
	//|	И СотрудникиМестаРаботы.Ссылка.ЭтоГруппа = ЛОЖЬ
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	СотрудникиМестаРаботы.СтруктурнаяЕдиница";  
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.СтруктурнаяЕдиница КАК Клиника
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НЕ НастройкиСотрудников.СтруктурнаяЕдиница.Ссылка ЕСТЬ NULL
	|	И НастройкиСотрудников.Сотрудник = &Сотрудник
	|	И НЕ НастройкиСотрудников.СтруктурнаяЕдиница.ПометкаУдаления
	|	И НЕ НастройкиСотрудников.СтруктурнаяЕдиница.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("Сотрудник", ПараметрыСеанса.ТекущийПользователь.Сотрудник);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытийТабличногоДокумента

&НаКлиенте
// Процедура - Обработка события "Выбор" табличного документа
// 
// 
Процедура ГрафикПериодовРаботыТабДокВыбор(Элемент, Область, СтандартнаяОбработка)
	
	Если ЕстьПравоРедактирования Тогда
		
		ИмяОбласти = Область.Имя;
		
		Позиция = СтрНайти(ИмяОбласти,"C");
		Позиция_Двоеточие = СтрНайти(ИмяОбласти,":");
		
		НомерКолонки = Сред(ИмяОбласти, Позиция+1, Позиция_Двоеточие-Позиция-1);
		
		// Если это первая колонка, то открыть его форму сотрудника,
		// в противном случае добавлять периоды 	
		Если НомерКолонки = "1" Тогда
			
			// сотрдуник
			НомерСтроки		= Сред(ИмяОбласти, 2, позиция - 2 );
			ИД_Сотрудника	= ГрафикПериодовРаботыТабДок.Область("R"+СтрЗаменить(НомерСтроки,Символы.НПП,"")+"C2").Текст;
			
			Сотрудник		= НайтиСотрудникаПоИД(ИД_Сотрудника); 
			
			Если Сотрудник <> Неопределено Тогда
				ОткрытьФорму("Справочник.Сотрудники.Форма.ФормаЭлемента", Новый Структура("Ключ",Сотрудник));
			КонецЕсли;
			
		Иначе
			
			СтруктураДанныхОбласти = ПолучитьДанныеВыделеннойОбластиГрафикПериодовРаботыТабДок(ИмяОбласти);
			
			СтартоваяДата = СтруктураДанныхОбласти.ВыбПериод;
			Если Не ЗначениеЗаполнено(СтартоваяДата) Тогда
				Возврат;
			КонецЕсли;     	
			
			Сотрудник = СтруктураДанныхОбласти.Сотрудник;
			Если Не ЗначениеЗаполнено(Сотрудник) Тогда
				Возврат;
			КонецЕсли;   
			
			ПериодЗаполнения      = Новый СтандартныйПериод(ОтборПериод.ДатаНачала, ОтборПериод.ДатаОкончания);        	
			ИнтервалыСформированы = ФормированиеИнтерваловЗавершено(Ложь);
			ИнтервалыРаботы		  = ОтборИнтервалыРаботы.Скопировать();
			Если НЕ ИнтервалыСформированы Тогда
				ИнтервалыРаботы.Очистить();
			КонецЕсли;      
			
			// Добавляем выбранные периоды если содержимое ячейки пустое или очищаем если содержимое есть
			ФлагНеобходимоОчиститьОбласть	= ПроверитьНеобходимостьОчисткиОбласти(СтруктураДанныхОбласти.Содержимое, ИнтервалыРаботы);
			
			ПриемыВходятВИнтервалыРабот		= ПроверитьПриемыВходятВИнтервалыРабот(Сотрудник, СтартоваяДата, ОтборСтруктурнаяЕдиница, ?(ФлагНеобходимоОчиститьОбласть, Новый СписокЗначений, ИнтервалыРаботы));   			
			
			// Проверяем на работу структурой единицы в выбранный интервал
			ВремяРаботыСтруктурнойЕдиницыДень = ВернутьВремяРаботыСтруктурнойЕдиницыПоДате(СтартоваяДата,ОтборСтруктурнаяЕдиница);
			
			Если ВремяРаботыСтруктурнойЕдиницыДень <> неопределено Тогда
				
				Для Каждого Интервал из ИнтервалыРаботы Цикл	
					
					// Корректируем интервал начало или конец если он выходит за рамки работы структурной 
					Если Интервал.Значение.НачалоРаботы    < ВремяРаботыСтруктурнойЕдиницыДень.НачалоРаботы Тогда
						Интервал.Значение.НачалоРаботы = ВремяРаботыСтруктурнойЕдиницыДень.НачалоРаботы;
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Скорректировано время начала работы на "+ Формат(СтартоваяДата, "ДЛФ = ДДММГГ") + " по времени работы клиники.");
					КонецЕсли;
					
					Если Интервал.Значение.ОкончаниеРаботы > ВремяРаботыСтруктурнойЕдиницыДень.ОкончаниеРаботы Тогда
						Интервал.Значение.ОкончаниеРаботы =  ВремяРаботыСтруктурнойЕдиницыДень.ОкончаниеРаботы ;
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Скорректировано время окончания работы на "+ Формат(СтартоваяДата, "ДЛФ = ДДММГГ") + " по времени работы клиники.");
					КонецЕсли;
					
				КонецЦикла;
				
				
			Иначе
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Клиника не работает "+ Формат(СтартоваяДата, "ДЛФ = ДДММГГ"));
				Возврат;
				
			КонецЕсли;  	
			
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("СтартоваяДата"				, СтартоваяДата);
			СтруктураПараметров.Вставить("ФлагНеобходимоОчиститьОбласть", ФлагНеобходимоОчиститьОбласть);
			СтруктураПараметров.Вставить("ИнтервалыРаботы"				, ИнтервалыРаботы);
			СтруктураПараметров.Вставить("Сотрудник"					, Сотрудник);
			
			Если НЕ ПриемыВходятВИнтервалыРабот Тогда
				Если ТипЗнч(ИнтервалыРаботы) = Тип("СписокЗначений") И ИнтервалыРаботы.Количество() > 0 Тогда
					Оповещение = Новый ОписаниеОповещения("ГрафикПериодовРаботыТабДокВыборПродолжить", ЭтотОбъект, СтруктураПараметров);
					ПоказатьВопрос(Оповещение, "У сотрудника " + Сотрудник + " " + Формат(СтартоваяДата, "ДЛФ = ДДММГГ")+ " запланированы приемы, не входящие в выбранные смены. Продолжить?", РежимДиалогаВопрос.ДаНетОтмена);			
					
				Иначе
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У сотрудника " + Сотрудник + " " + Формат(СтартоваяДата, "ДЛФ = ДДММГГ")+ " запланированы приемы. Удаление интервала невозможно.");			
				КонецЕсли;
			Иначе
				ГрафикПериодовРаботыТабДокВыборПродолжить(КодВозвратаДиалога.Да, СтруктураПараметров);
			КонецЕсли;	
			
			Отказ = истина;
			
		КонецЕсли;  
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - график периодов работы продолжить
// 
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
// 
Процедура ГрафикПериодовРаботыТабДокВыборПродолжить(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗаполнитьТаблицуРезультатПланирования(Параметры.СтартоваяДата, ?(Параметры.ФлагНеобходимоОчиститьОбласть, Новый СписокЗначений, Параметры.ИнтервалыРаботы), Параметры.Сотрудник);
		//ПослеЗакрытияФормыСозданияОповещение(РезультатПланированияРазовый, Результат);
		ПослеЗакрытияФормыСозданияОповещение(РезультатПланированияРазовый,);
		МодифицированностьГрафикаРаботы = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция проверяет необходимость очищения значения в выбранной ячейке табличного документа "ГрафикПериодовРаботыТабДок"
// 
// 
Функция ПроверитьНеобходимостьОчисткиОбласти(Знач СодержимоеОбласти, Знач ИнтервалыРаботы)
	
	Результат = Истина;
	
	//Если ИнтервалыРаботы.Количество() = 1 Тогда
	//	Результат = Ложь;
	//КонецЕсли;
	
	СодержимоеОбласти = СтрЗаменить(СодержимоеОбласти," ","");
	СодержимоеОбласти = СтрЗаменить(СодержимоеОбласти,"*","");
	
	Если СтрЧислоВхождений(СодержимоеОбласти, Символы.ПС)+1 <> ИнтервалыРаботы.Количество() Тогда
		Результат = Ложь;		
	КонецЕсли;
	
	Для каждого СтрокаТЧ из ИнтервалыРаботы Цикл
		Если СтрНайти(СодержимоеОбласти, СокрЛП(Лев(СтрокаТЧ.Представление, СтрНайти(СтрокаТЧ.Представление,"(")-1))) = 0 тогда
			Результат = Ложь;
			Прервать;
		КонецЕсли;		
	КонецЦикла;
	
	Возврат Результат;	
	
КонецФункции

&НаКлиенте
// Процедура - Подключаемый декорация формы удалить текущий интервал нажатие
// 
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура Подключаемый_ДекорацияФормы_УдалитьТекущийИнтервал_Нажатие(Элемент)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Элемент);
	
	Если НЕ СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда
		Если ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы].Количество() = 1 Тогда 
			ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы][СтруктураДанныеЭлемента.ИндексСтроки].Значение = Новый Структура("НачалоРаботы, ОкончаниеРаботы", Неопределено, Неопределено);
			ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы][СтруктураДанныеЭлемента.ИндексСтроки].Представление = "";
		Иначе 
			ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы].Удалить(ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы][СтруктураДанныеЭлемента.ИндексСтроки]);
		КонецЕсли;	
		ОбновитьМенюОтбораИнтерваловРабот();
		ОбновитьОбщееВремяИнтервалов();		
		ОбновитьДекорациюУпраленияСохранениемШаблонов();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Обработчик кнопки формирования плана занятий
// 
Процедура КомандаСформировать(Команда)	
	
	Если ПроверитьНеобходимостьФиксацииИзмененийВПлане() Тогда
		
		Если ПроверитьБуферФормированияНаПересечениеПериодов() Тогда
			ЗафиксироватьИзмененияВПланеЗанятий();			
			ПоказатьОповещениеПользователя(,,"График работы сохранен.", БиблиотекаКартинок.Информация32, СтатусОповещенияПользователя.Информация);
		КонецЕсли;
	Иначе
		ПоказатьОповещениеПользователя(,,"Изменений в графике работы не обнаружено.", БиблиотекаКартинок.Информация32, СтатусОповещенияПользователя.Информация);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Показать список шаблонов.
// 
// Параметры:
//  Команда	 - 	 - 
// 
Процедура ПоказатьСписокШаблонов(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыборШаблонаИзСписка", ЭтотОбъект);
	СписокПериодов     = ПолучитьСписокПериодовРаботы(ОтборСтруктурнаяЕдиница);
	Если СписокПериодов.Количество() > 10 Тогда
		мПараметры = Новый Структура();
		мПараметры.Вставить("ВариантОтображения","Период");
		мПараметры.Вставить("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);
		ОткрытьФорму("Справочник.ПериодыРаботы.Форма.ФормаВыбораГрафикРаботы",мПараметры,,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе 
		ПоказатьВыборИзМеню(ОписаниеОповещения, СписокПериодов, Элементы.ПоказатьСписокШаблонов);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбрать период планирования
// 
// Параметры:
//  Команда	 - 	 - 
// 
Процедура ВыбратьПериодПланирования(Команда)
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период = ОтборПериод;
	Диалог.Показать(Новый ОписаниеОповещения("ОтборПериодаПланированииПриИзменении", ЭтаФорма)); 

КонецПроцедуры

&НаКлиенте
// Процедура - Команда добавить интервал
// 
// Параметры:
//  Команда	 - 	 - 
// 
Процедура КомандаДобавитьИнтервал(Команда)
	
	ОтборИнтервалыРаботы.Добавить(Новый Структура("НачалоРаботы, ОкончаниеРаботы", Неопределено, Неопределено));
	ОбновитьМенюОтбораИнтерваловРабот();
	ОбновитьДекорациюУпраленияСохранениемШаблонов();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Подключаемый выбор начала интервала
// 
// Параметры:
//  Команда	 - 	 - 
// 
Процедура Подключаемый_ВыборНачалаИнтервала(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Команда);
	
	Если НЕ СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда 
		
		Шаг = 15; // в минутах		
		ИмяЭлемента = "Кнопка_ВыборНачалаИнтервала_" + СтруктураДанныеЭлемента.ИндексСтроки;
		СтруктураДанныеЭлемента.Вставить("ИмяЭлемента"			, ИмяЭлемента);			
		СтруктураДанныеЭлемента.Вставить("ЭтоНачалоИнтервала"	, Истина);
		
		ЭлементМассиваДней = Неопределено;
		
		Для Каждого ЭлементМ ИЗ ВремяРаботыСтруктурнойЕдиницы Цикл
				
			Если ЭлементМассиваДней = Неопределено Тогда 
				ЭлементМассиваДней = ЭлементМ;
			ИначеЕсли ЭлементМассиваДней.ДатаНачала > ЭлементМ.ДатаНачала Тогда // находим минимум
				ЭлементМассиваДней = ЭлементМ;
			КонецЕсли;
			
		КонецЦикла;			
		Если ЭлементМассиваДней <> Неопределено Тогда
			// Заполнить список интервалов времени
			МассивПериодов = Новый Массив;
			МассивПериодов.Добавить(ЭлементМассиваДней);
			НачинаяСВремени 		= ВернутьПоследнееУказанноеВремя(СтруктураДанныеЭлемента, Шаг);			
			СписокВермениРаботы  	= ОбщегоНазначенияКлиентСерверСтоматология.ВернутьСписокВремени(МассивПериодов, Истина, Шаг, , НачинаяСВремени);	
			ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВремениИзСписка", ЭтотОбъект, СтруктураДанныеЭлемента);
			
			Если СписокВермениРаботы.Количество() > 10 Тогда
				
				мПараметры = Новый Структура();				
				мПараметры.Вставить("ВариантОтображения", "НачалоПериода");
                мПараметры.Вставить("Таблица", СписокВермениРаботы);
				ОткрытьФорму("Справочник.ПериодыРаботы.Форма.ФормаВыбораГрафикРаботы", мПараметры,,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
				
			Иначе
			
			ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокВермениРаботы, Элементы[ИмяЭлемента]);
			
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Подключаемый выбор окончания интервала
// 
// Параметры:
//  Команда	 - 	 - 
// 
Процедура Подключаемый_ВыборОкончанияИнтервала(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Команда);
	
	Если НЕ СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда 
		
		Шаг = 15; // в минутах
		ИмяЭлемента = "Кнопка_ВыборОкончанияИнтервала_" + СтруктураДанныеЭлемента.ИндексСтроки;
		СтруктураДанныеЭлемента.Вставить("ИмяЭлемента"			, ИмяЭлемента);			
		СтруктураДанныеЭлемента.Вставить("ЭтоНачалоИнтервала"	, Ложь);
		
		ЭлементМассиваДней = Неопределено;
		Для Каждого ЭлементМ ИЗ ВремяРаботыСтруктурнойЕдиницы Цикл
			
			Если ЭлементМассиваДней = Неопределено Тогда
				
				ЭлементМассиваДней = ЭлементМ; 
				
			ИначеЕсли ЭлементМассиваДней.ДатаОкончания < ЭлементМ.ДатаОкончания Тогда // находим минимум
									
				ЭлементМассиваДней = ЭлементМ;
				
			КонецЕсли;
				
		КонецЦикла;
		
		Если ЭлементМассиваДней <> Неопределено Тогда
			
			// Заполнить список интервалов времени
			МассивПериодов = Новый Массив();
			МассивПериодов.Добавить(ЭлементМассиваДней);
			НачинаяСВремени 		= ВернутьПоследнееУказанноеВремя(СтруктураДанныеЭлемента, Шаг);
			СписокВермениРаботы 	= ОбщегоНазначенияКлиентСерверСтоматология.ВернутьСписокВремени(МассивПериодов, Ложь, Шаг, , НачинаяСВремени);	
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВремениИзСписка", ЭтотОбъект, СтруктураДанныеЭлемента);
			Если СписокВермениРаботы.Количество() > 10 Тогда
				
				мПараметры = Новый Структура();				
				мПараметры.Вставить("ВариантОтображения", "КонецПериода");
