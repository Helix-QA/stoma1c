Процедура СопоставитьВидЦен(ВидЦен, ВидЦен_ВходящиеДанные, ЗначениеПоУмолчанию) Экспорт
	
	Если НЕ ПустаяСтрока(ВидЦен_ВходящиеДанные) Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ВидЦен_ВходящиеДанные", СокрЛП(ВидЦен_ВходящиеДанные));
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СпрВидыЦен.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВидыЦен КАК СпрВидыЦен
		|ГДЕ
		|	СпрВидыЦен.Наименование ПОДОБНО &ВидЦен_ВходящиеДанные
		|	И НЕ СпрВидыЦен.ПометкаУдаления
		|	И НЕ СпрВидыЦен.ЭтоГруппа";
		Запрос.УстановитьПараметр("ВидЦен_ВходящиеДанные", ВидЦен_ВходящиеДанные + "%");
		Выборка = Запрос.Выполнить().Выбрать();            
		
		ВидЦен = ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидЦен) Тогда
		
		ВидЦен = ЗначениеПоУмолчанию;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СопоставитьУпаковку(Упаковка, Упаковка_ВходящиеДанные, Номенклатура, ЗначениеПоУмолчанию) Экспорт
	
	Если НЕ ПустаяСтрока(Упаковка_ВходящиеДанные) Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Упаковка_ВходящиеДанные", СокрЛП(Упаковка_ВходящиеДанные));
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	УпаковкиНоменклатуры.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
		|ГДЕ
		|	НЕ УпаковкиНоменклатуры.ПометкаУдаления
		|	И УпаковкиНоменклатуры.Наименование ПОДОБНО &Упаковка_ВходящиеДанные
		|	И УпаковкиНоменклатуры.Владелец = &Владелец";
		Запрос.УстановитьПараметр("Упаковка_ВходящиеДанные", Упаковка_ВходящиеДанные + "%");
		Запрос.УстановитьПараметр("Владелец", Номенклатура);
		Выборка = Запрос.Выполнить().Выбрать();            
		
		Упаковка = ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Упаковка) Тогда
		
		Упаковка = ЗначениеПоУмолчанию;
		
	КонецЕсли;
	
КонецПроцедуры

