// Процедура, выполняет формирование блока цен.
//
Процедура СформироватьБлокЦен()	
		
	// . Удаляем элементы ранее созданные.
	Для Каждого СтрокаДанных из ТаблицаЦенНоменклатуры Цикл
		ИДСтрокиДанных = СтрокаДанных.ПолучитьИдентификатор();
		
		ЗаголовокЦены = Элементы.Найти("_ЗаголовокЦены_" + ИДСтрокиДанных);
		Если Не ЗаголовокЦены = Неопределено Тогда
			Элементы.Удалить(ЗаголовокЦены);			
		КонецЕсли;
		
		Элементы.Удалить(Элементы["_ВидЦен_"     + ИДСтрокиДанных]);
		Элементы.Удалить(Элементы["_Цена_"       + ИДСтрокиДанных]);
		Элементы.Удалить(Элементы["_ИсторияЦен_" + ИДСтрокиДанных]);
		
	КонецЦикла;		
	
	// Добавлено для БЕСПЛАТНО
	Элементы.ГруппаБесплатно.ЦветФона = ?(Объект.Бесплатно, Новый Цвет(135,206,250), Новый Цвет());
	Элементы.ГруппаПриПродаже.Видимость = НЕ Объект.Бесплатно;
	Элементы.ГруппаЦеныДобавить.Видимость = НЕ Объект.Бесплатно;      
		
	ТаблицаЦенНоменклатуры.Очистить();
	
	// Если услуга бесплатная, то мы не выводим блок цен.
	Если Объект.Бесплатно Тогда
		Возврат;
	КонецЕсли;  
	
	ТаблицаЦенНоменклатуры.Загрузить(РегистрыСведений.ЦеныНоменклатуры.ПолучитьЦеныНомеклатуры(Объект.Ссылка,,,ТекущаяДата(),, Ложь));
	
	НомерСтроки = 0;
	ЗаголовокЦены = ""; 
	Для Каждого СтрокаДанных из ТаблицаЦенНоменклатуры Цикл
		ИДСтрокиДанных = СтрокаДанных.ПолучитьИдентификатор();  		
		ГруппаНовыхЭл = Элементы.Найти("_ГруппаСтрокаЦены_" + ИДСтрокиДанных);
		Если ГруппаНовыхЭл = Неопределено Тогда		
			ГруппаНовыхЭл                      = Элементы.Вставить("_ГруппаСтрокаЦены_" + ИДСтрокиДанных, Тип("ГруппаФормы"), Элементы.Группа_Лаборатория_Скидки, Элементы.ГруппаЦеныДобавить);
			ГруппаНовыхЭл.Вид                  = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаНовыхЭл.Группировка          = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаНовыхЭл.Отображение          = ОтображениеОбычнойГруппы.Нет;
			ГруппаНовыхЭл.ОтображатьЗаголовок  = Ложь;
		КонецЕсли;		
		
		ПолеНовогоЭлемента                          = Элементы.Добавить("_ВидЦен_" + ИДСтрокиДанных, Тип("ДекорацияФормы"), ГруппаНовыхЭл);
		ПолеНовогоЭлемента.Заголовок            = "" + СтрокаДанных.ВидЦен + ?(ЗначениеЗаполнено(СтрокаДанных.Упаковка), " (" + СтрокаДанных.Упаковка + ")", "");
		
		ПолеНовогоЭлемента.АвтоМаксимальнаяШирина   = Ложь;
		ПолеНовогоЭлемента.РастягиватьПоГоризонтали = Истина;
		ПолеНовогоЭлемента.МаксимальнаяШирина 	    = 39;		
		
		ПолеНовогоЭлемента                          = Элементы.Добавить("_Цена_" + ИДСтрокиДанных, Тип("ПолеФормы"), ГруппаНовыхЭл);													 
		ПолеНовогоЭлемента.Вид                      = ВидПоляФормы.ПолеВвода;
		ПолеНовогоЭлемента.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеНовогоЭлемента.Ширина                   = 9;
		ПолеНовогоЭлемента.КнопкаВыбора             = Ложь;
		ПолеНовогоЭлемента.РастягиватьПоГоризонтали = Ложь;
		ПолеНовогоЭлемента.ПутьКДанным              = "ТаблицаЦенНоменклатуры[" + НомерСтроки +"].Цена";
		ПолеНовогоЭлемента.УстановитьДействие("ПриИзменении", "ЦенаПриИзменении");
		
		ПолеНовогоЭлемента                          = Элементы.Добавить("_ИсторияЦен_" + ИДСтрокиДанных, Тип("ДекорацияФормы"), ГруппаНовыхЭл);
		ПолеНовогоЭлемента.Заголовок                = Нстр("ru = 'История'; en = 'History'");
		ПолеНовогоЭлемента.Гиперссылка              = Истина;
		ПолеНовогоЭлемента.УстановитьДействие("Нажатие", "ИсторияИзмененияЦеныНажатие");
		
		НомерСтроки = НомерСтроки + 1;      
				
	КонецЦикла;  	
			
КонецПроцедуры

