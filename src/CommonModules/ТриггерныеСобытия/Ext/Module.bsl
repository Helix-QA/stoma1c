// Функция - Получить данные события пациент регистрация
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПациентРегистрация(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		Запрос.УстановитьПараметр("ТриггерноеСобытие"		, ДанныеТриггера.ТриггерноеСобытие);		
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(СправочникКонтрагенты.Ссылка КАК Справочник.Контрагенты) КАК Контрагент,
		|	СправочникКонтрагенты.Ссылка КАК ОбъектСобытия,
		|	ВЫРАЗИТЬ(СправочникКонтрагенты.СтруктурнаяЕдиница КАК Справочник.СтруктурныеЕдиницы) КАК СтруктурнаяЕдиница,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ПОМЕСТИТЬ ТаблицаКонтрагентов
		|ИЗ
		|	Справочник.Контрагенты КАК СправочникКонтрагенты
		|ГДЕ
		|	СправочникКонтрагенты.Ссылка = &Контрагент
		|	И СправочникКонтрагенты.ЭтоГруппа = ЛОЖЬ
		|	И СправочникКонтрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		|	И СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)
		|	И СправочникКонтрагенты.ПометкаУдаления = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	СправочникКонтрагенты.Ссылка,
		|	ВЫРАЗИТЬ(СправочникКонтрагенты.СтруктурнаяЕдиница КАК Справочник.СтруктурныеЕдиницы),
		|	ВЫРАЗИТЬ(СправочникКонтрагенты.Ссылка КАК Справочник.Контрагенты)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ РеестрОтработанных
		|ИЗ
		|	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|ГДЕ
		|	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
		|	И ЖурналРегистрацииТриггерныхСобытий.Контрагент В
		|			(ВЫБРАТЬ
		|				ТаблицаКонтрагентов.Контрагент
		|			ИЗ
		|				ТаблицаКонтрагентов)
		|	И ЖурналРегистрацииТриггерныхСобытий.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаКонтрагентов.Контрагент КАК Контрагент,
		|	ТаблицаКонтрагентов.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаКонтрагентов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаКонтрагентов.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	ТаблицаКонтрагентов.РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаКонтрагентов КАК ТаблицаКонтрагентов
		|ГДЕ
		|	НЕ ТаблицаКонтрагентов.Контрагент В
		|				(ВЫБРАТЬ
		|					РеестрОтработанных.Контрагент
		|				ИЗ
		|					РеестрОтработанных)";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)",
			"СправочникКонтрагенты.Ссылка В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если РегистрацияПоПодписке Тогда 
			Запрос.УстановитьПараметр("Контрагент"			, ОбъектСобытия);
		ИначеЕсли РегистрацияЗапланированных Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СправочникКонтрагенты.Ссылка = &Контрагент", "СправочникКонтрагенты.Ссылка В(&МассивКонтрагентов)");
			Запрос.УстановитьПараметр("МассивКонтрагентов"	, ДанныеТриггера.МассивНеобработанныхКонтрагентов);
		КонецЕсли;	
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		Запрос.УстановитьПараметр("ТриггерноеСобытие"		, ДанныеТриггера.ТриггерноеСобытие);		
		Запрос.УстановитьПараметр("ДатаТриггера"			, ПолучитьДатуТриггера(ДанныеТриггера));
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
		|ИЗ
		|	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|ГДЕ
		|	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
		|	И ЖурналРегистрацииТриггерныхСобытий.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СправочникКонтрагенты.Ссылка КАК Контрагент,
		|	СправочникКонтрагенты.Ссылка КАК ОбъектСобытия,
		|	СправочникКонтрагенты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	Справочник.Контрагенты КАК СправочникКонтрагенты
		|ГДЕ
		|	СправочникКонтрагенты.ЭтоГруппа = ЛОЖЬ
		|	И СправочникКонтрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		|	И НАЧАЛОПЕРИОДА(СправочникКонтрагенты.ДатаРегистрации, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		|	И СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)
		|	И СправочникКонтрагенты.ПометкаУдаления = ЛОЖЬ
		|	И НЕ СправочникКонтрагенты.Ссылка В
		|				(ВЫБРАТЬ
		|					ТаблицаОтработанныхКонтрагентов.Контрагент
		|				ИЗ
		|					ТаблицаОтработанныхКонтрагентов)
		|
		|СГРУППИРОВАТЬ ПО
		|	СправочникКонтрагенты.Ссылка,
		|	СправочникКонтрагенты.СтруктурнаяЕдиница,
		|	СправочникКонтрагенты.Ссылка";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)",
			"СправочникКонтрагенты.Ссылка В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
				
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события день рождения клиента
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  РегистрацияПоПодписке	 - 	 - 
//  ОбъектСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ДеньРожденияПациента(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СправочникКонтрагенты.Ссылка КАК Контрагент,
		|	СправочникКонтрагенты.Ссылка КАК ОбъектСобытия,
		|	СправочникКонтрагенты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	Справочник.Контрагенты КАК СправочникКонтрагенты
		|ГДЕ
		|	СправочникКонтрагенты.ЭтоГруппа = ЛОЖЬ
		|	И СправочникКонтрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		|	И СправочникКонтрагенты.ДатаРожденияКлиента <> ДАТАВРЕМЯ(1, 1, 1)
		|	И МЕСЯЦ(СправочникКонтрагенты.ДатаРожденияКлиента) = МЕСЯЦ(&ДатаТриггера)
		|	И ДЕНЬ(СправочникКонтрагенты.ДатаРожденияКлиента) = ДЕНЬ(&ДатаТриггера)
		|	И СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)
		|	И СправочникКонтрагенты.ПометкаУдаления = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	СправочникКонтрагенты.Ссылка,
		|	СправочникКонтрагенты.СтруктурнаяЕдиница,
		|	СправочникКонтрагенты.Ссылка";
				
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)",
			"СправочникКонтрагенты.Ссылка В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СправочникКонтрагенты.Ссылка В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события клиент смена статуса
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПациентСменаСтатуса(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);	
	Запрос.УстановитьПараметр("ТриггерноеСобытие"			, ДанныеТриггера.ТриггерноеСобытие);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ЗАПЛАНИРОВАННЫХ_ИЛИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("Контрагент"			, ОбъектСобытия.Контрагент);
		Запрос.УстановитьПараметр("ДатаТриггера"		, ОбъектСобытия.Период);
		Запрос.Текст = "ВЫБРАТЬ
		               |	СтатусыКонтрагентов.Период КАК Период,
		               |	СтатусыКонтрагентов.Контрагент КАК Контрагент,
		               |	СтатусыКонтрагентов.Статус КАК Статус
		               |ПОМЕСТИТЬ ТаблицаКонтрагентовСменившихСтатус
		               |ИЗ
		               |	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
		               |ГДЕ
		               |	СтатусыКонтрагентов.Период = &ДатаТриггера
		               |	И СтатусыКонтрагентов.Контрагент = &Контрагент
		               |	И СтатусыКонтрагентов.Контрагент В(&СегментКонтрагентов)
		               |	И СтатусыКонтрагентов.Статус = &ПереходНаСтатус
		               |	И НЕ СтатусыКонтрагентов.Контрагент.ОбезличенныйКлиент
		               |	И СтатусыКонтрагентов.Контрагент.ПометкаУдаления = ЛОЖЬ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
		               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК Статус
		               |ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
		               |ИЗ
		               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		               |ГДЕ
		               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
		               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент = &Контрагент
		               |	И ЖурналРегистрацииТриггерныхСобытий.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
		               |	И НАЧАЛОПЕРИОДА(ЖурналРегистрацииТриггерныхСобытий.Период, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент,
		               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаКонтрагентовСменившихСтатус.Период КАК Период,
		               |	ТаблицаКонтрагентовСменившихСтатус.Контрагент КАК Контрагент,
		               |	ТаблицаКонтрагентовСменившихСтатус.Статус КАК Статус
		               |ПОМЕСТИТЬ ТаблицаНеОтработанныхКонтрагентов
		               |ИЗ
		               |	ТаблицаКонтрагентовСменившихСтатус КАК ТаблицаКонтрагентовСменившихСтатус
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхКонтрагентов КАК ТаблицаОтработанныхКонтрагентов
		               |		ПО ТаблицаКонтрагентовСменившихСтатус.Контрагент = ТаблицаОтработанныхКонтрагентов.Контрагент
		               |			И ТаблицаКонтрагентовСменившихСтатус.Статус = ТаблицаОтработанныхКонтрагентов.Статус
		               |ГДЕ
		               |	ТаблицаОтработанныхКонтрагентов.Контрагент ЕСТЬ NULL
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	СтатусыКонтрагентов.Период КАК Период,
		               |	СтатусыКонтрагентов.Контрагент КАК Контрагент,
		               |	СтатусыКонтрагентов.Статус КАК Статус
		               |ПОМЕСТИТЬ ТаблицаИсторииСтатусов
		               |ИЗ
		               |	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
		               |ГДЕ
		               |	СтатусыКонтрагентов.Контрагент = &Контрагент
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
