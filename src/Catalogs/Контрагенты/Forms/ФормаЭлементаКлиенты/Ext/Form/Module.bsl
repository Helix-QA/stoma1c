// Функция - Установить обязательные динам поля
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОбязательныеДинамПоля()
	
	СтруктураОбязательныхДинамПолей = Новый Структура();
	СтруктураОбязательныхДинамПолей.Вставить("ФлагТелефон", Ложь);
	СтруктураОбязательныхДинамПолей.Вставить("ФлагEmail"  , Ложь);
	СтруктураОбязательныхДинамПолей.Вставить("ФлагАдрес"  , Ложь);
	
	СтруктураОбязательныеПоля = ВернутьЗначКонстантыОбязПоля();
	
	Если СтруктураОбязательныеПоля <> Неопределено Тогда
		
		Для Каждого ОбязательноеПоле Из СтруктураОбязательныеПоля Цикл
			
			Если ОбязательноеПоле.Значение = Истина Тогда
				
				Если ОбязательноеПоле.Ключ = "КЛИЕНТ_ПредставлениеКИ_0" Тогда
					СтруктураОбязательныхДинамПолей.ФлагТелефон = Истина;
				ИначеЕсли ОбязательноеПоле.Ключ = "КЛИЕНТ_ПредставлениеКИ_1" Тогда
					СтруктураОбязательныхДинамПолей.ФлагEmail   = Истина;
				ИначеЕсли ОбязательноеПоле.Ключ = "КЛИЕНТ_ПредставлениеКИ_2" Тогда
					СтруктураОбязательныхДинамПолей.ФлагАдрес   = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СтруктураОбязательныхДинамПолей;
	
КонецФункции

&НаКлиенте
// Функция - Проверить обязательные динам поля
//
// Параметры:
//  Элемент						 - 	 - 
//  СтруктураФлаговДинамПолей	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьОбязательныеДинамПоля(Элемент, СтруктураФлаговДинамПолей)
	
	Если СтруктураФлаговДинамПолей = Неопределено Тогда
		СтруктураФлаговДинамПолей = СоздатьОбнуленнуюСтруктуруФлаговДинамПолей();
	КонецЕсли;
	
	Попытка
		ИДСтроки = Число(СтрРазделить(Элемент.Имя, "_")[1]);
		ТипКИ    = ЭтаФорма.КонтактнаяИнформация[ИДСтроки].Тип;
	Исключение
		Возврат СтруктураФлаговДинамПолей;
	КонецПопытки;
	
	Если ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон") Тогда 
		
		Если СтруктураФлаговДинамПолей.ХотяБыОдинТелефон = Ложь Тогда
			СтруктураФлаговДинамПолей.ХотяБыОдинТелефон  = ЗначениеЗаполнено(Элемент.ТекстРедактирования);
		КонецЕсли;
		
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты") Тогда 
		
		Если СтруктураФлаговДинамПолей.ХотяБыОдинEmail = Ложь Тогда
			СтруктураФлаговДинамПолей.ХотяБыОдинEmail  = ЗначениеЗаполнено(Элемент.ТекстРедактирования);
		КонецЕсли;
		
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес") Тогда 
		
		Если СтруктураФлаговДинамПолей.ХотяБыОдинАдрес = Ложь Тогда
			СтруктураФлаговДинамПолей.ХотяБыОдинАдрес  = ЗначениеЗаполнено(Элемент.ТекстРедактирования);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СтруктураФлаговДинамПолей;
	
КонецФункции

&НаКлиенте
