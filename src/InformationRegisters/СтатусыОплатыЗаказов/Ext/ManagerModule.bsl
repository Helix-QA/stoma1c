// Функция - Получить не оплаченные заказы по документу
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНеОплаченныеЗаказыПоДокументу(Основание = Неопределено, НомерЗаказа = Неопределено, ЭквайринговыйТерминал = Неопределено) Экспорт
	
	МассивЗаказов = Новый Массив;	
	Если ЗначениеЗаполнено(НомерЗаказа) Тогда
		МассивЗаказов.Добавить(НомерЗаказа);
		Цифры = "0123456789";
		Если ОбщегоНазначенияКлиентСервер.СтрокаСодержитТолькоДопустимыеСимволы(НомерЗаказа, Цифры) Тогда			
			МассивЗаказов.Добавить(Число(НомерЗаказа));
		КонецЕсли;
	КонецЕсли;
	
	МассивОснований = Новый Массив;
	Если ТипЗнч(Основание) = Тип("Массив") Тогда
		МассивОснований = Основание;
	ИначеЕсли Основание <> Неопределено Тогда 		
		МассивОснований.Добавить(Основание);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.Сумма КАК Сумма,
	|	СтатусыОплатыЗаказов.СсылкаОплаты КАК СсылкаОплаты,
	|	СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки КАК ДатаОкончанияДействияСсылки,
	|	СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа КАК ДатаРегистрацииЗаказа,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
	|	СтатусыОплатыЗаказов.Основание КАК Основание,
	|	СтатусыОплатыЗаказов.ТипСсылкиНаОплату КАК ТипСсылкиНаОплату,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка КАК ТипБанка,
	|	СтатусыОплатыЗаказов.Основание КАК ДокументЗадолженности,
	|	СтатусыОплатыЗаказов.Сумма КАК Задолженность,
	|	СтатусыОплатыЗаказов.Контрагент КАК Контрагент,
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)
	|	И &УсловиеНомерЗаказа
	|	И &УсловиеОснованиеЗаказа
	|	И &УсловиеЭквайринговыйТерминал");
	
	УсловиеНомерЗаказа = ?(ЗначениеЗаполнено(НомерЗаказа), "И СтатусыОплатыЗаказов.НомерЗаказа В (&МассивЗаказов)", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеНомерЗаказа", УсловиеНомерЗаказа);
	
	УсловиеОснованиеЗаказа = ?(ЗначениеЗаполнено(Основание), "И СтатусыОплатыЗаказов.Основание В (&МассивОснований)", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеОснованиеЗаказа", УсловиеОснованиеЗаказа);
	
	УсловиеЭквайринговыйТерминал = ?(ЗначениеЗаполнено(ЭквайринговыйТерминал), "И СтатусыОплатыЗаказов.ЭквайринговыйТерминал = &ЭквайринговыйТерминал", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеЭквайринговыйТерминал", УсловиеЭквайринговыйТерминал);
	
	Запрос.УстановитьПараметр("МассивОснований"	 		, МассивОснований);
	Запрос.УстановитьПараметр("ТекущаяДата"	 			, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("МассивЗаказов"			, МассивЗаказов);
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал"	, ЭквайринговыйТерминал);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Заказ актуален по входным документам
//
// Параметры:
//  СписокДокументов - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСсылкуНаОплату(СписокДокументов, ЭквайринговыйТерминал) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.Наименование КАК ЭквайринговыйТерминал,
	|	СтатусыОплатыЗаказов.ТипСсылкиНаОплату КАК ТипСсылкиНаОплату,
	|	СтатусыОплатыЗаказов.СсылкаОплаты КАК СсылкаОплаты,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал КАК СсылкаЭТ,
	|	СтатусыОплатыЗаказов.Основание КАК Основание,
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Основание В(&СписокДокументов)
	|	И ВЫБОР
	|			КОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки > &ТекущаяДата
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)");
	
	Запрос.УстановитьПараметр("СписокДокументов"		, СписокДокументов);
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДатаСеанса());
    Запрос.УстановитьПараметр("ЭквайринговыйТерминал"	, ЭквайринговыйТерминал);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка, Неопределено); 
	
КонецФункции

