//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура СотрудникНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда 
		
		Объект[Параметры.Сотрудник] = Результат;
		Объект[Параметры.Должность] = ПолучитьДолжность(Результат);  

	КонецЕсли;

