// Процедура - Удалить из избранного.
//
// Параметры:
//  СтрокаТЗ	 - 	 - 
//  Контрагент	 - 	 - 
//
Процедура УдалитьИзИзбранного(СтрокаТЗ, Заявка);

	МенеджерЗаписи = РегистрыСведений.ЗакрепленныеВзаимодействия.СоздатьМенеджерЗаписи();		
	
	Если СтрокаТЗ.ТипСобытия = "Заметка" Тогда
		МенеджерЗаписи.ВзаимодействиеИд = Новый УникальныйИдентификатор(СтрокаТЗ.ВзаимодействиеИд);
	Иначе
		МенеджерЗаписи.Взаимодействие = СтрокаТЗ.Взаимодействие;
	КонецЕсли;
	
	МенеджерЗаписи.Контрагент = Заявка;
	
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		МенеджерЗаписи.Удалить();	
	КонецЕсли;
	
КонецПроцедуры	

