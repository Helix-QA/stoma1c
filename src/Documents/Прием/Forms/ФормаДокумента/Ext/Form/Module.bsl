// Процедура - Обработчик события "ПриАктивацииСтроки"
//
Процедура ПодаркиПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.Подарки.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда
		
		Если ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
			
			// Если Не ЭтотОбъект.ДокументЗаблокирован Тогда
				
				РеквизитыНоменклатуры = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(
																		ТекущиеДанные.Номенклатура, 
																		"ТипНоменклатуры, ВидНоминала");
				
				Если РеквизитыНоменклатуры.ТипНоменклатуры = Предопределенноезначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат")
					И РеквизитыНоменклатуры.ВидНоминала = Истина Тогда
					
					Элементы.ПодаркиСуммаПодарочногоСертификата.ТолькоПросмотр = ЗначениеЗаполнено(Объект.НомерЧекаККМ);
					Элементы.ПодаркиСуммаПодарочногоСертификата.Доступность    = Истина;
				КонецЕсли;
				
			// КонецЕсли;
					
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

