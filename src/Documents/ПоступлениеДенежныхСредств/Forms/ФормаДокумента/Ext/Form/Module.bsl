&НаСервереБезКонтекста
// Функция - Получить ссылку документа списания по отмене ошибочной оплаты
//
// Параметры:
//  СылкаПоступления - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСсылкуДокументаСписанияПоОтменеОшибочнойОплаты(СылкаПоступления)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.ОснованиеДополнительное = &Основание
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту)
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен = ИСТИНА");
	
	Запрос.УстановитьПараметр("Основание", СылкаПоступления);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

