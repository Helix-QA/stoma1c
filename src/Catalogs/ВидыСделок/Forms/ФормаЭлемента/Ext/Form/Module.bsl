// Процедура - Переключатель поле список
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПереключательПолеСписок(Команда)
	
	Если РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле" Тогда 
		РежимОтображенияСпискаСтруктурныхЕдиниц = "Список";
		МассивПустыхСтрок = Объект.СтруктурныеЕдиницыПрименения.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка")));
		Для Каждого ПустаяСтрока Из МассивПустыхСтрок Цикл 
			Объект.СтруктурныеЕдиницыПрименения.Удалить(Объект.СтруктурныеЕдиницыПрименения.Индекс(ПустаяСтрока));
		КонецЦикла;	
	Иначе 
		Если Объект.СтруктурныеЕдиницыПрименения.Количество() = 0 Тогда
			НоваяСтрока = Объект.СтруктурныеЕдиницыПрименения.Добавить();
		ИначеЕсли Объект.СтруктурныеЕдиницыПрименения.Количество() > 1 Тогда
			ОписаниеОповещенияВопроса = Новый ОписаниеОповещения("ПредупреждениеКлиникиПримененияОчистятся", ЭтотОбъект);
			ПоказатьВопрос(ОписаниеОповещенияВопроса, "Внимание!" + Символы.ПС + "Указанный список клиник очистится." + Символы.ПС + "Продолжить?", РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, "Вопрос пользователю");
			Возврат;
		КонецЕсли;
		РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле";		
		Объект.СтруктурныеЕдиницыПрименения[0].СтруктурнаяЕдиница = ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка");
	КонецЕсли;	
	
	УстановитьВидимостьЭлементамСпискаСтруктурныхЕдиниц();

КонецПроцедуры

