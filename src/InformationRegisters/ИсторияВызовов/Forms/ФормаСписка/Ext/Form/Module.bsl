// Процедура - Установить отбор по периоду
//
Процедура УстановитьОтборПоПериоду(Знач СозданиеНаСервере = Ложь)
	
	// Сформируем текст периода
	КомандаВыбораПериода = ЭтаФорма.Команды.Найти("Отбор_Период");
	
	Если ОтборПериод.ДатаНачала = Дата(1,1,1) И ОтборПериод.ДатаОкончания = Дата(1,1,1) Тогда 
		Элементы.ВыбратьПериод.Заголовок = "За весь период";//"< Период не указан >";
		//Элементы.ГруппаДляКнопкиПериода.ЦветФона = Новый Цвет(240, 240, 240);
		Если НЕ КомандаВыбораПериода = Неопределено Тогда 
			КомандаВыбораПериода.Подсказка = "Щелкните для выбора периода истории звонков";
		КонецЕсли;	
	Иначе
		//Элементы.ГруппаДляКнопкиПериода.ЦветФона = Новый Цвет(188, 231, 201);		
		Если ОтборПериод.Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда
			Если НачалоДня(ОтборПериод.ДатаНачала) = НачалоДня(ОтборПериод.ДатаОкончания) Тогда 
				Элементы.ВыбратьПериод.Заголовок = Формат(ОтборПериод.ДатаНачала, "ДФ='дддд'','' д ММММ гггг'");
			Иначе 	
				Элементы.ВыбратьПериод.Заголовок = ?(ЗначениеЗаполнено(ОтборПериод.ДатаНачала), Формат(ОтборПериод.ДатаНачала, "ДФ=dd.MM.yy"), "не огранич.") + " - " + ?(ЗначениеЗаполнено(ОтборПериод.ДатаОкончания), Формат(ОтборПериод.ДатаОкончания, "ДФ=dd.MM.yy"), "не огранич.");
			КонецЕсли;	
		Иначе 
			Элементы.ВыбратьПериод.Заголовок = Строка(ОтборПериод.Вариант);
		КонецЕсли;
		Если НЕ КомандаВыбораПериода = Неопределено Тогда 
			КомандаВыбораПериода.Подсказка = Элементы.ВыбратьПериод.Заголовок;
		КонецЕсли;			
	КонецЕсли;	
	
	// Установим отбор по периоду
	ОтборыСписковКлиентСервер.УстановитьДиапазонДатДляСписка(Список, "НачалоВызова", ОтборПериод.ДатаНачала, ОтборПериод.ДатаОкончания, Истина);
	
	Если СозданиеНаСервере = Ложь Тогда 
		АктуализироватьКоличествоНеОбработанныхЗвонков();
	КонецЕсли;
	
КонецПроцедуры

