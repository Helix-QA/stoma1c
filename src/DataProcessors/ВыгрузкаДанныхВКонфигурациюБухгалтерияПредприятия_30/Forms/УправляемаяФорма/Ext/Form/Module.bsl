&НаКлиенте
Процедура НаКлиенте(Команда)
	
	Если Не ЭтоКлиент Тогда
		
		ЭтоКлиент = Истина;
		ИзменитьРежимОбработки(ЭтоКлиент);
		мМакет = ВыполнитьАвтоматическуюЗагрузкуПравилОбмена();   	
		мУникальныйИдентификатор       = Новый УникальныйИдентификатор();
		ИмяВременногоФайлаПравилОбмена = КаталогВременныхФайлов() + мУникальныйИдентификатор + ".xml";
		мМакет.Записать(ИмяВременногоФайлаПравилОбмена);
		ИмяФайлаПравил = ИмяВременногоФайлаПравилОбмена;
		Объект.ИмяФайлаПравилОбмена = ИмяФайлаПравил;
		ПрочитатьПравилаОбмена(Неопределено);
		
	КонецЕсли;
	
