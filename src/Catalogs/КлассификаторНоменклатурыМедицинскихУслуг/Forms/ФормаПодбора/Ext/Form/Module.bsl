// Процедура, выполняет заполнение таблицы номенклатруры.
//
Процедура ЗаполнитьТаблицуНоменклатуры(Родитель) 
	
	ДанныеДерева = Родитель.ПолучитьЭлементы();	
	
	Для Каждого СтрокаДерева из ДанныеДерева Цикл		
		Если СтрокаДерева.ЭтоГруппа Тогда
			ЗаполнитьТаблицуНоменклатуры(СтрокаДерева);
		Иначе
			ЗаполнитьСтрокуТаблицыНоменклатуры(СтрокаДерева);	
		КонецЕсли;
	КонецЦикла;   
	
КонецПроцедуры

