// Процедура, Обработчик события "ДекорацияПЗНаСледующийприемНажатие"
//
Процедура ДекорацияПЗНаСледующийприемНажатие(Элемент)

	Если Объект.Ссылка.Пустая() Тогда
		//ОповещениеДляВопроса = Новый ОписаниеОповещения("ПослеВопросаЗавершение", ЭтотОбъект);
		//ПоказатьВопрос(ОповещениеДляВопроса, "Данные ещё не записаны. Записать?", РежимДиалогаВопрос.ДаНет); 
		ЭтаФорма.Записать(Новый Структура("РежимЗаписи",РежимЗаписиДокумента.Запись)); 
		ЭтаФорма.Модифицированность = Истина;
	КонецЕсли;
	//Иначе 
	ФормаПовторныйПриемИспользовать = Истина;
	// Если предварительная запись еще не создана откр. форму создания
	Если НЕ ЗначениеЗаполнено(Объект.ПредварительнаяЗаписьНаСледующийПрием) Тогда  
		ПодготовитьДанныеДляЗаписиВРегистр(Ложь);
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Контрагент"              , Объект.Контрагент);
		ПараметрыФормы.Вставить("Сотрудник"               , Объект.Сотрудник);
		ПараметрыФормы.Вставить("ПереключательПериода"    , ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Неделя"));
		ПараметрыФормы.Вставить("ЗакрытьПриСозданииЗаписи", Истина);
		ПараметрыФормы.Вставить("Дата", ВернутьДатуСледующегоПриемаПриОкончании(Объект.Дата, ЭтотОбъект.ФормаПовторныйПриемИнтервал, ЭтотОбъект.ФормаИнтервалПередПриемом));

		ФормаЗаписи        = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыФормы, "ФормаПредварительнойЗаписи");
		ОписаниеОповещения = Новый ОписаниеОповещения("ДекорацияПЗНаСледующийПриемНажатиеЗавершение", ЭтотОбъект); 	
		ОткрытьФорму(ФормаЗаписи, ПараметрыФормы,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	Иначе
		// Если предварительная запись создана открываем форму документа
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Объект.ПредварительнаяЗаписьНаСледующийПрием));
	КонецЕсли;
	//КонецЕсли;
	
КонецПроцедуры  

