Процедура ОбработкаЗакрытияФормыНачалаРаботы(ЗначенияРеквизитов, ПараметрыНачалаРаботы, ОбработкаЗавершена) Экспорт
	
	ПараметрыРаботыКлиента = ПараметрыНачалаРаботы.ПараметрыРаботыКлиента;
	
	ОбновитьПользователяИДругиеДанные(ЗначенияРеквизитов, ПараметрыРаботыКлиента);
	
	//ВыполнитьЗаполнениеПоВидуБизнеса(ЗначенияРеквизитов, ПараметрыРаботыКлиента);
	
	//ОбновитьЗаписатьОрганизации(ЗначенияРеквизитов, ПараметрыРаботыКлиента);
		
	ЗафиксироватьОкончаниеПервогоВходаВПрограмму();
	
	ОбработкаЗавершена = Истина;
	
КонецПроцедуры

#Область ПользователиИКонтактнаяИнформация

// Дублируем метод из УправлениеКонтактнойИнформацией
Процедура ЗаполнитьРеквизитыТабличнойЧастиДляАдресаЭлектроннойПочты(СтрокаТабличнойЧасти, Источник)
	
	Результат = ОбщегоНазначенияКлиентСервер.РазобратьСтрокуСПочтовымиАдресами(СтрокаТабличнойЧасти.Представление, Ложь);
	
	Если Результат.Количество() > 0 Тогда
		СтрокаТабличнойЧасти.АдресЭП = Результат[0].Адрес;
		
		Поз = СтрНайти(СтрокаТабличнойЧасти.АдресЭП, "@");
		Если Поз <> 0 Тогда
			СтрокаТабличнойЧасти.ДоменноеИмяСервера = Сред(СтрокаТабличнойЧасти.АдресЭП, Поз+1);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьПользователяИДругиеДанные(ЗначенияРеквизитов, ПараметрыРаботыКлиента)
	Перем ПользовательСсылка;
	
	Если НЕ ЗначенияРеквизитов.Свойство("Пользователь", ПользовательСсылка)
		ИЛИ НЕ ЗначениеЗаполнено(ПользовательСсылка) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	НачатьТранзакцию(); 
	
	СотрудникОбъект = Справочники.Сотрудники.СоздатьЭлемент();
	
	// Доступно только в локальном режиме
	СотрудникОбъект.Наименование = ЗначенияРеквизитов.ПользовательИмя;
	
	ОписаниеПользователяИБ = Новый Структура;
	ОписаниеПользователяИБ.Вставить("Действие",					"Записать");
	ОписаниеПользователяИБ.Вставить("Имя",						ЗначенияРеквизитов.ПользовательИмя);
	ОписаниеПользователяИБ.Вставить("ПолноеИмя",				ЗначенияРеквизитов.ПользовательИмя);   
	
	ДоступныеРоли = Новый Массив;
	ДоступныеРоли.Добавить(Метаданные.Роли.ПолныеПрава.Имя);
	
	Если НЕ ПараметрыРаботыКлиента.РазделениеВключено Тогда
		
		ОписаниеПользователяИБ.Вставить("Пароль", 					ЗначенияРеквизитов.ПользовательПароль);
		ОписаниеПользователяИБ.Вставить("АутентификацияСтандартная",Истина);
		ОписаниеПользователяИБ.Вставить("ПарольУстановлен", 		Истина);
		ОписаниеПользователяИБ.Вставить("ПоказыватьВСпискеВыбора",	Истина);
		
		ДоступныеРоли.Добавить(Метаданные.Роли.АдминистраторСистемы.Имя);
		//ДоступныеРоли.Добавить(Метаданные.Роли.ИспользованиеЛичногоКабинета.Имя);
		
	КонецЕсли;
	
	ОписаниеПользователяИБ.Вставить("Роли", ДоступныеРоли);
	
	СотрудникОбъект.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", ОписаниеПользователяИБ);
	СотрудникОбъект.ДополнительныеСвойства.Вставить("СозданиеАдминистратора", НСтр("ru = 'Создание первого администратора.'"));
	СотрудникОбъект.Роль = Перечисления.РольПользователя.АдминистраторБазыДанных;
	//ПользовательОбъект.Служебный = Ложь;
	//ПользовательОбъект.ЭтоПользовательИБ = Истина;
	СотрудникОбъект.ИдентификаторПользователяИБ = Новый УникальныйИдентификатор();
	СотрудникОбъект.Имя = ЗначенияРеквизитов.ПользовательИмя;
	
	Если НЕ ПустаяСтрока(ЗначенияРеквизитов.ПользовательEmail) Тогда
		
		ВидКИ = Справочники.ВидыКонтактнойИнформации.EmailПользователя;
		
		МассивСтрок = СотрудникОбъект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКИ));
		
		СтрокаКИ = ?(МассивСтрок.Количество() = 0,СотрудникОбъект.КонтактнаяИнформация.Добавить(), МассивСтрок[0]);
		СтрокаКИ.Вид = ВидКИ;
		СтрокаКИ.Представление = ЗначенияРеквизитов.ПользовательEmail;		
		СтрокаКИ.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияXMLПоПредставлению(СтрокаКИ.Представление, СтрокаКИ.Вид);
		СтрокаКИ.Значение = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(СтрокаКИ.Представление, СтрокаКИ.Вид);
		СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		
		ЗаполнитьРеквизитыТабличнойЧастиДляАдресаЭлектроннойПочты(СтрокаКИ, СотрудникОбъект);
		
	КонецЕсли;
	
		
	Если НЕ ПустаяСтрока(ЗначенияРеквизитов.ПользовательТелефон) Тогда
		
		ВидКИ = Справочники.ВидыКонтактнойИнформации.ТелефонПользователя;
		
		МассивСтрок = СотрудникОбъект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКИ));
		
		СтрокаКИ = ?(МассивСтрок.Количество() = 0,СотрудникОбъект.КонтактнаяИнформация.Добавить(), МассивСтрок[0]);
		СтрокаКИ.Вид = ВидКИ;
		СтрокаКИ.Представление = ЗначенияРеквизитов.ПользовательТелефон;		
		СтрокаКИ.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияXMLПоПредставлению(СтрокаКИ.Представление, СтрокаКИ.Вид);
		СтрокаКИ.Значение = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(СтрокаКИ.Представление, СтрокаКИ.Вид);
		СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
		
	КонецЕсли;
	
	ДолжностьДиректора = Справочники.Должности.СоздатьЭлемент();
	ДолжностьДиректора.Наименование = "Директор";
	ДолжностьДиректора.ОтображатьВЖурналеПредварительнойЗаписи = Ложь;
	ДолжностьДиректора.Записать();
		 
	Если ТипЗнч(СотрудникОбъект) = Тип("СправочникОбъект.Сотрудники") И Не ЗначениеЗаполнено(СотрудникОбъект.Должность) Тогда 
		СотрудникОбъект.Должность = ДолжностьДиректора.Ссылка;
	КонецЕсли;
	
	ОсновнаяОрганизация = Справочники.Организации.СоздатьЭлемент();
	
	ОсновнаяОрганизация.Наименование = ЗначенияРеквизитов.НазваниеСалона;
	ОсновнаяОрганизация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая;
	ОсновнаяОрганизация.ОбъектНалогообложения = Перечисления.ОбъектыНалогообложенияПоУСН.Доходы;
	
	ОсновнаяОрганизация.Записать();
	
	ОсновнойСклад = Справочники.Склады.СоздатьЭлемент();
    ОсновнойСклад.Наименование = "Основной склад";
	ОсновнойСклад.Записать();
	
	ОсновнаяКасса = Справочники.Кассы.СоздатьЭлемент();
    ОсновнаяКасса.Наименование = "Основная касса";
	ОсновнаяКасса.ТипКассы = Перечисления.ТипыКасс.ОперационнаяКасса;
	ОсновнаяКасса.ИспользоватьБезПодключенияОборудования = Истина;
	ОсновнаяКасса.Склад = ОсновнойСклад.Ссылка;
	ОсновнаяКасса.Записать();

	// Заполнение структурной единицы, ставки НДС и времени работы.
	ВыборкаСтруктурныхЕдиниц = Справочники.СтруктурныеЕдиницы.Выбрать();
	
	Если ВыборкаСтруктурныхЕдиниц.Следующий() Тогда
		ОсновнаяСтруктурнаяЕдиница = ВыборкаСтруктурныхЕдиниц.ПолучитьОбъект();
	Иначе
		ОсновнаяСтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.СоздатьЭлемент();
	КонецЕсли;
	
	ОсновнаяСтруктурнаяЕдиница.Наименование = ЗначенияРеквизитов.НазваниеСалона;
	ОсновнаяСтруктурнаяЕдиница.Организация = ОсновнаяОрганизация.Ссылка;
	ОсновнаяСтруктурнаяЕдиница.ОсновнаяКасса = ОсновнаяКасса.Ссылка;
	ОсновнаяСтруктурнаяЕдиница.ОсновнойСклад = ОсновнойСклад.Ссылка;
	ОсновнаяСтруктурнаяЕдиница.ВидЦенРеализации = Справочники.ВидыЦен.Розничная;
	
	// Запись расписания дней в табличную часть.
	ОсновнаяСтруктурнаяЕдиница.РасписаниеРаботы.Очистить();
	
	Для ИНД = 1 ПО 7 Цикл
		ДеньД = ОсновнаяСтруктурнаяЕдиница.РасписаниеРаботы.Добавить();
		ДеньД.Активность = Истина;
		ДеньД.ДеньНедели = Дата("2001010"+Строка(ИНД));
		ДеньД.НачалоРаботы = ЗначенияРеквизитов.ВремяНачалаРаботы;
		ДеньД.ОкончаниеРаботы = ЗначенияРеквизитов.ВремяОкончанияРаботы;
	КонецЦикла;                   
		
	//Если ОсновнаяСтруктурнаяЕдиница.РасписаниеРаботы.Количество() = 7 Тогда
	//	СтрокаРасписание = ОсновнаяСтруктурнаяЕдиница.РасписаниеРаботы.Добавить();
	//	СтрокаРасписание.НачалоРаботы    = ЗначенияРеквизитов.ВремяНачалаРаботы;
	//	СтрокаРасписание.ОкончаниеРаботы = ЗначенияРеквизитов.ВремяОкончанияРаботы;
	//КонецЕсли;
	
	ОсновнаяСтруктурнаяЕдиница.Записать();
	
	//ПервыйКабинет = Справочники.Помещения.СоздатьЭлемент();
	//ПервыйКабинет.ОтображатьВРасписанииЗанятий = Истина;
	//ПервыйКабинет.СтруктурнаяЕдиница = ОсновнаяСтруктурнаяЕдиница.Ссылка;
	//ПервыйКабинет.Записать(); 
	
	ОсновнаяКасса.СтруктурнаяЕдиница = ОсновнаяСтруктурнаяЕдиница.Ссылка;
	ОсновнаяКасса.Записать();
	
	ОсновнойСклад.СтруктурнаяЕдиница = ОсновнаяСтруктурнаяЕдиница.Ссылка;
	ОсновнойСклад.Записать();
		
	Если ЗначениеЗаполнено(ЗначенияРеквизитов.СтавкаНДС) Тогда 
		Мета = Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления.Найти("БезНДС");
		СтавкаНДС = Перечисления.СтавкиНДС[СтрЗаменить(ЗначенияРеквизитов.СтавкаНДС, " ", "")];
		ОрганизацияОсновнойСЕ = ОсновнаяСтруктурнаяЕдиница.Организация; 
		Если ЗначениеЗаполнено(ОрганизацияОсновнойСЕ) Тогда 
			ОрганизацияОбъект = ОрганизацияОсновнойСЕ.ПолучитьОбъект();
			ОрганизацияОбъект.СтавкаНДС = СтавкаНДС;
			ОрганизацияОбъект.Записать();
		КонецЕсли;
	КонецЕсли;
	
	// Страна учета
	Если ЗначениеЗаполнено(ЗначенияРеквизитов.СтранаУчета) Тогда
		СтранаУч = Справочники.СтраныМира.НайтиПоНаименованию(ЗначенияРеквизитов.СтранаУчета);
		Если СтранаУч <> Неопределено Тогда			
			СтранаУчета = СтранаУч;
		Иначе
			СтранаУчета = Справочники.СтраныМира.Россия;
		КонецЕсли;
		
		Константы.СтранаУчета.Установить(СтранаУчета);
		
		Константы.ВалютаУчета.Установить(Справочники.Валюты.НайтиПоКоду(Число(СтранаУчета.Код)));
		
	КонецЕсли;	

	ОбновлениеИнформационнойБазы.ЗаписатьОбъект(СотрудникОбъект, Ложь, Истина);
	
	Если ПараметрыРаботыКлиента.РазделениеВключено Тогда
		
		ПользовательCистемы = ПользовательСсылка.ПолучитьОбъект();

	Иначе

		ПользовательCистемы = Справочники.Пользователи.СоздатьЭлемент();
		
	КонецЕсли;
	
	ПользовательCистемы.Наименование = ЗначенияРеквизитов.ПользовательИмя;
	ПользовательCистемы.ИдентификаторПользователяИБ = СотрудникОбъект.ИдентификаторПользователяИБ;
	ПользовательCистемы.РольПользователя = Перечисления.РольПользователя.Руководитель;
	ПользовательCистемы.Сотрудник = СотрудникОбъект.Ссылка;
	ПользовательCистемы.ЭтоПользовательИБ = Истина;
	ПользовательCистемы.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", ОписаниеПользователяИБ);
	ПользовательCистемы.ДополнительныеСвойства.Вставить("СозданиеАдминистратора", НСтр("ru = 'Создание первого администратора.'"));
		
	ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ПользовательCистемы, Ложь, Истина);
	
	Если ПользовательCистемы.ИдентификаторПользователяИБ <> СотрудникОбъект.ИдентификаторПользователяИБ Тогда
		СотрудникОбъект.ИдентификаторПользователяИБ = ПользовательCистемы.ИдентификаторПользователяИБ;
		СотрудникОбъект.Записать();
	КонецЕсли;
	
	Если СотрудникОбъект.ДоступныеСтруктурныеЕдиницы.Количество() = 0 Тогда 
		НаборНастройкиСотрудников = РегистрыСведений.НастройкиСотрудников.СоздатьМенеджерЗаписи();
		НаборНастройкиСотрудников.Сотрудник = СотрудникОбъект.Ссылка; 
		НаборНастройкиСотрудников.СтруктурнаяЕдиница = ОсновнаяСтруктурнаяЕдиница.Ссылка;
		НаборНастройкиСотрудников.Записать();
	КонецЕсли;

	ЗафиксироватьТранзакцию();
	
	Если ОсновнаяСтруктурнаяЕдиница <> Неопределено и ЗначениеЗаполнено(ОсновнаяСтруктурнаяЕдиница.Ссылка) Тогда
		ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница = ОсновнаяСтруктурнаяЕдиница.Ссылка;
	КонецЕсли;
	
		
КонецПроцедуры

