	ДекорацияФормы_Картинка_УдалитьСтроку.Вид 						   = ВидДекорацииФормы.Картинка;
	ДекорацияФормы_Картинка_УдалитьСтроку.Заголовок 				   = "";
	ДекорацияФормы_Картинка_УдалитьСтроку.Картинка 					   = БиблиотекаКартинок.ОчиститьДанные_Ровная;
	ДекорацияФормы_Картинка_УдалитьСтроку.Гиперссылка                  = Истина;
	ДекорацияФормы_Картинка_УдалитьСтроку.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
	ДекорацияФормы_Картинка_УдалитьСтроку.УстановитьДействие("Нажатие", "Подключаемый_УдалитьСтрокуТабличнойЧастиОжидание");
	
КонецПроцедуры

//  Процедура - Установить параметры выбора номенклатуры
// 
//  Параметры:
//   Элемент	 - 	 - 
//   СтрокаТЧ - 	 - 
// 
Процедура УстановитьПараметрыВыбораНоменклатуры(Элемент, СтрокаТЧ)
	
	МассивПараметров 		= Новый Массив;
	
	МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Услуга));
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
	
