// Процедура - Переключатель переключатель при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ВклОтклПриложениеУправляющегоПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.УидСессии) Тогда
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ПослеВопросаОРегистрацииВЛК", ЭтотОбъект), "Для доступа к приложению управляющего необходимо авторизоваться в личном кабинете. Открыть личный кабинет?", РежимДиалогаВопрос.ДаНет);			
		
	ИначеЕсли Объект.Ссылка.Пустая() Или Модифицированность Тогда 
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаОЗаписиСотрудника", ЭтотОбъект, Новый Структура("Событие", "ДоступКРасписаниюУправляющего"));
		Вопрос = ?(Объект.Ссылка.Пустая(), "Для доступа к расписанию необходимо записать нового сотрудника. Записать?", "Необходимо сохранить изменения. Сохранить?");  // на случай если изменился номер или места работы
		ПоказатьВопрос(ОписаниеОповещения, Вопрос, РежимДиалогаВопрос.ДаНет);				
		
	Иначе
		Если МестаРаботыСотрудника(Объект.Ссылка,"Массив").Количество() = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Мобильное приложение: Для работы с мобильным приложением необходимо указать место работы");
			ВклОтклПриложениеУправляющего = Ложь;
			Возврат;
		КонецЕсли;
		
		Если Объект.ПометкаУдаления Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Мобильное приложение: Для работы с мобильным приложением пользователь не должен быть удален");
			ВклОтклПриложениеУправляющего = Ложь;
			Возврат;
		КонецЕсли;
		
		ОписаниеОшибки = "";
		ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего = ЭтотОбъект.ВклОтклПриложениеУправляющего = Истина;
		ВыполненоУспешно = ИзменитьДоступКМобильномуПриложению(
		ОписаниеОшибки,
		ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего,
		ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего,
		ПредопределенноеЗначение("Перечисление.ТипыВнешнихСистем.МобильноеПриложениеУправляющего")
		);
		
		Если Не ВыполненоУспешно Тогда
			
			ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего = Ложь;			
			// Если ЗначениеЗаполнено(ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего) Тогда
			//	ВыключитьВнешнююСистемуНаСервере(ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего);
			// КонецЕсли;
			Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Мобильное приложение: " + ОписаниеОшибки); 		
			КонецЕсли;
			
		КонецЕсли;
		
		Элементы.ГруппаКодПодтвержденияДляУправляющего.Видимость = ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего;
		Элементы.КодПодтверждения.Видимость = ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего 
		И (Объект.Роль <> ПредопределенноеЗначение("Перечисление.РольПользователя.Руководитель") ИЛИ ПравоДоступаРедактированиеСотрудников());
		
		Если Элементы.ГруппаКодПодтвержденияДляУправляющего.Видимость = Истина Тогда
			ПолучитьКодПодтвержденияДляАвторизации(ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего, Истина);
		КонецЕсли;
		
		ЭтотОбъект.ВклОтклПриложениеУправляющего = ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего; 
		
	КонецЕсли;
	
КонецПроцедуры

