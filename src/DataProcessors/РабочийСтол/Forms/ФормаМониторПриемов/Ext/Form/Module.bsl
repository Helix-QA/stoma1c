
#Область ___________________________ОБРАБОТЧИКИ_СОБЫТИЙ_ФОРМЫ___________________________

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТекущийПользователь 		= ПараметрыСеанса.ТекущийСотрудник;
	ТекущаяСтруктурнаяЕдиница 	= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ТекущаяВалюта				= Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки(ТекущаяСтруктурнаяЕдиница).ВалютаУчета;
	
	// Инициализируем настройки при первом открытии формы
	Если ХранилищеСистемныхНастроек.Загрузить("Обработка.РабочийСтол.Форма.ФормаМониторПриемов/ТекущиеДанные") = Неопределено Тогда
		Настройки = Новый Соответствие;
		ХранилищеСистемныхНастроек.Сохранить("Обработка.РабочийСтол.Форма.ФормаМониторПриемов/ТекущиеДанные", ,Настройки);
	КонецЕсли;
	     
	УстановитьПривилегированныйРежим(Ложь);
	
	Элементы.СоздатьСделку.Видимость = ПравоДоступа("Добавление", Метаданные.Справочники.Сделки); 
	
КонецПроцедуры

&НаСервере
// Процедура - При загрузке данных из настроек на сервере
//
// Параметры:
//  Настройки	 - 	 - 
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)

	// Если ПараметрыСеанса.ТекущийПользователь.Служебный Тогда 
	//	УстановитьПривилегированныйРежим(Истина);
	// КонецЕсли;
	
	ИнициализироватьНастройкиМонитора();
	
	// Обновление (подсчет) общих сведений
	ОбновитьОбщиеСведения();
	
	// Генерация элементов этапов по каждому виду сделки
	ОтобразитьВсеВидыСделок();
	
	// Восстановим историю поиска
	СпискиВыбораКлиентСервер.Загрузить("Обработка.РабочийСтол.Форма.ФормаМониторПриемов/ИсторияПоиска", Элементы.ПоискКлиента.СписокВыбора, Истина);
	
	// Отключаем знакомство при первом запуске
	ПоказатьВидеоРоликПриПервомЗапуске = Ложь;
	
	ЭтаФорма.Заголовок = ?(ПоказатьВидеоРоликПриПервомЗапуске, Нстр("ru='Новая CRM-система. Что изменилось?';en='New CRM-system. What changed?'"), Нстр("ru='Монитор приемов';en='Monitor of sales'"));
	Элементы.ОсновнаяПанель.Видимость 								= НЕ ПоказатьВидеоРоликПриПервомЗапуске;
	Элементы.ГруппаПросмотраВидеоРоликаПриПервомЗапуске.Видимость 	= ПоказатьВидеоРоликПриПервомЗапуске;	
	Если ПоказатьВидеоРоликПриПервомЗапуске Тогда 
		ИнициироватьВидеоРоликПриПервомЗапуске();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)
	
	Если НЕ ПоказатьВидеоРоликПриПервомЗапуске Тогда
		Если АвтоматическоеАвтообновление Тогда 
			ПодключитьОбработчикОжидания("ОбновитьМониторПродаж", ПериодАвтообновления, Ложь);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ" Тогда 
		ОбновитьВсеСведенияПоСделкам();
	ИначеЕсли ИмяСобытия = "ОБНОВИТЬ_ВИДЫ_И_ЭТАПЫ_СДЕЛОК" Тогда
		ОтобразитьВсеВидыСделок();		
	ИначеЕсли ИмяСобытия = "КЛЮЧЕВОЙ_ПОКАЗАТЕЛЬ_ЗАПИСАН" ИЛИ ИмяСобытия = "ОБНОВЛЕН_СОСТАВ_СОТРУДНИКОВ_КЛЮЧЕВОГО_ПОКАЗАТЕЛЯ" Тогда
		// ПоказатьОповещениеПользователя(Нстр("ru='Виджеты KPI обновлены';en='KPI widgets updated'"), , Нстр("ru='Применение настроек...';en='Application of settings...'"), БиблиотекаКартинок.ТерминалНастройки, СтатусОповещенияПользователя.Информация);
	ИначеЕсли ИмяСобытия = "ОповещениеОНовыхЗаявках" Тогда
		ОбновитьСведенияПоЗаявкам();
	КонецЕсли;
	
	// Работа с внешним оборудованием
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "TracksData" Тогда
			
			ДанныеКарты = МенеджерОборудованияКлиент.ОбработатьДанныеМагнитнойКарты(Параметр);		   		   
			Если ЗначениеЗаполнено(ДанныеКарты.ТипДанных) Тогда
				ОбработатьДанныеСВнешнегоУстройстваСчитывания(ДанныеКарты);
			Иначе
				ПоказатьПредупреждение(, Нстр("ru='Данная карта/штрихкод не зарегистрированы в системе! Код: ';en='This card barcode is not registered in the system! Code:'") + ДанныеКарты.КодШифра);			   
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			
			ДанныеШтрихКода = МенеджерОборудованияКлиент.ОбработатьДанныеШтрихКода(Параметр);	
			Если ЗначениеЗаполнено(ДанныеШтрихКода.ТипДанных) Тогда			
				ОбработатьДанныеСВнешнегоУстройстваСчитывания(ДанныеШтрихКода);		
			Иначе
				ПоказатьПредупреждение(, Нстр("ru='Данная карта/штрихкод не зарегистрированы в системе! Код: ';en='This card barcode is not registered in the system! Code:'") + ДанныеШтрихКода.КодШифра);			   
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

	
КонецПроцедуры

&НаКлиенте
// Функция обрабатывает код карты, полученный от внешнего оборудования
//
Процедура ОбработатьДанныеСВнешнегоУстройстваСчитывания(СтруктураДанных) 
	
	Если СтруктураДанных.ТипДанных = "КАРТА_КЛИЕНТА" Тогда		
		
		СтандартнаяОбработка = Истина;
		
		КлиентОбработкаВыбора(Элементы.ПоискКлиента, СтруктураДанных.Клиент, СтандартнаяОбработка);
		Если СтандартнаяОбработка Тогда 			
			ЭтаФорма.ПоискКлиента = СтруктураДанных.Клиент;
		КонецЕсли; 	
		
	КонецЕсли;  
	
КонецПроцедуры 

&НаКлиенте
// Процедура - Перед закрытием
//
// Параметры:
//  Отказ				 - 	 - 
//  ЗавершениеРаботы	 - 	 - 
//  ТекстПредупреждения	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	ДатаПросмотраИсторииСобытий = ТекущаяДата();
	
	Если ЗавершениеРаботы = Ложь Тогда
		ЗаписатьНастройкиПользователя();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ______________________ОБРАБОТЧИКИ_СОБЫТИЙ_ЭЛЕМЕНТОВ_ФОРМЫ______________________

&НаКлиенте
// Процедура, обработчик события "ОбработкаВыбора"
//
Процедура КлиентОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПоказатьЗначение(, ВыбранноеЗначение);
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		// Обновляем историю поиска
		СпискиВыбораКлиентСервер.ОбновитьСписокВыбора(Элементы.ПоискКлиента.СписокВыбора, ВыбранноеЗначение, 10, Истина);
		СпискиВыбораКлиентСервер.Сохранить("Обработка.РабочийСтол.Форма.ФормаМониторПриемов/ИсторияПоиска", Элементы.ПоискКлиента.СписокВыбора);
	КонецЕсли;
	Если ЗначениеЗаполнено(Элементы.ПоискКлиента.ТекстРедактирования) Тогда
		// Обновляем историю поиска
		СпискиВыбораКлиентСервер.ОбновитьСписокВыбора(СписокВводимыхЗначений, Элементы.ПоискКлиента.ТекстРедактирования, 10, Истина);
		СпискиВыбораКлиентСервер.Сохранить("Обработка.РабочийСтол.Форма.ФормаМониторПриемов/ИсторияВводаПоиска", СписокВводимыхЗначений);
	КонецЕсли;		
	ВыбранноеЗначение = Неопределено;
	ПоискКлиента = Неопределено;
	Элемент.ОбновитьТекстРедактирования(); 

КонецПроцедуры

&НаКлиенте
// Процедура - Поиск клиента авто подбор
//
// Параметры:
//  Элемент					 - 	 - 
//  Текст					 - 	 - 
//  ДанныеВыбора			 - 	 - 
//  ПараметрыПолученияДанных - 	 - 
//  Ожидание				 - 	 - 
//  СтандартнаяОбработка	 - 	 - 
//
Процедура ПоискКлиентаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ПараметрыПолученияДанных.Отбор.Вставить("ИскатьВЗавяках", Истина);	
	ПараметрыПолученияДанных.Отбор.Вставить("ИскатьВСделках", Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - История событий при нажатии
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеСобытия		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ИсторияСобытийПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ПорцияСобытий = ПорцияСобытий + 10;
	ОбсужденияКлиент.ОбработатьНажатие(ЭтаФорма, Элемент, ДанныеСобытия, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Декорация настройки нажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДекорацияНастройкиНажатие(Элемент)

	Элементы.ГруппаНастройкиФормы.Показать();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Период автообновления при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ПериодАвтообновленияПриИзменении(Элемент)
	
	Элементы.ДекорацияСекунды.Заголовок = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Секунд", ПериодАвтообновления); // подготовить к переводу
	ОтключитьОбработчикОжидания("ОбновитьМониторПродаж");
	ПодключитьОбработчикОжидания("ОбновитьМониторПродаж", ПериодАвтообновления, Ложь);
	
	ЗаписатьЗначениеНастройкиПользователяНаСервере("МониторПродаж_ПериодАвтообновления", ПериодАвтообновления);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Таблица сортировки показателей KPIПри изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ТаблицаСортировкиПоказателейKPIПриИзменении(Элемент)
	
	Счетчик = 0;
	Для Каждого СтрокаПоказательKPI Из ЭтаФорма[Элемент.Имя] Цикл
		Счетчик = Счетчик + 1;
		СтрокаПоказательKPI.Порядок = Счетчик;
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Таблица сортировки показателей KPIВыбор
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбраннаяСтрока		 - 	 - 
//  Поле				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ТаблицаСортировкиПоказателейKPIВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущиеДанные <> Неопределено Тогда 
		Если ЗначениеЗаполнено(Элемент.ТекущиеДанные.ПоказательЭффективности) Тогда 
			Возврат;
			// ОткрытьФорму("Справочник.КлючевыеПоказателиЭффективности.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.ПоказательЭффективности));
	    КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Декорация добавить KPIНажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДекорацияДобавитьKPIНажатие(Элемент)
	
	// ОткрытьФорму("Справочник.КлючевыеПоказателиЭффективности.ФормаОбъекта");
	
	Возврат;
	
КонецПроцедуры

#КонецОбласти

#Область ___________________________ОБРАБОТЧИКИ_КОМАНД_ФОРМЫ____________________________

&НаКлиенте
// Процедура - Более не показывать мне эту кромолу
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура БолееНеПоказыватьМнеЭтуКромолу(Команда)
	
	ПоказатьВидеоРоликПриПервомЗапуске 								= Ложь;
	ЭтаФорма.Заголовок = ?(ПоказатьВидеоРоликПриПервомЗапуске, Нстр("ru='Новая CRM-система. Что изменилось?';en='New CRM-system. What changed?'"), Нстр("ru='Монитор приемов';en='Receive Monitor'"));		
	Элементы.ОсновнаяПанель.Видимость 								= Истина;
	Элементы.ГруппаПросмотраВидеоРоликаПриПервомЗапуске.Видимость 	= Ложь;
	СтраницаВидеоРолика = "";
	Если АвтоматическоеАвтообновление Тогда 
		ПодключитьОбработчикОжидания("ОбновитьМониторПродаж", ПериодАвтообновления, Ложь);
	КонецЕсли;
	
	ЗаписатьЗначениеНастройкиПользователяНаСервере("МониторПродаж_ПоказатьВидеоРоликПриПервомЗапуске", ПоказатьВидеоРоликПриПервомЗапуске);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Посмотрю позже
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПосмотрюПозже(Команда)
	
	ПоказатьВидеоРоликПриПервомЗапуске 								= Истина;
	ЭтаФорма.Заголовок												= Нстр("ru='Монитор приемов';en='Monitor of sales'");		
	Элементы.ОсновнаяПанель.Видимость 								= Истина;
	Элементы.ГруппаПросмотраВидеоРоликаПриПервомЗапуске.Видимость 	= Ложь;
	СтраницаВидеоРолика = "";
	Если АвтоматическоеАвтообновление Тогда 	
		ПодключитьОбработчикОжидания("ОбновитьМониторПродаж", ПериодАвтообновления, Ложь);
	КонецЕсли;
	
	ЗаписатьЗначениеНастройкиПользователяНаСервере("МониторПродаж_ПоказатьВидеоРоликПриПервомЗапуске", ПоказатьВидеоРоликПриПервомЗапуске);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Создать потенциального клиента
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СоздатьПотенциальногоКлиента(Команда)
	
	МассивВидовСделок = ПолучитьМассивВсехВидовСделокПоПродажамНаСервере(, ОтборСтруктурнаяЕдиница, ТекущийПользователь);
	СписокВариантовСоздания = Новый СписокЗначений;
	СписокВариантовСоздания.ЗагрузитьЗначения(МассивВидовСделок);
	
	Для Каждого ЭлементСписка Из СписокВариантовСоздания Цикл			
		ЭлементСписка.Представление = Нстр("ru = 'Потенциальный пациент + '; en = 'Potential patient + '") + ЭлементСписка.Значение; 
	КонецЦикла;
	
	Если СписокВариантовСоздания.Количество() = 0 Тогда 
		ОбработкаВыбораВариантаСоздания(Новый Структура("Значение", ПредопределенноеЗначение("Справочник.ВидыСделок.ПустаяСсылка")), Новый Структура("ЭтоСозданиеКлиента", Истина));
	Иначе 	
		СписокВариантовСоздания.Добавить(ПредопределенноеЗначение("Справочник.ВидыСделок.ПустаяСсылка"), Нстр("ru = 'Потенциальный пациент'; en = 'Potential patient'"));
		
		Оповещение = Новый ОписаниеОповещения("ОбработкаВыбораВариантаСоздания", ЭтотОбъект, Новый Структура("ЭтоСозданиеКлиента", Истина));
		ПоказатьВыборИзМеню(Оповещение, СписокВариантовСоздания, Элементы.КомандаНовыйПЧК);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Создать сделку1
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ИнициализироватьФормуСозданияСделки(Команда)
	
	МассивВидовСделок = ПолучитьМассивВсехВидовСделокПоПродажамНаСервере(, ОтборСтруктурнаяЕдиница, ТекущийПользователь);
	СписокВариантовСоздания = Новый СписокЗначений;
	СписокВариантовСоздания.ЗагрузитьЗначения(МассивВидовСделок);
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаВыбораВариантаСоздания", ЭтотОбъект, Новый Структура("ЭтоСозданиеКлиента", Ложь));
	ПоказатьВыборИзМеню(Оповещение, СписокВариантовСоздания, Элементы.СоздатьСделку);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка выбора варианта создания
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОбработкаВыбораВариантаСоздания(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	ИначеЕсли НЕ ЗначениеЗаполнено(РезультатВыбора.Значение) Тогда
		ДанныеЗаполнения = Новый Структура();
		ДанныеЗаполнения.Вставить("ЗначенияЗаполнения", Новый Структура("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница));		
		ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", ДанныеЗаполнения, , Истина);
	ИначеЕсли ТипЗнч(РезультатВыбора.Значение) = Тип("СправочникСсылка.ВидыСделок") И ЗначениеЗаполнено(РезультатВыбора.Значение) Тогда
		Если ДополнительныеПараметры.ЭтоСозданиеКлиента Тогда 
			Сделка = СоздатьСделку(РезультатВыбора.Значение, ОтборСтруктурнаяЕдиница);
			
			ДанныеЗаполнения = Новый Структура();
			ДанныеЗаполнения.Вставить("Сделка", Сделка);
			ДанныеЗаполнения.Вставить("ЗначенияЗаполнения", Новый Структура("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница));					
			ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", ДанныеЗаполнения);
		Иначе
			ПерыйЭтап 	= ПолучитьСтартовыйЭтапВидаСделкиНаСервере(РезультатВыбора.Значение);
			ДанныеЗаполнения = Новый Структура();
			ДанныеЗаполнения.Вставить("ВидСделки"				, РезультатВыбора.Значение);
			ДанныеЗаполнения.Вставить("ЭтапСделки"				, ПерыйЭтап);
			ДанныеЗаполнения.Вставить("СформироватьНаименование", Истина);
			ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"		, ОтборСтруктурнаяЕдиница);					
			ОткрытьФорму("Справочник.Сделки.ФормаОбъекта", Новый Структура("ЗначенияЗаполнения", ДанныеЗаполнения), , Истина);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

