	|	ГруппировкаПоУслуге КАК ГруппировкаПоУслуге
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВозвратОтПокупателя КАК ВозвратОтПокупателя
	|		ПО ГруппировкаПоУслуге.Услуга = ВозвратОтПокупателя.Услуга
	|			И ГруппировкаПоУслуге.Цена = ВозвратОтПокупателя.Цена
	|ГДЕ
	|	(ГруппировкаПоУслуге.Количество - ЕСТЬNULL(ВозвратОтПокупателя.Количество, 0) > 0
	|			ИЛИ ГруппировкаПоУслуге.Сумма - ЕСТЬNULL(ВозвратОтПокупателя.Сумма, 0) > 0)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|АВТОУПОРЯДОЧИВАНИЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументАванса КАК ДокументАванса,
	|	СУММА(ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток) КАК СуммаОстаток
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
	|			,
	|			Контрагент = &Контрагент
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И ВЫБОР
	|					КОГДА ДокументАванса ССЫЛКА Документ.ПланЛечения
	|						ТОГДА ДокументАванса <> ЗНАЧЕНИЕ(Документ.ПланЛечения.ПустаяСсылка)
	|					КОГДА ДокументАванса ССЫЛКА Документ.НарядЗаказ
	|						ТОГДА ДокументАванса <> ЗНАЧЕНИЕ(Документ.НарядЗаказ.ПустаяСсылка)
	|				КОНЕЦ
	|				И (ДокументРеализации = НЕОПРЕДЕЛЕНО
	|					ИЛИ ДокументРеализации = ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	|					ИЛИ ДокументРеализации = ЗНАЧЕНИЕ(Документ.Реализация.ПустаяСсылка)
	|					ИЛИ ДокументРеализации = ЗНАЧЕНИЕ(Документ.Поступление.ПустаяСсылка)
	|					ИЛИ ДокументРеализации = ЗНАЧЕНИЕ(Документ.ВводНачальныхОстатков.ПустаяСсылка))) КАК ВзаиморасчетыСКонтрагентамиОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументАванса
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументАванса.Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДенежныеСредстваНаЛицевыхСчетахОстатки.ВидСчета КАК ВидСчета,
	|	СУММА(ЕСТЬNULL(ДенежныеСредстваНаЛицевыхСчетахОстатки.СуммаОстаток, 0)) КАК СуммаОстаток
	|ИЗ
	|	РегистрНакопления.ДенежныеСредстваНаЛицевыхСчетах.Остатки(
	|			,
	|			Контрагент = &Контрагент
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ДенежныеСредстваНаЛицевыхСчетахОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ДенежныеСредстваНаЛицевыхСчетахОстатки.ВидСчета
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДенежныеСредстваНаЛицевыхСчетахОстатки.ВидСчета.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВозвратОтПокупателя.Сумма) КАК Сумма,
	|	СУММА(ВозвратОтПокупателя.СуммаСкидки) КАК СуммаСкидки
	|ИЗ
	|	ВозвратОтПокупателя КАК ВозвратОтПокупателя";
	
	Запрос.УстановитьПараметр("Ссылка"                       , ТекущийДокумент);
	Запрос.УстановитьПараметр("Контрагент"                   , ТекущийДокумент.Контрагент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"           , ТекущийДокумент.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Дата"                         , НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор", Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
	Возврат Запрос.ВыполнитьПакет();
	
КонецФункции

// Функция - Получить данные документа
//
// Параметры:
//  Документ - 	 Документ 
// 
Функция ПолучитьДанныеДокумента(Документ)
	
	ДанныеДокумента = 
	Новый Структура("Дата, ДатаТалонаЧисло, ДатаТалонаМесяц, ДатаТалонаГод, " +
	"ЦельПосещения, ЦельОбращения, Врач2Специальность, Врач2ФИО, НаименованиеОрганизации, АдресОрганизации, " +
	"РезультатОбращения, ЗаконченныйСлучай, ВидОбращения, ВидОплаты, Врач1Специальность, Врач1ФИО, " +
	"Пациент, ОМССерияПолиса, ОМСНомерПолиса, СМО, Фамилия, Имя, Отчество, Пол, ДатаРожденияЧисло, ДатаРожденияМесяц, " +
	"ДатаРожденияГод, Занятость, МестоРаботыЧасть1, НомерКарты, ДокументВид, ДокументСерия, ДокументНомер");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Дата,
	|	Прием.Дата КАК Дата,
	|	1 КАК ЦельОбращения,
	|	ВЫБОР
	|		КОГДА Прием.РезультатПриема = 1
	|			ТОГДА 1
	|		КОГДА Прием.РезультатПриема = 2
	|			ТОГДА 10
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК РезультатОбращения,
	|	ВЫБОР
	|		КОГДА Прием.РезультатПриема = 1
	|			ТОГДА 1
	|		КОГДА Прием.РезультатПриема = 2
	|			ТОГДА 2
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ЗаконченныйСлучай,
	|	ВЫБОР
	|		КОГДА Прием.СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Первичный)
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ВидОбращения,
	|	ВЫБОР
	|		КОГДА Прием.ПолисМедСтрахования <> ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяСсылка)
	|			ТОГДА ВЫБОР
	|				  	КОГДА Прием.ПолисМедСтрахования.ТипПолиса = ЗНАЧЕНИЕ(Перечисление.ТипыПолиса.ДобровольноеМедицинскоеСтрахование)
	|						ТОГДА 4
	|					ИНАЧЕ 1
	|				  КОНЕЦ
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК ВидОплаты,
	|	Прием.Сотрудник.Должность КАК Врач1Специальность,
	|	Прием.Сотрудник.Представление КАК Врач1ФИО,
	|	Прием.Ассистент.Должность КАК Врач2Специальность,
	|	Прием.Ассистент.Представление КАК Врач2ФИО,
	|	Прием.Контрагент КАК Пациент,
	|	Прием.ПолисМедСтрахования.СерияПолиса КАК ОМССерияПолиса,
	|	Прием.ПолисМедСтрахования.НомерПолиса КАК ОМСНомерПолиса,
	|	Прием.ПолисМедСтрахования.СтраховаяКомпания КАК СМО,
	|	Прием.Контрагент.Фамилия КАК Фамилия,
	|	Прием.Контрагент.Имя КАК Имя,
	|	Прием.Контрагент.Отчество КАК Отчество,
	|	ВЫБОР
	|		КОГДА Прием.Контрагент.ПолКлиента = ЗНАЧЕНИЕ(Перечисление.ПолФизическогоЛица.Мужской)
	|			ТОГДА 1
	|		КОГДА Прием.Контрагент.ПолКлиента = ЗНАЧЕНИЕ(Перечисление.ПолФизическогоЛица.Женский)
	|			ТОГДА 2
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Пол,
	|	ВЫБОР
	|		КОГДА Прием.Контрагент.СоциальныйСтатус = ЗНАЧЕНИЕ(Справочник.СоциальныеСтатусыКонтрагентов.Работающий)
	|			ТОГДА 1
	|		КОГДА Прием.Контрагент.СоциальныйСтатус = ЗНАЧЕНИЕ(Справочник.СоциальныеСтатусыКонтрагентов.Военнослужащий)
	|			ТОГДА 2
	|		КОГДА Прием.Контрагент.СоциальныйСтатус = ЗНАЧЕНИЕ(Справочник.СоциальныеСтатусыКонтрагентов.Пенсионер)
	|			ТОГДА 3
	|		КОГДА Прием.Контрагент.СоциальныйСтатус = ЗНАЧЕНИЕ(Справочник.СоциальныеСтатусыКонтрагентов.Учащийся)
	|			ТОГДА 4
	|		КОГДА Прием.Контрагент.СоциальныйСтатус = ЗНАЧЕНИЕ(Справочник.СоциальныеСтатусыКонтрагентов.Неработающий)
	|			ТОГДА 5
	|		ИНАЧЕ 6
	|	КОНЕЦ КАК Занятость,
	|	Прием.Контрагент.Организация КАК МестоРаботыЧасть1,
	|	Прием.Контрагент.ТекущаяМедицинскаяКарта.КодБезНулей КАК НомерКарты,
	|	Прием.Контрагент.ДатаРожденияКлиента КАК ДатаРождения,
	|	Прием.СтруктурнаяЕдиница.Организация КАК Организация
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Документ);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеДокумента, Выборка);
		
		Если ЗначениеЗаполнено(Выборка.Дата) Тогда
			ДанныеДокумента.ДатаТалонаЧисло = Формат(Выборка.Дата, "ДФ=dd");
			ДанныеДокумента.ДатаТалонаМесяц = Формат(Выборка.Дата, "ДФ=MM");
			ДанныеДокумента.ДатаТалонаГод   = Формат(Выборка.Дата, "ДФ=yyyy");
		КонецЕсли;
		Если ЗначениеЗаполнено(Выборка.ДатаРождения) Тогда
			ДанныеДокумента.ДатаРожденияЧисло = Формат(Выборка.ДатаРождения, "ДФ=dd");
			ДанныеДокумента.ДатаРожденияМесяц = Формат(Выборка.ДатаРождения, "ДФ=MM");
			ДанныеДокумента.ДатаРожденияГод   = Формат(Выборка.ДатаРождения, "ДФ=yyyy");
		КонецЕсли;
		Организация = Выборка.Организация;
		НаименованиеОрганизации = Выборка.Организация.ПолноеНаименование;
		АдресОрганизации = Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, "Вид");
		Если АдресОрганизации <> Неопределено Тогда
			АдресОрганизации = АдресОрганизации.Представление;
		Иначе
			АдресОрганизации = "";
		КонецЕсли;
		ДанныеДокумента.НаименованиеОрганизации = НаименованиеОрганизации;
		ДанныеДокумента.АдресОрганизации = АдресОрганизации;
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДокументыФизическихЛиц.ВидДокумента.Наименование КАК ДокументВид,
		|	ДокументыФизическихЛиц.Серия КАК ДокументСерия,
		|	ДокументыФизическихЛиц.Номер КАК ДокументНомер
		|ИЗ
		|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
		|ГДЕ
		|	ДокументыФизическихЛиц.Физлицо = &Физлицо";
		Запрос.УстановитьПараметр("Физлицо", Выборка.Пациент);
		ТаблицаРезультат = Запрос.Выполнить().Выгрузить();
		Для Каждого Стр Из ТаблицаРезультат Цикл
			ДанныеДокумента.ДокументВид = Стр.ДокументВид;
			ДанныеДокумента.ДокументСерия = Стр.ДокументСерия;
			ДанныеДокумента.ДокументНомер = Стр.ДокументНомер;
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ДанныеДокумента;
	
КонецФункции

// Процедура: ВыделитьЯчейку
//   Задает шрифт (жирный, подчеркнутый) для ячейки.
//
// Параметры:
//   ОбщееИмяЯчеек {Строка}
//     Начальная часть имени ячейки, для которой нужно изменить шрифт.
//   НомерЯчейки {Число}
//     Конечная часть имени ячейки, для которой нужно изменить шрифт.
//   Макет.
//     Макет, в котором находится ячейка.
///
Процедура ВыделитьЯчейку(ОбщееИмяЯчеек, НомерЯчейки, Макет)
	Если Не ЗначениеЗаполнено(НомерЯчейки) Тогда
		Возврат;
	КонецЕсли;
	ИмяЯчейки = ОбщееИмяЯчеек + НомерЯчейки;
	ОбластьЯчеек = Макет.Область(ИмяЯчейки);
	ОбластьЯчеек.Шрифт = Новый Шрифт(ОбластьЯчеек.Шрифт, , 10, Истина, , Истина);
	Если Макет.Области.Найти(ИмяЯчейки + "_") <> Неопределено Тогда
		ОбластьЯчеек = Макет.Область(ИмяЯчейки + "_");
		ОбластьЯчеек.Шрифт = Новый Шрифт(ОбластьЯчеек.Шрифт, , 10, Истина, , Истина);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ПредставленияДанных

// Процедура - Обработка получения полей представления
// 
// Параметры:
//  Поля				 - 	 - 
//  СтандартнаяОбработка - 	 - 
// 
Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Поля.Добавить("Ссылка");
	Поля.Добавить("ВремяНачалаПриема");
	Поля.Добавить("ВремяОкончанияПриема");
	Поля.Добавить("Номер");
	Поля.Добавить("Проведен");
	Поля.Добавить("ПометкаУдаления");
	Поля.Добавить("ТипЗаписи");
	Поля.Добавить("Продажа");
	Поля.Добавить("РезультатПриема");
    Поля.Добавить("ПометкаУдаления");

КонецПроцедуры

// Процедура - Обработка получения представления
// 
// Параметры:
//  Данные				 - 	 - 
//  Представление		 - 	 - 
//  СтандартнаяОбработка - 	 - 
// 
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Представление = "";
	
	Если Данные.Номер = Null ИЛИ НЕ ЗначениеЗаполнено(Данные.Ссылка) Тогда
		Возврат;
	КонецЕсли;
	Номер = Данные.Номер;
	СтандартнаяОбработка = Ложь;
	
	Состояние = "";
	Если Данные.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)'");
	ИначеЕсли НЕ Данные.Проведен Тогда
		Состояние = НСтр("ru='(не проведен)'");
	КонецЕсли;
   	Если Данные.РезультатПриема <> 0 Тогда
		Статус = "окончен";
		ДатаДокумента = "в " + Формат(Данные.ВремяОкончанияПриема, "ДФ=HH:мм")+ ", " +  Формат(Данные.ВремяОкончанияПриема, "ДЛФ=DD");  
	Иначе
		Статус = "начат";
		ДатаДокумента = "в " + Формат(Данные.ВремяНачалаПриема, "ДФ=HH:мм") + ", " +  Формат(Данные.ВремяНачалаПриема, "ДЛФ=DD");
	КонецЕсли;
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1%2 %3 %4 %5'"),
	"Прием № ",
	Номер,
	Статус,
	ДатаДокумента,
	Состояние
	);
	
КонецПроцедуры

#КонецОбласти

#Область ДОПОЛНИТЕЛЬНЫЕ_ПРОЦЕДУРЫ_И_ФУНКЦИИ

// Процедура производит запись номинала партии сертификата.
//
Процедура ЗаписатьНоминалСертификатаПриПродаже(ДокументСсылкаПрием) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемЗапасы.Партия,
	|	ПриемЗапасы.Цена
	|ИЗ
	|	Документ.Прием.Запасы КАК ПриемЗапасы
	|ГДЕ
	|	ПриемЗапасы.Ссылка = &Ссылка
	|	И ПриемЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	|	И ПриемЗапасы.Номенклатура.ВидНоминала
	|	И ПриемЗапасы.Ссылка.Проведен");
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаПрием);
	СписокЗапасов = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаЗапасов Из СписокЗапасов Цикл
		Если ЗначениеЗаполнено(СтрокаЗапасов.Партия) Тогда
			Партия = СтрокаЗапасов.Партия.ПолучитьОбъект();
			Партия.Номинал = СтрокаЗапасов.Цена;
			Партия.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Получить массив обязательных для заполнения реквизитов реквизитов
//
Процедура ПолучитьМассивыОбязательныхРеквизитов(ДокументОбъект,МассивОбязательныхРеквизитов) Экспорт
	
	МассивОбязательныхРеквизитов.Добавить("Контрагент");
	МассивОбязательныхРеквизитов.Добавить("СтруктурнаяЕдиница");
	МассивОбязательныхРеквизитов.Добавить("Касса");
	МассивОбязательныхРеквизитов.Добавить("Склад");
	МассивОбязательныхРеквизитов.Добавить("Сотрудник");
	МассивОбязательныхРеквизитов.Добавить("Запасы.Номенклатура");
	МассивОбязательныхРеквизитов.Добавить("Запасы.КоличествоУпаковок");
	МассивОбязательныхРеквизитов.Добавить("Запасы.Цена");
	МассивОбязательныхРеквизитов.Добавить("Лечение.Номенклатура");
	МассивОбязательныхРеквизитов.Добавить("Лечение.Зуб");
	МассивОбязательныхРеквизитов.Добавить("Лечение.КоличествоУпаковок");
	МассивОбязательныхРеквизитов.Добавить("Лечение.Цена");
	
	Если НЕ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьНулевуюСумму, Ложь) Тогда
		МассивОбязательныхРеквизитов.Добавить("СуммаДокумента");
	КонецЕсли;	
	Если ДокументОбъект.Лечение.Количество() > 0 Тогда
		МассивОбязательныхРеквизитов.Добавить("РезультатПриема");
	КонецЕсли;
	
КонецПроцедуры

// Функция вернет массив не повторяющихся ссылок на документы аванса из указанного приема
//
Функция ПолучитьДокументыАвансаИзПриема(ПриемСсылка) Экспорт
	
	МассивВозврата  = Новый Массив;
	Для Каждого СтрокаТЧ ИЗ ПриемСсылка.Лечение Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) И МассивВозврата.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда
			МассивВозврата.Добавить(СтрокаТЧ.ДокументАванса);	
		КонецЕсли;
	КонецЦикла;
	Для Каждого  СтрокаТЧ ИЗ ПриемСсылка.Запасы Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) И МассивВозврата.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда
			МассивВозврата.Добавить(СтрокаТЧ.ДокументАванса);	
		КонецЕсли;
	КонецЦикла;
	
	Возврат  МассивВозврата;
КонецФункции

//
//
Функция СформироватьДатуОплаты(МассивОбъектов)
	
	Результат = "";
	Для каждого ОбъектДокумента Из МассивОбъектов Цикл
		
		Результат = Результат + ?(Результат = "", "", ", ") + Формат(ОбъектДокумента.Дата, "ДФ=dd.MM.yy");
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Функция, возвращает приемы и предварительные записи сотрудников.
//
Функция ПолучитьПриемыИЗаписиСотрудников(
		СтруктурнаяЕдиница,
		МассивСотрудников,
		ДатаСреза = Неопределено,
		НачалоПериода = Неопределено,
		КонецПериода = Неопределено,
		МассивРолей = Неопределено) Экспорт
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Ссылка КАК Ссылка,
	|	ВложенныйЗапрос.Сотрудник КАК Сотрудник,
	|	ВложенныйЗапрос.ДатаНачала КАК ДатаНачала,
	|	ВложенныйЗапрос.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ПриемЛечение.Ссылка КАК Ссылка,
	|		ПриемЛечение.Ссылка.Сотрудник КАК Сотрудник,
	|		НАЧАЛОПЕРИОДА(ПриемЛечение.Ссылка.ВремяНачалаПриема, МИНУТА) КАК ДатаНачала,
	|		НАЧАЛОПЕРИОДА(ПриемЛечение.Ссылка.ВремяОкончанияПриема, МИНУТА) КАК ДатаОкончания
	|	ИЗ
	|		Документ.Прием.Лечение КАК ПриемЛечение
	|	ГДЕ
	|		ПриемЛечение.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|		И ПриемЛечение.Сотрудник В(&МассивСотрудников)
	|		И ПриемЛечение.Ссылка.Проведен = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		СобытиеУслуги.Ссылка,
	|		СобытиеУслуги.Сотрудник,
	|		СобытиеУслуги.ДатаНачала,
	|		СобытиеУслуги.ДатаОкончания
	|	ИЗ
	|		Документ.Событие.Услуги КАК СобытиеУслуги
	|	ГДЕ
	|		СобытиеУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|		И СобытиеУслуги.Сотрудник В(&МассивСотрудников)
	|		И СобытиеУслуги.Ссылка.Проведен = ИСТИНА
	|		И СобытиеУслуги.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемНеСостоялся)
	|		И СобытиеУслуги.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)) КАК ВложенныйЗапрос
	|ГДЕ
	|	&УсловиеВремяПриема
	|	И &УсловиеРолиСотрудника
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаНачала,
	|	ДатаОкончания");
	
	Запрос.УстановитьПараметр("МассивСотрудников" , МассивСотрудников);
	Запрос.УстановитьПараметр("ДатаСреза"  		  , ?(ЗначениеЗаполнено(ДатаСреза), ДатаСреза, ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("НачалоПериода"     , НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода"	  , КонецПериода);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("РолиСотрудника"	  , МассивРолей);

	Если ЗначениеЗаполнено(НачалоПериода)
		И ЗначениеЗаполнено(КонецПериода) Тогда
			
		УсловиеВремяПриема = " ((ВложенныйЗапрос.ДатаНачала >= &НачалоПериода
						     |И ВложенныйЗапрос.ДатаНачала < &КонецПериода)
							 |ИЛИ (ВложенныйЗапрос.ДатаОкончания > &НачалоПериода
							 |И ВложенныйЗапрос.ДатаОкончания <= &КонецПериода)
							 |ИЛИ (ВложенныйЗапрос.ДатаОкончания <= &НачалоПериода
							 |И ВложенныйЗапрос.ДатаОкончания >= &КонецПериода))";
	Иначе
		
		УсловиеВремяПриема = ?(ЗначениеЗаполнено(ДатаСреза), "(ВложенныйЗапрос.ДатаНачала >= &ДатаСреза
														 |ИЛИ ВложенныйЗапрос.ДатаОкончания > &ДатаСреза)
														 |И НАЧАЛОПЕРИОДА(ВложенныйЗапрос.ДатаНачала, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаСреза, ДЕНЬ)", "ВложенныйЗапрос.ДатаОкончания > &ДатаСреза");
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВремяПриема", УсловиеВремяПриема);
	УсловиеРолиСотрудника = ?(ЗначениеЗаполнено(МассивРолей), "И ВложенныйЗапрос.Сотрудник.Роль В (&РолиСотрудника)", "");
	Запрос.Текст 		  = СтрЗаменить(Запрос.Текст, "И &УсловиеРолиСотрудника", УсловиеРолиСотрудника);

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Получить последний прием по сделке
//
// Параметры:
//  Сделка	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПоследнийПриемПоСделке(Сделка) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Сделка", Сделка);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Прием.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Проведен
	|	И Прием.Сделка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Прием.Дата УБЫВ";
	
	ВыборкаПриема = Запрос.Выполнить().Выбрать();
	
	Возврат ?(ВыборкаПриема.Следующий(), ВыборкаПриема.Ссылка, Неопределено);
	
КонецФункции

// Функция - Результат приема изменен
//
// Параметры:
//  Прием					 - 	 - 
//  ТекущийРезультатПриема	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция РезультатПриемаИзменен(Прием, ТекущийРезультатПриема) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(Прием) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Прием"					, Прием);
	Запрос.УстановитьПараметр("ТекущийРезультатПриема"	, ТекущийРезультатПриема);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДокументПрием.Ссылка КАК Прием
	|ИЗ
	|	Документ.Прием КАК ДокументПрием
	|ГДЕ
	|	ДокументПрием.Ссылка = &Прием
	|	И ДокументПрием.РезультатПриема = &ТекущийРезультатПриема";
	
	Возврат Запрос.Выполнить().Пустой();	
	
КонецФункции

