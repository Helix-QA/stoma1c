
#Область СлужебныйПрограммныйИнтерфейс

// Функция - Получить представление статуса пациента для списка выбора
//
// Параметры:
//  СтатусПациента	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеСтатусаПациентаДляСпискаВыбора(СтатусПациента) Экспорт
	
	ПредставлениеСтатусаПациента = "";
	
	Если СтатусПациента = Потенциальный Тогда 
		ПредставлениеСтатусаПациента = "Потенциальных пациентов";
	ИначеЕсли СтатусПациента = Первичный Тогда 	
		ПредставлениеСтатусаПациента = "Новых пациентов";
	ИначеЕсли СтатусПациента = НеВернувшийся Тогда 	
		ПредставлениеСтатусаПациента = "Не вернувшихся пациентов";
	ИначеЕсли СтатусПациента = Постоянный Тогда 	
		ПредставлениеСтатусаПациента = "Постоянных пациентов";
	ИначеЕсли СтатусПациента = Отказ Тогда 	
		ПредставлениеСтатусаПациента = "Пациентов со статусом ""Отказ""";
	КонецЕсли;
	
	Возврат ПредставлениеСтатусаПациента;
	
КонецФункции

#КонецОбласти