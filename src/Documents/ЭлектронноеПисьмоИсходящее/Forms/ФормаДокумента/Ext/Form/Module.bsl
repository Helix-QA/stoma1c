&НаКлиенте
Процедура ДобавитьВложениеВыполнить()
	
	Если ПисьмоОтправлено Тогда
		Возврат;
	КонецЕсли;
	
	#Если Не ВебКлиент Тогда
		
		Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		Диалог.МножественныйВыбор = Истина;
		Диалог.Показать(Новый ОписаниеОповещения("ДобавитьВложениеВыполнитьЗавершение1", ЭтотОбъект, Новый Структура("Диалог", Диалог)));
		
	#Иначе

		Адрес = "";
		ВыбранныйФайл = "";
		НачатьПомещениеФайла(Новый ОписаниеОповещения("ДобавитьВложениеВыполнитьЗавершение", ЭтотОбъект, Новый Структура("Адрес, ВыбранныйФайл", Адрес, ВыбранныйФайл)), Адрес, , Истина, УникальныйИдентификатор);
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВложениеВыполнитьЗавершение1(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Диалог = ДополнительныеПараметры.Диалог;
	
	
	Если Не (ВыбранныеФайлы <> Неопределено) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ВыбранныйФайл Из Диалог.ВыбранныеФайлы Цикл
		новСтр = Вложения.Добавить();
		новСтр.Расположение = 2;
		новСтр.ИмяФайлаНаКомпьютере = ВыбранныйФайл;
		
		ИмяФайла   = "";
		Расширение = "";
		ФайловыеФункцииКлиентСервер.ПолучитьКаталогИИмяФайла(ВыбранныйФайл, "", ИмяФайла);
		новСтр.ИмяФайла = ИмяФайла;
		
		Расширение = ФайловыеФункцииКлиентСервер.ПолучитьРасширениеФайла(ИмяФайла);
		новСтр.ИндексКартинки = ФайловыеФункцииКлиентСервер.ПолучитьИндексПиктограммыФайла(Расширение);
	КонецЦикла;
	
	Записать();

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВложениеВыполнитьЗавершение(Результат, Адрес, ВыбранныйФайл, ДополнительныеПараметры) Экспорт
	
	Адрес = ДополнительныеПараметры.Адрес;
	
	
	Если Не Результат Тогда
		Возврат;
	КонецЕсли;
	
	новСтр = Вложения.Добавить();
	новСтр.Расположение = 4;
	новСтр.ИмяФайлаНаКомпьютере = Адрес;
	новСтр.ИмяФайла = ВыбранныйФайл;
	
	Расширение = ФайловыеФункцииКлиентСервер.ПолучитьРасширениеФайла(ВыбранныйФайл);
	новСтр.ИндексКартинки = РаботаСФайламиСлужебныйКлиентСервер.ПолучитьИндексПиктограммыФайла(Расширение);
	
	ОбновитьОтображениеДанных();

КонецПроцедуры

