	ОбновитьИнтерфейс();
	Оповестить("ИЗМЕНЕНА_НАСТРОЙКА_АВТОМАТИЧЕСКОЙ_ГЕНЕРАЦИИ_ДОКУМЕНТОВ_ПОСТУПЛЕНИЯ");
	
КонецПроцедуры

