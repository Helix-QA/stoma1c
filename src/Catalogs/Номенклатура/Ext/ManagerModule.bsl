// Функция получает наименование номенклатуры для чека.
//
Функция ПолучитьНаименованиеДляЧека(Номенклатура) Экспорт
	
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТипЗнч(Номенклатура) <> Тип("СправочникСсылка.Номенклатура") Тогда 
		Возврат Номенклатура;
	КонецЕсли;
	
	СтруктураРеквизитов = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Номенклатура, "Наименование, НаименованиеПолное");
	
	Возврат ?(ЗначениеЗаполнено(СтруктураРеквизитов.НаименованиеПолное), СтруктураРеквизитов.НаименованиеПолное, СтруктураРеквизитов.Номенклатура);	
		
КонецФункции

// вид налога и ставка НДС       

// Функция, возвращает вид налога номенклатуры по структурной единице.
//
Функция ПолучитьВидНалогаНоменклатуры(Номенклатура, СтруктурнаяЕдиница) Экспорт
	
	Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Организация = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "Организация");
	
	ДанныеОрганизации	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Организация	,
							"СПриоритетомНоменклатуры, СистемаНалогообложенияДляТоваров, СистемаНалогообложенияДляАвансов");
	ДанныеНоменклатуры	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Номенклатура	,
							"ВидНалога, ТипНоменклатуры");
	
	Если Не ДанныеОрганизации.СПриоритетомНоменклатуры
		ИЛИ Не ЗначениеЗаполнено(ДанныеНоменклатуры.ВидНалога) Тогда
		
		Если ДанныеНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
			И ЗначениеЗаполнено(ДанныеОрганизации.СистемаНалогообложенияДляАвансов) Тогда
			
			Возврат ДанныеОрганизации.СистемаНалогообложенияДляАвансов;     			
		Иначе
			Возврат ДанныеОрганизации.СистемаНалогообложенияДляТоваров;
		КонецЕсли;
		
	Иначе
		Возврат ДанныеНоменклатуры.ВидНалога;
	КонецЕсли;
	
КонецФункции

// Функция - Проверить виды налога номеклатуры совпадают
//
// Параметры:
//  Номенклатура1		 - 	 - 
//  Номенклатура2		 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  Организация			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьВидыНалогаНомеклатурыСовпадают(Номенклатура1, Номенклатура2, СтруктурнаяЕдиница = Неопределено, Организация = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Организация) Тогда   
		Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		КонецЕсли;
		Организация = СтруктурнаяЕдиница.Организация;
	КонецЕсли;
	
	ДанныеОрганизации = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Организация,
							"СПриоритетомНоменклатуры, СистемаНалогообложенияДляТоваров, СистемаНалогообложенияДляАвансов");
		
	МассивНоменклатур = Новый Массив;
	МассивНоменклатур.Добавить(Номенклатура1);
	МассивНоменклатур.Добавить(Номенклатура2);
	ВидНалогаНоменклатура1 = Неопределено;
	ВидНалогаНоменклатура2 = Неопределено;

	Запрос       = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.ВидНалога КАК ВидНалога,
		|	Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В(&МассивНоменклатур)";	
	Запрос.УстановитьПараметр("МассивНоменклатур", МассивНоменклатур);	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.Ссылка = Номенклатура1 Тогда 
			 ВидНалога1       = Выборка.ВидНалога;
			 ТипНоменклатуры1 = Выборка.ТипНоменклатуры; 
		 Иначе
			 ВидНалога2       = Выборка.ВидНалога;
			 ТипНоменклатуры2 = Выборка.ТипНоменклатуры;
		КонецЕсли;
		
	КонецЦикла;
		
	Если Не ДанныеОрганизации.СПриоритетомНоменклатуры
		ИЛИ Не ЗначениеЗаполнено(ВидНалога1) Тогда
		Если ТипНоменклатуры1 = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
			И ЗначениеЗаполнено(ДанныеОрганизации.СистемаНалогообложенияДляАвансов) Тогда			
			ВидНалогаНоменклатура1 = ДанныеОрганизации.СистемаНалогообложенияДляАвансов;     			
		Иначе
			ВидНалогаНоменклатура1 = ДанныеОрганизации.СистемаНалогообложенияДляТоваров;
		КонецЕсли;
	Иначе
		ВидНалогаНоменклатура1 = ВидНалога1;
	КонецЕсли;
	
	Если Не ДанныеОрганизации.СПриоритетомНоменклатуры
		ИЛИ Не ЗначениеЗаполнено(ВидНалога2) Тогда
		Если ТипНоменклатуры2 = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
			И ЗначениеЗаполнено(ДанныеОрганизации.СистемаНалогообложенияДляАвансов) Тогда			
			ВидНалогаНоменклатура2 = ДанныеОрганизации.СистемаНалогообложенияДляАвансов;     			
		Иначе
			ВидНалогаНоменклатура2 = ДанныеОрганизации.СистемаНалогообложенияДляТоваров;
		КонецЕсли;
	Иначе
		ВидНалогаНоменклатура2 = ВидНалога2;
	КонецЕсли;
	
	Возврат (ВидНалогаНоменклатура1 = ВидНалогаНоменклатура2);
	
КонецФункции

// Процедура, возвращает стаку НДС номенклатуры.
//
Функция ПолучитьСтавкуНДСНоменклатуры(Номенклатура, СтруктурнаяЕдиница) Экспорт
	
	Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Организация = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "Организация");
	
	СтавкаНДС = Неопределено;
	
	ДанныеОрганизации	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Организация , "СПриоритетомНоменклатуры, СтавкаНДС, СтавкаНДСДляАвансов");
	ДанныеНоменклатуры	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Номенклатура, "СтавкаНДС, ТипНоменклатуры");
	
	Если НЕ ДанныеОрганизации.СПриоритетомНоменклатуры 
		ИЛИ (ДанныеОрганизации.СПриоритетомНоменклатуры И Не ЗначениеЗаполнено(ДанныеНоменклатуры.СтавкаНДС)) Тогда
		
		Если ДанныеНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
			И ЗначениеЗаполнено(ДанныеОрганизации.СтавкаНДСДляАвансов) Тогда
			
			Возврат ДанныеОрганизации.СтавкаНДСДляАвансов; 
		Иначе
			СтавкаНДС = ДанныеОрганизации.СтавкаНДС;
		КонецЕсли;
		
	Иначе
		СтавкаНДС = ДанныеНоменклатуры.СтавкаНДС;
	КонецЕсли;
	
	Возврат ?(ЗначениеЗаполнено(СтавкаНДС), СтавкаНДС, Перечисления.СтавкиНДС.БезНДС);	
	
КонецФункции

