#Область wallet

Функция walletPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СоответствиеСЗаголовками = ПолучитьСоответствиеЗаголовков(Запрос);
	
	api_key = СоответствиеСЗаголовками.Получить("apikey");
	
	ВнешняяСистема    = Неопределено;
	СообщениеОбОшибке = ПроверитьКлючПриложения(api_key, ВнешняяСистема); 
	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда		
		Возврат ПолучитьHTTPОтвет(СообщениеОбОшибке);
	КонецЕсли;
	
	Метод 		  = НРег(Запрос.ПараметрыURL["method"]);
	ПараметрыJSON = ПолучитьПараметрыJSON(Запрос);
	
	Если Метод = "webhook" Тогда		
		Ответ1с = Справочники.Карты.ОбработатьВебХук(ВнешняяСистема, ПараметрыJSON);		
	Иначе	
		Ответ1с = ПолучитьСтруктуруВозвратаОшибки(1040);		
	КонецЕсли;
	
	Возврат ПолучитьHTTPОтвет(Ответ1с);

