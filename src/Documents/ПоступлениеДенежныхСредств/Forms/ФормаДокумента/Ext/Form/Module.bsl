&НаКлиенте
// Процедура - Напечатать чек обработка
// Завершение процедуры Напечатать чек ответ.
//
Процедура ВыполнитьОперациюНаЭТиНапечататьЧекФР(ДопПараметры = Неопределено)
	
	Если ТипЗнч(ДопПараметры) = Тип("Структура") Тогда
		ПечататьЧек		= ?(ДопПараметры.Свойство("Печать"), ДопПараметры.Печать		  , Ложь);
		ПочтаКлиента	= ?(ДопПараметры.Свойство("ПокупательEmail"), ДопПараметры.ПокупательEmail, Неопределено);
		ТелефонКлиента	= ?(ДопПараметры.Свойство("ПокупательНомер"), ДопПараметры.ПокупательНомер, Неопределено);
	Иначе
		ПечататьЧек		= Истина;
		ПочтаКлиента	= Неопределено;
		ТелефонКлиента	= Неопределено;
	КонецЕсли;

	ДанныеЭквайринга = Неопределено;
	
	Если Не ЗначениеЗаполнено(Объект.НомерВходящегоДокумента)
		И ВыполнятьОперациюНаЭТ(Объект.ТипДенежныхСредств, Объект.ВидОперации, Объект.Касса, Объект.ЭквайрингТерминал) = Истина Тогда		
		ОписаниеОшибки = "";
		ДанныеЭквайринга = ВыполнитьОперациюНаЭТ(ОписаниеОшибки);
		Если НЕ ЗначениеЗаполнено(ДанныеЭквайринга) ИЛИ ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			Возврат;
		КонецЕсли; 	
	КонецЕсли;	    
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеИзКассыПредприятия") Тогда
		
		СтатусФР = РозничныеПродажи.ПроверитьИспользованиеФРвКассе(Объект.Касса);		
		
		Если СтатусФР Тогда
			
			// 2. Выполняем команду поступления денег на ФР 
			ДокументОснование = Новый Массив;
			ДокументОснование.Добавить(Объект.Ссылка);			
			ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(Объект.Касса);
			ПараметрыОперации = Новый Структура("ТипИнкассации, Сумма, ДокументОснование, Документ, Касса, Сотрудник",
			1, Объект.СуммаДокумента, ДокументОснование, Объект.Ссылка, Объект.Касса, Объект.АвторДокумента);
			ОповещениеПриЗавершении = Новый ОписаниеОповещения("ИнкассацияНаФискальномУстройствеЗавершение", ЭтотОбъект);
			МенеджерОборудованияКлиент.НачатьИнкассациюНаФискальномУстройстве(
			ОповещениеПриЗавершении, 
			УникальныйИдентификатор, 
			ПараметрыОперации, 
			ИдентификаторУстройстваФР);			
			
		КонецЕсли;	
		
	Иначе
		
		Если ИспользоватьСтаруюСистемуФормированияДляФРдляККТ(Объект.Касса) = Ложь Тогда
			ФормированиеЧека = ПодготовитьПараметрыЧекаДляККТ(ПочтаКлиента, ТелефонКлиента, ПечататьЧек);  		
		Иначе
			ФормированиеЧека = ПодготовитьПараметрыЧекаДляФР(ПочтаКлиента, ТелефонКлиента, ПечататьЧек); 
		КонецЕсли;
		
		Если ФормированиеЧека.Результат Тогда
			
			ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(Объект.Касса);
			
			Если ФормированиеЧека.Свойство("ФискальныйЧек") Тогда		
				
				Контекст = Новый Структура();
				Контекст.Вставить("ТипЧека", Истина);			
				Оповещение            = Новый ОписаниеОповещения("ПробитьЧекЗавершение"            , ЭтотОбъект, Контекст);
				ПослеОткрытияЧека     = Новый ОписаниеОповещения("ПечатьЧека_ПослеОткрытияЧека"    , ЭтотОбъект, Контекст);
				ПослеОшибкиПечатиЧека = Новый ОписаниеОповещения("ПечатьЧека_ПослеОшибкиПечатиЧека", ЭтотОбъект, Контекст);
				
				ОбщиеПараметры = ФормированиеЧека.ФискальныйЧек;
				МенеджерОборудованияКлиент.НачатьФискализациюЧекаНаФискальномУстройстве(Оповещение, УникальныйИдентификатор, ОбщиеПараметры, ИдентификаторУстройстваФР, , ПослеОткрытияЧека, ПослеОшибкиПечатиЧека);		
				
			КонецЕсли;			
			
			Если ФормированиеЧека.Свойство("НефискальныйЧек") Тогда
				
				ТекстЧека  = ФормированиеЧека.НефискальныйЧек;
				Контекст   = Новый Структура();
				Контекст.Вставить("ТипЧека", Ложь);
				Оповещение = Новый ОписаниеОповещения("ПробитьЧекЗавершение", ЭтотОбъект, Контекст);
				МенеджерОборудованияКлиент.НачатьПечатьТекста(Оповещение, УникальныйИдентификатор, ТекстЧека, ИдентификаторУстройстваФР);
				
			КонецЕсли;		
			
		Иначе
			
			ОписаниеОшибки = ФормированиеЧека.ОписаниеОшибки;
			ТекстСообщения = НСтр("ru='При проведение оплаты произошла ошибка.
			|Дополнительное описание: %ДополнительноеОписание%';
			|en='With holding payment happened mistake.
			|Additional description: %ДополнительноеОписание%'");
			
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);			
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НомерФискальногоЧека)
			ИЛИ ЗначениеЗаполнено(НомерНефискальногоЧека) Тогда
			
			Объект.НомерЧекаККМ = ?(ЗначениеЗаполнено(НомерФискальногоЧека), НомерФискальногоЧека, НомерНеФискальногоЧека);
			
			Если ЗначениеЗаполнено(НомерВходящегоДокумента) Тогда
				Объект.НомерВходящегоДокумента = НомерВходящегоДокумента;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДанныеЭквайринга) 
				И ТипЗнч(ДанныеЭквайринга) = Тип("Структура") Тогда
				
				Объект.ЭквайрингСсылочныйНомер      = ДанныеЭквайринга.СсылочныйНомер;
				Объект.ЭквайрингКодАвторизации      = ДанныеЭквайринга.КодАвторизации;
				Объект.ЭквайрингНомерЧека           = ДанныеЭквайринга.НомерЧека;
				Объект.ЭквайрингНомерПлатежнойКарты = ДанныеЭквайринга.НомерКарты;
				
			КонецЕсли;  			
			
			// перезаписываем кассовую смену по факту пробития на ФР.
			Попытка
				Объект.КассоваяСмена = РозничныеПродажи.ПолучитьТекущуюОткрытуюКассовуюСмену(Объект.Касса);
			Исключение
			КонецПопытки;
			
			ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));	
			
			УстановитьВидимость();
			
		КонецЕсли; 
	КонецЕсли;
		
КонецПроцедуры	

&НаКлиенте
// Процедура - Выполинть операцию на ЭТ
//
Функция ВыполнитьОперациюНаЭТ(ОписаниеОшибки)
	
	//ЭТКассы = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Касса, "ЭквайринговыйТерминал");
	ФРКассы = ПолучитьСсылкиНаОборудованиеФР();
		
	Возврат МенеджерОборудованияКлиент.ВыполнитьПоступлениеПлатежаЭквайринг(Объект.ЭквайрингТерминал, ФРКассы, ЭтаФорма.УникальныйИдентификатор, Объект.СуммаДокумента, ОписаниеОшибки);
	
