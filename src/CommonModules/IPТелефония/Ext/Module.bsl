// Процедура - IPТелефония получение записей по регламенту
// 
Процедура IPТелефонияПолучениеЗаписейПоРегламенту() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.IPТелефонияПолучениеЗаписей);
	
	ОтказВыполнения = Ложь;		
	РегламентныеЗаданияСерверСтоматология.АктуализироватьЗаданиеОчереди(Метаданные.РегламентныеЗадания.IPТелефонияПолучениеЗаписей, Истина, , ОтказВыполнения);
	Если ОтказВыполнения Тогда 
		Возврат;
	КонецЕсли;
	
	ПОIPТелефонии = ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM);
	Если ПОIPТелефонии <> Неопределено Тогда
		ROSTELECOM_ПолучитьURLЗаписейИЗаписатьВРегистр(ПОIPТелефонии, 100); // записи сразу не появляются на сайте, приходится через время получить ссылку на запись разговора.
	КонецЕсли;
	
	Если МенеджерОборудованияВызовСервера.ПолучитьСписокОборудования("IPТелефония").Количество() = 0 Тогда
		Возврат;
	ИначеЕсли Константы.ХранитьФайлыВТомахНаДиске.Получить() <> Истина Тогда
		ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.ПолучениеЗаписейПоРегламенту", УровеньЖурналаРегистрации.Предупреждение, , , "Для сохранения записей звонков необходимо включить параметр 'Хранение файлов в томах на диске'");
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 100
	               |	ИсторияВызовов.ОборудованиеТелефонии,
	               |	ИсторияВызовов.IDЗвонка,
	               |	ИсторияВызовов.НомерТелефона,
	               |	ИсторияВызовов.ПользовательSip,
	               |	ИсторияВызовов.Пользователь,
	               |	ИсторияВызовов.URLЗаписи
	               |ИЗ
	               |	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	               |ГДЕ
	               |	ИсторияВызовов.IDЗвонка <> """"
	               |	И ИсторияВызовов.URLЗаписи <> """"
	               |	И ИсторияВызовов.ФайлЗаписи = ЗНАЧЕНИЕ(Справочник.Файлы.ПустаяСсылка)
	               |	И ИсторияВызовов.ОкончаниеЗвонка <= ДОБАВИТЬКДАТЕ(&ТекущаяДата, МИНУТА, -5)
	               |	И ИсторияВызовов.ПопытокПолученияФайлаЗаписи < 5
	               |	И ИсторияВызовов.ОкончаниеЗвонка >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИсторияВызовов.ОкончаниеЗвонка";
	
	ОжидатьПослеЗапроса = Ложь;
	ЗаписьСИсторииВыборка = Запрос.Выполнить().Выбрать();
	Пока ЗаписьСИсторииВыборка.Следующий() Цикл
		
		Если ОжидатьПослеЗапроса = Истина Тогда
			Пауза_WScript_Shell(5); // Гребанный MANGO выбивает ошибку если подряд получать записи
		КонецЕсли;
		
		ОписаниеОшибки = "";
		ОжидатьПослеЗапроса = Истина;
		ДобавитьПопыткуПолучениеФайла(ЗаписьСИсторииВыборка.ОборудованиеТелефонии, ЗаписьСИсторииВыборка.IDЗвонка);
		
		Если ЗаписьСИсторииВыборка.ОборудованиеТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсMANGO Тогда
			IDЗаписи = ЗаписьСИсторииВыборка.URLЗаписи;
			IDЗаписи = Сред(IDЗаписи, 1, СтрНайти(IDЗаписи, "/", НаправлениеПоиска.СКонца)-1);
			IDЗаписи = Сред(IDЗаписи, СтрНайти(IDЗаписи, "/", НаправлениеПоиска.СКонца)+1);
			АдресВоВременномХранилище = MANGO_ПолучениеФайлаЗаписиРазговора(ЗаписьСИсторииВыборка.ОборудованиеТелефонии, IDЗаписи, ОписаниеОшибки);
				
		Иначе
			СтруктураПолучениеФайла = ПолучениеФайловИзИнтернета.СкачатьФайлВоВременноеХранилище(ЗаписьСИсторииВыборка.URLЗаписи,, Ложь);
			Если СтруктураПолучениеФайла.Статус = Истина Тогда
				АдресВоВременномХранилище = СтруктураПолучениеФайла.Путь;
			Иначе
				ОписаниеОшибки = СтруктураПолучениеФайла.СообщениеОбОшибке;
			КонецЕсли; 			
			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(АдресВоВременномХранилище) Тогда
			ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.ПолучениеЗаписейПоРегламенту", УровеньЖурналаРегистрации.Предупреждение, , , ОписаниеОшибки);
			Продолжить;
		КонецЕсли;
		
		ФайлСсылка = ПоместитьФайлВХранилищеФайлов(АдресВоВременномХранилище, ЗаписьСИсторииВыборка.ПользовательSip, ЗаписьСИсторииВыборка.НомерТелефона, ОписаниеОшибки);
		Если ФайлСсылка = Неопределено Тогда
			ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.ПолучениеЗаписейПоРегламенту", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
			Продолжить;
		КонецЕсли;		
		
		УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();		
		УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ЗаписьСИсторииВыборка.ОборудованиеТелефонии;
		УнифицированнаяСтруктураСобытия.IDЗвонка 					= ЗаписьСИсторииВыборка.IDЗвонка;
		УнифицированнаяСтруктураСобытия.ФайлСсылкаЗаписиРазговора	= ФайлСсылка;
		УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Ложь;
		
		ДобавитьОбновитьЗвонокВИсторию(, УнифицированнаяСтруктураСобытия);

	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

