// Функция - Инициализировать структуру содержания шаблона мессенджера
//
// Параметры:
//  ШаблонСообщения	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСтруктуруСодержанияШаблонаМессенджера(ШаблонСообщения) Экспорт 
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("СодержаниеМессенджерHTML"	, "");
	СтруктураВозврата.Вставить("СодержаниеМессенджер"		, "");
	СтруктураВозврата.Вставить("Содержание"					, "");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ШаблонСообщения", ШаблонСообщения);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШаблоныСообщений.СодержаниеМессенджерHTML КАК СодержаниеМессенджерHTML,
	|	ШаблоныСообщений.СодержаниеМессенджер КАК СодержаниеМессенджер,
	|	ШаблоныСообщений.Содержание КАК Содержание
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	ШаблоныСообщений.Ссылка = &ШаблонСообщения";
	
	ВыборкаСодержания = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаСодержания.Следующий() Тогда 
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, ВыборкаСодержания);
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

