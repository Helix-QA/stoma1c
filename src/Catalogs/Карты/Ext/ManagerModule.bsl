	Возврат ПараметрыJson;
	
КонецФункции

// Функция, возвращает тело запроса на рассылку push-сообщений.
// 
Функция ПолучитьТелоЗапросаМассовойРассылки(МассивСообщений, ЭтоГрупповаяРассылка = Ложь)
	
	ПараметрыJson = Новый Массив;
	
	Для Каждого Сообщение Из МассивСообщений Цикл
		Если ЗначениеЗаполнено(Сообщение.ВнутреннийКодКарты) Тогда
			ПараметрыJson.Добавить(ПолучитьСтруктуруPushСообщения(Сообщение, ЭтоГрупповаяРассылка));
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПараметрыJson;
		
КонецФункции

// Функция, возвращает структуру параметров для отправки push-сообщения.
// 
Функция ПолучитьСтруктуруPushСообщения(ДанныеСообщения, ЭтоГрупповаяРассылка = Ложь)
	
	ИмяПоля			 = ?(ЭтоГрупповаяРассылка, "news", "message");
	ИконкаСообщения	 = ПолучитьИконкиУведомлений().Сообщение;
	
	СтруктураСообщения = Новый Структура;
	СтруктураСообщения.Вставить("serial_number"	, ДанныеСообщения.ВнутреннийКодКарты);
	СтруктураСообщения.Вставить("fields"		, Новый Структура(ИмяПоля, ИконкаСообщения + ДанныеСообщения.ТекстСообщения));
	
	Возврат СтруктураСообщения;
	
КонецФункции

