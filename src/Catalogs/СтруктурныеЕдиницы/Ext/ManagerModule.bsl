// Функция вернет массив рабочих дней недели СЕ, если выставлен флаг ДобавитьВремяРаботы
// будет возвращен массив структур с рабочим временем
// Функция - вернет начало дня и окончание дня заданной СЕ
// 
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  ДеньНедели			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВремяРаботыСтруктурнойЕдиницы(
	Знач Дата 			  = Неопределено,
	Знач СтруктурнаяЕдиница = Неопределено,
	Знач ДеньНедели 		  = Неопределено,
	ТолькоВремя 			  = Истина) Экспорт
	
	Если Дата = Неопределено Тогда 
		Дата = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если СтруктурнаяЕдиница = Неопределено Тогда 
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Если ДеньНедели = Неопределено Тогда 
		ДеньНедели = ДеньНедели(Дата);
	КонецЕсли;		
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницыРасписаниеРаботы.НачалоРаботы КАК НачалоРаботы,
	|	СтруктурныеЕдиницыРасписаниеРаботы.ОкончаниеРаботы КАК ОкончаниеРаботы
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК СтруктурныеЕдиницыРасписаниеРаботы
	|ГДЕ
	|	ДЕНЬНЕДЕЛИ(СтруктурныеЕдиницыРасписаниеРаботы.ДеньНедели) = &ДеньНедели
	|	И СтруктурныеЕдиницыРасписаниеРаботы.Активность = ИСТИНА
	|	И СтруктурныеЕдиницыРасписаниеРаботы.Ссылка = &СтруктурнаяЕдиница");
	
	Запрос.УстановитьПараметр("ДеньНедели"        , ДеньНедели);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	РезВыборки = Запрос.Выполнить().Выбрать();
	
	Если РезВыборки.Следующий() Тогда
		Начало = ?(РезВыборки.НачалоРаботы = Дата(0001,01,01,00,00,00),  Дата(0001,01,01,00,00,00), РезВыборки.НачалоРаботы); 
		Конец  = ?(РезВыборки.ОкончаниеРаботы = Дата(0001,01,01,00,00,00) 
			ИЛИ РезВыборки.ОкончаниеРаботы = Дата(0001,01,02,00,00,00),  Дата(0001,01,01,23,59,59), РезВыборки.ОкончаниеРаботы); 
		
		Если НЕ ТолькоВремя Тогда 
			Начало  = НачалоДня(Дата) + Час(Начало)	* 3600 + Минута(Начало) *60;
			Конец 	= НачалоДня(Дата) + Час(Конец) 	* 3600 + Минута(Конец)	*60 + Секунда(Конец);
		КонецЕсли;
		
		Минуты 							= Цел((Конец - Начало) / 60);
		Часов  							= Цел(Минуты / 60);
		Минут 							= Минуты - (Часов * 60);
		Продолжительность  				= Дата(1, 1, 1) + Часов * 3600 + Минут * 60;
		ПродолжительностьПредставление 	= СокрЛП(?(Часов > 0 ,"" + Часов + ?(Часов = 1, " час ", " часа "), "") + ?(Минут > 0 ,"" + Минут + " мин.", ""));
					
		Возврат Новый Структура("НачалоРаботы, ОкончаниеРаботы, Продолжительность, ПродолжительностьПредставление",
			Начало, Конец, Продолжительность, ПродолжительностьПредставление);		
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

