Функция ПолучитьГруппуКлиенты()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЭтоГруппа = ИСТИНА
	|	И Контрагенты.Наименование = ""Клиенты""";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Процедура, формирует полисы страхования.
//
Процедура СформироватьПолисыСтрахования(СтрокаТаблицы)
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.НомерПолиса) И ЗначениеЗаполнено(СтрокаТаблицы.СтраховаяКомпания) Тогда 
		ВыборкаСтраховыхПолисов = Справочники.ПолисыМедицинскогоСтрахования.Выбрать( , , Новый Структура("Контрагент", СтрокаТаблицы.Клиент));
		ПолноеСовпадение = Ложь;
		Пока ВыборкаСтраховыхПолисов.Следующий() Цикл
			Если ВыборкаСтраховыхПолисов.СтраховаяКомпания = СтрокаТаблицы.СтраховаяКомпания Тогда
				Если ВыборкаСтраховыхПолисов.НомерПолиса = СокрЛП(СтрокаТаблицы.НомерПолиса) Тогда 
					Если ЗначениеЗаполнено(СтрокаТаблицы.СерияПолиса) Тогда 
						Если ВыборкаСтраховыхПолисов.СерияПолиса = СокрЛП(СтрокаТаблицы.СерияПолиса) Тогда								 
							ПолноеСовпадение = Истина;
							ПолисДляОбновленияДанных = ВыборкаСтраховыхПолисов.ПолучитьОбъект();
							Прервать;
						КонецЕсли;
					Иначе 
						ПолноеСовпадение = Истина;
						ПолисДляОбновленияДанных = ВыборкаСтраховыхПолисов.ПолучитьОбъект();
						Прервать;
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;	
		КонецЦикла;
		Если НЕ ПолноеСовпадение Тогда 
			// Создаем полис медицинского страхования
			НовыйОбъектПМС = Справочники.ПолисыМедицинскогоСтрахования.СоздатьЭлемент();
			НовыйОбъектПМС.Контрагент 			= СтрокаТаблицы.Клиент;
			НовыйОбъектПМС.ТипПолиса 			= СтрокаТаблицы.ТипПолиса;
			НовыйОбъектПМС.СтраховаяКомпания 	= СтрокаТаблицы.СтраховаяКомпания;
			НовыйОбъектПМС.СерияПолиса 			= ?(ЗначениеЗаполнено(СтрокаТаблицы.СерияПолиса), СтрокаТаблицы.СерияПолиса, "");
			НовыйОбъектПМС.НомерПолиса 			= СтрокаТаблицы.НомерПолиса;
			НовыйОбъектПМС.ДанаНачала 			= СтрокаТаблицы.НачалоДействияПолиса;
			НовыйОбъектПМС.ДатаОкончания 		= СтрокаТаблицы.КонецДействияПолиса;
			Попытка
				НовыйОбъектПМС.Записать();
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Неудалось создать полис медицинского страхования для пациента: " + Строка(СтрокаТаблицы.Клиент));
			КонецПопытки;					
		КонецЕсли;
		
		Если ПолноеСовпадение = Истина И ПолисДляОбновленияДанных <> Неопределено Тогда 
			// Будем обновлять данные полиса. 
			Если ЗначениеЗаполнено(ПолисДляОбновленияДанных.ДанаНачала) = Ложь И ЗначениеЗаполнено(СтрокаТаблицы.НачалоДействияПолиса) = Истина Тогда
				ПолисДляОбновленияДанных.ДанаНачала = СтрокаТаблицы.НачалоДействияПолиса;
			КонецЕсли;
			Если ЗначениеЗаполнено(ПолисДляОбновленияДанных.ДатаОкончания) = Ложь И ЗначениеЗаполнено(СтрокаТаблицы.КонецДействияПолиса) = Истина Тогда
				ПолисДляОбновленияДанных.ДатаОкончания = СтрокаТаблицы.КонецДействияПолиса;
			КонецЕсли;
			Если ЗначениеЗаполнено(ПолисДляОбновленияДанных.ТипПолиса) = Ложь И ЗначениеЗаполнено(СтрокаТаблицы.ТипПолиса) = Истина Тогда
				ПолисДляОбновленияДанных.ТипПолиса = СтрокаТаблицы.ТипПолиса;
			КонецЕсли;							
			ПолисДляОбновленияДанных.Записать();
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

// Функция - Получить папку по типу контрагента
//
Функция ПолучитьПапкуПоТипу(ТипКонтрагента) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("ТипКонтрагента"	, ТипКонтрагента);
	Запрос.Параметры.Вставить("Наименование"	, "%" + Строка(ТипКонтрагента) + "%");	
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Контрагенты.Ссылка КАК Ссылка,
	               |	1 КАК Приоритет,
	               |	Контрагенты.ТипКонтрагента КАК ТипКонтрагента
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	Контрагенты.ЭтоГруппа = ИСТИНА
	               |	И Контрагенты.ТипКонтрагента = &ТипКонтрагента
				   |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Контрагенты.Ссылка,
	               |	2,
	               |	Контрагенты.ТипКонтрагента
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	Контрагенты.ЭтоГруппа = ИСТИНА
	               |	И Контрагенты.Наименование ПОДОБНО &Наименование
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Приоритет";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	СоздатьРодителя 			= Ложь;	
	АктуализироватьРодителя 	= Ложь;
	ГруппаКонтрагентов 			= Неопределено;
	ГруппаКонтрагентов_Объект 	= Неопределено;

	Если Выборка.Следующий() Тогда
		ГруппаКонтрагентов = Выборка.Ссылка;
		Если НЕ ЗначениеЗаполнено(Выборка.ТипКонтрагента) Тогда 
			АктуализироватьРодителя = Истина;
		КонецЕсли;	
	Иначе
		СоздатьРодителя = Истина;
	КонецЕсли;
	
	Если СоздатьРодителя Тогда 
		ГруппаКонтрагентов_Объект 					= Справочники.Контрагенты.СоздатьГруппу();
	ИначеЕсли АктуализироватьРодителя Тогда      
		ГруппаКонтрагентов_Объект 					= ГруппаКонтрагентов.ПолучитьОбъект();
	КонецЕсли;
	
	Если НЕ ГруппаКонтрагентов_Объект = Неопределено Тогда 
		ГруппаКонтрагентов_Объект.Наименование 		= Строка(ТипКонтрагента);
		ГруппаКонтрагентов_Объект.ТипКонтрагента 	= ТипКонтрагента;
		// ГруппаКонтрагентов_Объект.Автокоррекция 	= 1;
		Попытка
			ГруппаКонтрагентов_Объект.Записать();
		Исключение
			
		КонецПопытки;	
		Возврат ГруппаКонтрагентов_Объект.Ссылка;
	Иначе 
		Возврат ГруппаКонтрагентов;
	КонецЕсли;
	
КонецФункции

// Процедура, заполнить медицинскую карту.
//
// Параметры:
//  НомерАмбулаторнойКарты	 - 	 - 
//  ВидМедицинскихКарт		 - 	 - 
//  ДатаЗавершения			 - 	 - 
//  НовыйЭлемент			 - 	 - 
//
Функция ЗаполнитьМедицинскуюКарту(НомерАмбулаторнойКарты, ВидМедицинскихКарт, ДатаРегистрацииМедКарты, ДатаЗавершения, НовыйЭлемент, НаименованиеКлиента)
	
	МедКарта = Справочники.МедицинскиеКарты.НайтиПоКоду(СокрЛП(НомерАмбулаторнойКарты));
	Если НЕ МедКарта.Пустая() Тогда
		Если МедКарта.ВладелецКарты <> НовыйЭлемент Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Мед. карта № "+СокрЛП(НомерАмбулаторнойКарты)+" принадлежит другому владельцу!");
			Возврат Неопределено;
		Иначе	
			МедКартаОбъект = МедКарта.ПолучитьОбъект();	
		КонецЕсли;	
	Иначе								
		
		МедКартаОбъект = Справочники.МедицинскиеКарты.СоздатьЭлемент();
		
	КонецЕсли;							
	
	МедКартаОбъект.Код					 = НомерАмбулаторнойКарты;
	МедКартаОбъект.ДатаРегистрации		 = ДатаРегистрацииМедКарты;			
	МедКартаОбъект.ДатаЗакрытия			 = ДатаЗавершения;
	МедКартаОбъект.ВидМедицинскойКарты	 = ?(ЗначениеЗаполнено(ВидМедицинскихКарт), ВидМедицинскихКарт, Справочники.ВидыМедицинскихКарт.ОсновнойВидМедицинскойКарты);		
	МедКартаОбъект.ВладелецКарты		 = НовыйЭлемент;
	МедКартаОбъект.ДополнительныеСвойства.Вставить("ВладелецКартыНаименование", НаименованиеКлиента);
	МедКартаОбъект.Записать();
 
	Справочники.МедицинскиеКарты.УстановитьМестоположениеМедицинскойКарты(МедКартаОбъект.Ссылка, Справочники.Местоположения.ВКлинике);
	
	Возврат МедКартаОбъект.Ссылка;
		
КонецФункции

// Функция, находит или если не найдена группа, то создает ее.
//
// Параметры:
//  РодительНаименование	 - Строка 				- Наименование группы которую ищем. 
//  РодительВерхнегоУровня	 - СправочникСсылка 	- Ссылка на справочник родителя группы которую ищем.
//  ТипНоменклатуры			 - ПеречислениеСсылка 	- Перечисление типов номенклатуры. 
// 
// Возвращаемое значение:
//  Родитель - Ссылка на группу номенклатуры.
//
Функция НайтиСоздатьГруппу(РодительНаименование, РодительВерхнегоУровня = Неопределено)
	
	Родитель = Справочники.Контрагенты.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЭтоГруппа = ИСТИНА
	|	И Контрагенты.Наименование = &Наименование
	|	И ВЫБОР
	|			КОГДА &РодительВерхнегоУровня <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Контрагенты.Родитель = &РодительВерхнегоУровня
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Наименование"          , РодительНаименование);
	Запрос.УстановитьПараметр("РодительВерхнегоУровня", РодительВерхнегоУровня);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Родитель = Выборка.Ссылка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Родитель) Тогда
		
		// Создать родителя
		РодительОбъект                 = Справочники.Контрагенты.СоздатьГруппу();
		РодительОбъект.Наименование    = РодительНаименование;
		Если ЗначениеЗаполнено(РодительВерхнегоУровня) Тогда 
			РодительОбъект.Родитель = РодительВерхнегоУровня;
		КонецЕсли;
		
		РодительОбъект.Записать();
		Родитель = РодительОбъект.Ссылка;
		
	КонецЕсли;
	
	Возврат Родитель;
	
КонецФункции

// Функция, создает клиента.
//
Функция СоздатьКлиента(Фамилия, Имя, Отчество = "", Телефон, Email, СтруктурнаяЕдиница = Неопределено, ДатаРождения, Пол = Неопределено, Адрес = Неопределено) Экспорт
	
	КлиентОбъект = Справочники.Контрагенты.СоздатьЭлемент();
	КлиентОбъект.Фамилия  			= Фамилия;
	КлиентОбъект.Имя      			= Имя;
	КлиентОбъект.Отчество 			= Отчество;
	КлиентОбъект.Наименование 		= КлиентОбъект.Фамилия + ?(ЗначениеЗаполнено(КлиентОбъект.Фамилия), " ", "") + КлиентОбъект.Имя + ?(ЗначениеЗаполнено(КлиентОбъект.Имя), " ", "") + КлиентОбъект.Отчество;
	КлиентОбъект.ТипКонтрагента 	= Перечисления.ТипыКонтрагентов.Клиенты;
	КлиентОбъект.ЮрФизЛицо 			= Перечисления.ЮрФизЛицо.ФизЛицо;
	КлиентОбъект.ДатаРегистрации 	= ТекущаяДатаСеанса();
	КлиентОбъект.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
	КлиентОбъект.Родитель 			= ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты);
	КлиентОбъект.ПолКлиента 		= ?(ЗначениеЗаполнено(Пол), Пол, ОбщегоНазначенияСтоматология.ОпределитьПолКлиента(Фамилия, Имя, Отчество));
	
	Попытка
		Если ЗначениеЗаполнено(ДатаРождения) Тогда
			КлиентОбъект.ДатаРожденияКлиента = Дата(Сред(ДатаРождения,1,4), Сред(ДатаРождения,6,2), Сред(ДатаРождения,9)); 
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Если ЗначениеЗаполнено(Телефон) Тогда
		УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(Телефон, Новый СписокЗначений);
		ДобавитьНомерТелефонаВКонтактнуюИнформациюКлиента(КлиентОбъект, Телефон);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Email) Тогда
		ДобавитьEmailВКонтактнуюИнформациюКлиента(КлиентОбъект, Email);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Адрес) Тогда
		Результат = РаботаСАдресами.КонвертироватьАдресИзJSONВXML(Адрес, "", Перечисления.ТипыКонтактнойИнформации.Адрес);
		ЗаполнитьАдрес(КлиентОбъект, Результат, Справочники.ВидыКонтактнойИнформации.АдресКлиента);
	КонецЕсли;
	
	Попытка
		КлиентОбъект.Записать();
	Исключение
		Инф = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат КлиентОбъект.Ссылка;
	
КонецФункции

// Процедура, добавляет телефон в табличную часть "КонтактнаяИнформация".
//
Процедура ДобавитьНомерТелефонаВКонтактнуюИнформациюКлиента(КлиентОбъект, НомерТелефона) Экспорт
	
	ОбъектXDTOИнформации 					= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(НомерТелефона, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
	НоваяСтрока 							= КлиентОбъект.КонтактнаяИнформация.Добавить();				
	НоваяСтрока.Тип 						= Перечисления.ТипыКонтактнойИнформации.Телефон;
	НоваяСтрока.Вид 						= Справочники.ВидыКонтактнойИнформации.ТелефонКлиента;
	НоваяСтрока.НомерТелефона 				= "" + ОбъектXDTOИнформации.Состав.КодСтраны + ОбъектXDTOИнформации.Состав.КодГорода + ОбъектXDTOИнформации.Состав.Номер;
	НоваяСтрока.НомерТелефонаБезКодов 		= ОбъектXDTOИнформации.Состав.Номер; 
	НоваяСтрока.НомерТелефонаБезКодаСтраны 	= ОбъектXDTOИнформации.Состав.КодГорода + ОбъектXDTOИнформации.Состав.Номер;		
	НоваяСтрока.НомерТелефонаПоследниеЦифры	= Прав(СокрЛП(ОбъектXDTOИнформации.Состав.Номер), 4);
	НоваяСтрока.Представление 				= НомерТелефона; // ОбъектXDTOИнформации.Представление;
	НоваяСтрока.ЗначенияПолей 				= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(ОбъектXDTOИнформации);
	
КонецПроцедуры

// Процедура, добавляет email в табличную часть "КонтактнаяИнформация".
//
Процедура ДобавитьEmailВКонтактнуюИнформациюКлиента(КлиентОбъект, АдресЭП) Экспорт
	
	ОбъектXDTOИнформации      = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(АдресЭП, Справочники.ВидыКонтактнойИнформации.EmailКлиента);
	НайденныеСтроки 		  = КлиентОбъект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип, Вид", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты, Справочники.ВидыКонтактнойИнформации.EmailКлиента));
	НоваяСтрока 			  = ?(НайденныеСтроки.Количество() > 0, НайденныеСтроки[0], КлиентОбъект.КонтактнаяИнформация.Добавить());
	НоваяСтрока.Тип 		  = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	НоваяСтрока.Вид 		  = Справочники.ВидыКонтактнойИнформации.EmailКлиента;
	НоваяСтрока.АдресЭП 	  = АдресЭП;
	НоваяСтрока.ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(ОбъектXDTOИнформации);
	НоваяСтрока.Представление = ОбъектXDTOИнформации.Представление;
	
КонецПроцедуры

#КонецОбласти

#Область ИсторияВзаимодействий

// Функция, формирует таблицу истории взаимодействия клиента.
//
Функция ПолучитьИсториюВзаимодействияКлиента(ПараметрыДанных, РежимПодробно = Ложь, Фильтры = Неопределено) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ПОМЕСТИТЬ ВТТелефоны
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ОбъектыОтбора
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка = &Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заявки.Ссылка
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ОсновнойКлиент = &Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	КонтактыМессенджеров.Идентификатор КАК Идентификатор
	|ПОМЕСТИТЬ ТаблицаИдентификаторовКонтактовМессенджеров
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|ГДЕ
	|	КонтактыМессенджеров.ОбъектИдентификации В
	|			(ВЫБРАТЬ
	|				ОбъектыОтбора.Ссылка КАК Ссылка
	|			ИЗ
	|				ОбъектыОтбора КАК ОбъектыОтбора)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТаблицаИдентификаторовКонтактовМессенджеров.Идентификатор КАК Идентификатор,
	|	ЕСТЬNULL(КонтактыМессенджеров.ФотоКлиента, """") КАК Фото
	|ПОМЕСТИТЬ ВтКонтактыМессенджеровИФото
	|ИЗ
	|	ТаблицаИдентификаторовКонтактовМессенджеров КАК ТаблицаИдентификаторовКонтактовМессенджеров
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
