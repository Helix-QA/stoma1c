// Функция -  проверяет наличия документа ф регистре свдеений Фискальные операции.
//
Функция ДокументЕстьВФискальныхОперациях(ДокументСсылка) Экспорт
	
	Запрос = Новый ЗАпрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ФискальныеОперацииДокументы.ИдентификаторЗаписи КАК ИдентификаторЗаписи
	|ИЗ
	|	РегистрСведений.ФискальныеОперацииДокументы КАК ФискальныеОперацииДокументы
	|ГДЕ
	|	ФискальныеОперацииДокументы.ДокументОснование = &ДокументОснование");
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументСсылка);
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции


