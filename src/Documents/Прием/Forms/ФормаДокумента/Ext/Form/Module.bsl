// Обработчик при начале редактирования данных таблицы
//
Процедура ТаблицаУслугиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)

	Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования)
		И НоваяСтрока
		И Копирование
		И Элемент.ТекущиеДанные <> Неопределено Тогда
		
		Объект.Лечение.Удалить(Элемент.ТекущиеДанные);
		ПоказатьПредупреждение(, "Запрещено копировать услугу по полису. Добавьте новую строку.");
		Возврат;
		
	КонецЕсли;
	
    КлючИсточника = Неопределено;
	Если НоваяСтрока Тогда
		КлючИсточника = Элемент.ТекущиеДанные.КлючСтроки;
		Элемент.ТекущиеДанные.КлючСтроки  = Новый УникальныйИдентификатор;
		Если НЕ Копирование Тогда 		
			Элемент.ТекущиеДанные.Сотрудник = Объект.Сотрудник;
			МассивЗубов = МассивВыделенныхЗубов.ВыгрузитьЗначения();
			Если МассивЗубов.Количество() = 0 Тогда
				Элемент.ТекущиеДанные.Зуб       = ОбщиеПараметры.Перечисление_Зубы_ВсяПолость;
			Иначе
				Элемент.ТекущиеДанные.Зуб		= МассивЗубов[0];
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
    // При копировании строик
	Если Копирование Тогда
		Элемент.ТекущиеДанные.Рекламация = Неопределено;	
		// Копирвоание материалов строки источника
		Если КлючИсточника <> Неопределено Тогда
			ПредставлениеСписка = "";
			НайденныеСтроки     = Объект.Материалы.НайтиСтроки(Новый Структура("КлючСтроки",КлючИсточника));
			Для Каждого СтрокаТ ИЗ НайденныеСтроки Цикл
