// 
Процедура НастроитьНажатиеЗавершение(Расписание, ДополнительныеПараметры) Экспорт
		
	Если Не Расписание = Неопределено Тогда

		ЭтотОбъект.Расписание = Расписание; 	
		СохранитьРасписание(); 
		УстановитьНадписьРасписания();
		
