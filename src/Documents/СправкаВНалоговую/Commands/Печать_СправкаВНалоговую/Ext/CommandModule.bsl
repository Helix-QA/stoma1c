
#Область ОбработчикиСобытий

&НаКлиенте
// Процедура - обработчик события "ОбработкаКоманды".
//
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	МассивДокументов = ПолучитьМассивПриемов(ПараметрКоманды);
	
	Если МассивДокументов = Неопределено Тогда 
		Возврат;
	ИначеЕсли ТипЗнч(МассивДокументов) = Тип("Массив") Тогда
		МассивДокументов.Добавить(ПараметрКоманды);
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.Прием", "ПФ_MXL_Справка", МассивДокументов, Неопределено, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Получить массив приемов
//
// Параметры:
//  Справка	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивПриемов(Справка)
	
	МассивВозврата = Новый Массив;
	
	Для Каждого СтрокаПрием Из Справка.Приемы Цикл
		МассивВозврата.Добавить(СтрокаПрием.Прием);	
	КонецЦикла;	
	
	Возврат МассивВозврата;
	
КонецФункции

#КонецОбласти