
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	Если Константы.ИспользоватьВидыЛицевыхСчетов.Получить() = Ложь Тогда
		Элементы.Таблица1ВидЛицевогоСчета.Видимость = Ложь;
	КонецЕсли;
	Элементы.СтруктурнаяЕдиницаНадпись.Заголовок = Объект.СтруктурнаяЕдиница;
	
	// СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	Настройки = Новый Структура("Продажи,БонусныеСчета,ПакетыУслуг,СерийныеНомераСертификатов,ДенежныеСредстваНаЛицевыхСчетах");
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Документы.ВводНачальныхОстатков.ТабличныеЧасти.Продажи, Настройки.Продажи, ЭтотОбъект, Ложь);
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Документы.ВводНачальныхОстатков.ТабличныеЧасти.БонусныеСчета, Настройки.БонусныеСчета, ЭтотОбъект, Ложь);
	// ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Документы.ВводНачальныхОстатков.ТабличныеЧасти.ПакетыУслуг, Настройки.ПакетыУслуг, ЭтотОбъект, Ложь);
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Документы.ВводНачальныхОстатков.ТабличныеЧасти.СерийныеНомераСертификатов, Настройки.СерийныеНомераСертификатов, ЭтотОбъект, Ложь);
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Документы.ВводНачальныхОстатков.ТабличныеЧасти.ДенежныеСредстваНаЛицевыхСчетах, Настройки.ДенежныеСредстваНаЛицевыхСчетах, ЭтотОбъект, Ложь);
	НастройкиЗагрузкиДанных = Новый ФиксированнаяСтруктура(Настройки);
	// Конец СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик событя "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УставитьТекущуюСтраницу();
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовФормы 

&НаКлиенте
// Процедура - Раздел учета при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура РазделУчетаПриИзменении(Элемент)
	
	// Установка текущей страницы формы.
	УставитьТекущуюСтраницу();
	
	Объект.СерийныеНомераСертификатов.Очистить();
	Объект.ДенежныеСредстваНаЛицевыхСчетах.Очистить();
	Объект.Продажи.Очистить();  
	Объект.РасчетыСПодотчетниками.Очистить();
	Объект.РасчетыСПерсоаналом.Очистить();
	Объект.ВзаиморасчетыСКонтрагентами.Очистить();
	Объект.БонусныеСчета.Очистить();

КонецПроцедуры 

&НаКлиенте 
// Процедура, Дата при изменении.
//
Процедура ДатаПриИзменении(Элемент)

    ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура - Структурная единица надпись нажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура СтруктурнаяЕдиницаНадписьНажатие(Элемент)  
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ЭтоПользователь", Истина);
    СтруктураПараметров.Вставить("Ссылка", ОбщегоНазначенияСтоматология.ДоступныеСтруктурныеЕдиницы()); 
	СтруктураПараметров.Вставить("ВидСравненияКомпоновкиДанных", ВидСравненияКомпоновкиДанных.ВСписке);

	ОткрытьФорму("Справочник.СтруктурныеЕдиницы.ФормаВыбора", СтруктураПараметров,,,,, Новый ОписаниеОповещения("ОбработкаВыбораСтруктурнойЕдиницы", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
   
КонецПроцедуры

#Область СерийныеНомераСертификатов

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура СерийныеНомераСертификатовПартияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СтрокаТабличнойЧасти = Элементы.СерийныеНомераСертификатов.ТекущиеДанные;
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
			
		мПараметрыВыбора = Новый Структура;
		мПараметрыВыбора.Вставить("Владелец"                       , СтрокаТабличнойЧасти.Номенклатура);
		мПараметрыВыбора.Вставить("Склад"                          , ВернутьСклад());
		мПараметрыВыбора.Вставить("СтруктурнаяЕдиница"             , Объект.СтруктурнаяЕдиница);
		мПараметрыВыбора.Вставить("Дата"                           , Объект.Дата);
        мПараметрыВыбора.Вставить("МножественныйВыбор"             , Истина);

		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", мПараметрыВыбора,,,,, Новый ОписаниеОповещения("ВыборПартииЗавершение", ЭтотОбъект, Новый Структура("СтрокаТабличнойЧасти", СтрокаТабличнойЧасти)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поля "Номенклатура" табличноый части "СерийныеНомераСертификатов".
//
Процедура СерийныеНомераСертификатовНоменклатураПриИзменении(Элемент)
		
	ТекСертификат = Элементы.СерийныеНомераСертификатов.ТекущиеДанные.Номенклатура;
	Элементы.СерийныеНомераСертификатов.ТекущиеДанные.Количество = 1;
	Элементы.СерийныеНомераСертификатов.ТекущиеДанные.Сумма = ВернутьЗначениеРеквизитаСправочника(ТекСертификат, "Номинал");
	СертификатСерийный = ВернутьЗначениеРеквизитаСправочника(ТекСертификат, "ИспользоватьПартии");
    СтрокаТабличнойЧасти = Элементы.СерийныеНомераСертификатов.ТекущиеДанные;
	СтрокаТабличнойЧасти.ИспользоватьПартии = СертификатСерийный; 
	СтрокаТабличнойЧасти.ЭтоИменнойСертификат =  ВернутьЗначениеРеквизитаСправочника(ТекСертификат, "ЭтоИменнойСертификат");
	СтрокаТабличнойЧасти.СертификатМногоразовоеИспользование = ВернутьЗначениеРеквизитаСправочника(ТекСертификат, "СертификатМногоразовоеИспользование");
	СтрокаТабличнойЧасти.ВидНоминала = ВернутьЗначениеРеквизитаСправочника(ТекСертификат, "ВидНоминала");
	
КонецПроцедуры

&НаКлиенте
// Процедура - Серийные номера сертификатов при активизации ячейки
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура СерийныеНомераСертификатовПриАктивизацииЯчейки(Элемент)  
	
	ТекущаяСтрока = Элементы.СерийныеНомераСертификатов.ТекущиеДанные;	
	Если ТекущаяСтрока <> Неопределено Тогда
		Элементы.СерийныеНомераСертификатовКоличество.ТолькоПросмотр = ТекущаяСтрока.ИспользоватьПартии;
		Элементы.СерийныеНомераСертификатовКлиент.ТолькоПросмотр = не ТекущаяСтрока.ЭтоИменнойСертификат;
        Элементы.СерийныеНомераСертификатовСумма.ТолькоПросмотр = не ТекущаяСтрока.СертификатМногоразовоеИспользование;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте 
// Процедура, Обработчик события "ТаблицаДенежныеСредстваНаЛицевыхСчетахПриНачалеРедактирования".
//
Процедура ТаблицаДенежныеСредстваНаЛицевыхСчетахПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		Элемент.ТекущиеДанные.ВидЛицевогоСчета = ПредопределенноеЗначение("Справочник.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Расчеты с подотчетниками сотрудник начало выбора.
//
Процедура РасчетыСПодотчетникамиСотрудникНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;  
	ФормаПараметрыВыбора = Новый Структура("ОтбиратьВрачей, БезОтбораПоРолям, ВыводитьПомеченныхНаУдаление", Ложь, Истина, Истина);
	ОписаниеОповещения   = Новый ОписаниеОповещения("РасчетыСПодотчетникамиСотрудникНачалоВыбораЗавершение", ЭтаФорма);	
	ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора", ФормаПараметрыВыбора,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры  

#Область ВзаиморасчетыСКонтрагентами

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
Процедура ВзаиморасчетыСКонтрагентамиКонтрагентПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ВзаиморасчетыСКонтрагентами.ТекущиеДанные;
	ТекущаяСтрока.ДокументРеализации = Неопределено;
	ТекущаяСтрока.Сумма = 0;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура ВзаиморасчетыСКонтрагентамиДокументРеализацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтрокаТабличнойЧасти = Элементы.ВзаиморасчетыСКонтрагентами.ТекущиеДанные;
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Контрагент) Тогда
		СтандартнаяОбработка = Ложь;
		мПараметрыВыбора = Новый Структура;
		мПараметрыВыбора.Вставить("Контрагент"        , СтрокаТабличнойЧасти.Контрагент);
		мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);

		ОткрытьФорму("Документ.Прием.Форма.ФормаВыбора", мПараметрыВыбора,,,,, Новый ОписаниеОповещения("ВыборПриемаЗавершение", ЭтотОбъект, Новый Структура("СтрокаТабличнойЧасти", СтрокаТабличнойЧасти)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте 
// Процедура, обработчик события "БонусныеСчетаБонусныйСчетНачалоВыбора" 
//
Процедура БонусныеСчетаБонусныйСчетНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	 ТекущиеДанные = Элементы.БонусныеСчета.ТекущиеДанные;
	 
	 Если ЗначениеЗаполнено(ТекущиеДанные.Контрагент) Тогда
		 
		  СтандартнаяОбработка = Ложь;
		  МассивБонусныхСчетов = ПолучитьБонусныеСчетаКонтрагента(ТекущиеДанные.Контрагент);
		  ДанныеВыбора = Новый СписокЗначений;
		  ДанныеВыбора.ЗагрузитьЗначения(МассивБонусныхСчетов);
		  
	 КонецЕсли;	
	 
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиКомандФормы
  
&НаКлиенте
// Процедура - Скрыть показать дополнительно
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СкрытьПоказатьДополнительно(Команда) 
	
	Элементы.ГруппаДополнительно.Видимость = Не Элементы.ГруппаДополнительно.Видимость;
	
КонецПроцедуры

#Область ЗагрузкаДанныхИзВнешнегоИсточника

&НаКлиенте
// Процедура - Загрузить данные из внешнего источника продажи.
//
Процедура ЗагрузитьДанныеИзВнешнегоИсточникаПродажи(Команда)
	
	ТекущаяНастройкаЗагрузкиДанных = НастройкиЗагрузкиДанных.Продажи;
	ТекущаяНастройкаЗагрузкиДанных.ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.Продажи";
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузкаДанныхИзВнешнегоИсточникаОбработкаРезультата", ЭтотОбъект, ТекущаяНастройкаЗагрузкиДанных);
	ЗагрузкаДанныхИзВнешнегоИсточникаКлиент.ПоказатьФормуЗагрузкиДанныхИзВнешнегоИсточника(ТекущаяНастройкаЗагрузкиДанных, ОписаниеОповещения, ЭтотОбъект);

КонецПроцедуры 

