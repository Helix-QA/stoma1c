&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ВидСделкиОтбор(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораВидаСделки", ЭтотОбъект);
	ПоказатьВыборИзМеню(ОписаниеОповещения, ЭтотОбъект.ДоступныеВидыСделок, Элементы.ИзменитьВидСделки);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОткрытьКанбан(Команда)
	
	ФормаКанбана = ПолучитьОткрытуюФорму("Справочник.Сделки.Форма.ФормаСпискаКанбан");
	
	ПараметрыОтбора = ПараметрыВыбранныхФильтровКлиент();
	ПараметрыОтбора.Вставить("ВидСделки"			, ЭтотОбъект.ОтборВидСделки);
	ПараметрыОтбора.Вставить("ОтборСтатусПациента"	, ЭтотОбъект.ОтборСтатусПациента);
	ПараметрыОтбора.Вставить("ОтборПоЗадачам"		, ЭтотОбъект.ОтборПоЗадачам);
	
	Если ФормаКанбана = Неопределено Тогда
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ПараметрыОтбора", ПараметрыОтбора);
		
		ОткрытьФорму("Справочник.Сделки.Форма.ФормаСпискаКанбан", ПараметрыОткрытия);
		
	Иначе
		ФормаКанбана.Активизировать();
		ФормаКанбана.УстановитьОтбор(ПараметрыОтбора);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события команды "Изменить".
//
Процедура Изменить(Команда)
	
	// Получаем выделенные элементы с динамического списка.
	ВыделенныеЭлементы = Элементы.Список.ВыделенныеСтроки.Количество();
	ЭтотОбъект.Действие = ?(ЗначениеЗаполнено(ЭтотОбъект.Действие), ЭтотОбъект.Действие, "РекламныйИсточник"); 	
	
	// Устанавливаем параметры для открытия формы.
	ПараметрыФормы = Новый Структура;
	
	ПараметрыФормы.Вставить("Действие"			 , ЭтотОбъект.Действие);
	ПараметрыФормы.Вставить("ВыделенныеЭлементы" , ВыделенныеЭлементы);
	ПараметрыФормы.Вставить("Количество"		 , ЭтотОбъект.КоличествоСделок);
	
	Если ЭтотОбъект.Действие = "Менеджера" Тогда
		
		ПараметрыФормы.Вставить("ДанныеДействия" 	 , ПолучениеТаблицыДействия());
		ПараметрыФормы.Вставить("ЗаменитьМенеджера"  , ЭтотОбъект.ЗаменитьМенеджераПоПродажамВКлиенте);
		ПараметрыФормы.Вставить("ЗаменитьИсполнителя", ЭтотОбъект.ЗаменитьИсполнителяВНеЗавершенныхЗадачах);
				
	КонецЕсли;
	
	ОткрытьФорму("Справочник.Сделки.Форма.ФормаИзменить", 
				 ПараметрыФормы,,,,,
				 Новый ОписаниеОповещения("ИзменитьЗавершение", ЭтотОбъект),
				 РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаКлиенте
// Процедура Обработчик описания оповещения.
//
Процедура ИзменитьЗавершение(Результат, ДопПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		
		// Заполнение "Действие".
		Если Результат.Свойство("Действие") Тогда
			ЭтотОбъект.Действие = Результат.Действие;
			
			Если Результат.Действие = "Менеджера" Тогда
				
				// Заполнение таблицы значений ТаблицаДействия.
				Если Результат.Свойство("ДанныеДействия") Тогда
					ЗаполнениеТаблицыДействия(Результат.ДанныеДействия);
				КонецЕсли;
				
				// Установка параметра ЗаменитьМенеджераПоПродажамВКлиенте.
				Если Результат.Свойство("ЗаменитьМенеджера") Тогда
					ЭтотОбъект.ЗаменитьМенеджераПоПродажамВКлиенте = Результат.ЗаменитьМенеджера;
				КонецЕсли;
				
				// Установка параметра ЗаменитьИсполнителяВНеЗавершенныхЗадачах.
				Если Результат.Свойство("ЗаменитьИсполнителя") Тогда
					ЭтотОбъект.ЗаменитьИсполнителяВНеЗавершенныхЗадачах = Результат.ЗаменитьИсполнителя;
				КонецЕсли;
				
			ИначеЕсли Результат.Действие = "РекламныйИсточник" ИЛИ Результат.Действие = "КаналПривлечения" Тогда
				
				// Заполнение поля ЗначениеДействия. 
				Если Результат.Свойство("ЗначениеДействия") Тогда
					ЭтотОбъект.ЗначениеДействия = Результат.ЗначениеДействия;
				КонецЕсли;
				
			ИначеЕсли Результат.Действие = "ВидСделки" Тогда
				
				// Заполнение поля ВидСделки. 
				Если Результат.Свойство("ВидСделкиВыбор") Тогда
					ЭтотОбъект.ВидСделки = Результат.ВидСделкиВыбор;
				КонецЕсли;
				
				// Заполнение поля Этап. 
				Если Результат.Свойство("Этап") Тогда
					ЭтотОбъект.ЗначениеДействия = Результат.Этап;
				КонецЕсли;
				
			КонецЕсли;
			
			// Выполнение выбранной команды. 
			Если Результат.Свойство("ИмяВыбраннойКоманды") Тогда
				
				Если Результат.ИмяВыбраннойКоманды = "ПрименитьКВыделенным"  Тогда
					
					ВыделенныеЭлементы = Элементы.Список.ВыделенныеСтроки.Количество();
					
					Вопрос = СтрШаблон(НСтр("ru='Внимание!!! Изменения будут применены ко всем %1 выделенным строкам в списке. Эти изменения необратимы. Продолжить?';en='Attention!!! Changes will be applied to to all %1 selected lines in list. These changes are irreversible. Continue?'"), ВыделенныеЭлементы);
					
					Оповещение = Новый ОписаниеОповещения("ПослеВопросаОбИзменении", ЭтотОбъект, Новый Структура("КоличествоВыделенныхСтрок", ВыделенныеЭлементы)); 
					
				ИначеЕсли Результат.ИмяВыбраннойКоманды = "ПрименитьКоВсем" Тогда 
					
					Вопрос = СтрШаблон(НСтр("ru='Внимание!!! Изменения будут применены ко всем %1 видимым строкам в списке (даже не выделенным). Эти изменения необратимы. Продолжить?';en='Attention!!! Changes will be applied to all %1 visible lines in list not even selected). These changes are irreversible. Continue?'"), ЭтотОбъект.КоличествоСделок);
					
					Оповещение = Новый ОписаниеОповещения("ПослеВопросаОбИзменении", ЭтотОбъект); 
					
				КонецЕсли;
				
				ПоказатьВопрос(Оповещение,
				Вопрос,
				РежимДиалогаВопрос.ДаНет,
				0, // таймаут в секундах
				КодВозвратаДиалога.Да, // (необ.) кнопка по умолчанию
				НСтр("ru='Вопрос пользователю';en='Question to user'"));  // (необ.) заголовок
					
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		Возврат;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, заполнение данных в ТаблицаДействия.
//
Процедура ЗаполнениеТаблицыДействия(АдресВХ)
	
	ТаблицаДействия.Очистить();
	
	ДанныеДействия = ПолучитьИзВременногоХранилища(АдресВХ);
	
	Для каждого СтрокаТЗ из ДанныеДействия Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаДействия.Добавить(), СтрокаТЗ) 
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Функция, получение данных из ТаблицаДействия.
//
Функция ПолучениеТаблицыДействия()
		
	Возврат ПоместитьВоВременноеХранилище(ТаблицаДействия.Выгрузить(), Новый УникальныйИдентификатор); 
	
КонецФункции

&НаКлиенте
// Процедура, ПослеВопросаОбИзменении.
//
Процедура ПослеВопросаОбИзменении(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ПрименитьНаСервере(ДопПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды.
//
Процедура УстановитьФильтрПостоянные(Команда)
	
	СтатусПостоянный = ПредопределенноеЗначение("Перечисление.СтатусыКонтрагентов.Постоянный");
	
	ЭтотОбъект.ОтборСтатусПациента = ?(ЭтотОбъект.ОтборСтатусПациента = СтатусПостоянный, Неопределено, СтатусПостоянный);
	УстановитьОтображениеФильтраСтатусПациента(ЭтотОбъект);
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры

&НаКлиенте
