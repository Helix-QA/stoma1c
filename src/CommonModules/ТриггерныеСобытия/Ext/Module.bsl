	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область _________ДИНАМИЧЕСКОЕ_ПОСТРОЕНИЕ_ДЕЙСТВИЙ_ТРИГГЕРНЫХ_СОБЫТИЙ________

Процедура ОбновитьОтображениеТаблицыДействий(Форма, СозданиеФормы = Ложь, ДобавитьЭлементВвода = Ложь, ВыводитьУдаленные = Ложь) Экспорт
	
	Если Форма.Объект.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь)).Количество() = 0 ИЛИ СозданиеФормы ИЛИ ДобавитьЭлементВвода Тогда 
		НоваяСтрока 						= Форма.Объект.Действия.Добавить();
		НоваяСтрока.ИдентификаторДействия 	= Новый УникальныйИдентификатор();
		// Если ДобавитьЭлементВвода Тогда 
		//	НоваяСтрока.Использование 			= Истина;
		// КонецЕсли; 
	КонецЕсли;
	
	// Определяем родительские группы
	ГруппаРазмещенияДействий		= Форма.Элементы.Найти("ГруппаДействий");
	ГруппаРазмещенияДействийШаблон 	= Форма.Элементы.Найти("ГруппаДействий_Шаблон_");
	
	// Инициализируем параметры
	ПараметрыОтображенияЭлементов = ИнициализироватьСтруктуруПараметровОтрисовки(Форма, ВыводитьУдаленные);
	
	// Обновим текущие действия
	Если НЕ ГруппаРазмещенияДействий = Неопределено Тогда 
		// Очищаем родительские группы					
		УдалитьЭлементыГруппы(Форма, ГруппаРазмещенияДействий);
		// Создаем элементы
		ОбновитьЭлементыНастроекНаФормеСогласноШаблона(Форма, ГруппаРазмещенияДействий, ГруппаРазмещенияДействийШаблон, , , ПараметрыОтображенияЭлементов);
		// Отключаем видимость у шаблона
		ГруппаРазмещенияДействийШаблон.Видимость = Ложь;
		// Форма.УстановитьСвойстваЭлементамДействий();
	КонецЕсли;

КонецПроцедуры

// Функция - Инициализировать структуру параметров отрисовки
//
// Параметры:
//  Объект	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСтруктуруПараметровОтрисовки(Форма, ВыводитьУдаленные)
	
	ПараметрыОтрисовки = Форма.ИнициализироватьСтруктуруПараметровОтрисовки();
	
	// Помещаем сам объект
	ПараметрыОтрисовки.Вставить("Владелец"			, Форма.Объект);
	// Признак вывода удаленных
	ПараметрыОтрисовки.Вставить("ВыводитьУдаленные"	, ВыводитьУдаленные);
	
	Возврат ПараметрыОтрисовки;
	
КонецФункции

// Процедура - Удалить элементы группы
//
// Параметры:
//  Форма				 - 	 - 
//  РодительскаяГруппа	 - 	 - 
//
Процедура УдалитьЭлементыГруппы(Форма, РодительскаяГруппа) Экспорт
	
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из Форма.Элементы[РодительскаяГруппа.Имя].ПодчиненныеЭлементы Цикл
		// Если ГруппаЭлементов.Имя = "ГруппаПланирования" Тогда 
		//	Продолжить;
		// КонецЕсли;	
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Форма.Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Обновить элементы на форме согласно шаблона
//
// Параметры:
//  Форма				 - 	 - 
//  ГруппаДляРазмещения	 - 	 - 
//  ГруппаШаблон		 - 	 - 
//  БизнесПроцессСсылка	 - 	 - 
//  ИндексСтроки		 - 	 - 
//  СтрокаТаблицы		 - 	 - 
//
Процедура ОбновитьЭлементыНастроекНаФормеСогласноШаблона(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки = Неопределено, СтрокаТаблицы = Неопределено, ПараметрыОтображенияЭлементов = Неопределено)
	
	Если Форма.Объект.Действия.Количество() = 0 Тогда 
		СрисоватьСШаблонаНастроек(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки, СтрокаТаблицы);
	ИначеЕсли ГруппаШаблон.Имя = "ГруппаДляПолученияИнтервала_Шаблон_" Тогда
		МассивАктуальныхСтрок = ПараметрыОтображенияЭлементов.Владелец.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь));		
		Для Каждого СтрокаТаблицы Из Форма.Объект.Действия Цикл
			Если НЕ ПараметрыОтображенияЭлементов.ВыводитьУдаленные И СтрокаТаблицы.Удалено Тогда 
				Продолжить;
			КонецЕсли;	
			ИндексСтроки = Форма.Объект.Действия.Индекс(СтрокаТаблицы);
			Если ТипЗнч(ПараметрыОтображенияЭлементов) = Тип("Структура") Тогда 
				ПараметрыОтображенияЭлементов.Вставить("ЭтоПерваяАктуальнаяСтрока", ?(МассивАктуальныхСтрок.Количество() = 0, Истина, ИндексСтроки = ПараметрыОтображенияЭлементов.Владелец.Действия.Индекс(МассивАктуальныхСтрок[0])));
			КонецЕсли;	
			СрисоватьСШаблонаНастроек(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
		КонецЦикла;
	Иначе 
		СрисоватьСШаблонаНастроек(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Обновить элементы настроек каналов уведомлений на форме согласно шаблона
//
// Параметры:
//  Форма							 - 	 - 
//  ГруппаДляРазмещения				 - 	 - 
//  ГруппаШаблон					 - 	 - 
//  ИндексСтроки					 - 	 - 
//  СтрокаТаблицы					 - 	 - 
//  ПараметрыОтображенияЭлементов	 - 	 - 
//
Процедура ОбновитьЭлементыНастроекКаналовУведомленийНаФормеСогласноШаблона(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки = Неопределено, СтрокаТаблицы = Неопределено, ПараметрыОтображенияЭлементов = Неопределено) Экспорт
	
	Если Форма.МоделируемыеНастройкиКаналовУведомлений.Количество() = 0 Тогда 
		СрисоватьСШаблонаНастроекКаналов(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки, СтрокаТаблицы);
	ИначеЕсли ГруппаШаблон.Имя = "ГруппаДляПолученияИнтервала_Шаблон_" Тогда
		Для Каждого СтрокаТаблицы Из Форма.МоделируемыеНастройкиКаналовУведомлений Цикл
			Если НЕ Форма.ИдентификаторДействия = СтрокаТаблицы.ИдентификаторДействия Тогда 
				Продолжить;
			КонецЕсли;
			ИндексСтроки = Форма.МоделируемыеНастройкиКаналовУведомлений.Индекс(СтрокаТаблицы);
			//Если Форма.ИмяФормы = "Справочник.ТриггерныеСобытия.Форма.ФормаЭлемента" Тогда 
				Форма.ИнициализироватьСтруктуруПараметровОтрисовки(, ИндексСтроки);			
			//КонецЕсли;	
			СрисоватьСШаблонаНастроекКаналов(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
		КонецЦикла;
	Иначе 
		СрисоватьСШаблонаНастроекКаналов(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Срисовать с шаблона
//
// Параметры:
//  Форма				 - 	 - 
//  ГруппаДляРазмещения	 - 	 - 
//  ГруппаШаблон		 - 	 - 
//  БизнесПроцессСсылка	 - 	 - 
//  ИндексСтроки		 - 	 - 
//  СтрокаТаблицы		 - 	 - 
//
Процедура СрисоватьСШаблонаНастроек(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки = Неопределено, СтрокаТаблицы = Неопределено, ПараметрыОтображенияЭлементов = Неопределено)
	
	Для Каждого ЭлементФормы Из ГруппаШаблон.ПодчиненныеЭлементы Цикл
		ИндексСтрокой = ?(ИндексСтроки = Неопределено, "", "_Индекс_" + Строка(ИндексСтроки));		
		Если ТипЗнч(ЭлементФормы) = Тип("ГруппаФормы") Тогда
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ГруппаФормы"), ГруппаДляРазмещения);
			НовыйЭлемент.Вид = ЭлементФормы.Вид;
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы, , ПолучитьСписокИсключенныхСвойств(ЭлементФормы.Вид));
			МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, , ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
			ОбновитьЭлементыНастроекНаФормеСогласноШаблона(Форма, НовыйЭлемент, ЭлементФормы, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ДекорацияФормы") Тогда 
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ДекорацияФормы"), ГруппаДляРазмещения);
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы);
            МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, , ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
			УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ДекорацияФормы"));
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ПолеФормы") Тогда  
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ПолеФормы"), ГруппаДляРазмещения);
			НовыйЭлемент.Вид = ЭлементФормы.Вид;
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы, , ПолучитьСписокИсключенныхСвойств(ЭлементФормы.Вид));
			СкопироватьСписокВыбораЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ПолеФормы"));
			МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, , ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
			УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ПолеФормы"));			
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") Тогда
			// Если ЭлементФормы.Имя = "Кнопка_ДобавитьСервисныйЗвонок_Шаблон_" Тогда 
			//	ИндексСтрокой = "";
			// КонецЕсли;	
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("КнопкаФормы"), ГруппаДляРазмещения);
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы);				
			НоваяКоманда = Форма.Команды.Найти(СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + ИндексСтрокой);
			ШаблонКоманда = Форма.Команды.Найти(НовыйЭлемент.ИмяКоманды);
			Если НЕ НоваяКоманда = Неопределено Тогда 
				// Удалим команду
				Форма.Команды.Удалить(НоваяКоманда);
			КонецЕсли;
			// Создаем команду
			НоваяКоманда = Форма.Команды.Добавить(СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + ИндексСтрокой);
			ЗаполнитьЗначенияСвойств(НоваяКоманда, ШаблонКоманда);
			НоваяКоманда.Действие = "Подключаемый_" + СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + "_ВыполнитьКоманду";				
			НовыйЭлемент.ИмяКоманды = НоваяКоманда.Имя;
			МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, НоваяКоманда, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Срисовать с шаблона настроек каналов
//
// Параметры:
//  Форма							 - 	 - 
//  ГруппаДляРазмещения				 - 	 - 
//  ГруппаШаблон					 - 	 - 
//  ИндексСтроки					 - 	 - 
//  СтрокаТаблицы					 - 	 - 
//  ПараметрыОтображенияЭлементов	 - 	 - 
//
Процедура СрисоватьСШаблонаНастроекКаналов(Форма, ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки = Неопределено, СтрокаТаблицы = Неопределено, ПараметрыОтображенияЭлементов = Неопределено)
	
	Для Каждого ЭлементФормы Из ГруппаШаблон.ПодчиненныеЭлементы Цикл
		ИндексСтрокой = ?(ИндексСтроки = Неопределено, "", "_Индекс_" + Строка(ИндексСтроки));		
		Если ТипЗнч(ЭлементФормы) = Тип("ГруппаФормы") Тогда
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ГруппаФормы"), ГруппаДляРазмещения);
			НовыйЭлемент.Вид = ЭлементФормы.Вид;
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы, , ПолучитьСписокИсключенныхСвойств(ЭлементФормы.Вид));
			МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, , ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
			ОбновитьЭлементыНастроекКаналовУведомленийНаФормеСогласноШаблона(Форма, НовыйЭлемент, ЭлементФормы, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ДекорацияФормы") Тогда 
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ДекорацияФормы"), ГруппаДляРазмещения);
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы);
            МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, , ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
			УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ДекорацияФормы"));
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ПолеФормы") Тогда  
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ПолеФормы"), ГруппаДляРазмещения);
			НовыйЭлемент.Вид = ЭлементФормы.Вид;
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы, , ПолучитьСписокИсключенныхСвойств(ЭлементФормы.Вид));
			СкопироватьСписокВыбораЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ПолеФормы"));
			МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, , ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
			УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ПолеФормы"));			
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") Тогда
			// Если ЭлементФормы.Имя = "Кнопка_ДобавитьСервисныйЗвонок_Шаблон_" Тогда 
			//	ИндексСтрокой = "";
			// КонецЕсли;	
			НовыйЭлемент = Форма.Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("КнопкаФормы"), ГруппаДляРазмещения);
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы);				
			НоваяКоманда = Форма.Команды.Найти(СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + ИндексСтрокой);
			ШаблонКоманда = Форма.Команды.Найти(НовыйЭлемент.ИмяКоманды);
			Если НЕ НоваяКоманда = Неопределено Тогда 
				// Удалим команду
				Форма.Команды.Удалить(НоваяКоманда);
			КонецЕсли;
			// Создаем команду
			НоваяКоманда = Форма.Команды.Добавить(СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + ИндексСтрокой);
			ЗаполнитьЗначенияСвойств(НоваяКоманда, ШаблонКоманда);
			НоваяКоманда.Действие = "Подключаемый_" + СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + "_ВыполнитьКоманду";				
			НовыйЭлемент.ИмяКоманды = НоваяКоманда.Имя;
			МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, НовыйЭлемент, НоваяКоманда, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Скопировать список выбора элемента
//
// Параметры:
//  НовыйЭлемент - 	 - 
//  ЭлементФормы - 	 - 
//  ТипЭлемента	 - 	 - 
//
Процедура СкопироватьСписокВыбораЭлемента(НовыйЭлемент, ЭлементФормы, ТипЭлемента)
	
	Если ТипЭлемента = Тип("ПолеФормы") И НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода Тогда
		Если НовыйЭлемент.РежимВыбораИзСписка = Истина Тогда 
			Если ЗначениеЗаполнено(ЭлементФормы.СписокВыбора) Тогда 
				НовыйЭлемент.СписокВыбора.ЗагрузитьЗначения(ЭлементФормы.СписокВыбора.ВыгрузитьЗначения());
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Модифицировать элемент для частного случая
//
// Параметры:
//  Элемент			 - 	 - 
//  Команда			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//
Процедура МодифицироватьЭлементНастройкиДляЧастногоСлучая(Форма, Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов)
	
	ПроверяемыйЭлемент = ?(Команда = Неопределено, Элемент, Команда);	
	Если НЕ ЗначениеЗаполнено(ПроверяемыйЭлемент.Подсказка) ИЛИ СтрНайти(ПроверяемыйЭлемент.Подсказка, "Процедура_") = 0 Тогда 
      	Возврат;
	КонецЕсли;
	
	ИмяОбработчика = СокрЛП(ПроверяемыйЭлемент.Подсказка);
	
	Если ИмяОбработчика = "Процедура_ОбработкаГруппаСтрока_ТЧ_Действия" Тогда 
