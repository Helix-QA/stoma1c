КонецПроцедуры

&НаКлиенте
Функция GetMessage(messageId) Экспорт
	
	Запрос = Новый HTTPЗапрос("/V2/messages/{messageId}");
	Запрос.Заголовки.Вставить("Authorization", "Bearer "+ token);
	
	URL_УстановитьПараметр(Запрос.АдресРесурса, "messageId", messageId);
	
	Ответ = Клиент_get(Запрос,ХостАпи());
	
	Если Ответ.КодСостояния = 404 Тогда
		ВызватьИсключение "Сообщение не найдено: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния = 401 Тогда
		ВызватьИсключение "Запрос не авторизован: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния = 400 Тогда
		ВызватьИсключение "Некорректный формат идентификатора сообщения: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния >= 300 Тогда
		ВызватьИсключение "Не удалось выполнить запрос: " + Ответ.ПолучитьТелоКакСтроку();
	КонецЕсли;
	
	Возврат JSON_Прочитать(Ответ.ПолучитьТелоКакСтроку());
	
КонецФункции

&НаКлиенте
Процедура СписокОтборПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "documentType", СписокОтбор, Истина, ВидСравненияКомпоновкиДанных.Равно);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.Список.ТекущиеДанные;
	
	Если ТекСтрока.documentType = "Ihclme" Тогда
		ДатаДокумента = Дата(ТекСтрока.documentDate);
		СтандартнаяОбработка = Ложь;
		АктОказанныхУслуг = ПолучитьСсылкуНаАкт(ТекСтрока.documentNumber, ДатаДокумента); 
		ОткрытьФорму("Документ.АктОказанияУслуг.Форма.ФормаДокумента", Новый Структура("Ключ", АктОказанныхУслуг), , Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСсылкуНаАкт(НомерДокумента, ДатаДокумента)
	
	Возврат Документы.АктОказанияУслуг.НайтиПоНомеру(НомерДокумента, ДатаДокумента);
	
КонецФункции  

