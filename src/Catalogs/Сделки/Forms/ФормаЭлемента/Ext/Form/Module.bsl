&НаКлиенте
// Процедура, редактирует заметку.
//
Процедура РедактироватьЗаметку(ЭлементHTML, ТекстЗаметки, СтрокаТЗ)	
	
	Обработчик = Новый ОписаниеОповещения("ЗавершитьРедактированиеЗаметки", ЭтотОбъект, Новый Структура("ЭлементHTML, СтрокаТЗ", ЭлементHTML, СтрокаТЗ));
	
	КлючЗаписи = ПолучитьКлючЗаписи(СтрокаТЗ.ИДЗаметки);
	
	ОткрытьФорму("РегистрСведений.Заметки.Форма.ФормаРедактированияЗаметки", Новый Структура("ТекстЗаметки, Заголовок, Контрагент, ВзаимодействиеСделка, Ключ", ТекстЗаметки, "Редактирование заметки", Объект.Контрагент, Объект.Ссылка, КлючЗаписи),,,,, Обработчик, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить ключ записи.
//
// Параметры:
//  ЗаметкаИД	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКлючЗаписи(ЗаметкаИД)
		
	Выборка = РегистрыСведений.Заметки.Выбрать(,,Новый Структура ("ИД", Новый УникальныйИдентификатор(ЗаметкаИД)));
	Если Выборка.Следующий() Тогда
		
		СтруктураОтбора = Новый Структура();
		СтруктураОтбора.Вставить("Объект"			, Выборка.Объект);
		СтруктураОтбора.Вставить("АктивностьЗаметки", Выборка.АктивностьЗаметки);
		СтруктураОтбора.Вставить("Автор"			, Выборка.Автор);
		СтруктураОтбора.Вставить("Период"			, Выборка.Период);
		СтруктураОтбора.Вставить("ИД"				, Выборка.ИД);
		
	КонецЕсли; 	
	
	МассивСтруктураЗаписи = Новый Массив;
	МассивСтруктураЗаписи.Добавить(СтруктураОтбора);
	
	Возврат Новый("РегистрСведенийКлючЗаписи.Заметки", МассивСтруктураЗаписи);

КонецФункции

&НаКлиенте
// Процедура, открывает профосмотр.
//
Процедура РедактироватьПрофосмотр(ДанныеСсылкиHTML)
	
	Обработчик = Новый ОписаниеОповещения("ЗавершитьРедактированиеПрофосмотра", ЭтотОбъект, Новый Структура("ДанныеСсылкиHTML", ДанныеСсылкиHTML));
	
	СтрокаТЗ 				= ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ДанныеСсылкиHTML.id);
	КлючЗаписиПрофосмотра 	= ПолучитьПараметрыОткрытияФормыПрофосмотр(СтрокаТЗ);
	
	ОткрытьФорму("РегистрСведений.Профосмотры.Форма.ФормаРедактированияЗаписиПлана", Новый Структура("Ключ", КлючЗаписиПрофосмотра),,,,,Обработчик, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	                                	
КонецПроцедуры 

&НаКлиенте  
// Функция - Получить параметры открытия формы профосмотр
//
// Параметры:
//  СтрокаТЗ - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрыОткрытияФормыПрофосмотр(СтрокаТЗ)
		
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("СтруктурнаяЕдиница"	, СтрокаТЗ.СтруктурнаяЕдиница);
	СтруктураОтбора.Вставить("Сотрудник"			, СтрокаТЗ.Сотрудник);
	СтруктураОтбора.Вставить("ВидОсмотра"			, СтрокаТЗ.ВидОсмотра);
	СтруктураОтбора.Вставить("Контрагент"			, Объект.Контрагент);
	СтруктураОтбора.Вставить("Период"				, СтрокаТЗ.Начало);
	
	МассивСтруктураЗаписи = Новый Массив;
	МассивСтруктураЗаписи.Добавить(СтруктураОтбора);

	Возврат Новый("РегистрСведенийКлючЗаписи.Профосмотры", МассивСтруктураЗаписи);
	
КонецФункции

