// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ КОМАНД

&НаКлиенте
// Процедура обработчик команды "ДобавитьПериодРаботыИзСправочника".
//
Процедура ДобавитьПериодРаботыИзСправочника(Команда)   
	
	ОткрытьФорму("Справочник.ПериодыРаботы.ФормаВыбора",,,,,, Новый ОписаниеОповещения("ПослеДобавленияПериодаРаботы", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды "ДобавитьПериодРаботыИзСправочника".
//
Процедура УдалитьПериодРаботыИзСправочника(Команда)
	Если Элементы.ПериодыРаботы.ТекущиеДанные <> Неопределено Тогда
		Элементы.ПериодыРаботы.Обновить();
		ПериодыРаботы.Удалить(Элементы.ПериодыРаботы.ТекущиеДанные.НомерСтроки);
		Элементы.УдалитьПериодРаботыИзСправочника.Доступность = (ПериодыРаботы.Количество() > 0);
		Для Каждого СтрокаТЧ Из ПериодыРаботы Цикл
			СтрокаТЧ.НомерСтроки = ПериодыРаботы.Индекс(СтрокаТЧ);	
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды "ДобавитьПериодРаботыИзСправочника".
//
Процедура ДобавитьПериод(Команда)
	
	СтрокаТЧ 								= УстановленныеПериоды.Добавить();
	СтрокаТЧ.НомерСтроки 					= УстановленныеПериоды.Количество();
	Элементы.УстановитьПериоды.Доступность 	= (УстановленныеПериоды.Количество() > 0 И ПериодыРаботы.Количество() > 0);
	Элементы.УдалитьПериод.Доступность		= (УстановленныеПериоды.Количество() > 0);
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды "УдалитьПериод".
//
Процедура УдалитьПериод(Команда)
	
	Если Элементы.УстановленныеПериоды.ТекущиеДанные <> Неопределено Тогда
		Элементы.ПериодыРаботы.Обновить();
		УстановленныеПериоды.Удалить(Элементы.УстановленныеПериоды.ТекущиеДанные.НомерСтроки - 1);
		Элементы.УдалитьПериод.Доступность = (УстановленныеПериоды.Количество() > 0);
		Для Каждого СтрокаТЧ Из УстановленныеПериоды Цикл
			СтрокаТЧ.НомерСтроки = УстановленныеПериоды.Индекс(СтрокаТЧ) + 1;	
		КонецЦикла;
	КонецЕсли;
	Элементы.УстановитьПериоды.Доступность 	= (УстановленныеПериоды.Количество() > 0 И ПериодыРаботы.Количество() > 0);
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды "УстановитьПериоды".
//
Процедура УстановитьПериоды(Команда)
	
	АдресВременногоХранилища = УстановитьПериодыНаСервере();
	ОповеститьОВыборе(АдресВременногоХранилища);
	
КонецПроцедуры

&НаСервере
// Процедура обработчик команды "УстановитьПериодыНаСервере".
//
Функция УстановитьПериодыНаСервере()
	
	Если Не ЗначениеЗаполнено(ДатаНачала) И Не ЗначениеЗаполнено(ДатаОкончания) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены значения периодов!");
		Возврат Неопределено;
	КонецЕсли;
	
	ГрафикРаботы = Новый ТаблицаЗначений;
	ГрафикРаботы.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Число"));
	ГрафикРаботы.Колонки.Добавить("МассивСообщений", Новый ОписаниеТипов("Массив"));
	ГрафикРаботы.Колонки.Добавить("ДатаНачала", Новый ОписаниеТипов("Дата"));
	ГрафикРаботы.Колонки.Добавить("ДатаОкончания", Новый ОписаниеТипов("Дата"));
	МассивСообщений = Новый Массив;
	Для Инд = 1 По 31 Цикл
		ГрафикРаботы.Колонки.Добавить("День"+Инд, Новый ОписаниеТипов("СписокЗначений"));	
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из ТаблицаСотрудники Цикл
		
		ГраничноеЗначение = ((ДатаОкончания) - (ДатаНачала))/60/60/24;
		ДатаНачалаСмены = ДатаНачала;
		МассивСообщений = Новый Массив;
		
		СтрокаГР = ГрафикРаботы.Добавить();
		СтрокаГР.Идентификатор = СтрокаТаблицы.Идентификатор;
		СтрокаГР.ДатаНачала = ДатаНачала;
		СтрокаГР.ДатаОкончания = ДатаОкончания;
		
		КоличествоСтрок = УстановленныеПериоды.Количество() - 1;		
			
		Пока ДатаНачалаСмены <= ДатаОкончания Цикл
			
			Для Каждого СтрокаТЧ Из УстановленныеПериоды Цикл
				
				
				Если  ДатаНачалаСмены > КонецМесяца(Объект.Период) Тогда 
					Прервать;	
				КонецЕсли;
					
				Если ТипПериодаЗаполнения Тогда
					СтрокаТЧ = УстановленныеПериоды[ДеньНедели(ДатаНачалаСмены) - 1]
				КонецЕсли;
				
					
				ЕстьЗаписи = ОбщегоНазначенияСтоматология.ПроверитьНаличиеПредварительнойЗаписи(СтрокаТаблицы.Сотрудник, ДатаНачалаСмены, СтрокаТЧ.СписокПериодов.ВыгрузитьЗначения(), Объект.СтруктурнаяЕдиница); 
				
				ЕстьЗанятость = ОбщегоНазначенияСтоматология.ПроверитьЗанятостьСотрудника(СтрокаТЧ.СписокПериодов.ВыгрузитьЗначения(), СтрокаТаблицы.Сотрудник, объект.СтруктурнаяЕдиница, ДатаНачалаСмены);
				
				Если ОбщегоНазначенияСтоматология.ПроверитьДатуУвольнения(СтрокаТаблицы.Сотрудник, ДатаНачалаСмены, Объект.СтруктурнаяЕдиница) Тогда
					ДатаНачалаСмены = КонецДня(ДатаНачалаСмены) + 1;
					Продолжить;
				КонецЕсли;
				
				Если ЕстьЗаписи Тогда
					МассивСообщений.Добавить("Для сотрудника "+СтрокаТаблицы.Сотрудник+" имеются предварительные записи на "+Формат(ДатаНачалаСмены, "ДЛФ=ДД")+", не соответствующие устанавливаемому периоду");
				ИначеЕсли ЕстьЗанятость Тогда
					МассивСообщений.Добавить("Сотрудник "+СтрокаТаблицы.Сотрудник+" уже работает в период "+Формат(ДатаНачалаСмены, "ДЛФ=ДД")+" в другой структурной единице!");
				Иначе
					СтрокаГР["День"+ День(ДатаНачалаСмены)] = СтрокаТЧ.СписокПериодов;	
				КонецЕсли;
				
				
				ДатаНачалаСмены = КонецДня(ДатаНачалаСмены) + 1;
				
				
			КонецЦикла;
			
			СтрокаГР.МассивСообщений = МассивСообщений;
		КонецЦикла;
	КонецЦикла;
	Возврат ПоместитьВоВременноеХранилище(ГрафикРаботы, ЭтаФорма.УникальныйИдентификатор);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

///////////////////////////////////////////////////////////////////////////////
// ОБЩИЕ ПРОЦЕДУРЫ

// Процедура - производит инициализацию элемнтов на форме
//
&НаКлиенте
Процедура ИнициализироватьСписокУстановленныхПериодов()
	
	УстановленныеПериоды.Очистить();
	
	// Если выбран тип заполнения "По дням" заполняем таблицу днями недели
	Если ТипПериодаЗаполнения Тогда
		Элементы.УстановитьПериоды.Доступность = Истина;
		Элементы.УдалитьПериод.Доступность = Ложь;
		Элементы.ДобавитьПериод.Доступность = Ложь;
		Для Индекс = 1 По 7 Цикл
			СтрокаТЧ = УстановленныеПериоды.Добавить(); 
			СтрокаТЧ.НомерСтроки = Индекс;
			СтрокаТЧ.ДеньНедели = ТРег(Формат(Дата("1000010" + Индекс),"ДФ = дддд")); 
		КонецЦикла;
	Иначе
		Элементы.УдалитьПериод.Доступность = Истина;
		Элементы.ДобавитьПериод.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - производит заполнение строки табличной части "СтановленныеПериода"
//
Процедура ЗаполнитьСтрокуТЧ(СтрокаТЧ, СсылкаНаЭлемент)
	ЗаполнитьЗначенияСвойств(СтрокаТЧ, СсылкаНаЭлемент);
	СтрокаТЧ.КартинкаСтрок 	= БиблиотекаКартинок.Картинка_Реквизит;
КонецПроцедуры

&НаКлиенте
// Процедура обработчик события "ПослеДобавленияПериодаРаботы"
//
Процедура ПослеДобавленияПериодаРаботы(Результат, ДопПараметры) Экспорт

	Если ЗначениеЗаполнено(Результат) Тогда
		СтрокаТЧ 				= ПериодыРаботы.Добавить();
		ЗаполнитьСтрокуТЧ(СтрокаТЧ, Результат);
		Элементы.УдалитьПериодРаботыИзСправочника.Доступность = (ПериодыРаботы.Количество() > 0);
	КонецЕсли;
	
КонецПроцедуры	

#КонецОбласти