
#Область ОбработчикиСобытийФормы

// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	РедактированиеДоступно = РедактированиеДоступно();
	ЭтаФорма.Доступность   = РедактированиеДоступно;
	
	Элементы.КнопкаИменная.Доступность  = РедактированиеДоступно;
	Элементы.НаПредъявителя.Доступность = РедактированиеДоступно;
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	ВнешняяСистемаWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);			

	ЭтотОбъект.ВСНастроена = Константы.ИспользоватьWallet.Получить() И ЗначениеЗаполнено(ВнешняяСистемаWallet.КлючШифрования) И ЗначениеЗаполнено(ВнешняяСистемаWallet.ТокенДоступа);
			
	Элементы.ДекорацияЗаглушка2.Ширина = ?(ЭтотОбъект.ВСНастроена, 11, 8);
	
	ИспользуемыйВидКарт = Константы.ИспользуемыйВидКарт.Получить();
	
	Если Не ЗначениеЗаполнено(Объект.ТипКода) Тогда
		
		Объект.ТипКода = ?(ИспользуемыйВидКарт = Перечисления.ВидыКарт.Wallet И ЭтотОбъект.ВСНастроена, ИспользуемыйВидКарт, Перечисления.ВидыКарт.Штриховая);
		ЭтаФорма.Модифицированность = Истина;
		
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда		
		Объект.ШаблонСообщения = Справочники.ШаблоныСообщений.СозданиеКарты;			
	КонецЕсли;
	
	Элементы.ГруппаЭлектроннаяКарта.Видимость = ЭтотОбъект.ВСНастроена Или ЗначениеЗаполнено(Объект.ИдентификаторПроекта);
	
	Элементы.ГруппаВыборТипаКарты.Доступность = Не ЗначениеЗаполнено(Объект.ИдентификаторПроекта);
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УстановитьТекущийВидКарты();
	
	АктивныйЭлемент   = ?(Объект.Именная, Элементы.ГруппаКнопкаИменная       , Элементы.ГруппаКнопкаНаПредъявителя);
	НеАктивныйЭлемент = ?(Объект.Именная, Элементы.ГруппаКнопкаНаПредъявителя, Элементы.ГруппаКнопкаИменная);
	
	УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(АктивныйЭлемент, НеАктивныйЭлемент,, ЭтаФорма, Элементы.ДекорацияШтриховаяКарта);
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает текущий вид карт.
//
Процедура УстановитьТекущийВидКарты()
	
	Элементы.ГруппаЭлектроннаяКарта.ЦветФона = Новый Цвет(255, 255, 255);
	Элементы.ГруппаМагнитнаяКарта.ЦветФона   = Новый Цвет(255, 255, 255);
	Элементы.ГруппаШтриховаяКарта.ЦветФона   = Новый Цвет(255, 255, 255);
	
	Если Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet") Тогда	
		Элементы.ГруппаЭлектроннаяКарта.ЦветФона = Новый Цвет(195, 217, 246);	
	ИначеЕсли Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Магнитная") Тогда
		Элементы.ГруппаМагнитнаяКарта.ЦветФона = Новый Цвет(195, 217, 246);
	Иначе
		Элементы.ГруппаШтриховаяКарта.ЦветФона = Новый Цвет(195, 217, 246);
	КонецЕсли;
	
	ЭлектронныйВидКарты = Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet");
	
	Если Не ЗначениеЗаполнено(Объект.ИдентификаторПроекта) И ЭлектронныйВидКарты И ЭтотОбъект.ВСНастроена Тогда
		Если Элементы.Нумератор.СписокВыбора.Количество() = 0 Тогда
			ЗаполнитьНумераторы();	
		КонецЕсли;
		Если Элементы.Сертификат.СписокВыбора.Количество() = 0 Тогда
			ЗаполнитьСертификаты();	
		КонецЕсли;
		Элементы.ГруппаНумератор.Видимость = Истина;
		Элементы.Сертификат.Видимость = Истина;
	Иначе
		Элементы.ГруппаНумератор.Видимость = Ложь;
		Элементы.Сертификат.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ШаблонСообщений.Видимость = ЭлектронныйВидКарты;
	Элементы.ДекорацияЗаглушка2.Ширина = ?(ЭлектронныйВидКарты, 11, 8);
	Элементы.ДекорацияЗаглушка.Ширина  = ?(ЭлектронныйВидКарты, 11, 8);
	
	Элементы.ГруппаТумблер.Доступность = Не ЭлектронныйВидКарты;
	Элементы.Наименование.Доступность  = Не ЗначениеЗаполнено(Объект.ИдентификаторПроекта);
		
	Если ЭлектронныйВидКарты Тогда
		
		Если РедактированиеДоступно Тогда
			Объект.Именная = Истина;
		КонецЕсли;
		
		УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(Элементы.ГруппаКнопкаИменная, Элементы.ГруппаКнопкаНаПредъявителя,, ЭтаФорма, Элементы.ДекорацияШтриховаяКарта);
		
		Если Не ЗначениеЗаполнено(Объект.ШаблонСообщения)
			И РедактированиеДоступно Тогда
			
			Объект.ШаблонСообщения = ПредопределенноеЗначение("Справочник.ШаблоныСообщений.СозданиеКарты");
			
		КонецЕсли;
		
	ИначеЕсли РедактированиеДоступно Тогда
		
		Объект.ШаблонСообщения = Неопределено;
		
	КонецЕсли;
	
	Элементы.НастроитьКарту.Видимость     = ЗначениеЗаполнено(Объект.ИдентификаторПроекта) И ЭлектронныйВидКарты;
	Элементы.ГруппаКоманднаяПанель.Ширина = ?(Элементы.НастроитьКарту.Видимость, 37, 17);
	Элементы.НастроитьКарту.Доступность   = ПолныеПрава();
	
	Элементы.ГруппаДеактивацияКарты.Видимость = ЭлектронныйВидКарты;
			
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает признак доступности изменения.
//
Функция РедактированиеДоступно()
	
	Возврат ПравоДоступа("Редактирование", Метаданные.Справочники.ВидыКарт);
	
КонецФункции

&НаСервере
// Функция, возвращает Истина если пользователь имеет Роль - Полные права, в противном случае возвращает Ложь.
//
Функция  ПолныеПрава()
	
	Возврат РольДоступна("ПолныеПрава");
	
КонецФункции

