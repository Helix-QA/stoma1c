#Область СлужебныйПрограммныйИнтерфейс

Функция Подключены() Экспорт
	
	Возврат ОбсужденияСистемыВзаимодействияСлужебный.Подключены();
	
КонецФункции

Процедура Разблокировать() Экспорт 
	
	ОбсужденияСистемыВзаимодействияСлужебный.Разблокировать();
	
КонецПроцедуры

// Функция, создает обсуждение журнала оповещений.
//
Функция СоздатьОбсуждениеЖурналОповещений() Экспорт
	
	Возврат ОбсужденияСистемыВзаимодействияСлужебный.СоздатьОбсуждениеЖурналОповещений();
	
КонецФункции

// Функция, проверяет, необходило ли оповестить пользователя.
//
Функция ОповещатьТекущегоПользователя(ОбъектОповещения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	Если ТипЗнч(ОбъектОповещения) = Тип("Массив") Тогда
		// Поиск по рабочему месту клиента.
		НайденныйОбъект = ОбъектОповещения.Найти(ПараметрыСеанса.РабочееМестоКлиента);
		Если НайденныйОбъект <> Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Поиск по номеру сеанса.
		НайденныйОбъект = ОбъектОповещения.Найти(НомерСеансаИнформационнойБазы());
		Если НайденныйОбъект <> Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
		
	ИначеЕсли ОбъектОповещения = ПараметрыСеанса.ТекущийПользователь
		ИЛИ ОбъектОповещения = ПараметрыСеанса.РабочееМестоКлиента 
		ИЛИ ОбъектОповещения = НомерСеансаИнформационнойБазы() Тогда
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти                                                                                                                              