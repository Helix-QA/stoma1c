

#Область СлужебныйПрограммныйИнтерфейс

// Процедура, выполняет формирование отчета по информации клиента
//
Процедура ВывестиИнформациюПоКонграгенту(Контрагент, СтруктурнаяЕдиница, ТабличныйДокумент) Экспорт 
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Проверка, выбран ли клиент
	Если Контрагент = Справочники.Контрагенты.ПустаяСсылка() Тогда
		
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru = 'Не выбран клиент!'");
		Сообщение.Сообщить();
		Возврат;
		
	КонецЕсли;
	
	ТабличныйДокумент.Очистить();
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	Если не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	// Получение макета	
		
	Макет = Отчеты.ИнформацияПоКлиенту.ПолучитьМакет("Макет");
	
	// Формирование контактной информации
	СтрокаАдреса  = Контрагент.КонтактнаяИнформация.Найти(Перечисления.ТипыКонтактнойИнформации.Адрес                ,"Тип"); 
	СтрокаТелефон = Контрагент.КонтактнаяИнформация.Найти(Перечисления.ТипыКонтактнойИнформации.Телефон              ,"Тип");
	СтрокаЕмайл   = Контрагент.КонтактнаяИнформация.Найти(Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты,"Тип");
	
	Адрес   = ?(СтрокаАдреса  = Неопределено, "", СтрокаАдреса .Представление);
	Телефон = ?(СтрокаТелефон = Неопределено, "", СтрокаТелефон.Представление);
	Емайл   = ?(СтрокаЕмайл   = Неопределено, "", СтрокаЕмайл  .Представление);
	
	ЭтоСетьСтоматологий = (Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть);
	
	ЗапросОбщейИнформации = Новый Запрос;
	ЗапросОбщейИнформации.УстановитьПараметр("Клиент", Контрагент);
	ЗапросОбщейИнформации.УстановитьПараметр("СтруктурнаяЕдиница", ?(НЕ ЭтоСетьСтоматологий, СтруктурнаяЕдиница, Неопределено));
	ЗапросОбщейИнформации.Текст = ПолучитьЗапросОбщейИнформации();
	
	МассивРезультатов      	= ЗапросОбщейИнформации.ВыполнитьПакет(); 	
	ОбщаяИнформация        	= МассивРезультатов[0].Выгрузить();
	ПредпочтенияПоМастерам 	= МассивРезультатов[1].Выгрузить();
	СегментКлиента  		= МассивРезультатов[2].Выгрузить();
	ВыборкаПриемы		    = МассивРезультатов[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаВзаимодействия  	= МассивРезультатов[4].Выбрать();
	ВыборкаПланыЛечения 	= МассивРезультатов[5].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаНарядЗаказы   	= МассивРезультатов[6].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	// ===============================================ВЫВОД ОБЩИХ ДАННЫХ====================================================	
	ОбластьЗаголовок = Макет.ПолучитьОбласть("ОбщиеДанные");
	ОбластьЗаголовок.Параметры.ФИОКлиента   	= Контрагент.Фамилия + " "+Контрагент.Имя+" "+Контрагент.Отчество;
	Если Не Контрагент.ТекущаяМедицинскаяКарта.Пустая() Тогда 
		ОбластьЗаголовок.Параметры.НомерМедКарты = Контрагент.ТекущаяМедицинскаяКарта.КодБезНулей;
	КонецЕсли;
	
	// Вывод КИ с учетом установленной роли пользователя
	ВыводОбщейИнформацииПоКонтрагенту(ОбластьЗаголовок, Контрагент, Адрес, Телефон, Емайл);
	
	Если ОбщаяИнформация.Количество() > 0 Тогда
		ОбластьЗаголовок.Параметры.ДатаПервогоПосещения    = Формат(ОбщаяИнформация[0].ДатаПервогоПосещения, "ДЛФ=DD");
		ОбластьЗаголовок.Параметры.ДатаПоследнегоПосещения = Формат(ОбщаяИнформация[0].ДатаПоследнегоПосещения, "ДЛФ=DD");
		
		Если ЗначениеЗаполнено(Контрагент) И ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			СуммаЗадолженности = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокПоВзаиморасчетамСконтрагентом(Контрагент,, СтруктурнаяЕдиница);		
			Если  СуммаЗадолженности > 0 Тогда
				ОбластьЗаголовок.Область("ОбластьДолгКлиента").ЦветТекста = WebЦвета.Красный;
				ОбластьЗаголовок.Параметры.ДолгКлиента  = ""+ ?(ЗначениеЗаполнено(СуммаЗадолженности), Формат(СуммаЗадолженности,"ЧДЦ=2; ЧРД=.") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(), "0.00" + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
				ОбластьЗаголовок.Параметры.НадписьДолг = "Долг пациента:";
			Иначе	
				ОбластьЗаголовок.Параметры.ДолгКлиента  = ""+ ?(ЗначениеЗаполнено(СуммаЗадолженности), Формат(-СуммаЗадолженности,"ЧДЦ=2; ЧРД=.") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(), "0.00" + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
				ОбластьЗаголовок.Параметры.НадписьДолг = "Наш долг перед пациентом:";
			КонецЕсли;
				
			ОбластьЗаголовок.Параметры.Остаток = ""+ ?(ЗначениеЗаполнено(ОбщаяИнформация[0].Остаток), Формат(ОбщаяИнформация[0].Остаток,"ЧДЦ=2; ЧРД=.") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(), "0.00" + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
		КонецЕсли;
		Если ЗначениеЗаполнено(ОбщаяИнформация[0].Остаток) И ОбщаяИнформация[0].Остаток < 0 Тогда 
			ОбластьЗаголовок.Область("ОбластьОстаток").ЦветТекста = WebЦвета.Красный;			
		КонецЕсли;
		ОбластьЗаголовок.Рисунки["ПиктограммаПерейтиЛицевыеСчета"].Расшифровка  = "ОткрытьЛицевыеСчета";
		ОбластьЗаголовок.Рисунки["ПиктограммаПерейтиВзаиморасчеты"].Расшифровка = "ОткрытьВзаиморасчеты";
		
		СтруктураРасшифровкиОткрытьЛицевыеСчета = Новый Структура;
		СтруктураРасшифровкиОткрытьЛицевыеСчета.Вставить("ОткрытьЛицевыеСчетаКонтрагента", Контрагент);
		СтруктураРасшифровкиОткрытьВзаиморасчеты = Новый Структура;
		СтруктураРасшифровкиОткрытьВзаиморасчеты.Вставить("ОткрытьВзаиморасчетыКонтрагента", Контрагент);		
		ОбластьЗаголовок.Параметры.ОткрытьЛицевыеСчета = СтруктураРасшифровкиОткрытьЛицевыеСчета;
		ОбластьЗаголовок.Параметры.ОткрытьВзаиморасчеты = СтруктураРасшифровкиОткрытьВзаиморасчеты;
	КонецЕсли;
	
	ОбластьЗаголовок.Рисунки["ПиктограммаОткрытияФормыПечати"].Расшифровка = "ПечатьОтчета";
	
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	
	// =========================================ВЫВОД ДОПОЛНИТЕЛЬНОЙ ИНФОРМАЦИИ=============================================	
	Если НЕ Контрагент.ДополнительныеРеквизиты.Количество() = 0 Тогда 		
		ОбластьДопИнформацияЗаголовок = Макет.ПолучитьОбласть("ДополнительнаяИнформацияЗаголовок");
		// ТабличныйДокумент.Вывести(ОбластьДопИнформацияЗаголовок);
		
		Для каждого Строка из Контрагент.ДополнительныеРеквизиты Цикл
			ОбластьДопИнформация = Макет.ПолучитьОбласть("ДополнительнаяИнформацияДанные");
			ОбластьДопИнформация.Параметры.Заполнить(Строка);
			// ТабличныйДокумент.Вывести(ОбластьДопИнформация);			
			ОбластьДопИнформацияЗаголовок.Присоединить(ОбластьДопИнформация);
		КонецЦикла;	
		
		ТабличныйДокумент.Вывести(ОбластьДопИнформацияЗаголовок);
		
	КонецЕсли;
	
	// ===========================================ВЫВОД ПРЕДВАРИТЕЛЬНЫХ ЗАПИСЕЙ=============================================
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СобытиеУслуги.Ссылка КАК Ссылка,
	               |	СобытиеУслуги.Номенклатура КАК Номенклатура,
	               |	СобытиеУслуги.ПричинаЗаписи КАК ПричинаЗаписи,
	               |	СобытиеУслуги.Сотрудник КАК Сотрудник,
	               |	СобытиеУслуги.ДатаНачала КАК ДатаНачала,
	               |	СобытиеУслуги.Цена КАК Цена,
	               |	СобытиеУслуги.Ссылка.Контрагент КАК Контрагент
	               |ИЗ
	               |	Документ.Событие.Услуги КАК СобытиеУслуги
	               |ГДЕ
	               |	СобытиеУслуги.Ссылка.ПометкаУдаления = ЛОЖЬ
	               |	И СобытиеУслуги.ДатаНачала >= &ДатаНачала
	               |	И СобытиеУслуги.Ссылка.Статус = &Статус
	               |	И СобытиеУслуги.Ссылка.Контрагент = &Клиент
	               |	И СобытиеУслуги.Ссылка.Проведен";
					
	ЗапросЗаписи = Новый Запрос(ТекстЗапроса);
	ЗапросЗаписи.УстановитьПараметр("ДатаНачала", НачалоДня(ТекущаяДата()));
	ЗапросЗаписи.УстановитьПараметр("Статус", Перечисления.СтатусыСобытия.Подтверждена);
	ЗапросЗаписи.УстановитьПараметр("Клиент",Контрагент);
	
	РезультатЗаписи = ЗапросЗаписи.Выполнить().Выбрать();

	Если РезультатЗаписи.Количество() > 0 Тогда
		
		ОбластьПредварительнаяЗаписьЗаголовок = Макет.ПолучитьОбласть("ПредварительнаяЗаписьЗаголовок");
		ОбластьПредварительнаяЗаписьЗаголовок.НайтиТекст("Печать талона").Расшифровка = "ОткрытьПечатьТалона";
		СтруктураРасшифровкиОткрытьПечатьТалона = Новый Структура;
		СтруктураРасшифровкиОткрытьПечатьТалона.Вставить("ОткрытьПечатьТалона", Контрагент);		
		ОбластьПредварительнаяЗаписьЗаголовок.Параметры.ОткрытьПечатьТалона = СтруктураРасшифровкиОткрытьПечатьТалона;

		ТабличныйДокумент.Вывести(ОбластьПредварительнаяЗаписьЗаголовок);
 		Пока РезультатЗаписи.Следующий() Цикл
			
			СтрокаЗапись = Формат(РезультатЗаписи.ДатаНачала,"ДФ='ддд дд ММММ ЧЧ:мм'") + ", " + Строка(РезультатЗаписи.Сотрудник) + ?(ЗначениеЗаполнено(РезультатЗаписи.ПричинаЗаписи), (", "+Строка(РезультатЗаписи.ПричинаЗаписи)), "") + ?(РезультатЗаписи.Цена <> 0, (", "+Строка(РезультатЗаписи.Цена)+" руб."), "");
			Секция = Макет.ПолучитьОбласть("ПредварительнаяЗаписьДанные");
			Секция.Параметры.СтрокаЗапись = СтрокаЗапись;
			Секция.Параметры.СтруктураЗапись = Новый Структура("СсылкаНаЗапись", РезультатЗаписи.Ссылка);
			Секция.Параметры.ДеньКалендаря = Новый Структура("ДеньКалендаря", РезультатЗаписи.ДатаНачала);
			ТабличныйДокумент.Вывести(Секция);
			
		КонецЦикла;
		
	КонецЕсли;

	// ============================================ВЫВОД ПОСЛЕДНИЕ МАСТЕРА==============================================	
	Если ПредпочтенияПоМастерам.Количество() > 0 Тогда
		ОбластьПредпочтенияМастераЗаголовок = Макет.ПолучитьОбласть("ПредпочтениеПоМастерамЗаголовок");
		// ТабличныйДокумент.Вывести(ОбластьПредпочтенияМастераЗаголовок);
		Для Каждого Мастер из ПредпочтенияПоМастерам Цикл
			ОбластьПредпочтенияМастера = Макет.ПолучитьОбласть("ПредпочтениеПоМастерамДанные");
			ОбластьПредпочтенияМастера.Параметры.Заполнить(Мастер);
			// ТабличныйДокумент.Вывести(ОбластьПредпочтенияМастера);
			ОбластьПредпочтенияМастераЗаголовок.Присоединить(ОбластьПредпочтенияМастера);
		КонецЦикла;
		ТабличныйДокумент.Вывести(ОбластьПредпочтенияМастераЗаголовок);
	КонецЕсли;
	
	// =========================================ВЫВОД ПРИНАДЛЕЖИТ СЕГМЕНТАМ=============================================	
	Если СегментКлиента.Количество() > 0 Тогда
		ОбластьПринадлежностиСегментамЗаголовок = Макет.ПолучитьОбласть("ПринадлежитСегментамЗаголовок");
		ТабличныйДокумент.Вывести(ОбластьПринадлежностиСегментамЗаголовок);
		Для Каждого Сегмент из СегментКлиента Цикл
			ОбластьПринадлежностиСегментам = Макет.ПолучитьОбласть("ПринадлежитСегментамДанные");
			ОбластьПринадлежностиСегментам.Параметры.Заполнить(Сегмент);
			ТабличныйДокумент.Вывести(ОбластьПринадлежностиСегментам);
		КонецЦикла;
	КонецЕсли;

	// ============================================ВЫВОД СТРАХОВЫЕ ПОЛИСЫ===============================================	
	
	МассивПолисов = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(Контрагент, ТекущаяДата());
	
	Если МассивПолисов.Количество() <> 0 Тогда 
	
		Область_СтраховыеПолисы_Заголовок = Макет.ПолучитьОбласть("СтраховыеПолисы_Заголовок");
		ТабличныйДокумент.Вывести(Область_СтраховыеПолисы_Заголовок);
		
		Для Каждого СтраховойПолис Из МассивПолисов Цикл 
			
			
			Область_СтраховыеПолисы_Строка = Макет.ПолучитьОбласть("СтраховыеПолисы_Строка");
			ТипПолиса = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАббревиатуруТипаПолиса(СтраховойПолис.ТипПолиса);
			СтрокаПолис = ТипПолиса + ":  " + Строка(СтраховойПолис.СтраховаяКомпания) + "  № " + СтраховойПолис.СерияПолиса + "-" + СтраховойПолис.НомерПолиса + "  действителен с: "+ Формат(СтраховойПолис.ДанаНачала, "ДФ=dd.MM.yyyy") + " по " + Формат(СтраховойПолис.ДатаОкончания, "ДФ=dd.MM.yyyy") + ".    ";
			СуммаОказанныхУслуг = ПолучитьСуммуОказанныхУслугПоПолису(СтраховойПолис);			
			Если СтраховойПолис.ЛимитПолиса = 0 Тогда 
				ЛимитПолиса = "Сумма, оказанных услуг по полису: " + Формат(СуммаОказанныхУслуг, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				СтрокаПолис = СтрокаПолис + ЛимитПолиса;			
			Иначе 
				ЛимитПолиса = "Лимит: " + Формат(СтраховойПолис.ЛимитПолиса, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				Если СтраховойПолис.ЛимитПолиса - СуммаОказанныхУслуг >= 0 Тогда 
					ОстатокПоЛимиту = "Остаток по лимиту: " + Формат(СтраховойПолис.ЛимитПолиса - СуммаОказанныхУслуг, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				Иначе 
					ОстатокПоЛимиту = "Остаток по лимиту: " + Формат(0, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				КонецЕсли;
				СтрокаПолис = СтрокаПолис + ЛимитПолиса + "    " + ОстатокПоЛимиту;			
			КонецЕсли;
		    Область_СтраховыеПолисы_Строка.Параметры.СтрокаПолис = СтрокаПолис;
		    ТабличныйДокумент.Вывести(Область_СтраховыеПолисы_Строка);
		
		КонецЦикла;
		
	КонецЕсли;
	
	// =============================================ВЫВОД ИСТОРИИ ВЗАИМОДЕЙСТВИЙ========================================
	Если ВыборкаВзаимодействия.Количество() > 0 Тогда
		
		// ИсторияВзаимодействий_Заголовок	
		ОбластьИсторияВзаимодействий_Заголовок = Макет.ПолучитьОбласть("ИсторияВзаимодействий_Заголовок");
		
		ТабличныйДокумент.Вывести(ОбластьИсторияВзаимодействий_Заголовок);
		
		Пока ВыборкаВзаимодействия.Следующий() Цикл
			
