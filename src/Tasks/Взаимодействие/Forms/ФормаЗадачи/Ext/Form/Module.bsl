&НаСервере
Функция ПроверитьПравильностьПериода()
	
	Флаг = истина;
	
	Если РежимПериода Тогда // период 
		Если  НЕ ЗначениеЗаполнено(Объект.ЗадачаНазначеннаяДатаНачало) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Укажите дату начала действия задачи.';en='Specify the date beginnings actions tasks.'"), ЭтотОбъект, "Объект.ЗадачаНазначеннаяДатаНачало");
			Флаг = ложь;
		КонецЕсли;
		
		 Если  НЕ ЗначениеЗаполнено(Объект.ЗадачаНазначеннаяДата) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Укажите дату начала действия задачи.';en='Specify the date beginnings actions tasks.'"), ЭтотОбъект, "Объект.ЗадачаНазначеннаяДата");
			Флаг = ложь;
		КонецЕсли;

		Если ЗначениеЗаполнено(Объект.ЗадачаНазначеннаяДатаНачало) и ЗначениеЗаполнено(Объект.ЗадачаНазначеннаяДата)
			и Объект.ЗадачаНазначеннаяДатаНачало > Объект.ЗадачаНазначеннаяДата Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Указан не верный период. Дата окончания не может быть меньше даты начала.';en='Invalid period specified. Date graduation cannot be less dates beginnings.'"));
			Флаг = ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Флаг;
КонецФункции

