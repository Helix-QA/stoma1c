// Процедура - обработчик события "АвтоПодбор"
//
Процедура ЗапасыНоменклатураАвтоПодбор(Элемент, Текст, ДанныеВыбора, Параметры, Ожидание, СтандартнаяОбработка)

	Если ЗначениеЗаполнено(СегментНоменклатуры) Тогда 
		СтандартнаяОбработка = Ложь;		
		ДанныеВыбора         = НайтиНоменклатуруПоСтроке(Текст, 10, СегментНоменклатуры, Элемент.Родитель.Имя);
		
		// Если найден один элемент выбираем его сразу
		Если НЕ ЗначениеЗаполнено(ДанныеВыбора) ИЛИ ДанныеВыбора.Количество() = 0 Тогда			
			ПерваяСсылкаВСпикеПодбораНоменклатуры = Неопределено;		
		ИначеЕсли ЗначениеЗаполнено(ДанныеВыбора) И ДанныеВыбора.Количество() = 1 Тогда			
				Элемент.Родитель.Родитель.ТекущиеДанные.Номенклатура = ДанныеВыбора[0].Значение;
				ДанныеВыбора      							= Неопределено;
				ЗапасыНоменклатураПриИзменении(Элемент);			
		ИначеЕсли ЗначениеЗаполнено(ДанныеВыбора) И ДанныеВыбора.Количество() > 1 Тогда			
			ПерваяСсылкаВСпикеПодбораНоменклатуры = ДанныеВыбора[0].Значение;			
		КонецЕсли;
		    
	Иначе
		ПерваяСсылкаВСпикеПодбораНоменклатуры = "ЭтоСтандартнаяОбработка";
		СтандартнаяОбработка = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ОкончаниеВводаТекста"
//
Процедура ЗапасыНоменклатураОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	Если ПерваяСсылкаВСпикеПодбораНоменклатуры = "ЭтоСтандартнаяОбработка" Тогда 
		
	Иначе 	
		Если ПерваяСсылкаВСпикеПодбораНоменклатуры = Неопределено Тогда 
			Элемент.Родитель.Родитель.ТекущиеДанные.Номенклатура	= ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
			
		ИначеЕсли ПерваяСсылкаВСпикеПодбораНоменклатуры <> Неопределено Тогда
			
			Элемент.Родитель.Родитель.ТекущиеДанные.Номенклатура	= ПерваяСсылкаВСпикеПодбораНоменклатуры;
			ДанныеВыбора                      			= Неопределено;
			ПерваяСсылкаВСпикеПодбораНоменклатуры 		= Неопределено;
			ЗапасыНоменклатураПриИзменении(Элемент);
			
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция выполняет поиск номенклатуры
//
Функция НайтиНоменклатуруПоСтроке(СтрокаПоиска, РазмерПорции = 30, Сегмент, ИмяЭлемента)
	
	СтрокаПоиска = СокрЛ(СтрокаПоиска);
	Если СокрЛ(СтрокаПоиска) = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МассивРазрешенныхТипов = Новый Массив;
	Если ИмяЭлемента = "ТаблицаЛечение" Тогда 
		МассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Услуга);
	Иначе 
		МассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Запас);
		МассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.ПодарочныйСертификат);
	КонецЕсли;		
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	НоменклатураСегмента.Номенклатура КАК Номенклатура
	               |ИЗ
	               |	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	               |ГДЕ
	               |	НЕ НоменклатураСегмента.Номенклатура.ЭтоГруппа
	               |	И НЕ НоменклатураСегмента.Номенклатура.ПометкаУдаления
	               |	И НоменклатураСегмента.Номенклатура.Наименование ПОДОБНО &Наименование
	               |	И НоменклатураСегмента.Сегмент = &Сегмент
	               |	И ВЫБОР
	               |			КОГДА НЕ &СписокРазрешенныхТипов ЕСТЬ NULL 
	               |				ТОГДА НоменклатураСегмента.Номенклатура.ТипНоменклатуры В (&СписокРазрешенныхТипов)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Сегмент", 				Сегмент);			   
	Запрос.УстановитьПараметр("Наименование", 			"%" + СокрЛ(СтрокаПоиска) + "%");
	Запрос.УстановитьПараметр("СписокРазрешенныхТипов", ?(ЗначениеЗаполнено(МассивРазрешенныхТипов) И МассивРазрешенныхТипов.Количество() > 0 , МассивРазрешенныхТипов, NULL));
	
   	Результат = Запрос.Выполнить().Выбрать();			
	
	СписокНоменклатуры = Новый СписокЗначений;
	
	Если Результат.Количество() > РазмерПорции Тогда		
		 СписокНоменклатуры.Добавить(Справочники.Номенклатура.ПустаяСсылка(), "Найдено более "+РазмерПорции+" позиций номенклатуры, уточните поиск.");		
		 Возврат СписокНоменклатуры;
	КонецЕсли;
	
	Пока Результат.Следующий() Цикл
		СписокНоменклатуры.Добавить(Результат.Номенклатура, Результат.Номенклатура.Наименование + " (" + Результат.Номенклатура.Код + ")");
	КонецЦикла;

	Возврат СписокНоменклатуры;
	
КонецФункции

