///////////////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИК СОБЫТИЙ ФОРМЫ

#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик при создании формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Параметры.Свойство("Сотрудник", Сотрудник);
	
	Если НЕ Сотрудник.Пустая() Тогда		
		Если Параметры.Свойство("Режим") Тогда
			Режим = Параметры.Режим;
		Иначе
			Режим = "День";  
		КонецЕсли;
	Иначе
		Режим = "Неделя";
	КонецЕсли;
	
	Если Параметры.Свойство("Дата") Тогда
		ВыбраннаяДата = Параметры.Дата;
	Иначе
		ВыбраннаяДата = ПолучитьТекущуюДату();  
	КонецЕсли;
	
	Если Режим = "Неделя" Тогда
		
		Элементы.День.Пометка 	           = Ложь;
		Элементы.Неделя.Пометка            = Истина;
		Элементы.ГруппаДатДня.Видимость    = Ложь;
		Элементы.ГруппаДатНедели.Видимость = Истина;
		
	ИначеЕсли Режим = "День" Тогда
		
		Элементы.День.Пометка              = Истина;
		Элементы.Неделя.Пометка 	       = Ложь;
		Элементы.ГруппаДатДня.Видимость    = Истина;
		Элементы.ГруппаДатНедели.Видимость = Ложь;
		
	КонецЕсли;
	
	ОбновитьПанельДниНедели();
	
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	НачалоНеделиПоНомеру = НачалоНедели(ВыбраннаяДата);
	КонецНеделиПоНомеру  = КонецНедели(ВыбраннаяДата);
	
	СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;	
		
	ПараметрыПостроения = Новый Структура("ВыбранныеСотрудники, ВыбранныеПомещения, СтраницаМенеджера, РазрешениеЭкрана, СтруктурнаяЕдиница, Дата, РазрешитьСмещениеГрафика, УчитыватьГрафикРаботыСотрудников, НаВсюФорму, ВыводитьКартинки, МассивСотрудниковИОбластей, ИнтервалГрафикаЗанятий");
	Параметры.Свойство("СтраницаМенеджера", ПараметрыПостроения.СтраницаМенеджера);
	Параметры.Свойство("СтруктурнаяЕдиница", ПараметрыПостроения.СтруктурнаяЕдиница);
	Параметры.Свойство("Дата", ПараметрыПостроения.Дата);
	
	Параметры.Свойство("РазрешитьСмещениеГрафика", ПараметрыПостроения.РазрешитьСмещениеГрафика);
	Параметры.Свойство("РазрешениеЭкрана", ПараметрыПостроения.РазрешениеЭкрана);

	Параметры.Свойство("УчитыватьГрафикРаботыСотрудников", ПараметрыПостроения.УчитыватьГрафикРаботыСотрудников);
	Параметры.Свойство("НаВсюФорму", ПараметрыПостроения.НаВсюФорму);
	Параметры.Свойство("ВыводитьКартинки", ПараметрыПостроения.ВыводитьКартинки);
	Параметры.Свойство("ВыбранныеСотрудники", ПараметрыПостроения.ВыбранныеСотрудники);
	Параметры.Свойство("ВыбранныеПомещения", ПараметрыПостроения.ВыбранныеПомещения);
	Параметры.Свойство("МассивСотрудниковИОбластей", ПараметрыПостроения.МассивСотрудниковИОбластей);
	Параметры.Свойство("ИнтервалГрафикаЗанятий", ПараметрыПостроения.ИнтервалГрафикаЗанятий);

	
	Если Сотрудник.Пустая() Тогда		
		Элементы.ГруппаНастройки.Видимость = Истина;
		Элементы.КнопкаНастройка.Пометка   = Истина;
		Область                         = ТабличныйДокумент.Область(2,1,3,8);
		// Область.ШиринаКолонки           = ПараметрыМакета.ШиринаЗаголовкаДень;
		Область.ВысотаСтроки            = 22;
		Область.Шрифт                   = Новый Шрифт(,14, Истина,,);
		Область.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Лево;
		Область.ВертикальноеПоложение   = ВертикальноеПоложение.Верх;		
		Область.Текст                   = "Выберите сотрудника";
		Область.Объединить();
		
	Иначе		
		Элементы.ГруппаНастройки.Видимость = Ложь;
		Элементы.КнопкаНастройка.Пометка   = Ложь;	
		ГрафикСобытий  = ОбщегоНазначенияСтоматология.СформироватьГрафикСобытий(ПараметрыПостроения, ПараметрыПостроения.МассивСотрудниковИОбластей, ?(ПараметрыПостроения.ИнтервалГрафикаЗанятий = 0, 15, 10), Истина);
		ТабличныйДокумент.Очистить();
		ТабличныйДокумент.ВставитьОбласть(ГрафикСобытий.Область());
	КонецЕсли;	
	
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.МасштабПечати = 93;
	
КонецПроцедуры

#КонецОбласти                      

/////////////////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ПАНЕЛИ УПРАВЛЕНИЯ

#Область ОбработчикиКомандФормы

&НаКлиенте
//
//
Процедура ПерейтиНеделяПредыдущая(Команда)
	
	ВыбраннаяДата = ВыбраннаяДата - 7 * 24 * 60 * 60;
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	ОбновитьПанельДниНедели();
	ПостроитьГрафикРасписанияНаСервере("Дата");

КонецПроцедуры

&НаКлиенте
//
//
Процедура ПерейтиНеделяСледующая(Команда)
	
	ВыбраннаяДата = ВыбраннаяДата + 7 * 24 * 60 * 60;
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	ОбновитьПанельДниНедели();	
	ПостроитьГрафикРасписанияНаСервере("Дата");
	
КонецПроцедуры

&НаКлиенте
//
//
Процедура ПерейтиПредыдущийМесяц(Команда)
	
	ВыбраннаяДата = ДобавитьМесяц(ВыбраннаяДата, -1);
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	НачалоНеделиПоНомеру=НачалоНедели(ВыбраннаяДата);
	КонецНеделиПоНомеру=КонецНедели(ВыбраннаяДата);

	ОбновитьПанельДниНедели();
	ПостроитьГрафикРасписанияНаСервере("Дата");
	
КонецПроцедуры

&НаКлиенте
//
//
Процедура ПерейтиСледующийМесяц(Команда)
	
	ВыбраннаяДата = ДобавитьМесяц(ВыбраннаяДата, 1);
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	НачалоНеделиПоНомеру=НачалоНедели(ВыбраннаяДата);
	КонецНеделиПоНомеру=КонецНедели(ВыбраннаяДата);

	ОбновитьПанельДниНедели();
	ПостроитьГрафикРасписанияНаСервере("Дата");
	
КонецПроцедуры

&НаКлиенте
//
//
Процедура ПерейтиДеньНедели(Команда)
	
 	ВыбраннаяДата = НачалоНедели(ВыбраннаяДата) + Число(Сред(Команда.Имя, СтрДлина(Команда.Имя), 1) - 1) * 24 * 60 * 60;
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	ОбновитьПанельДниНедели();
	ПостроитьГрафикРасписанияНаСервере("Дата");
	
КонецПроцедуры

&НаКлиенте
//
//
Процедура ПерейтиНеделяМесяца(Команда)
	
	НеобходимаяДата = НачалоМесяца(ВыбраннаяДата) + Число(Сред(Команда.Имя, СтрДлина(Команда.Имя), 1) - 1) * 7 * 24 * 60 * 60;
	
	Если Месяц(ВыбраннаяДата) = Месяц(НеобходимаяДата) Тогда
		ВыбраннаяДата = НачалоМесяца(ВыбраннаяДата) + Число(Сред(Команда.Имя, СтрДлина(Команда.Имя), 1) - 1) * 7 * 24 * 60 * 60;
	Иначе
		ВыбраннаяДата = КонецМесяца(ВыбраннаяДата);
	КонецЕсли;
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	
	НачалоНеделиПоНомеру = НачалоНедели(ВыбраннаяДата);
	КонецНеделиПоНомеру  = КонецНедели(НачалоНеделиПоНомеру);

	ОбновитьПанельДниНедели();
	
	ПостроитьГрафикРасписанияНаСервере("Дата");	
	
КонецПроцедуры

&НаКлиенте
// Процедура изменяет пометку кнопки Неделя.
//
Процедура ПерейтиСтраницаНеделя(Команда)
	
	ПостроитьГрафикРасписанияНаСервере("Неделя");
	
КонецПроцедуры

&НаКлиенте
// Процедура изменяет пометку кнопки Неделя.
//
Процедура ПерейтиСтраницаДень(Команда)
	
	ПостроитьГрафикРасписанияНаСервере("День");
	
КонецПроцедуры

&НаКлиенте
// Функция управляет видимостью панели с настройками отчета
//
Процедура СкрытьПоказатьНастройки(Команда)
	
		Элементы.ГруппаНастройки.Видимость = НЕ Элементы.ГруппаНастройки.Видимость;
		Элементы.КнопкаНастройка.Пометка =НЕ Элементы.КнопкаНастройка.Пометка;
КонецПроцедуры

&НаКлиенте
// Обработчик диалога колендаря
//
Процедура ДиалогКалендаря(Команда)
	  
	ЭтаФорма.ТекущийЭлемент = Элементы.ДатаКалендаряДиалога;
	
	#Если не ВебКлиент Тогда
		
		Системнаяинформация = Новый Системнаяинформация;
		
		Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда 
			
			Shell = Новый COMОбъект("WScript.Shell");
			Shell.SendKeys("{F4}");
			
		КонецЕсли;
		
	#Конецесли  
	
	
КонецПроцедуры
   
&НаКлиенте
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Процедура ДатаПриИзменении(Элемент)
	
	НачалоНеделиПоНомеру = НачалоНедели(ВыбраннаяДата);
	КонецНеделиПоНомеру  = КонецНедели(ВыбраннаяДата);
	Элементы.ДекорацияДата.Заголовок = Формат(ВыбраннаяДата,"ДЛФ=DD");
	ОбновитьПанельДниНедели();
	
	ПостроитьГрафикРасписанияНаСервере("Дата");
	
КонецПроцедуры

&НаКлиенте
// Начало выбора даты календаря
//
Процедура ДатаКалендаряДиалогаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ЭтаФорма.ТекущийЭлемент = Элементы.КнопкаКалендарь;
	
КонецПроцедуры

&НаКлиенте
// При изменении выбора сотрудника
//
Процедура СотрудникПриИзменении(Элемент)
	
	ПостроитьГрафикРасписанияНаСервере("Сотрудник");
	
КонецПроцедуры

&НаСервере
// Процедура, заполняем график расписания на сервере.
//
Процедура ПостроитьГрафикРасписанияНаСервере(Параметр)
	
	Если Параметр = "Сотрудник" Тогда
		МассивСотрудников = Новый Массив;
		МассивСотрудников.Добавить(Сотрудник);
		ПараметрыПостроения.ВыбранныеСотрудники = МассивСотрудников;
		ПараметрыПостроения.СтраницаМенеджера	= ?(Режим = "Неделя", "Неделя", "Сотрудники");
	ИначеЕсли Параметр = "Неделя" Тогда		
		Элементы.День.Пометка 	           = Ложь;
		Элементы.Неделя.Пометка            = Истина;
		Элементы.ГруппаДатДня.Видимость    = Ложь;
		Элементы.ГруппаДатНедели.Видимость = Истина;
		Режим                              = Параметр;
		ПараметрыПостроения.СтраницаМенеджера	= "Неделя";
		ОбновитьПанельДниНедели();
	ИначеЕсли Параметр = "День" Тогда		
		Элементы.День.Пометка              = Истина;
		Элементы.Неделя.Пометка 	       = Ложь;
		Элементы.ГруппаДатДня.Видимость    = Истина;
		Элементы.ГруппаДатНедели.Видимость = Ложь;
		Режим                              = Параметр;
		ПараметрыПостроения.СтраницаМенеджера	= "Сотрудники";	
		ОбновитьПанельДниНедели();
	ИначеЕсли Параметр = "Дата" Тогда
		ПараметрыПостроения.Дата = ВыбраннаяДата;
	КонецЕсли;
		
	ГрафикСобытий  = ОбщегоНазначенияСтоматология.СформироватьГрафикСобытий(ПараметрыПостроения, ПараметрыПостроения.МассивСотрудниковИОбластей, ?(ПараметрыПостроения.ИнтервалГрафикаЗанятий = 0, 15, 10), Истина);
	ТабличныйДокумент.Очистить();
	ТабличныйДокумент.ВставитьОбласть(ГрафикСобытий.Область());	
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	
КонецПроцедуры

#КонецОбласти

///////////////////////////////////////////////////////////////////////
// ДОПОЛНИТЕЛЬНЫЕ ФУНКЦИИ ОБРАБОТКИ ИНТЕРФЕЙСА

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Процедура ОбновитьПанельДниНедели()
	
	Если Элементы.Неделя.Пометка Тогда
		
		КонецМесяца = КонецМесяца(ВыбраннаяДата);
		НомерВсегоНедель = Цел((День(КонецМесяца) - ДеньНедели(КонецМесяца)) / 7) + ?((День(КонецМесяца) - ДеньНедели(КонецМесяца)) % 7 > 0, 1, 0) + 1;
		Элементы.ДатаНеделяМесяца1.Шрифт = Новый Шрифт();
		Элементы.ДатаНеделяМесяца2.Шрифт = Новый Шрифт();
		Элементы.ДатаНеделяМесяца3.Шрифт = Новый Шрифт();
		Элементы.ДатаНеделяМесяца4.Шрифт = Новый Шрифт();
		Элементы.ДатаНеделяМесяца5.Шрифт = Новый Шрифт();
		Элементы.ДатаНеделяМесяца6.Шрифт = Новый Шрифт();
		Элементы.ДатаНеделяМесяца1.ЦветФона = Новый Цвет();
		Элементы.ДатаНеделяМесяца2.ЦветФона = Новый Цвет();
		Элементы.ДатаНеделяМесяца3.ЦветФона = Новый Цвет();
		Элементы.ДатаНеделяМесяца4.ЦветФона = Новый Цвет();
		Элементы.ДатаНеделяМесяца5.ЦветФона = Новый Цвет();
		Элементы.ДатаНеделяМесяца6.ЦветФона = Новый Цвет();		
		Элементы.ДатаНеделяМесяца1.Заголовок = ВернутьЗаголовокНеделиМесяца(ВыбраннаяДата, 1);
		Элементы.ДатаНеделяМесяца2.Заголовок = ВернутьЗаголовокНеделиМесяца(ВыбраннаяДата, 2);
		Элементы.ДатаНеделяМесяца3.Заголовок = ВернутьЗаголовокНеделиМесяца(ВыбраннаяДата, 3);
		Элементы.ДатаНеделяМесяца4.Заголовок = ВернутьЗаголовокНеделиМесяца(ВыбраннаяДата, 4);
		Элементы.ДатаНеделяМесяца5.Заголовок = ВернутьЗаголовокНеделиМесяца(ВыбраннаяДата, 5);
		Элементы.ДатаНеделяМесяца6.Заголовок = ВернутьЗаголовокНеделиМесяца(ВыбраннаяДата, 6);
		НомерНедели = Цел((День(ВыбраннаяДата) + ДеньНедели(НачалоМесяца(ВыбраннаяДата) ) - 2 ) / 7) + 1;
		Элементы["ДатаНеделяМесяца" + Строка(НомерНедели)].ЦветФона = WebЦвета.СеребристоСерый;
		
		Если Месяц(ВыбраннаяДата) = Месяц(ТекущаяДата()) Тогда
			Элементы["ДатаНеделяМесяца" + ВернутьНомерНеделиМесяца(ТекущаяДата())].Шрифт = Новый Шрифт( , , Истина);
		КонецЕсли;		
		Для а = 1 По 6 Цикл
			Элементы["ДатаНеделяМесяца" + а].Видимость = ?(а <= НомерВсегоНедель, Истина, Ложь);
		КонецЦикла;
		
	Иначе
		
		Элементы.ДатаДеньНедели1.Шрифт = Новый Шрифт();
		Элементы.ДатаДеньНедели2.Шрифт = Новый Шрифт();
		Элементы.ДатаДеньНедели3.Шрифт = Новый Шрифт();
		Элементы.ДатаДеньНедели4.Шрифт = Новый Шрифт();
		Элементы.ДатаДеньНедели5.Шрифт = Новый Шрифт();
		Элементы.ДатаДеньНедели6.Шрифт = Новый Шрифт();
		Элементы.ДатаДеньНедели7.Шрифт = Новый Шрифт();
		Элементы.ДатаДеньНедели1.ЦветФона = Новый Цвет();
		Элементы.ДатаДеньНедели2.ЦветФона = Новый Цвет();
		Элементы.ДатаДеньНедели3.ЦветФона = Новый Цвет();
		Элементы.ДатаДеньНедели4.ЦветФона = Новый Цвет();
		Элементы.ДатаДеньНедели5.ЦветФона = Новый Цвет();
		Элементы.ДатаДеньНедели6.ЦветФона = Новый Цвет();
		Элементы.ДатаДеньНедели7.ЦветФона = Новый Цвет();
		Элементы.ДатаДеньНедели1.Заголовок = ВернутьЗаголовокДняНедели(ВыбраннаяДата, 1);
		Элементы.ДатаДеньНедели2.Заголовок = ВернутьЗаголовокДняНедели(ВыбраннаяДата, 2);
		Элементы.ДатаДеньНедели3.Заголовок = ВернутьЗаголовокДняНедели(ВыбраннаяДата, 3);
