
#Область СлужебныеПроцедурыИФункции

// Процедура - Зарегистрировать событие триггера
//
// Параметры:
//  ДанныеТриггера								 - 	 - 
//  ДатаВремяНачалаРаботы						 - 	 - 
//  ДатаВремяОкончанияРаботы					 - 	 - 
//  УникальныйИдентификаторРегистрацииСобытия	 - 	 - 
//
Процедура ЗарегистрироватьСобытиеТриггера(ПараметрыРегистрацииТриггера) Экспорт 
	                        
	// Создаем менеджер записи
	МенеджерЗаписи = СоздатьМенеджерЗаписи();
	
	// Инициируем явную блокировку по ключевым измерениям
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрСведений.ЖурналРегистрацииТриггерныхСобытий");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("ТриггерноеСобытие"	, ПараметрыРегистрацииТриггера.ТриггерноеСобытие);
	Если ЗначениеЗаполнено(ПараметрыРегистрацииТриггера.Контрагент) Тогда 	
		ЭлементБлокировки.УстановитьЗначение("Контрагент"		, ПараметрыРегистрацииТриггера.Контрагент);
	КонецЕсли;	
	Если ЗначениеЗаполнено(ПараметрыРегистрацииТриггера.ОбъектСобытия) Тогда 
		ЭлементБлокировки.УстановитьЗначение("ОбъектСобытия"	, ПараметрыРегистрацииТриггера.ОбъектСобытия);
	КонецЕсли;
	Если ЗначениеЗаполнено(ПараметрыРегистрацииТриггера.ИсточникСобытия) Тогда 
		ЭлементБлокировки.УстановитьЗначение("ИсточникСобытия"	, ПараметрыРегистрацииТриггера.ИсточникСобытия);
	КонецЕсли;		
	ЭлементБлокировки.УстановитьЗначение("РегистрацияПоПодписке", ПараметрыРегистрацииТриггера.РегистрацияПоПодписке);
	ЭлементБлокировки.УстановитьЗначение("ИдентификаторДействия", ПараметрыРегистрацииТриггера.ИдентификаторДействия);
	
	// Блокируем	
	БлокировкаДанных.Заблокировать();
	
	// Начинаем работу с записью
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ПараметрыРегистрацииТриггера);
	МенеджерЗаписи.Прочитать();
	// Сохраняем текущий статус
	Статус = МенеджерЗаписи.Статус;
	// Заполняем основные измерения, если запись не была прочитана
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ПараметрыРегистрацииТриггера);
	
	// Заполняем объект генерации
	Если ЗначениеЗаполнено(ПараметрыРегистрацииТриггера.ОбъектГенерации) Тогда 
		Если ТипЗнч(ПараметрыРегистрацииТриггера.ОбъектГенерации) = Тип("ЗадачаСсылка.Взаимодействие") Тогда 
			МенеджерЗаписи.Взаимодействие 				= ПараметрыРегистрацииТриггера.ОбъектГенерации;
		КонецЕсли;	
		Если ТипЗнч(ПараметрыРегистрацииТриггера.ОбъектГенерации) = Тип("ДокументСсылка.РассылкаСообщений") Тогда 
			МенеджерЗаписи.SMSРассылка 					= ПараметрыРегистрацииТриггера.ОбъектГенерации;
		КонецЕсли;
		Если ТипЗнч(ПараметрыРегистрацииТриггера.ОбъектГенерации) = Тип("ДокументСсылка.ЭлектронноеПисьмоИсходящее") Тогда 
			МенеджерЗаписи.ЭлектронноеПисьмоИсходящее 	= ПараметрыРегистрацииТриггера.ОбъектГенерации;
		КонецЕсли;
		Если ТипЗнч(ПараметрыРегистрацииТриггера.ОбъектГенерации) = Тип("СправочникСсылка.Сделки") Тогда 
			МенеджерЗаписи.Сделка 						= ПараметрыРегистрацииТриггера.ОбъектГенерации;
		КонецЕсли;	
		Если ТипЗнч(ПараметрыРегистрацииТриггера.ОбъектГенерации) = Тип("Строка") ИЛИ ТипЗнч(ПараметрыРегистрацииТриггера.ОбъектГенерации) = Тип("УникальныйИдентификатор") Тогда 
			МенеджерЗаписи.IDСообщения 					= ПараметрыРегистрацииТриггера.ОбъектГенерации;
		КонецЕсли;
	КонецЕсли;
	
	МенеджерЗаписи.Описание 							= ПараметрыРегистрацииТриггера.Описание;
	МенеджерЗаписи.Сообщение 							= ПараметрыРегистрацииТриггера.Сообщение;
	
	Если Статус = Перечисления.СтатусыРегистрацииСобытий.ОшибкаРегистрации Тогда 
		МенеджерЗаписи.Статус 							= Перечисления.СтатусыРегистрацииСобытий.ОшибкаРегистрации;	
	КонецЕсли;
	
	МенеджерЗаписи.Записать();

КонецПроцедуры	

// Функция - Действие зарегистрировано
// 
// Возвращаемое значение:
//   - 
//
Функция ДействиеЗарегистрировано(ИдентификаторДействия, ВидДействия = Неопределено) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ЖурналРегистрацииТриггерныхСобытий.Взаимодействие КАК Взаимодействие,
	               |	ЖурналРегистрацииТриггерныхСобытий.SMSРассылка КАК SMSРассылка,
	               |	ЖурналРегистрацииТриггерныхСобытий.ЭлектронноеПисьмоИсходящее КАК ЭлектронноеПисьмоИсходящее,
	               |	ЖурналРегистрацииТриггерныхСобытий.Сделка КАК Сделка
	               |ИЗ
	               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
	               |ГДЕ
	               |	ЖурналРегистрацииТриггерныхСобытий.ИдентификаторДействия = &ИдентификаторДействия";
	
	Запрос.УстановитьПараметр("ИдентификаторДействия", ИдентификаторДействия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ФлагВозврата = НЕ РезультатЗапроса.Пустой();
	
	Если ФлагВозврата = Истина Тогда
		ВыборкаСтрокиРегистрации = РезультатЗапроса.Выбрать();
		Если ВыборкаСтрокиРегистрации.Следующий() Тогда 
			Если ЗначениеЗаполнено(ВыборкаСтрокиРегистрации.Взаимодействие) Тогда 
				ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру;
			ИначеЕсли ЗначениеЗаполнено(ВыборкаСтрокиРегистрации.SMSРассылка) Тогда	
				ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение;
			ИначеЕсли ЗначениеЗаполнено(ВыборкаСтрокиРегистрации.ЭлектронноеПисьмоИсходящее) Тогда	
				ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо;
			ИначеЕсли ЗначениеЗаполнено(ВыборкаСтрокиРегистрации.Сделка) Тогда	
				ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат ФлагВозврата;
	
КонецФункции

// Процедура - Актуализировать записи в журнале регистрации
//
// Параметры:
//  ТриггерноеСобытие	 - 	 - 
//
Процедура АктуализироватьЗаписиВЖурналеРегистрации(ТриггерноеСобытие) Экспорт
	
	Если ТипЗнч(ТриггерноеСобытие) = Тип("СправочникСсылка.ТриггерныеСобытия") Тогда 
		ТриггерноеСобытиеСсылка = ТриггерноеСобытие;
	ИначеЕсли ТипЗнч(ТриггерноеСобытие) = Тип("СправочникОбъект.ТриггерныеСобытия") Тогда	
		ТриггерноеСобытиеСсылка = ТриггерноеСобытие.Ссылка;
	Иначе 
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТриггерныеСобытияДействия.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ТриггерныеСобытияДействия.Использование КАК Использование,
	               |	ТриггерныеСобытияДействия.ВидДействия КАК ВидДействия,
	               |	ТриггерныеСобытияДействия.Описание КАК Описание
	               |ПОМЕСТИТЬ ТаблицаПланДействийТриггера
	               |ИЗ
	               |	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытияДействия
	               |ГДЕ
	               |	ТриггерныеСобытияДействия.Ссылка = &ТриггерноеСобытие
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЖурналРегистрацииТриггерныхСобытий.Период КАК Период,
	               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
	               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК ОбъектСобытия,
	               |	ЖурналРегистрацииТриггерныхСобытий.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
	               |	ЖурналРегистрацииТриггерныхСобытий.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ЖурналРегистрацииТриггерныхСобытий.Взаимодействие КАК Взаимодействие,
	               |	ЖурналРегистрацииТриггерныхСобытий.SMSРассылка КАК SMSРассылка,
	               |	ЖурналРегистрацииТриггерныхСобытий.ЭлектронноеПисьмоИсходящее КАК ЭлектронноеПисьмоИсходящее,
	               |	ЖурналРегистрацииТриггерныхСобытий.Сделка КАК Сделка,
	               |	ЖурналРегистрацииТриггерныхСобытий.IDСообщения КАК IDСообщения,
	               |	ЖурналРегистрацииТриггерныхСобытий.Статус КАК Статус,
	               |	ЖурналРегистрацииТриггерныхСобытий.Описание КАК Описание,
	               |	ЖурналРегистрацииТриггерныхСобытий.Сообщение КАК Сообщение
	               |ПОМЕСТИТЬ ТаблицаСобытийТриггера
	               |ИЗ
	               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
	               |ГДЕ
	               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
	               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаСобытийТриггера.Период КАК Период,
	               |	ТаблицаСобытийТриггера.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ТаблицаСобытийТриггера.Контрагент КАК Контрагент,
	               |	ТаблицаСобытийТриггера.ОбъектСобытия КАК ОбъектСобытия,
	               |	ТаблицаСобытийТриггера.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
	               |	ТаблицаПланДействийТриггера.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ТаблицаСобытийТриггера.Взаимодействие КАК Взаимодействие,
	               |	ЗНАЧЕНИЕ(Документ.РассылкаСообщений.ПустаяСсылка) КАК SMSРассылка,
	               |	ЗНАЧЕНИЕ(Документ.ЭлектронноеПисьмоИсходящее.ПустаяСсылка) КАК ЭлектронноеПисьмоИсходящее,
	               |	ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка) КАК Сделка,
	               |	&ПустойIDСообщения КАК IDСообщения,
	               |	ТаблицаСобытийТриггера.Статус КАК Статус,
	               |	ТаблицаПланДействийТриггера.Описание КАК Описание,
	               |	ТаблицаСобытийТриггера.Сообщение КАК Сообщение
	               |ПОМЕСТИТЬ ИтоговаяТаблица
	               |ИЗ
	               |	ТаблицаСобытийТриггера КАК ТаблицаСобытийТриггера
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПланДействийТриггера КАК ТаблицаПланДействийТриггера
	               |		ПО (ТаблицаПланДействийТриггера.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру))
	               |ГДЕ
	               |	ТаблицаСобытийТриггера.Взаимодействие <> ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТаблицаСобытийТриггера.Период,
	               |	ТаблицаСобытийТриггера.ТриггерноеСобытие,
	               |	ТаблицаСобытийТриггера.Контрагент,
	               |	ТаблицаСобытийТриггера.ОбъектСобытия,
	               |	ТаблицаСобытийТриггера.РегистрацияПоПодписке,
	               |	ТаблицаПланДействийТриггера.ИдентификаторДействия,
	               |	ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка),
	               |	ТаблицаСобытийТриггера.SMSРассылка,
	               |	ЗНАЧЕНИЕ(Документ.ЭлектронноеПисьмоИсходящее.ПустаяСсылка),
	               |	ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка),
	               |	&ПустойIDСообщения,
	               |	ТаблицаСобытийТриггера.Статус,
	               |	ТаблицаПланДействийТриггера.Описание,
	               |	ТаблицаСобытийТриггера.Сообщение
	               |ИЗ
	               |	ТаблицаСобытийТриггера КАК ТаблицаСобытийТриггера
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПланДействийТриггера КАК ТаблицаПланДействийТриггера
	               |		ПО (ТаблицаПланДействийТриггера.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.СообщениеSMS))
	               |ГДЕ
	               |	ТаблицаСобытийТриггера.SMSРассылка <> ЗНАЧЕНИЕ(Документ.РассылкаСообщений.ПустаяСсылка)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТаблицаСобытийТриггера.Период,
	               |	ТаблицаСобытийТриггера.ТриггерноеСобытие,
	               |	ТаблицаСобытийТриггера.Контрагент,
	               |	ТаблицаСобытийТриггера.ОбъектСобытия,
	               |	ТаблицаСобытийТриггера.РегистрацияПоПодписке,
	               |	ТаблицаПланДействийТриггера.ИдентификаторДействия,
	               |	ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка),
	               |	ЗНАЧЕНИЕ(Документ.РассылкаСообщений.ПустаяСсылка),
	               |	ЗНАЧЕНИЕ(Документ.ЭлектронноеПисьмоИсходящее.ПустаяСсылка),
	               |	ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка),
	               |	ТаблицаСобытийТриггера.IDСообщения,
	               |	ТаблицаСобытийТриггера.Статус,
	               |	ТаблицаПланДействийТриггера.Описание,
	               |	ТаблицаСобытийТриггера.Сообщение
	               |ИЗ
	               |	ТаблицаСобытийТриггера КАК ТаблицаСобытийТриггера
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПланДействийТриггера КАК ТаблицаПланДействийТриггера
	               |		ПО (ТаблицаПланДействийТриггера.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.СообщениеВМесенджер))
	               |ГДЕ
	               |	ТаблицаСобытийТриггера.IDСообщения <> &ПустойIDСообщения
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТаблицаСобытийТриггера.Период,
	               |	ТаблицаСобытийТриггера.ТриггерноеСобытие,
	               |	ТаблицаСобытийТриггера.Контрагент,
	               |	ТаблицаСобытийТриггера.ОбъектСобытия,
	               |	ТаблицаСобытийТриггера.РегистрацияПоПодписке,
	               |	ТаблицаПланДействийТриггера.ИдентификаторДействия,
	               |	ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка),
	               |	ЗНАЧЕНИЕ(Документ.РассылкаСообщений.ПустаяСсылка),
	               |	ТаблицаСобытийТриггера.ЭлектронноеПисьмоИсходящее,
	               |	ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка),
	               |	&ПустойIDСообщения,
	               |	ТаблицаСобытийТриггера.Статус,
	               |	ТаблицаПланДействийТриггера.Описание,
	               |	ТаблицаСобытийТриггера.Сообщение
	               |ИЗ
	               |	ТаблицаСобытийТриггера КАК ТаблицаСобытийТриггера
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПланДействийТриггера КАК ТаблицаПланДействийТриггера
	               |		ПО (ТаблицаПланДействийТриггера.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо))
	               |ГДЕ
