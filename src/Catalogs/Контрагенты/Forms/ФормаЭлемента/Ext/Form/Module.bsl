// Функция, возвращает структуру с количеством договор.
//
Функция ПолучитьКоличествоДоговоров()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(ВЗ_Архивные.КоличествоАрхивных, 0) КАК КоличествоАрхивных,
	|	ЕСТЬNULL(ВЗ_Действующие.КоличествоДействующих, 0) КАК КоличествоДействующих
	|ИЗ
	|	(ВЫБРАТЬ
	|		СУММА(1) КАК КоличествоАрхивных
	|	ИЗ
	|		Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|	ГДЕ
	|		(ВЫБОР
	|					КОГДА ДоговорыКонтрагентов.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|						ТОГДА ДоговорыКонтрагентов.ДатаОкончания < &ТекущаяДата
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ
	|				ИЛИ ВЫБОР
	|					КОГДА ДоговорыКонтрагентов.ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
	|						ТОГДА ДоговорыКонтрагентов.ДатаНачала > &ТекущаяДата
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ)
	|		И ДоговорыКонтрагентов.Контрагент = &Контрагент) КАК ВЗ_Архивные,
	|	(ВЫБРАТЬ
	|		СУММА(1) КАК КоличествоДействующих
	|	ИЗ
	|		Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|	ГДЕ
	|		ВЫБОР
	|				КОГДА ДоговорыКонтрагентов.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ДоговорыКонтрагентов.ДатаОкончания >= &ТекущаяДата
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		И ВЫБОР
	|				КОГДА ДоговорыКонтрагентов.ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
	|					ТОГДА ДоговорыКонтрагентов.ДатаНачала <= &ТекущаяДата
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		И ДоговорыКонтрагентов.Контрагент = &Контрагент) КАК ВЗ_Действующие";
	Запрос.УстановитьПараметр("Контрагент" , Объект.Ссылка);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));	
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать(); 
	СтруктураКоличества = Новый Структура("КоличествоАрхивных, КоличествоДействующих");
	Пока ВыборкаЗапроса.Следующий() Цикл
		СтруктураКоличества.КоличествоАрхивных = ВыборкаЗапроса.КоличествоАрхивных;	
		СтруктураКоличества.КоличествоДействующих = ВыборкаЗапроса.КоличествоДействующих; 
	КонецЦикла;
	
	Возврат СтруктураКоличества;
	
КонецФункции

