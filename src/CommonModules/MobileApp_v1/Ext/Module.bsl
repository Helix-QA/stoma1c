// Функция - Reason appointment
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Сотрудник			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция reason_appointment(СтруктурнаяЕдиница, Сотрудник) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПричиныЗаписи.Ссылка КАК Ссылка,
	|	ПричиныЗаписи.Представление КАК Представление,
	|	ПричиныЗаписи.НормаВремени КАК НормаВремени
	|ИЗ
	|	Справочник.ПричиныЗаписи КАК ПричиныЗаписи
	|ГДЕ
	|	ПричиныЗаписи.ПометкаУдаления = ЛОЖЬ");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	МассивПричинЗаписи = Новый Массив;
	Пока Выборка.Следующий() Цикл     
		СтруктураПричины = Новый Структура("УИДПричины, Представление, Длительность", УникальныйИдентификатор(Выборка.Ссылка), Выборка.Представление, Выборка.НормаВремени);
		МассивПричинЗаписи.Добавить(СтруктураПричины);
	КонецЦикла;
	
	Возврат ПолучитьСтруктуруОтвета(МассивПричинЗаписи);
	
КонецФункции

#КонецОбласти

#Область get_appointment_prescription

// Функция - Get appointment prescription
//
// Параметры:
//  Прием	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция get_appointment_prescription(Прием) Экспорт
	
	СтруктураДанныхПриема = Документы.Прием.ПолучитьИнформациюИзТекущегоПриема(Прием);
	МассивУслуг = ?(СтруктураДанныхПриема.Свойство("МассивУслуг"), СтруктураДанныхПриема.МассивУслуг, Новый Массив); 
	ДанныеПриема = ПолучитьДополнительныеданныеПриема(Прием);
	
	МассивУслугВозвр = Новый Массив;
	Для Каждого СтрокаМ Из МассивУслуг Цикл
		
		СтруктураУслуги = Новый Структура;
		СтруктураУслуги.Вставить("НоменклатураНаименование"	, СтрокаМ.НоменклатураНаименование);
		СтруктураУслуги.Вставить("УИДНоменклатуры"			, УникальныйИдентификатор(СтрокаМ.Номенклатура));
		СтруктураУслуги.Вставить("Количество"				, СтрокаМ.Количество);
		СтруктураУслуги.Вставить("КодУслуги"				, СтрокаМ.КодУслуги);
		СтруктураУслуги.Вставить("Зуб"						, ПолучитьИмяЗначенияПеречисления(СтрокаМ.Зуб));
		
		МассивУслугВозвр.Добавить(СтруктураУслуги);
		
	КонецЦикла;
	
	СтруктураВозврата = Новый Структура;			
	СтруктураВозврата.Вставить("МассивОбследований"	, ?(СтруктураДанныхПриема.Свойство("МассивОбследований"), СтруктураДанныхПриема.МассивОбследований, Новый Массив));	
	СтруктураВозврата.Вставить("МассивУслуг"		, МассивУслугВозвр);
	СтруктураВозврата.Вставить("ДанныеПриема"		, ДанныеПриема);
	
	Возврат ПолучитьСтруктуруОтвета(ВалидацияJSON(СтруктураВозврата));
	
КонецФункции

Функция ПолучитьДополнительныеданныеПриема(Прием)
	
	СтруктураВозврата = Новый Структура("Номер, Контрагент, Полис, Врач, Ассистент");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Прием.Номер КАК Номер,
	|	Прием.ПолисМедСтрахования.Наименование КАК Полис,
	|	Прием.Контрагент.Наименование КАК Контрагент,
	|	Прием.Сотрудник.Наименование КАК Врач,
	|	Прием.Ассистент.Наименование КАК Ассистент
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Ссылка = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка", Прием);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, Выборка);	
	КонецЕсли;
		
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область doctor_schedule

// Функция - Doctor schedule
//
// Параметры:
//  Сотрудник			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  ДатаНачала			 - 	 - 
//  ДатаОкончания		 - 	 - 
//  МассивИдСотрудников	 - 	 - 
//  МассивИдПомещений	 - 	 - 
//  Режим				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция doctor_schedule(Сотрудник, СтруктурнаяЕдиница, ДатаНачала, ДатаОкончания, МассивИдСотрудников, МассивИдПомещений, Режим) Экспорт
	
	СтруктураВозврата = Новый Структура("ГрафикКлиники, МассивСотрудников, МассивЗаписей");
	СтруктураВозврата.ГрафикКлиники = ?(Режим = "РасписаниеКлиникВрачейПриемов", РабочиеДниСтруктурнойЕдиницы(СтруктурнаяЕдиница), Неопределено);
	
	Настройки = Новый Структура();
	ЗагрузитьНастройкиЖурналаЗаписи(СтруктурнаяЕдиница, Настройки, Сотрудник);
	РольСотрудника = ПолучитьРольСотрудника(Сотрудник);
	
	Если Режим <> "РасписаниеПриемов" Тогда
		
		Если ВерсияПОСерверАктуальна(Метаданные.Версия, "2.1.2.1") = Ложь Тогда 
			МассивСсылокСотрудников = Новый Массив;		
			Если РольСотрудника = Перечисления.РольПользователя.Регистратура ИЛИ РольСотрудника =  Перечисления.РольПользователя.Руководитель Тогда
				ТаблицаСотрудников = ПолучитьПодчиненныхСотрудников(Сотрудник, СтруктурнаяЕдиница);
				МассивСсылокСотрудников = ТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник");
			ИначеЕсли РольПользователяУрезана(Сотрудник, РольСотрудника) Тогда
				МассивСсылокСотрудников.Добавить(Сотрудник);
			КонецЕсли;
		Иначе 
			МассивСсылокСотрудников = Справочники.Сотрудники.ПолучитьСотрудниковДляЖурналаЗаписи(СтруктурнаяЕдиница, Настройки,,, НачалоДня(ДатаНачала));
		КонецЕсли;
	
		ТаблицаСотрудниковПредставление = ПолучитьРасширенноеПредставлениеСотрудников(МассивСсылокСотрудников, Настройки);
		
		СтрокаТЗ = ТаблицаСотрудниковПредставление.Найти(Сотрудник, "Сотрудник");
		Если СтрокаТЗ <> Неопределено Тогда
			ИндексСтроки = ТаблицаСотрудниковПредставление.Индекс(СтрокаТЗ);
			ТаблицаСотрудниковПредставление.Сдвинуть(ИндексСтроки, -ИндексСтроки);
		КонецЕсли;
	
		ГрафикРаботыСотрудников = РегистрыСведений.ВремяРаботыСотрудниковПлан.ПолучитьПлановоеВремяРаботыСотрудника(ДатаНачала, ДатаОкончания, МассивСсылокСотрудников, СтруктурнаяЕдиница);
		
		МассивВрачей = Новый Массив;
		Для Каждого СтрокаТЧ из ТаблицаСотрудниковПредставление Цикл
			
			Представление = Справочники.Сотрудники.ПолучитьПредставлениеСотрудникаПоНастройкеОтображения(СтрокаТЧ, Настройки.ОтображениеСотрудника);
			
			МассивСтрок = Новый Массив;
			МассивСтрок.Добавить(Представление);
			Если Настройки.ОтображениеДолжности = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеВариантОтображать И ЗначениеЗаполнено(СтрокаТЧ.Должность) Тогда
				МассивСтрок.Добавить(СтрокаТЧ.Должность);
			КонецЕсли;
			
			СтруктураДобавления = Новый Структура;
			СтруктураДобавления.Вставить("УИД"			   , УникальныйИдентификатор(СтрокаТЧ.Сотрудник));
			СтруктураДобавления.Вставить("Значение"		   , СтрокаТЧ.Наименование);
			СтруктураДобавления.Вставить("Представление"   , МассивСтрок);
			СтруктураДобавления.Вставить("РольПользователя", ПолучитьРольПользователя(СтрокаТЧ.Роль));
			СтруктураДобавления.Вставить("Должность"	   , ?(ЗначениеЗаполнено(СтрокаТЧ.Должность), СокрЛП(СтрокаТЧ.Должность), "Без должности"));
			
			НайденныеСтроки = ГрафикРаботыСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			
			Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
				ГрафикРаботыСотрудника = Новый Массив;
				Для Каждого СтрокаТЗ Из НайденныеСтроки Цикл		
					ГрафикРаботыСотрудника.Добавить(Новый Структура("ДатаНачала, ДатаОкончания", СтрокаТЗ.ДатаВремяНачала, СтрокаТЗ.ДатаВремяОкончания));
				КонецЦикла;
				СтруктураДобавления.Вставить("ГрафикРаботыСотрудника", ГрафикРаботыСотрудника);	
			Иначе
				СтруктураДобавления.Вставить("ГрафикРаботыСотрудника", Неопределено);
			КонецЕсли;
			
			МассивВрачей.Добавить(СтруктураДобавления);
			
		КонецЦикла;
		
		СтруктураВозврата.МассивСотрудников = МассивВрачей;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивИдПомещений) Тогда
		
		МассивПомещений = Новый Массив;		
		Для Каждого ИдПомещения Из МассивИдПомещений Цикл
			Если ИдПомещения <> "00000000-0000-0000-0000-000000000000" Тогда
				Ресурс = ПолучитьСсылкуОбъектаПоУИД(ИдПомещения, "Справочники", "Помещения");		
				Если Не ЗначениеЗаполнено(Ресурс) Тогда 
					Возврат ПолучитьСтруктуруОтвета(, 2004,, Ложь);
				КонецЕсли;
				МассивПомещений.Добавить(Ресурс);
			Иначе
				МассивПомещений.Добавить(Справочники.Помещения.ПустаяСсылка());
			КонецЕсли;
		КонецЦикла;
		
		ОтборПоИзмерению = "Ресурс";
		
	Иначе
		
		//Если ЗначениеЗаполнено(МассивИдСотрудников) Тогда
		//	
		//	МассивСотрудников = Новый Массив;		
		//	Для Каждого ИдСотрудника Из МассивИдСотрудников Цикл			
		//		Мастер = ПолучитьСсылкуОбъектаПоУИД(ИдСотрудника, "Справочники", "Сотрудники");		
		//		Если Не ЗначениеЗаполнено(Мастер) Тогда 
		//			Возврат ПолучитьСтруктуруОтвета(, 2003,, Ложь);
		//		КонецЕсли;
		//		МассивСотрудников.Добавить(Мастер);			
		//	КонецЦикла;
		//	
		//	Если РольСотрудника <> Перечисления.РольПользователя.Руководитель И МассивСотрудников.Найти(Сотрудник) = Неопределено Тогда
		//		МассивСотрудников.Добавить(Сотрудник);
		//	КонецЕсли;		
		//	
		//Иначе
		//	МассивСотрудников = ТаблицаСотрудниковПредставление.ВыгрузитьКолонку("Сотрудник");	
		//КонецЕсли;
		
	КонецЕсли;
	
	//МассивДанныхЗаполнения = РасширениеПланировщикаСервер.ДанныеЗаполненияПланировщикаВизитами(ДатаНачала, ДатаОкончания,,, МассивСотрудников, МассивПомещений, СтруктурнаяЕдиница, ОтборПоИзмерению,,, Настройки);
	МассивДанныхЗаполнения = РасширениеПланировщикаСервер.ДанныеЗаполненияПланировщикаВизитами(ДатаНачала, ДатаОкончания,,, МассивСсылокСотрудников, МассивПомещений, СтруктурнаяЕдиница, ОтборПоИзмерению,,, Настройки);	
	
	Если РольПользователяУрезана(Сотрудник, РольСотрудника) Тогда
		
		НастройкиМобильногоПриложенияСтоматологии = Константы.НастройкиМобильногоПриложенияСтоматологии.Получить().Получить();	
		
		ВыводитьКомментарий = НастройкиМобильногоПриложенияСтоматологии <> Неопределено 
		И НастройкиМобильногоПриложенияСтоматологии.Свойство("ВыводитьВрачуКомментарий") 
		И НастройкиМобильногоПриложенияСтоматологии.ВыводитьВрачуКомментарий;
		
	Иначе
		ВыводитьКомментарий = Истина;
	КонецЕсли;
	
	МассивЗаписей = Новый Массив;
	Для Каждого СтрокаМ Из МассивДанныхЗаполнения Цикл                  
		
		СтрокаДанных = Новый Структура();
		СтрокаДанных.Вставить("УИДПриема"			, УникальныйИдентификатор(СтрокаМ.Событие));
		СтрокаДанных.Вставить("ДанныеКонтрагента"	, ВалидацияJSON(СтрокаМ.ДанныеКонтрагента));	
		СтрокаДанных.Вставить("ДатаВремяНачала"		, СтрокаМ.ДатаНачала); 
		СтрокаДанных.Вставить("ДатаВремяОкончания"	, СтрокаМ.ДатаОкончания);
		СтрокаДанных.Вставить("Сотрудник"           , УникальныйИдентификатор(СтрокаМ.Сотрудник));
		СтрокаДанных.Вставить("Помещение"           , УникальныйИдентификатор(СтрокаМ.Помещение));
		СтрокаДанных.Вставить("СтатусВизита"        , ПолучитьСтатусСобытия(СтрокаМ.Статус));
		СтрокаДанных.Вставить("Комментарий"         , ?(ВыводитьКомментарий, СтрЗаменить(СтрокаМ.Комментарий, Символы.ПС, " "), Неопределено));
		СтрокаДанных.Вставить("РазрешеноИзменение"  , СтрокаМ.РазрешеноИзменение);
		СтрокаДанных.Вставить("ПризнакЗаблокировано", СтрокаМ.ПризнакЗаблокировано);
		СтрокаДанных.Вставить("Текст"    			, СтрЗаменить(ПолучитьПредставлениеСобытия(Настройки, СтрокаМ, РольСотрудника, ВыводитьКомментарий), Символы.ПС, " "));			
		СтрокаДанных.Вставить("ЦветФона"            , ?(СтрокаМ.Резерв, ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаМ.ЦветФонаРезерва),,, Истина), СтрокаМ.ЦветФона));
		СтрокаДанных.Вставить("ЦветТекста"          , СтрокаМ.ЦветТекста);
		СтрокаДанных.Вставить("ПредставлениеУслугТекст"	, "");
		СтрокаДанных.Вставить("ВсегоПоВизиту"			, 0);
		СтрокаДанных.Вставить("Резерв"					, СтрокаМ.Резерв);
		СтрокаДанных.Вставить("СсылкаНаПрием"			, УникальныйИдентификатор(СтрокаМ.СсылкаНаПрием));		
		МассивЗаписей.Добавить(СтрокаДанных);
		
	КонецЦикла;
	
	СтруктураВозврата.Вставить("МассивЗаписей", МассивЗаписей);
	Возврат ПолучитьСтруктуруОтвета(СтруктураВозврата);
	
КонецФункции

// Процедура - Загрузить настройки журнала записи
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Настройки			 - 	 - 
//  ТекущийСотрудник	 - 	 - 
//
Процедура ЗагрузитьНастройкиЖурналаЗаписи(СтруктурнаяЕдиница, Настройки, ТекущийСотрудник)
	
	Настройки       = Новый Структура();
	ТаблицаНастроек = РегистрыСведений.НастройкиИнтерфейсов.ПолучитьНастройкиИнтерфейсаЖурналаЗаписи(СтруктурнаяЕдиница, ТекущийСотрудник);

	Для Каждого СтрокаТЧ Из ТаблицаНастроек Цикл
		
		Если СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеВремени Тогда
			Настройки.Вставить("ОтображениеВремени", Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеВариантНеОтображать);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеСотрудника Тогда
			Настройки.Вставить("ОтображениеСотрудника", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеКлиента Тогда
			Настройки.Вставить("ОтображениеКлиента", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеТелефона Тогда
			Настройки.Вставить("ОтображениеТелефона", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеУслуги Тогда
			Настройки.Вставить("ОтображениеУслуги", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеРесурса Тогда
			Настройки.Вставить("ОтображениеРесурса", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеКомментария Тогда
			Настройки.Вставить("ОтображениеКомментария", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеДолжности Тогда
			Настройки.Вставить("ОтображениеДолжности", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеВозраста Тогда
			Настройки.Вставить("ОтображениеВозраста", СтрокаТЧ.Значение);	
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветНеПодтверждена Тогда
			Настройки.Вставить("ЦветНеПодтверждена"      , ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение),,,Истина));
			Настройки.Вставить("ЦветТекстаНеПодтверждена", ПолучитьЦветТекстаПоЦветуФона(Настройки.ЦветНеПодтверждена));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПодтверждена Тогда
			Настройки.Вставить("ЦветПодтверждена"      , ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение),,,Истина));
			Настройки.Вставить("ЦветТекстаПодтверждена", ПолучитьЦветТекстаПоЦветуФона(Настройки.ЦветПодтверждена));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемНачат Тогда
			Настройки.Вставить("ЦветПриемНачат"      , ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение),,,Истина));
			Настройки.Вставить("ЦветТекстаПриемНачат", ПолучитьЦветТекстаПоЦветуФона(Настройки.ЦветПриемНачат));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемОкончен Тогда
			Настройки.Вставить("ЦветПриемОкончен"      , ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение),,,Истина));
			Настройки.Вставить("ЦветТекстаПриемОкончен", ПолучитьЦветТекстаПоЦветуФона(Настройки.ЦветПриемОкончен));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемОтменен Тогда
			Настройки.Вставить("ЦветПриемОтменен"      , ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение),,,Истина));
			Настройки.Вставить("ЦветТекстаПриемОтменен", ПолучитьЦветТекстаПоЦветуФона(Настройки.ЦветПриемОтменен));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемНеСостоялся Тогда
			Настройки.Вставить("ЦветПриемНеСостоялся"  , ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение),,,Истина));
			Настройки.Вставить("ЦветТекстаПриемНеСостоялся", ПолучитьЦветТекстаПоЦветуФона(Настройки.ЦветПриемНеСостоялся));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПациентОжидает Тогда
			Настройки.Вставить("ЦветПациентОжидает"  	 , ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение),,,Истина));
			Настройки.Вставить("ЦветТекстаПациентОжидает", ПолучитьЦветТекстаПоЦветуФона(Настройки.ЦветПациентОжидает));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеТекущегоДня Тогда
			Настройки.Вставить("ОтображениеТекущегоДня", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеФильтров Тогда
			Настройки.Вставить("ОтображениеФильтров", ?(ЗначениеЗаполнено(СтрокаТЧ.Значение), СтрокаТЧ.Значение, Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеФильтровВариант1));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.РазмерШрифта Тогда
			Настройки.Вставить("РазмерШрифта", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеКоличестваСотрудников Тогда
			Настройки.Вставить("ОтображениеКоличестваСотрудников", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ИнтервалЗаписи Тогда
			Настройки.Вставить("ИнтервалЗаписи", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеМедКарты Тогда
			Настройки.Вставить("ОтображениеМедКарты", СтрокаТЧ.Значение); 
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеЗагруженностиСотрудников Тогда
			Настройки.Вставить("ОтображениеЗагруженностиСотрудников", СтрокаТЧ.Значение);  
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеСортировка Тогда
			Настройки.Вставить("ОтображениеСортировка", ?(ЗначениеЗаполнено(СтрокаТЧ.Значение), СтрокаТЧ.Значение, Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСортировкаВариант2));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеФотографийСотрудников Тогда
			Настройки.Вставить("ОтображениеФотографийСотрудников", СтрокаТЧ.Значение); 	
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция - Получить представление события
//
// Параметры:
//  Настройки		 - 	 - 
//  СтрокаТЗСобытий	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеСобытия(Настройки, Знач СтрокаТЗСобытий, Роль, ВыводитьКомментарий)
	
	ПредставлениеСобытия = "";
	ПредставлениеКонтрагента = "";
	ВариантНастройкиНеОтображать = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеВариантНеОтображать;
	Если Настройки.ОтображениеКлиента <> ВариантНастройкиНеОтображать Тогда
		Документы.Событие.ПолучитьПредставлениеКлиентаВизита(СтрокаТЗСобытий.ДанныеКонтрагента, Настройки.ОтображениеКлиента, ПредставлениеКонтрагента);
		Если ПредставлениеКонтрагента <> "" Тогда
			ПредставлениеСобытия = ПредставлениеКонтрагента;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТЗСобытий.ДанныеКонтрагента.НомерМедКарты) 
		И Настройки.ОтображениеМедКарты <> ВариантНастройкиНеОтображать Тогда  
		ПредставлениеСобытия = ПредставлениеСобытия + " №" + СтрокаТЗСобытий.ДанныеКонтрагента.НомерМедКарты;
	КонецЕсли;
	
	Если Настройки.ОтображениеВозраста <> ВариантНастройкиНеОтображать
		И ЗначениеЗаполнено(СтрокаТЗСобытий.ДанныеКонтрагента.ДатаРождения) Тогда
		
		ПредставлениеВозраста = Формат(СтрокаТЗСобытий.ДанныеКонтрагента.ДатаРождения, "ДФ=dd.MM.yyyy") + 
								 " (" + ОбщегоНазначенияСтоматология.ВозвратитьВозрастСтрокой(СтрокаТЗСобытий.ДанныеКонтрагента.ДатаРождения) + ")";
		ПредставлениеСобытия = ПредставлениеСобытия + ?(ЗначениеЗаполнено(ПредставлениеСобытия) И ЗначениеЗаполнено(ПредставлениеВозраста), ", ", "") + ПредставлениеВозраста;  
		
	КонецЕсли;
	
	ПредставлениеТелефон = СтрокаТЗСобытий.ДанныеКонтрагента.Телефон;
	
	Если ЗначениеЗаполнено(ПредставлениеТелефон) И Настройки.ОтображениеТелефона <> ВариантНастройкиНеОтображать И РольПользователяУрезана(Неопределено, Роль) = Ложь Тогда 
		
		МассивТелефонов = СтрРазделить(ПредставлениеТелефон, ",", Ложь);
		
		Для каждого Телефон Из МассивТелефонов Цикл
			ПредставлениеСобытия = ПредставлениеСобытия + Символы.ПС + " " + Телефон;	
		КонецЦикла;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТЗСобытий.Комментарий) И Настройки.ОтображениеКомментария <> ВариантНастройкиНеОтображать И ВыводитьКомментарий Тогда
		ПредставлениеСобытия = ПредставлениеСобытия + ", комментарий: " + СтрокаТЗСобытий.Комментарий; 	
	КонецЕсли;
	
	ПредставлениеСобытия = ПредставлениеСобытия + ?(ЗначениеЗаполнено(ПредставлениеСобытия), Символы.ПС, "");
	
	Возврат СокрЛП(СтрСоединить(СтрРазделить(ПредставлениеСобытия, Символы.ВК))) + ?(Не ЗначениеЗаполнено(ПредставлениеСобытия), СтрокаТЗСобытий.Текст, "");

КонецФункции

