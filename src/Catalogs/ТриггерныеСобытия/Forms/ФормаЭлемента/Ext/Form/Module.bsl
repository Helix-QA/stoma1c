//  Элемент	 - 	 - 
//
Процедура Подключаемый_ИспользованиеДействия_Поле_ПриИзменении(Элемент)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаНастройкиДействийТриггерногоСобытия(ЭтотОбъект, Элемент, ТекущаяСтруктурнаяЕдиница);
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		УстановитьСвойстваЭлементамДействий(, СтруктураДанныеЭлемента.ИндексСтроки);
		Если ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.ШаблонСообщения) Тогда
			ИнформирующееСообщение = "";
			Если ПустоеСодержаниеШаблона(СтруктураДанныеЭлемента.ДанныеЭлемента.ШаблонСообщения, , СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия, ИнформирующееСообщение) Тогда 
				// Сообщаем
				Если ЗначениеЗаполнено(ИнформирующееСообщение) Тогда 
					ОбщегоНазначенияКлиент.СообщитьПользователю(ИнформирующееСообщение,
					, "Объект.Действия[" + Формат(СтруктураДанныеЭлемента.ИндексСтроки, "ЧГ=0") + "]." + "ШаблонСообщения");
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;				
	КонецЕсли;
	
КонецПроцедуры

