&НаКлиенте
// Процедура - обработчик команды "Настройки".
//
Процедура Настройки(Команда)
	
	Элементы.ФормаНастройки.Пометка = НЕ Элементы.ФормаНастройки.Пометка;
	Элементы.ГруппаНастройки.Видимость = Элементы.ФормаНастройки.Пометка;
	
