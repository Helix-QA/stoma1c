			НайденныеУслуги = Объект.Лечение.НайтиСтроки(Новый Структура("КлючСтроки, Номенклатура", СтрокаМатериала.КлючСтроки, СтрокаМатериала.Услуга));
			Если НайденныеУслуги.Количество() = 0 Тогда
