// Функция проверяет корректность адреса электронной почты
// 
Функция ЭлектроннаяПочтаКорректна(ЭлектроннаяПочтаКлиента, СтрокаОшибки)
	
	СтрокаОшибки = "";
	
	Попытка
		Результат = ОбщегоНазначенияКлиентСервер.РазобратьСтрокуСПочтовымиАдресами(ЭлектроннаяПочтаКлиента);
		Если Результат.Количество() > 1 Тогда
			СтрокаОшибки = Нстр("ru = 'Допускается ввод только одного адреса электронной почты'");
		КонецЕсли;
	Исключение
		СтрокаОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат ПустаяСтрока(СтрокаОшибки);
	
КонецФункции

// Функция - Получить организацию салона
// 
// Возвращаемое значение:
//   - 
// 
&НаСервереБезКонтекста
Функция ПолучитьОрганизациюСалона()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Организации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	НЕ Организации.ПометкаУдаления
	|	И НЕ Организации.ЭтоГруппа");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Процедура - Проверить существованиеи создатьвнешние системы
// 
&НаСервере
Процедура ПроверитьСуществованиеиСоздатьвнешниеСистемы()
	
	  ТипыУпрИзКабинета = Справочники.ВнешниеСистемы.ТипыВнешнихСистемУправляемыхизЛичногоКабинета();
	  
	  Для Каждого ТипСистемы ИЗ ТипыУпрИзКабинета Цикл
		  
		  ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,ТипСистемы, Ложь);
		  
		  Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
			  
			  ВнешняяСистема = Справочники.ВнешниеСистемы.СоздатьВнешнююСистему(ТипСистемы);
			  
			  Если ТипСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи Тогда
				  
				  РезультатЗапроса = ОбновитьВнешнююСистемуВ_CRM(ВнешняяСистема,, ЭтотОбъект.УидСессии);
				  
				  Если РезультатЗапроса.ВыполненоУспешно = Истина Тогда				
					  Справочники.ВнешниеСистемы.УстановитьСостояниеВнешнейСистеме(ВнешняяСистема, Истина, Истина);				
				  КонецЕсли;
				  
			  КонецЕсли;
			  
		  КонецЕсли;
		  
	  КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
