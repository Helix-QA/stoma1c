&НаКлиенте
// Процедура - Проверка дублирования клиента контактная информация ответ
// Завершение немодального открытия окна "ПоказатьВопрос()" 
// Параметры:
//  РезультатВопроса - Ответ на вопрос
//  Параметры	     - Параметры вопроса 
//
Процедура ПроверкаДублированияКлиентаКонтактнаяИнформацияОтвет(РезультатВопроса, Параметры)  Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Отмена Тогда
		ЭтотОбъект.Телефон_НовыйПациент = "";
		Возврат;
	КонецЕсли;
	
	Если Параметры.МассивКлиентов.Количество() > 1 Тогда
		
		ЗначениеОтбора	 = Новый Структура("Телефон", ЭтотОбъект.Телефон_НовыйПациент);
		ПараметрыОтбора	 = Новый Структура("Отбор"	, ЗначениеОтбора);	
		ПараметрыОтбора.Вставить("РежимОтображения", "Список");
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВыбратьПациентаИзСпискаДублей", ЭтаФорма, РезультатВопроса);
		ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты",ПараметрыОтбора,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		Возврат;
	Иначе
		ПроверкаДублированияКлиентаКонтактнаяИнформацияЗавершение(РезультатВопроса, Параметры.МассивКлиентов[0]);
		Возврат;
	КонецЕсли;
	
	Если РезультатВопроса = КодВозвратаДиалога.Нет Тогда
		
		Объект.Контрагент = Параметры.МассивКлиентов[0];
		
		ПризнакСозданияНовогоПациента = Ложь;
		Элементы.ГруппаКонтрагента.Видимость = Истина;
		Элементы.Группировка2НовыйПациент.Видимость = Ложь;
		
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Да Тогда
		
		ПараметрыСозданияРодственника = Новый Структура;
		ПараметрыСозданияРодственника.Вставить("Фамилия"			, ЭтотОбъект.Фамилия_НовыйПациент);
		ПараметрыСозданияРодственника.Вставить("Имя"				, ЭтотОбъект.Имя_НовыйПациент);
		ПараметрыСозданияРодственника.Вставить("Отчество"			, ЭтотОбъект.Отчество_НовыйПациент);
		ПараметрыСозданияРодственника.Вставить("НомерТелефона"		, ЭтотОбъект.Телефон_НовыйПациент);
		ПараметрыСозданияРодственника.Вставить("ПолНовогоКлиента"	, ЭтотОбъект.Пол_НовыйПациент);
		ПараметрыСозданияРодственника.Вставить("ДатаРождения"		, ЭтотОбъект.ДатаРождения_НовыйПациент);
		ПараметрыСозданияРодственника.Вставить("СозданиеИзСобытия"	, Истина);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеСозданияРодственника", ЭтотОбъект); 
		
		ОткрытьФорму(
			"РегистрСведений.РодственныеСвязи.Форма.ФормаЗаписиБыстрая",
			ПараметрыСозданияРодственника,,,,,
			ОписаниеОповещения,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца
		);
		
	КонецЕсли;
	
КонецПроцедуры

