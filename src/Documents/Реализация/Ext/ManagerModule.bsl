Процедура ЗаписатьНоминалСертификатаПриПродаже(ДокументСсылкаРеализация) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияЗапасы.Партия КАК Партия,
	|	РеализацияЗапасы.Цена
	|ИЗ
	|	Документ.Реализация.Запасы КАК РеализацияЗапасы
	|ГДЕ
	|	РеализацияЗапасы.Ссылка = &Ссылка
	|	И РеализацияЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	|	И РеализацияЗапасы.Номенклатура.ВидНоминала
	|	И РеализацияЗапасы.Ссылка.Проведен");
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаРеализация);
	СписокЗапасов = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаЗапасов Из СписокЗапасов Цикл
		Если ЗначениеЗаполнено(СтрокаЗапасов.Партия) Тогда
			Партия = СтрокаЗапасов.Партия.ПолучитьОбъект();
			Партия.Номинал = СтрокаЗапасов.Цена;
			Партия.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

