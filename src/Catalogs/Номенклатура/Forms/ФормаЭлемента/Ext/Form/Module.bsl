// Процедура, выполняет выбор упаковки номенклатуры.
//  Параметры:
//   ДанныеВыбора - структура выбора;
//   СтандартнаяОбработка - признак выполнения стандартной обработки выбора.
//   ТекущаяСтрока - текущая строка табличной части, в которой осуществляется выбор значения.
Процедура ВыбратьУпаковкуНоменклатуры(ДанныеВыбора, СтандартнаяОбработка, ТекущаяСтрока)

	СтандартнаяОбработка = Ложь;

	Если ЗначениеЗаполнено(ТекущаяСтрока.НСМНоменклатура) Тогда
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Справочник.УпаковкиНоменклатуры.ПустаяСсылка"), "<без упаковки>");

		Если Не ОбщегоНазначенияСтоматология.ПроверитьИспользованиеУпаковокИПолучитьСписокДляВыбора(ТекущаяСтрока.НСМНоменклатура, ДанныеВыбора) Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Для данной номенклатуры нет упаковок.'"));
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

