#Область УдостоверенияЛичности

&НаКлиенте
Процедура ДобавитьУдостоверениеЛичности(Команда)
	
	ТипДопИнформации = Новый Структура;
	ТипДопИнформации.Вставить("ЭтоУдостоверениеЛичности", Истина);
	Если Объект.Ссылка.Пустая() Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ОткрытьФормуВводаДопИнформации", ЭтотОбъект, ТипДопИнформации), "Для ввода удостоверения личности необходимо произвести запись нового сотрудника. Записать?", РежимДиалогаВопрос.ДаНет);		
	Иначе 
		ОткрытьФормуВводаДопИнформации(, ТипДопИнформации);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтрокуУдостоверенияЛичности(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ПослеВопросаОПродолженииУдаленияУдостоверенияЛичности", ЭтаФорма);
	ПоказатьВопрос(Оповещение, "Будет удалено удостоверение личности. Продолжить?", РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВопросаОПродолженииУдаленияУдостоверенияЛичности(Ответ, ДопПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);	
		СтрокаДанных   = ЭтаФорма.УдостоверенияЛичностиСуществующие.НайтиПоИдентификатору(ИДСтрокиДанных);
		
		Если СтрокаДанных <> Неопределено Тогда
			
			ОписаниеОшибки = "";
			
			УдостоверениеУдалено = УдалитьСтрокуУдостоверениеЛичностиСервер(СтрокаДанных.ФизЛицо, СтрокаДанных.ВидДокумента, ОписаниеОшибки);
			
			Если УдостоверениеУдалено Тогда
				ЭтотОбъект.УдостоверенияЛичностиСуществующие.Удалить(СтрокаДанных);
				МассивРодителей = Новый Массив();
				МассивРодителей.Добавить("ГруппаУдостоверенияЛичностиСуществующие");
				ОтображениеДополнительнойИнформации(МассивРодителей);
			Иначе 
				ПоказатьПредупреждение(,"Не удалось удалить удостоверение личности. " + ОписаниеОшибки);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция УдалитьСтрокуУдостоверениеЛичностиСервер(ФизЛицо, ВидДокумента, ОписаниеОшибки = "")
	
	Попытка 
		Запись = РегистрыСведений.ДокументыФизическихЛиц.СоздатьМенеджерЗаписи();
		Запись.Физлицо = ФизЛицо;
		Запись.ВидДокумента = ВидДокумента;
		Запись.Удалить();		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;

КонецФункции

