// Процедура, заполнить параметры выбора организации.
//
Процедура ЗаполнитьПараметрыВыбораОрганизации()
	
	Если Объект.ЭтоГоловнаяОрганизация = Истина Тогда		
		Возврат;
	КонецЕсли;
	
	МассивОрганизаций = Новый Массив();
	
	Если ЗначениеЗаполнено(Объект.ИНН) Тогда
		
		ГоловнаяОрганизация = ПолучитьГоловнуюОрганизацию(Объект.ИНН);
		Если ЗначениеЗаполнено(ГоловнаяОрганизация) Тогда
			
			Если ГоловнаяОрганизация.КПП = Объект.КПП Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'У организации и головной организация совпадает КПП ("+ (Объект.КПП)+"). Введите другое значение.'")); 
				Объект.КПП = "";           			
			Иначе
				МассивОрганизаций = Новый Массив();
				МассивОрганизаций.Добавить(ГоловнаяОрганизация);
			КонецЕсли;
			
		Иначе
			
			// Алгоритм когда еще не существует головной организации, можно любую сделать таковой.
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Организации.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Организации КАК Организации
			|ГДЕ
			|	&УсловиеОтборов
			|	И Организации.ПометкаУдаления = ЛОЖЬ
			|	И Организации.ЭтоГруппа = ЛОЖЬ";
			
			Если Объект.Ссылка.Пустая() Тогда
				
				Если ЗначениеЗаполнено(Объект.КПП)
					И ЗначениеЗаполнено(Объект.ИНН) Тогда
					УсловиеОтборов = "Организации.КПП <> &КПП И Организации.ИНН = &ИНН";	
				Иначе
					УсловиеОтборов = "ЛОЖЬ";
				КонецЕсли;
				
			Иначе
				
				Если ЗначениеЗаполнено(Объект.КПП)
					И ЗначениеЗаполнено(Объект.ИНН) Тогда
					УсловиеОтборов = "Организации.Ссылка <> &Ссылка 
					|	И Организации.КПП <> &КПП 
					|	И Организации.ИНН = &ИНН";
				Иначе
					УсловиеОтборов = "ЛОЖЬ";
				КонецЕсли;
				
			КонецЕсли; 
			
			Если УсловиеОтборов = "ЛОЖЬ" Тогда
				МассивОрганизаций = Новый Массив();
			Иначе
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборов", УсловиеОтборов); 
				Запрос.УстановитьПараметр("Ссылка"	, Объект.Ссылка);
				Запрос.УстановитьПараметр("КПП"		, Объект.КПП);
				Запрос.УстановитьПараметр("ИНН"		, Объект.ИНН);
				МассивОрганизаций = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
		
	ФиксированныйМассив = Новый ФиксированныйМассив(МассивОрганизаций);
	ПараметрыОтбора = Новый ПараметрВыбора("Отбор.Ссылка", ФиксированныйМассив);
	
	НовыйМассив = Новый Массив();
	НовыйМассив.Добавить(ПараметрыОтбора);
	
	ФиксированныйМассив = Новый ФиксированныйМассив(НовыйМассив); 
	Элементы.ГоловнаяОрганизация.ПараметрыВыбора = ФиксированныйМассив;	
	
КонецПроцедуры

