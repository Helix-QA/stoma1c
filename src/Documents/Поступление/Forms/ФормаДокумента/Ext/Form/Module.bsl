// Процедура - Включение стоимости услуг в себестоимость запасов при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ВключениеСтоимостиУслугВСебестоимостьЗапасовПриИзменении(Элемент)

	Если Объект.ВключениеСтоимостиУслугВСебестоимостьЗапасов = 0 Тогда
		Элементы.ЗапасыСуммаРасходов.Видимость = Ложь;
		Для Каждого СтрокаТабличнойЧасти Из Объект.Запасы Цикл
			СтрокаТабличнойЧасти.СуммаРасходов = 0;
			РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
		КонецЦикла;
	ИначеЕсли Объект.ВключениеСтоимостиУслугВСебестоимостьЗапасов = 1 Тогда
		Элементы.ЗапасыСуммаРасходов.Видимость = Истина;
		РаспределитьТабЧастьРасходыПоКоличеству(Объект.Запасы, Объект.Расходы);
	ИначеЕсли Объект.ВключениеСтоимостиУслугВСебестоимостьЗапасов = 2 Тогда
		Элементы.ЗапасыСуммаРасходов.Видимость = Истина;
		РаспределитьТабЧастьРасходыПоСумме(Объект.Запасы, Объект.Расходы);
	КонецЕсли;
	
КонецПроцедуры

