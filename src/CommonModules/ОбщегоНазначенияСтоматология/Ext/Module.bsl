		СтруктураРеквизита = Новый Структура(ИмяРеквизита, КлючУникальности);
		ЗаполнитьЗначенияСвойств(СтруктураРеквизита, Объект);
		
		Возврат СтруктураРеквизита[ИмяРеквизита] <> КлючУникальности;
		
	ИначеЕсли НЕ МетаданныеОбъекта = Неопределено Тогда
		
		Возврат НЕ (МетаданныеОбъекта.Реквизиты.Найти(ИмяРеквизита) = Неопределено);
		
	КонецЕсли;
		
	Возврат Ложь;		

КонецФункции

// Функция - Есть реквизит формы
//
// Параметры:
//  Объект		 - 	 - 
//  ИмяРеквизита - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЕстьРеквизитФормы(Объект, ИмяРеквизита) Экспорт
	
	КлючУникальности   = Новый УникальныйИдентификатор;

	СтруктураРеквизита = Новый Структура(ИмяРеквизита, КлючУникальности);

	ЗаполнитьЗначенияСвойств(СтруктураРеквизита, Объект);
	
	Возврат СтруктураРеквизита[ИмяРеквизита] <> КлючУникальности;
	
КонецФункции

#Область ПроцедурыОтносящиесяКОбработкеЗаполненияОбъектов


// Процедура предназначена для заполнения общих реквизитов документов,
// вызывается в обработчиках событий "ОбработкаЗаполнения" И "ПриКопировании"
// в модулях объектов всех документов.
//
// Параметры:
//
// 1. Объект                 - объект редактируемого документа,
// 2. ПараметрКопирования    - указывает что документ создан копированием
// 3. ПараметрыЗаполнения    - ссылка на документ сонование
//
Процедура ЗаполнитьРеквизитыОбъектаПоУмолчанию(Объект, ПараметрКопирования = Неопределено, ПараметрыЗаполнения = Неопределено, ОбщиеПараметры = Неопределено) Экспорт
	
	Пользователь        = ТекущийПользователь();
	МетаданныеДокумента = Объект.Ссылка.Метаданные();
	// РазрешеноПроведение = МетаданныеДокумента.Проведение = Метаданные.СвойстваОбъектов.Проведение.Разрешить;
	
	ПараметрЗначениеКопирования = Неопределено;
	ПараметрыЗначенияЗаполнения = Новый Структура;	
	Если ПараметрКопирования = Неопределено Тогда 
		Если ПараметрыЗаполнения <> Неопределено Тогда 
			Если ТипЗнч(ПараметрыЗаполнения) = Тип("Структура") Тогда 
				Если ПараметрыЗаполнения.Свойство("Отбор") Тогда 
					ПараметрыЗначенияЗаполнения = ПараметрыЗаполнения.Отбор;
				Иначе 
					ПараметрыЗначенияЗаполнения = ПараметрыЗаполнения;
				КонецЕсли;	
			КонецЕсли;		
		КонецЕсли;
	Иначе 
		ПараметрЗначениеКопирования = ПараметрКопирования.Ссылка;
	КонецЕсли;
		
	// Заполнение реквизитов по-умолчанию
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Если НЕ ЗначениеЗаполнено(ПараметрЗначениеКопирования) Тогда
			
			Контрагент = ПолучитьИмяРеквизитаКонтрагент(МетаданныеДокумента);
			Если ОбщиеПараметры = Неопределено ИЛИ НЕ ОбщиеПараметры.Свойство("ПараметрыЗаполнения") Тогда
				Если Контрагент <> Неопределено Тогда 
					Если НЕ ЗначениеЗаполнено(Объект[Контрагент]) Тогда
						ЗаполнитьРеквизитКонтрагент(Объект, МетаданныеДокумента, ПараметрыЗначенияЗаполнения, Контрагент);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если Контрагент <> Неопределено Тогда
				КартаКлиента = ПолучитьИмяРеквизитаКартаКлиента(МетаданныеДокумента);
				Если КартаКлиента <> Неопределено Тогда				
					ЗаполнитьРеквизитКартаКлиента(Объект, МетаданныеДокумента, ПараметрыЗначенияЗаполнения, КартаКлиента, Контрагент);
				КонецЕсли;
			КонецЕсли;	
							
			Если ЕстьРеквизитДокумента("СервисSMSРассылки", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.СервисSMSРассылки) Тогда
				Объект.СервисSMSРассылки = Константы.СервисSMSРассылкиПоУмолчанию.Получить();									
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("СтруктурнаяЕдиница", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
				ЗаполнитьРеквизитСтруктурнаяЕдиница(Объект, ПараметрыЗначенияЗаполнения);									
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("Организация", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.Организация) Тогда 
				ЗначениеНастройки = ПользователиСтоматология.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь, "ОсновнаяОрганизация");
				Если ЗначениеЗаполнено(ЗначениеНастройки) Тогда
					Объект.Организация = ЗначениеНастройки;
				КонецЕсли;
				Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
					Если ЕстьРеквизитДокумента("СтруктурнаяЕдиница", МетаданныеДокумента) И ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) И ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница.Организация) Тогда 
						Объект.Организация = Объект.СтруктурнаяЕдиница.Организация;
					ИначеЕсли ЗначениеЗаполнено(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница) Тогда 					
						Объект.Организация = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;                                         
					КонецЕсли;
				КонецЕсли;
			КонецЕсли; 

			Если ЕстьРеквизитДокумента("СтруктурнаяЕдиницаПолучатель", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.СтруктурнаяЕдиницаПолучатель) Тогда
				Объект.СтруктурнаяЕдиницаПолучатель = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;									
			КонецЕсли;			
			
			Если ЕстьРеквизитДокумента("БанковскийСчет", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда 
				ЗаполнитьРеквизитБанковскийСчет(Объект, ПараметрыЗначенияЗаполнения)				
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("Касса", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.Касса) Тогда
				ЗаполнитьРеквизитКасса(Объект, Пользователь, ПараметрыЗначенияЗаполнения);					
			КонецЕсли; 			
			
			Если ЕстьРеквизитДокумента("ЭквайрингТерминал", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.ЭквайрингТерминал) Тогда
				Объект.ЭквайрингТерминал  = Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыйТерминалПоУмолчанию(Объект.Касса);					
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("КассоваяСмена", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.КассоваяСмена) Тогда
				СостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Объект.Касса);
				Если СостояниеКассовойСмены <> Неопределено Тогда
					Объект.КассоваяСмена = СостояниеКассовойСмены.КассоваяСмена;
				КонецЕсли;
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("СотрудникРегистрации", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.СотрудникРегистрации) И НЕ (ТипЗнч(Объект) = Тип("СправочникОбъект.Контрагенты") И Объект.ЭтоГруппа) Тогда
				Объект.СотрудникРегистрации = ПараметрыСеанса.ТекущийПользователь;
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("Сотрудник", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.Сотрудник) Тогда
				ЗаполнитьРеквизитСотрудник(Объект, ПараметрыЗначенияЗаполнения);				
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("Ассистент", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.Ассистент) Тогда
				ЗаполнитьРеквизитАссистент(Объект, ПараметрыЗначенияЗаполнения);				
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("Склад", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.Склад) Тогда
				ЗаполнитьРеквизитСклад(Объект, МетаданныеДокумента, Пользователь, ПараметрыЗначенияЗаполнения);
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("ШаблонОбследования", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.ШаблонОбследования) И ЗначениеЗаполнено(Объект.Контрагент) Тогда
				ЗаполнитьРеквизитШаблонОбследования(Объект);
			КонецЕсли;
			
			Если ЕстьРеквизитДокумента("Статус", МетаданныеДокумента) И НЕ ЗначениеЗаполнено(Объект.Статус) Тогда
				ЗаполнитьРеквизитСтатус(Объект);
			КонецЕсли;
			
			// Заполним автора документа
			Если ЕстьРеквизитДокумента("АвторДокумента", МетаданныеДокумента) Тогда
				Объект.АвторДокумента = ПараметрыСеанса.ТекущийПользователь;
			КонецЕсли;   			
			
			// Заполним автора документа
			Если ЕстьРеквизитДокумента("Автор", МетаданныеДокумента) Тогда
				Объект.Автор = ПараметрыСеанса.ТекущийПользователь;
			КонецЕсли;
			
		   // Заполним статьи документа
		   Если ЕстьРеквизитДокумента("ВидОперации", МетаданныеДокумента) И ЕстьРеквизитДокумента("Статья", МетаданныеДокумента)
			  И ЗначениеЗаполнено(Объект.ВидОперации) И Не ЗначениеЗаполнено(Объект.Статья) Тогда
				Объект.Статья = Справочники.СтатьиДоходовИРасходов.ПолучитьСтатьюПоУмолчаниюДляОперации(Объект.ВидОперации);
			КонецЕсли;

		ИначеЕсли ЕстьРеквизитДокумента("АвторДокумента", МетаданныеДокумента) Тогда
			Объект.АвторДокумента = ПараметрыСеанса.ТекущийПользователь;
		ИначеЕсли ЕстьРеквизитДокумента("Автор", МетаданныеДокумента) Тогда
			Объект.Автор = ПараметрыСеанса.ТекущийПользователь;			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры // ЗаполнитьШапкуДокумента()

// Процедура, осуществляет заполнение реквизита СтруктурнаяЕдиница
//
Процедура ЗаполнитьРеквизитСтруктурнаяЕдиница(Объект, ПараметрыЗначенияЗаполнения)
	
	Если ПараметрыЗначенияЗаполнения <> Неопределено Тогда
		Если ПараметрыЗначенияЗаполнения.Свойство("СтруктурнаяЕдиница") Тогда 
			Если ЗначениеЗаполнено(ПараметрыЗначенияЗаполнения.СтруктурнаяЕдиница) Тогда 
				Объект.СтруктурнаяЕдиница = ПараметрыЗначенияЗаполнения.СтруктурнаяЕдиница;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ВсеСсылки = Справочники.ТипВсеСсылки(); 
	Если НЕ ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) И ((ВсеСсылки.СодержитТип(ТипЗнч(Объект.Ссылка)) И НЕ Объект.ЭтоГруппа) ИЛИ НЕ ВсеСсылки.СодержитТип(ТипЗнч(Объект.Ссылка))) Тогда 
		Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;									
	КонецЕсли;	
	
КонецПроцедуры

// Процедура, осуществляет заполнение реквизита Касса
//
Процедура ЗаполнитьРеквизитКасса(Объект, Пользователь, ПараметрыЗначенияЗаполнения)
	
	Если ПараметрыЗначенияЗаполнения <> Неопределено Тогда
		Если ПараметрыЗначенияЗаполнения.Свойство("Касса") Тогда 
			Если ЗначениеЗаполнено(ПараметрыЗначенияЗаполнения.Касса) Тогда 
				Объект.Касса = ПараметрыЗначенияЗаполнения.Касса;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Касса) Тогда 
		ЗначениеНастройки = ПользователиСтоматология.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь, "ОсновнаяКасса", Объект.СтруктурнаяЕдиница);				
		Если ЗначениеЗаполнено(ЗначениеНастройки) Тогда
			Объект.Касса = ЗначениеНастройки;
		Иначе	
			Объект.Касса =  Объект.СтруктурнаяЕдиница.ОсновнаяКасса;
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

// Процедура, осуществляет заполнение реквизита БанковскийСчет
//
Процедура ЗаполнитьРеквизитКартаКлиента(Объект, МетаданныеДокумента, ПараметрыЗначенияЗаполнения, КартаКлиента, Контрагент)
	
	Если ЗначениеЗаполнено(Объект[Контрагент]) Тогда
		Если НЕ ЗначениеЗаполнено(Объект[КартаКлиента]) Тогда			
			Если ПараметрыЗначенияЗаполнения <> Неопределено Тогда 
				Если ПараметрыЗначенияЗаполнения.Свойство(КартаКлиента) Тогда
					Объект[КартаКлиента] = ПараметрыЗначенияЗаполнения[КартаКлиента];					
				КонецЕсли;	
			КонецЕсли;	
			
			Если Не ЗначениеЗаполнено(Объект[КартаКлиента]) Тогда	
				Если Объект.Ссылка.Пустая() И ЗначениеЗаполнено(Объект[Контрагент]) Тогда 
					Объект[КартаКлиента] = Справочники.Карты.ПолучитьКартуКлиента(Объект[Контрагент]);
				КонецЕсли;	
			КонецЕсли;			
		КонецЕсли;	
	Иначе
		Объект[КартаКлиента] = Справочники.Карты.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры

// Процедура, осуществляет заполнение реквизита БанковскийСчет
//
Процедура ЗаполнитьРеквизитБанковскийСчет(Объект, ПараметрыЗначенияЗаполнения)
	
	Если ПараметрыЗначенияЗаполнения <> Неопределено Тогда 
		Если ПараметрыЗначенияЗаполнения.Свойство("БанковскийСчет") Тогда
			Объект.БанковскийСчет = ПараметрыЗначенияЗаполнения.БанковскийСчет;					
		КонецЕсли;	
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда 	
		Объект.БанковскийСчет = Объект.СтруктурнаяЕдиница.Организация.БанковскийСчетПоУмолчанию;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, осуществляет заполнение реквизита Сотрудник
//
Процедура ЗаполнитьРеквизитСотрудник(Объект, ПараметрыЗначенияЗаполнения)
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") 
		ИЛИ ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.СписаниеДенежныхСредств") Тогда 					
		Объект.Сотрудник = Неопределено;
	ИначеЕсли ПараметрыЗначенияЗаполнения <> Неопределено Тогда 
		Если ПараметрыЗначенияЗаполнения.Свойство("Сотрудник") Тогда
			Объект.Сотрудник = ПараметрыЗначенияЗаполнения.Сотрудник;					
		КонецЕсли;	
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(Объект.Сотрудник) Тогда 	
		Объект.Сотрудник = ПараметрыСеанса.ТекущийПользователь.Сотрудник;
	КонецЕсли;
	
КонецПроцедуры

