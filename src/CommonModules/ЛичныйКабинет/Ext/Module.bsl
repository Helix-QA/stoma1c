// Функция вернет пустую структру данных передаваемых 
// в RemoteAccessService для регистрвции новой анкеты
Функция ПолучитьПустуюСтруктуруДанныхРегистрацииАнкеты() Экспорт
	
	ПарамтерыРегистрации = Новый Структура;
	
	ПарамтерыРегистрации.Вставить("КонтактноеЛицоИмя"                 ,Неопределено);
    ПарамтерыРегистрации.Вставить("КонтактноеЛицоТелефон"             ,Неопределено);
    ПарамтерыРегистрации.Вставить("КонтактноеЛицоПочта"               ,Неопределено);
	
	ПарамтерыРегистрации.Вставить("КлиникаТип"                        ,Неопределено);
	ПарамтерыРегистрации.Вставить("КлиникаНаименование"               ,Неопределено);
    ПарамтерыРегистрации.Вставить("КлиникаГород"                      ,Неопределено);
    ПарамтерыРегистрации.Вставить("КлиникаРазмер"                     ,Неопределено);
	
	ПарамтерыРегистрации.Вставить("ОрганизацияНаименование"           ,Неопределено);
	ПарамтерыРегистрации.Вставить("ОрганизацияАдресСтрокой"           ,Неопределено);
	ПарамтерыРегистрации.Вставить("ОрганизацияАдресXML"               ,Неопределено);
	ПарамтерыРегистрации.Вставить("ОрганизацияТелефон"                ,Неопределено);
	ПарамтерыРегистрации.Вставить("ОрганизацияПочта"                  ,Неопределено);
	ПарамтерыРегистрации.Вставить("ОрганизацияИНН"                    ,Неопределено);

	ПарамтерыРегистрации.Вставить("ОрганизацияОтправительИД"          ,Неопределено); 
	ПарамтерыРегистрации.Вставить("ОрганизацияОтправительПолноеИмя"   ,Неопределено);
	
	ПарамтерыРегистрации.Вставить("ПродуктНаименование"               ,ПолучитьАртикулПродукта());
	ПарамтерыРегистрации.Вставить("ПродуктАртикул"                    ,ПолучитьАртикулПродукта());
	ПарамтерыРегистрации.Вставить("ПродуктДатаПевогоЗапуска"          ,Константы.ДатаПервогоВходаВСистему.Получить());
	
	ПарамтерыРегистрации.Вставить("ПродуктРегистрационныйНомер"       ,Неопределено);
	ПарамтерыРегистрации.Вставить("ПродуктСкринАнкеты"                ,Неопределено);	
	ПарамтерыРегистрации.Вставить("ПродуктПароль"                     ,Неопределено);
	ПарамтерыРегистрации.Вставить("ПродуктУИДБазы"                    ,Неопределено); 
	ПарамтерыРегистрации.Вставить("ПродуктСЛКиспользуется"            ,Неопределено);
		
	Возврат ПарамтерыРегистрации;
	
КонецФункции

