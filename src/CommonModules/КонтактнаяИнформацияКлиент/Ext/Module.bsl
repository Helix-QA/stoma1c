Процедура ДействиеКИНажатие(Форма, Элемент) Экспорт
	
	ИндексКИ = Число(Сред(Элемент.Имя, СтрДлина("ДействиеКИ_")+1));
	ДанныеКИ = Форма.КонтактнаяИнформация[ИндексКИ];
	
	Если ЗначениеЗаполнено(ДанныеКИ.Представление) Тогда
		
		Если ДанныеКИ.Тип = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон") Тогда
			
			IPТелефонияКлиент.ИсходящийЗвонокОсуществитьПоКонтрагенту(Форма.Объект.Ссылка, ДанныеКИ.Представление);
			
		ИначеЕсли  ДанныеКИ.Тип = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты") Тогда
			
			ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения", Новый Структура("Предмет, Адрес", Форма.Объект.Ссылка, ДанныеКИ.Представление));
