
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест"
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Параметры.Свойство("Идентификатор", Идентификатор);
	Заголовок = НСтр("ru='Оборудование:'") + Символы.НПП  + Строка(Идентификатор);
	
	времСервер          	= Неопределено;
	времПароль	        	= Неопределено;
	времСтруктурнаяЕдиница 	= Неопределено;

	Параметры.ПараметрыОборудования.Свойство("Сервер"          		, времСервер);
	Параметры.ПараметрыОборудования.Свойство("Пароль"          		, времПароль);
	Параметры.ПараметрыОборудования.Свойство("СтруктурнаяЕдиница"	, времСтруктурнаяЕдиница);
	
	Сервер          	= ?(времСервер	        = Неопределено,   "wss://mobile.prostiezvonki.ru:443"	, времСервер);
	Пароль          	= ?(времПароль	        = Неопределено,   ""			, времПароль);
	СтруктурнаяЕдиница 	= ?(времСтруктурнаяЕдиница = Неопределено, Неопределено	, времСтруктурнаяЕдиница);
	
	Если Параметры.Свойство("Идентификатор") Тогда 
		КлючТелефонии = "_" + СтрЗаменить(Параметры.Идентификатор.Ссылка.УникальныйИдентификатор(), "-", "");		
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьИнформациюОДрайвере();
	ОбновитьНадписьСостояния();
	
КонецПроцедуры

// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПростыеЗвонки_ИзменилосьСостояние" Тогда
		
		ОбновитьНадписьСостояния(Параметр);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УстановитьДрайвер(Команда)
        
	ВременныйКаталог = КаталогВременныхФайлов();
	СсылкаНаФайл = МенеджерОборудованияВызовСервера.ПолучитьМакетССервера("ДрайверВедисофтПростыеЗвонки");
	ПолучитьФайл(СсылкаНаФайл, ВременныйКаталог + "ProstieZvonki_ActiveX_2.0.exe", Ложь);		
	Попытка		
		НачатьЗапускПриложения(Новый ОписаниеОповещения("УстановитьДрайверПослеУстановки", ЭтотОбъект), ВременныйКаталог + "ProstieZvonki_ActiveX_2.0.exe", , Истина); 
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
		
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДрайверПослеУстановки(КодВозврата, Параметры)  Экспорт
	
	ОбновитьИнформациюОДрайвере();

КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрытьВыполнить()
	
	НовыеЗначениеПараметров = Новый Структура;
	НовыеЗначениеПараметров.Вставить("Сервер"          , Сервер);
	НовыеЗначениеПараметров.Вставить("Пароль"          , Пароль);
	НовыеЗначениеПараметров.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	Результат = Новый Структура;
	Результат.Вставить("Идентификатор", Идентификатор);
	Результат.Вставить("ПараметрыОборудования", НовыеЗначениеПараметров);
	
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ТестУстройства(Команда)
	
	ОчиститьСообщения();
	ВыходныеПараметры  = Новый Массив;
	
	ОбновитьИнформациюОДрайвере();
	
	Результат = IPТелефонияКлиент.ПодключитьУстройство(Неопределено, Новый Структура("Сервер, Пароль", Сервер, Пароль), Неопределено, ВыходныеПараметры);
	Если Результат Тогда
		ТекстСообщения = НСтр("ru = 'Тест успешно выполнен.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	Иначе
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Тест не пройден. Ошибка: %1';"), ?(ВыходныеПараметры.Количество() > 0, ВыходныеПараметры[1], ""));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура СкрытьПоказатьДополнительно(Команда)
	
	Элементы.ГруппаДополнительно.Видимость = Не Элементы.ГруппаДополнительно.Видимость;
	
КонецПроцедуры

&НаКлиенте
Процедура ВерсияКомпонентыСкачатьНажатие(Элемент)
	НачатьЗапускПриложения(Новый ОписаниеОповещения("ЗапускПриложенияЗавершение", ЭтотОбъект), "http://www.prostiezvonki.ru/download");
КонецПроцедуры

// Процедура - Открытие навигационной ссылки из заголовка
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ОткрытиеНавигационнойСсылкиИзЗаголовка(Элемент)
	НачатьЗапускПриложения(Новый ОписаниеОповещения("ЗапускПриложенияЗавершение", ЭтотОбъект), Элемент.Заголовок);
КонецПроцедуры

&НаКлиенте
Процедура ЗапускПриложенияЗавершение(КодВозврата, ДополнительныеПараметры) Экспорт
	
	// Заглушка описания оповещения
	Возврат;	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьИнформациюОДрайвере()
	
	Элементы.АктуальнаяВерсияActiveX.Заголовок	= IPТелефонияКлиент.ПростыеЗвонки_ПолучитьНомерПоследнейВерсии();
	Элементы.ВерсияActiveX.Заголовок			= IPТелефонияКлиент.ПростыеЗвонки_ПолучитьВерсиюКомпоненты(КлючТелефонии);
	
	Элементы.ГруппаВерсияКомпонентыАктуальная.Видимость = (Элементы.АктуальнаяВерсияActiveX.Заголовок > Элементы.ВерсияActiveX.Заголовок И ЗначениеЗаполнено(Элементы.АктуальнаяВерсияActiveX.Заголовок));
	Элементы.ВерсияКомпонентыУстановленаПоследняя.Видимость = НЕ Элементы.ГруппаВерсияКомпонентыАктуальная.Видимость;
	
	Если Элементы.ВерсияActiveX.Заголовок = "" Тогда
		Элементы.ВерсияActiveX.ЦветТекста = Новый Цвет(255, 0, 0);
		Элементы.ВерсияActiveX.Заголовок = "Не установлено";
	Иначе
		Элементы.ВерсияActiveX.ЦветТекста = Новый Цвет(0, 0, 0);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНадписьСостояния(Статус = Неопределено)
	
	Если Статус = Неопределено Тогда
		Статус = IPТелефонияКлиент.ПростыеЗвонкиПолучитьСостояние();
	КонецЕсли;
	
	Если Статус = 1 Тогда
		Состояние = "Есть соединение";
		Элементы.Состояние1.ЦветТекста = WebЦвета.Зеленый;
	Иначе
		Если Статус = 0 Тогда
			Состояние = "Нет соединения";
		ИначеЕсли Статус = 2 Тогда
			Состояние = "Лицензия истекла";
		ИначеЕсли Статус = 3 Тогда
			Состояние = "Превышен лимит клиентов";
		КонецЕсли;
		Элементы.Состояние1.ЦветТекста = WebЦвета.Кирпичный;
		
		Если Статус = 4 Тогда
			Состояние = "Второе подключение пользователя";	
		КонецЕсли;
		Элементы.Состояние1.ЦветТекста = WebЦвета.Красный;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти