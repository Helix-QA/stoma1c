
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При чтении на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	ПользователиВарианта = ВернутьНастройкиДоступностиВариантаОтчета(ТекущийОбъект.Ссылка);
	
	ЗаполнитьИзПредопределенного(ТекущийОбъект);
    ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");

	Элементы.ГруппаИспользования.Доступность 				= НЕ ТекущийОбъект.ПометкаУдаления И ДоступноАдминистрированиеОтчетов;
	Элементы.ГруппаПодсистемы.Доступность 					= НЕ ТекущийОбъект.ПометкаУдаления И ПравоНаЭтотВариант;
	Элементы.НастроитьВидимостьПользователей.Доступность 	= НЕ ТекущийОбъект.ПометкаУдаления И ДоступноАдминистрированиеОтчетов;
	Элементы.НастроитьПодсистемы.Доступность 				= НЕ ТекущийОбъект.ПометкаУдаления И ПравоНаЭтотВариант;
	
	Элементы.Автор.ТолькоПросмотр 							= НЕ ПолныеПраваНаВарианты ИЛИ ТекущийОбъект.ПометкаУдаления;
	
	Если ТекущийОбъект.ПометкаУдаления Тогда 
		//Элементы.ГруппаКнопкиСохранить.ЦветФона 			= Новый Цвет(73, 195, 125);
		Элементы.ФормаКнопкаСохранитьИЗакрыть.ЦветТекста 	= Новый Цвет(255, 255, 255);
		Элементы.ФормаКнопкаСохранитьИЗакрыть.Заголовок 	= НСтр("ru = 'Восстановить';en = 'Recover'");
		КомандаВосстановить = ЭтаФорма.Команды.Найти("ЗаписатьИЗакрыть");
		Если НЕ КомандаВосстановить = Неопределено Тогда 
			КомандаВосстановить.Подсказка = НСтр("ru = 'Восстановить вариант отчета';en = 'Restore a report option'");
		КонецЕсли;	
	Иначе 
		//Элементы.ГруппаКнопкиСохранить.ЦветФона 			= Новый Цвет(255, 215, 40);
		Элементы.ФормаКнопкаСохранитьИЗакрыть.ЦветТекста 	= Новый Цвет(255, 255, 255);
		Элементы.ФормаКнопкаСохранитьИЗакрыть.Заголовок 	= НСтр("ru = 'Сохранить';en = 'Save'");
		КомандаЗаписатьИЗакрыть = ЭтаФорма.Команды.Найти("ЗаписатьИЗакрыть");		
		Если НЕ КомандаЗаписатьИЗакрыть = Неопределено Тогда 
			КомандаЗаписатьИЗакрыть.Подсказка = НСтр("ru = 'Сохранить вариант отчета и закрыть форму';en = 'Save the report option and close the form'");
		КонецЕсли;			
	КонецЕсли;
	Элементы.ПометитьНаУдаление.Видимость 					= НЕ ТекущийОбъект.ПометкаУдаления И ТекущийОбъект.Пользовательский;
	//Элементы.ГруппаКнопкиУдаления.ЦветФона 					= ?(ПравоНаЭтотВариант, Элементы.ГруппаКнопкиУдаления.ЦветФона, Новый Цвет(247, 247, 247));	
	
КонецПроцедуры

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	Доступен = ?(Объект.ТолькоДляАвтора, "ТолькоДляАвтора", "УказаннымПользователям");
	ДоступноАдминистрированиеОтчетов = РольДоступна("ПолныеПрава") ИЛИ РольДоступна("АдминистрированиеОтчетов");
	
	ПолныеПраваНаВарианты = ВариантыОтчетов.ПолныеПраваНаВарианты();
	ПравоНаЭтотВариант = (ПолныеПраваНаВарианты И Объект.Автор = Пользователи.АвторизованныйПользователь()) ИЛИ ДоступноАдминистрированиеОтчетов;
	Если НЕ ПравоНаЭтотВариант Тогда
		ТолькоПросмотр = Истина;
		Элементы.ГруппаПодсистемы.Доступность 				= Ложь;
		Элементы.НастроитьПодсистемы.Доступность 			= Ложь;		
	КонецЕсли;
	
	Элементы.ГруппаКнопкиУдаления.Доступность 				= ПравоНаЭтотВариант;
	Если Объект.ПометкаУдаления Тогда 
		Элементы.ФормаКнопкаСохранитьИЗакрыть.Доступность 	= ПравоНаЭтотВариант;		
		//Элементы.ГруппаКнопкиСохранить.ЦветФона 			= ?(ПравоНаЭтотВариант, Новый Цвет(73, 195, 125), Новый Цвет(247, 247, 247));
		Элементы.ФормаКнопкаСохранитьИЗакрыть.ЦветТекста 	= ?(ПравоНаЭтотВариант, Новый Цвет(255, 255, 255), Новый Цвет());
		Элементы.ФормаКнопкаСохранитьИЗакрыть.Заголовок 	= НСтр("ru = 'Восстановить';en = 'Recover'");
		КомандаВосстановить = ЭтаФорма.Команды.Найти("ЗаписатьИЗакрыть");
		Если НЕ КомандаВосстановить = Неопределено Тогда 
			КомандаВосстановить.Подсказка = НСтр("ru = 'Восстановить вариант отчета';en = 'Restore a report option'");
		КонецЕсли;			
	Иначе
		Элементы.ФормаКнопкаСохранитьИЗакрыть.Доступность 	= Истина;
		//Элементы.ГруппаКнопкиСохранить.ЦветФона 			= Новый Цвет(255, 215, 40);
		Элементы.ФормаКнопкаСохранитьИЗакрыть.ЦветТекста 	= Новый Цвет(255, 255, 255);
		Элементы.ФормаКнопкаСохранитьИЗакрыть.Заголовок 	= НСтр("ru = 'Сохранить';en = 'Save'");
		КомандаЗаписатьИЗакрыть = ЭтаФорма.Команды.Найти("ЗаписатьИЗакрыть");		
		Если НЕ КомандаЗаписатьИЗакрыть = Неопределено Тогда 
			КомандаЗаписатьИЗакрыть.Подсказка = НСтр("ru = 'Сохранить вариант отчета и закрыть форму';en = 'Save the report option and close the form'");
		КонецЕсли;					
	КонецЕсли;	
	//Элементы.ГруппаКнопкиУдаления.ЦветФона 				= ?(ПравоНаЭтотВариант, Элементы.ГруппаКнопкиУдаления.ЦветФона, Новый Цвет(247, 247, 247));	
	Элементы.ПометитьНаУдаление.Доступность 				= ПравоНаЭтотВариант;
	
	Если НЕ Объект.Пользовательский Тогда
		Элементы.Наименование.ТолькоПросмотр 				= Истина;
		Элементы.Описание.ТолькоПросмотр 					= Истина;
		Элементы.Автор.ТолькоПросмотр 						= Истина;
		Элементы.Автор.АвтоОтметкаНезаполненного 			= Ложь;
		Элементы.ПометитьНаУдаление.Видимость 				= Ложь;
	КонецЕсли;

	Элементы.ГруппаИспользования.Доступность 				= НЕ Объект.ПометкаУдаления И ДоступноАдминистрированиеОтчетов;
	Элементы.ГруппаПодсистемы.Доступность 					= НЕ Объект.ПометкаУдаления И ПравоНаЭтотВариант;
	Элементы.НастроитьВидимостьПользователей.Доступность 	= НЕ Объект.ПометкаУдаления И ДоступноАдминистрированиеОтчетов;
	Элементы.НастроитьПодсистемы.Доступность 				= НЕ Объект.ПометкаУдаления И ПравоНаЭтотВариант;
	
	ЭтоВнешний = (Объект.ТипОтчета = Перечисления.ТипыОтчетов.Внешний);
	Если ЭтоВнешний Тогда
		Элементы.ГруппаПодсистемы.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Элементы.Автор.ТолькоПросмотр = НЕ ПолныеПраваНаВарианты ИЛИ Объект.ПометкаУдаления;
	
	// Заполнение имени отчета для команды "Просмотр".
	Если Объект.ТипОтчета = Перечисления.ТипыОтчетов.Внутренний
		ИЛИ Объект.ТипОтчета = Перечисления.ТипыОтчетов.Расширение Тогда
		ИмяОтчета = Объект.Отчет.Имя;
	ИначеЕсли Объект.ТипОтчета = Перечисления.ТипыОтчетов.Дополнительный Тогда
		ИмяОтчета = Объект.Отчет.ИмяОбъекта;
	Иначе
		ИмяОтчета = Объект.Отчет;
	КонецЕсли;
	
	ПерезаполнитьДерево(Ложь);
	СписокПользователей = "";
	СписокПодсистем     = "";	
	Элементы.НастроитьВидимостьПользователей.Заголовок = ОписаниеПользователей();
	Элементы.НастроитьПодсистемы.Заголовок    = ОписаниеПодсистем();

	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаСервере
// Процедура - Перед записью на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// Запись свойств, связанных с предопределенным вариантом отчета.
	ОписаниеИзменено = Ложь;
	Если ЭтоПредопределенный Тогда
		
		ПредопределенныйВариант = ТекущийОбъект.ПредопределенныйВариант.ПолучитьОбъект();
		МультиязычностьСервер.ПриЧтенииПредставленийНаСервере(ПредопределенныйВариант);
		
		ОписаниеИзменено = Не ПустаяСтрока(Объект.Описание) И НРег(СокрЛП(Объект.Описание)) <> НРег(СокрЛП(ПредопределенныйВариант.Описание));
		Если Не ОписаниеИзменено Тогда
			ТекущийОбъект.Описание = "";
			Для каждого ПредставлениеВарианта Из ТекущийОбъект.Представления Цикл 
				ПредставлениеВарианта.Описание = "";
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
	
	// Запись дерева подсистем.
	ДеревоПриемник = РеквизитФормыВЗначение("ДеревоПодсистем", Тип("ДеревоЗначений"));
	Если ТекущийОбъект.ЭтоНовый() Тогда
		ИзмененныеРазделы = ДеревоПриемник.Строки.НайтиСтроки(Новый Структура("Использование", 1), Истина);
	Иначе
		ИзмененныеРазделы = ДеревоПриемник.Строки.НайтиСтроки(Новый Структура("Модифицированность", Истина), Истина);
	КонецЕсли;
	ВариантыОтчетов.ДеревоПодсистемЗаписать(ТекущийОбъект, ИзмененныеРазделы);
	
	МультиязычностьСервер.ПередЗаписьюНаСервере(ТекущийОбъект);
	Если ЭтоПредопределенный И Не ОписаниеИзменено Тогда
		ТекущийОбъект.Представления.Очистить();
	КонецЕсли;
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ПользователиВарианта", ПользователиВариантаРедактирование);
	ТекущийОбъект.ДополнительныеСвойства.Вставить("УстанавливатьПоПометке", ЗначениеЗаполнено(ПользователиВариантаРедактирование));

КонецПроцедуры

&НаСервере
// Процедура - При записи на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
КонецПроцедуры

&НаСервере
// Процедура - После записи на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ЗаполнитьИзПредопределенного(ТекущийОбъект);

КонецПроцедуры

&НаКлиенте
// Процедура - После записи
//
// Параметры:
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ВариантыОтчетовКлиент.ОбновитьОткрытыеФормы(Объект.Ссылка, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НастроитьВидимостьПользователей(Команда)
	
	//ПользователиВарианта = ВернутьНастройкиДоступностиВариантаОтчета(Объект.Ссылка);

	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("ВариантОтчета"						, Объект.Ссылка);
	ПараметрыФормы.Вставить("Пользователи"						, ПользователиВарианта);
	ПараметрыФормы.Вставить("ПользователиВариантаРедактирование", ПользователиВариантаРедактирование);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("РезультатВыбораВариантыОтчетовФормаРедактированиеВидимости", ЭтаФорма);
	ОткрытьФорму("Справочник.ВариантыОтчетов.Форма.РедактированиеВидимости", ПараметрыФормы, ЭтаФорма,,,,ОписаниеОповещения, 
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьПодсистемы(Команда)
	
	ПараметрыФормы = Новый Структура("ДеревоПодсистем", ДеревоПодсистем);
	ОписаниеОповещения = Новый ОписаниеОповещения("РезультатВыбораВариантыОтчетовФормаРедактированиеПодсистемы", ЭтаФорма);
	ОткрытьФорму("Справочник.ВариантыОтчетов.Форма.РедактированиеПодсистемы", ПараметрыФормы, ЭтаФорма,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
КонецПроцедуры

&НаКлиенте
// Процедура - Пометить на удаление снять пометку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПометитьНаУдалениеСнятьПометку(Команда)
	
	ОповещениеДиалога = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПометкаУдаления", ЭтотОбъект);
	Если Объект.ПометкаУдаления Тогда 
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Снять с ""%1"" пометку на удаление?';en = 'Uncheck %1 for deletion?'"), Строка(Объект.Ссылка));	
	Иначе 
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Пометить ""%1"" на удаление?';en = 'Mark %1 for deletion?'"), Строка(Объект.Ссылка));	
	КонецЕсли;
	
	ПоказатьВопрос(ОповещениеДиалога, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);

КонецПроцедуры

&НаКлиенте
// Процедура - Записать и закрыть
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ЗаписатьИЗакрыть(Команда)
	
	Если Объект.ПометкаУдаления Тогда 
		ОповещениеДиалога = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПометкаУдаления", ЭтотОбъект);
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Снять с ""%1"" пометку на удаление?';en = 'Uncheck %1 for deletion?'"), Строка(Объект.Ссылка));	
	
		ПоказатьВопрос(ОповещениеДиалога, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);
	Иначе 
		ЭтаФорма.Записать();
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - После закрытия вопроса пометка удаления
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеЗакрытияВопросаПометкаУдаления(Результат, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
        Возврат;
	ИначеЕсли Результат = КодВозвратаДиалога.Да Тогда 
		Объект.ПометкаУдаления = НЕ Объект.ПометкаУдаления;
		ЭтаФорма.Записать();
		Если Объект.ПометкаУдаления Тогда 
			ЭтаФорма.Закрыть();
		Иначе 	
			ЭтаФорма.Прочитать();
		КонецЕсли;	
    КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Вернуть настройки доступности варианта отчета
//
// Параметры:
//  ВариантОтчета						 - 	 - 
//  ПользователиВариантаРедактирование	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьНастройкиДоступностиВариантаОтчета(ВариантОтчета, ПользователиВариантаРедактирование = Неопределено)
	
	Возврат РегистрыСведений.НастройкиВариантовОтчетов.ПрочитатьНастройкиДоступностиВариантаОтчета2(ВариантОтчета, ПользователиВариантаРедактирование);
	
КонецФункции

Функция ОписаниеПользователей()
		
	Если ПользователиВарианта.Количество() = 0 Тогда
		ОписаниеПользователя = "Все пользователи";
	Иначе
		ОписаниеПользователя = "";
		Для каждого СтрокаПользователя Из ПользователиВарианта Цикл
			ОписаниеПользователя = ОписаниеПользователя + СтрокаПользователя.Представление + ", ";
		КонецЦикла;
		ОписаниеПользователя = Лев(ОписаниеПользователя, СтрДлина(ОписаниеПользователя)-2);
	КонецЕсли;

	Возврат ОписаниеПользователя;
	
КонецФункции

Функция ОписаниеПодсистем()
	
	СписокПодсистем = "";
		
	ДеревоЗнач = РеквизитФормыВЗначение("ДеревоПодсистем");
	ОбойтиУровеньДерева(ДеревоЗнач.Строки, СписокПодсистем);   
	
	Если СписокПодсистем = "" Тогда
		СписокПодсистем = "Раздел не выбран"
	КонецЕсли;
	
	Возврат СписокПодсистем;
	
КонецФункции

Процедура ОбойтиУровеньДерева(Строки, СписокПодсистем = "")
	
	Для Каждого Строка Из Строки Цикл
		
		Если Строка.Использование = 1 Тогда
			СписокПодсистем = СписокПодсистем + ?(ЗначениеЗаполнено(СписокПодсистем), ", ", "") + Строка.Представление;  
		КонецЕсли;
        ОбойтиУровеньДерева(Строка.Строки, СписокПодсистем);
		
 	КонецЦикла;
 
КонецПроцедуры

