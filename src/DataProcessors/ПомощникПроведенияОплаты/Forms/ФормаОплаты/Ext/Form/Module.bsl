#КонецОбласти

#Область ПроведениеОплаты

&НаКлиенте
// Обработчик проведения оплаты по подготовленным данным
Процедура Оплатить(Команда)
	
	Если ПредПолеВВодаСуммыОплаты <> Неопределено Тогда
	    ЗавершитьРедактированиеПоляВводаСуммы(ПредПолеВВодаСуммыОплаты);		
	КонецЕсли;
		
	СообщениеПользователю               = "";
	ТребуетсяПодтверждениеПользователя  = Ложь;
	ОперацияРазрешена                   = Ложь;
	ОперацияОплатыПроведеноУспешно      = Ложь;
	ДанныефискальныхЧеков               = Неопределено;
	ДанныеПлатежаПоКарте                = Неопределено;
	МассивДокОплаты                     = Новый Массив;
	ОшибкаПечатиЧека 					= "";
	ЭтоВозврат = ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Возврат");
	
	СтавкаНДСОрганизации		= ОбщегоНазначенияСтоматология.ПолучитьСтавкуНДС(СтруктурнаяЕдиница);
	СтавкаНДСОрганизацииАванс	= ОбщегоНазначенияСтоматология.ПолучитьСтавкуНДСАванс(СтруктурнаяЕдиница);

	Если ТаблицаЗадолженностейИзменена() = Истина Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ТаблицаЗадолженностейИзмененаЗавершение", ЭтотОбъект);
		ПоказатьПредупреждение(ОписаниеОповещения, НСтр("ru = 'Задолженность пациента изменилась. Форма оплаты будет обновлена.'"));
		Возврат;		
	КонецЕсли;
	
	МассивСтрок = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей"));
	
	Если МассивСтрок.Количество() > 0 Тогда
		
		ТекВыбраннаяСтрока = МассивСтрок[0]; 
		
		Если ЭтоВозврат Тогда
			
			Если ЗначениеЗаполнено(ДокументыЗадолженности) И ТипЗнч(ДокументыЗадолженности[0].Значение) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
				
				СтруктураПараметров = Новый Структура();
				СтруктураПараметров.Вставить("ЭквайринговыйТерминал", ТекВыбраннаяСтрока.ЭквайринговыйТерминал);
				СтруктураПараметров.Вставить("КассаОплаты"			, ТекВыбраннаяСтрока.КассаОплаты);
				СтруктураПараметров.Вставить("Контрагент"			, ТекВыбраннаяСтрока.Контрагент);
				СтруктураПараметров.Вставить("СуммаВозвратаВРублях"	, ТекВыбраннаяСтрока.Внесено);
				СтруктураПараметров.Вставить("ВозвратОтПокупателя"	, ДокументыЗадолженности[0].Значение);
				СтруктураПараметров.Вставить("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
				
				РезультатОперации = СсылкиНаОплатуИСБП.СформироватьВозвратПоСБП(СтруктураПараметров);
				
				Если Не РезультатОперации.ВыполненоУспешно Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОперации.ОписаниеОшибки);
				Иначе
					ПоказатьОповещениеПользователя("Система быстрых платежей",, "Заказ передан в банк для обработки возврата и через некоторое время будет сформирован в системе 1с");
					ЭтаФорма.Закрыть(Новый Структура("ОперацияВыполнена, ОплатаВыполнена, ТребуетсяВыполнитьОплатуВозвратаРеализации", Истина, Истина, Ложь));
				КонецЕсли;
				
				Возврат;
				
			Иначе
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Невозможно сформировать возврат через СБП по данному документу");
				Возврат;	
				
			КонецЕсли;
			
		Иначе 
			
			ЗавершитьВводСуммыОплатыСБП(ТекВыбраннаяСтрока);
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтотОбъект.ТекущаяКассаИспользуетсяККТ Тогда
		
		ВыполнятьОперациюНаФискальнике  = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущаяКасса, "ИспользоватьБезПодключенияОборудования") = Ложь; 
		
	Иначе
		
		ВыполнятьОперациюНаФискальнике  = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущаяКасса, "ИспользоватьБезПодключенияОборудования") = Ложь
		И (ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа") 
		ИЛИ ЭтотОбъект.ЭтоВозвратВДеньПродажи = Истина);
		
	КонецЕсли;
	
	// Проверка возможности выполнения операции оплаты
	Если ОплатаПодготовкаПроверкаВозможностиСервер(СообщениеПользователю, ТребуетсяПодтверждениеПользователя) Тогда		
		
		// Выполнить контроль кассовой смены
		ОписаниеОшибки   					= Неопределено;
		ПараметрыИспользованияКассовойСмены = Новый Структура("ВыполнятьОперациюНаФискальнике", ВыполнятьОперациюНаФискальнике);
