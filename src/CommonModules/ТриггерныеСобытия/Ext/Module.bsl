				Продолжить;
			КонецЕсли;			
			РеестрЗапланированных = ТаблицаЗапланированныхТриггеровВРазрезеКонтрагентов.Скопировать(Новый Структура("ОбъектСобытия, ТриггерноеСобытие", ОбъектСобытия, СтрокаЗапланированныйТриггер.ТриггерноеСобытие));
