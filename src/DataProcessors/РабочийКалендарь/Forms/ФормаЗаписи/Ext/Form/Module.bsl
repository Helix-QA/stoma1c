// Функция возвращает сотрудника по шапке
//
Функция ВернутьСотрудникаПоШапке(ИмяОбласти)
	
	Счетчик_1 = 0;
	НовоеИмяОбласти = "";
	ДлинаСтроки = СтрДлина(ИмяОбласти); 
	Пока Счетчик_1 <= ДлинаСтроки Цикл 
		Счетчик_1 = Счетчик_1 + 1;
		НовоеИмяОбласти = НовоеИмяОбласти + Сред(ИмяОбласти, Счетчик_1, 1);
		Если Сред(ИмяОбласти, Счетчик_1, 1) = "R" Тогда 
			Счетчик_2 = Счетчик_1;
			Пока Сред(ИмяОбласти, Счетчик_2, 1) <> "C" Цикл
				Счетчик_2 = Счетчик_2 + 1;				
				Если Сред(ИмяОбласти, Счетчик_2 + 1, 1) = "C" Тогда 
					НовоеИмяОбласти = НовоеИмяОбласти + "1C";	
				КонецЕсли;				
			КонецЦикла;
			Счетчик_1 = Счетчик_2;
		КонецЕсли;		
	КонецЦикла;
	
	НашСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
	НашаОбласть = ТабличныйДокумент.Область(НовоеИмяОбласти);
	Для Каждого Элемент Из МассивСотрудниковИОбластей Цикл
		ВыделеннаяОбласть = ПроверитьПринадлежность(Элемент.Область, НашаОбласть.Имя);
		Если ВыделеннаяОбласть = "ПРИНАДЛЕЖИТ" Тогда 
			НашСотрудник = Элемент.Сотрудник;
			Прервать;
		ИначеЕсли ВыделеннаяОбласть = "ВЫБРАННО_БОЛЕЕ_ОДНОГО_СОТРУДНИКА" Тогда	
			НашСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Установка рабочего/нерабочего времени возможна только для одного сотрудника!");
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат НашСотрудник;
	
КонецФункции

&НаКлиенте
// Функция проверяет принадлежность одной области к другой
//
Функция ПроверитьПринадлежность(ОбщаяОбласть, НашаОбласть)
	
	НомерПервойКолонки 		= ВернутьНомерПервойКолонки(ОбщаяОбласть);
	НомерПоследнейКолонки 	= ВернутьНомерПоследнейКолонки(ОбщаяОбласть);
	
	Если Найти(НашаОбласть, ":") = 0 Тогда 
		НомерНашейКолонки = ВернутьНомерПервойКолонки(НашаОбласть + ":");
		Если НомерНашейКолонки >= НомерПервойКолонки И НомерНашейКолонки <= НомерПоследнейКолонки Тогда 
			Возврат "ПРИНАДЛЕЖИТ";
		Иначе 
			Возврат "НЕ_ПРИНАДЛЕЖИТ";
		КонецЕсли;		
	Иначе
		НомерНашейПервойКолонки 	= ВернутьНомерПервойКолонки(НашаОбласть);
		НомерНашейПоследнейКолонки 	= ВернутьНомерПоследнейКолонки(НашаОбласть);
		Если НомерПоследнейКолонки >= НомерНашейПервойКолонки Тогда 
			Если НомерПоследнейКолонки - НомерПервойКолонки >= НомерНашейПоследнейКолонки - НомерНашейПервойКолонки Тогда			
				Если НомерНашейПервойКолонки >= НомерПервойКолонки И НомерНашейПоследнейКолонки <= НомерПоследнейКолонки Тогда 
					Возврат "ПРИНАДЛЕЖИТ";
				ИначеЕсли (НомерНашейПервойКолонки < НомерПервойКолонки ИЛИ НомерНашейПоследнейКолонки > НомерПоследнейКолонки) Тогда 
					Возврат "ВЫБРАННО_БОЛЕЕ_ОДНОГО_СОТРУДНИКА";
				Иначе
					Возврат "НЕ_ПРИНАДЛЕЖИТ";
				КонецЕсли;
			ИначеЕсли (НомерНашейПервойКолонки < НомерПервойКолонки И НомерНашейПоследнейКолонки <= НомерПоследнейКолонки)
				ИЛИ (НомерНашейПоследнейКолонки > НомерПоследнейКолонки И НомерНашейПервойКолонки >= НомерПервойКолонки)
				ИЛИ (НомерНашейПервойКолонки < НомерПервойКолонки И НомерНашейПоследнейКолонки > НомерПоследнейКолонки) Тогда 
				Возврат "ВЫБРАННО_БОЛЕЕ_ОДНОГО_СОТРУДНИКА";				
			КонецЕсли;
		Иначе Возврат "НЕ_ПРИНАДЛЕЖИТ";			
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Функция возвращает номер первой колонки переданной области
//
Функция ВернутьНомерПервойКолонки(ОбщаяОбласть)
	
	Счетчик_1 = 1;
	Номер = "";
	Пока Сред(ОбщаяОбласть, Счетчик_1, 1) <> ":" Цикл 
		Если Сред(ОбщаяОбласть, Счетчик_1, 1) = "C" Тогда
			Счетчик_2 = Счетчик_1 + 1;
			Пока Сред(ОбщаяОбласть, Счетчик_2, 1) <> ":" Цикл 
				Номер = Номер + Сред(ОбщаяОбласть, Счетчик_2, 1);
				Счетчик_2 = Счетчик_2 + 1;
			КонецЦикла;
			Счетчик_1 = Счетчик_2 - 1;
		КонецЕсли;
		Счетчик_1 = Счетчик_1 + 1;
	КонецЦикла;
	
	Возврат Число(Номер);
	
КонецФункции

