	Пока Счетчик < (МассивСтрок.Количество() - 1) И МассивСтрок[Счетчик] <> "ДопРеквизиты" Цикл
		ВыражениеРеквизита = ВыражениеРеквизита + ?(ЗначениеЗаполнено(ВыражениеРеквизита), ".", "") + МассивСтрок[Счетчик];
		Счетчик = Счетчик + 1;
	КонецЦикла;
	ИмяДопРеквизита = МассивСтрок[МассивСтрок.Количество() - 1];
		
	ВыражениеЦикла = 
	"Для Каждого ДопРеквизит Из " + ВыражениеРеквизита + ".ДополнительныеРеквизиты Цикл
		|Если Строка(ДопРеквизит.Свойство) = ИмяДопРеквизита Тогда
		|	Результат = ДопРеквизит.Значение;
		|КонецЕсли;
	|КонецЦикла;";
	
