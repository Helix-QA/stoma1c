			СтрокаТЧ.СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
		КонецЕсли;	
		
		ВидСделки_Объект.СтатусыПациентовПрименения.Очистить();
		ЗаполнитьЗначенияСвойств(ВидСделки_Объект.СтатусыПациентовПрименения.Добавить(), Новый Структура("СтатусПациента", Перечисления.СтатусыКонтрагентов.НеВернувшийся));
		ЗаполнитьЗначенияСвойств(ВидСделки_Объект.СтатусыПациентовПрименения.Добавить(), Новый Структура("СтатусПациента", Перечисления.СтатусыКонтрагентов.Постоянный));
		
		ВидСделки_Объект.ОбменДанными.Загрузка 		= Истина;
		Попытка
			ВидСделки_Объект.Записать();
			ВидСделки = ВидСделки_Объект.Ссылка;
		Исключение
			Отказ = Истина;
			ЗаписьЖурналаРегистрации(НСтр("ru='Ошибка создания вида сделки!';en='Mistake create kind of deals!'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ВидыСделок, , ОписаниеОшибки());			
		КонецПопытки;	
	КонецЕсли;
	
	Если НЕ Отказ Тогда 
		ТаблицаЭтапов = РезультатПакетаЗапросов[3].Выгрузить();
		СтруктураЭтаповМассивом = Справочники.ЭтапыСделок.ПолучитьПервоначальнуюСтруктуруЭтаповВидаСделки(ВидСделки);
		Для Каждого СтруктураЭтапа Из СтруктураЭтаповМассивом Цикл
			РанееСозданныйЭтап = ТаблицаЭтапов.Найти(СтруктураЭтапа.НомерЭтапа, "НомерЭтапа");
			Если ЗначениеЗаполнено(РанееСозданныйЭтап) Тогда 
				ЭтапСделки_Объект = РанееСозданныйЭтап.Ссылка.ПолучитьОбъект();
				РанееСозданныйЭтап.Удалить = Ложь;
			Иначе 
				ЭтапСделки_Объект = Справочники.ЭтапыСделок.СоздатьЭлемент();
				ЭтапСделки_Объект.УстановитьНовыйКод();
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(ЭтапСделки_Объект, СтруктураЭтапа);
			ЭтапСделки_Объект.ВидСделки 			= ВидСделки;
			ЭтапСделки_Объект.ОбменДанными.Загрузка = Истина;
			Попытка
				ЭтапСделки_Объект.Записать();
			Исключение
				Отказ = Истина;
				ЗаписьЖурналаРегистрации(НСтр("ru='Ошибка создания вида сделки!';en='Mistake create kind of deals!'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ЭтапыСделок, , ОписаниеОшибки());			
			КонецПопытки;
		КонецЦикла;
		Для Каждого РанееСозданныйЭтап Из ТаблицаЭтапов Цикл 
			Если РанееСозданныйЭтап.Удалить Тогда 
				ЭтапСделки_Объект = РанееСозданныйЭтап.Ссылка.ПолучитьОбъект();
				Попытка
					ЭтапСделки_Объект.УстановитьПометкуУдаления(Истина);
				Исключение
					
