
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.ATAMode 			  	= Параметры.Объект.ATAMode;	
	Микрофон					= Параметры.Объект.cobMicrophoneDevice;
	Наушники					= Параметры.Объект.cobSpeakerDevice;
	Объект.DisplayName 			= Параметры.Объект.DisplayName;
	Объект.DomainServer			= Параметры.Объект.DomainServer;
	Объект.MicrophoneMute 		= Параметры.Объект.MicrophoneMute;
	Объект.MicrophoneVolume		= Параметры.Объект.MicrophoneVolume;
	Объект.OutboundProxy 		= Параметры.Объект.OutboundProxy; 
	Объект.RegisterName 		= Параметры.Объект.RegisterName;
	Объект.RegisterPassword 	= Параметры.Объект.RegisterPassword; 
	Объект.RegistrationRequired = Параметры.Объект.RegistrationRequired; 
	Объект.SpeakerMute 			= Параметры.Объект.SpeakerMute;
	Объект.SpeakerVolume		= Параметры.Объект.SpeakerVolume;
	Объект.STUNserver 			= Параметры.Объект.STUNserver;
	Объект.tbRingtoneName 		= Параметры.Объект.tbRingtoneName;
	Объект.UserID 				= Параметры.Объект.UserID;

	ОткрыватьСофтФонПриЗапуске  = ?(ХранилищеСистемныхНастроек.Загрузить("СофтФон", "ОткрыватьСофтФон") = Неопределено, Ложь, 
	ХранилищеСистемныхНастроек.Загрузить("СофтФон", "ОткрыватьСофтФон"));
	
	СоздаватьДокументВзаимодействие = ?(ХранилищеСистемныхНастроек.Загрузить("СофтФон", "СоздаватьДокументВзаимодействие") = Неопределено, Ложь, 
	ХранилищеСистемныхНастроек.Загрузить("СофтФон", "СоздаватьДокументВзаимодействие"));

		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии"
//
Процедура ПриОткрытии(Отказ)
	
	Если Не СофтФон = Неопределено Тогда
		
		Если Не ЗначениеЗаполнено(Объект.UserID) Тогда
			Объект.RegistrationRequired = Истина;
			УстановитьПоУмолчанию(Неопределено);
			ОткрыватьСофтФонПриЗапуске = Истина;
			СоздаватьДокументВзаимодействие = Ложь;
		КонецЕсли;
		
		Элементы.cobSpeakerDevice.СписокВыбора.Очистить();
		Для Каждого СтрокаТЧ из СофтФон.ListSpeakerDevice Цикл	
			Ид  = Сред(СтрокаТЧ, 0, Найти(СтрокаТЧ, "|")-1);
			Имя = Сред(СтрокаТЧ,  Найти(СтрокаТЧ, "|")+1);
			Элементы.cobSpeakerDevice.СписокВыбора.Добавить(Ид, Имя);		
		КонецЦикла;
		
		Объект.cobSpeakerDevice = СофтФон.SelectSpeakerDevice;	
		Объект.SpeakerVolume = СофтФон.SpeakerVolume;
		Объект.SpeakerMute   = СофтФон.SpeakerMute;
		
		Элементы.cobMicrophoneDevice.СписокВыбора.Очистить();
		Для Каждого СтрокаТЧ из СофтФон.ListMicrophoneDevice Цикл	
			Ид  = Сред(СтрокаТЧ, 0, Найти(СтрокаТЧ, "|")-1);
			Имя = Сред(СтрокаТЧ,  Найти(СтрокаТЧ, "|")+1);
			Элементы.cobMicrophoneDevice.СписокВыбора.Добавить(Ид, Имя);		
		КонецЦикла;
		
		Объект.cobMicrophoneDevice = СофтФон.SelectMicrophoneDevice;
		Объект.MicrophoneVolume = СофтФон.MicrophoneVolume;
		Объект.MicrophoneMute = СофтФон.MicrophoneMute;
			
		ЗагрузитьКодеки();
	КонецЕсли;	
	
	Если СофтФон = Неопределено Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСистемныеНастройки;
		ЗаголовокСтраницы = "Системные настройки";		
		ВнешняяКомпонента = "Не установлена";
		Версия = "Не определена";
		Элементы.НастройкаКодеков.Доступность = Ложь;
		Элементы.НастройкаПараметровЗвука.Доступность = Ложь;
		Элементы.НастройкаУчетнойЗаписи.Доступность = Ложь;
		Элементы.ФормаОк.Доступность = Ложь;
	Иначе
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиУчетнойЗаписи;
		ЗаголовокСтраницы = "Учетная запись";
		ВнешняяКомпонента = "Установлена";
		Попытка 
			Версия = СофтФон.GetInfoDLL(); 
		Исключение
			Версия = "Не определена";
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура, выполняет загрузку кодеков
//
Процедура ЗагрузитьКодеки()
	
	Счетчик = 0;
	Индекс = 0;
	ТаблицаКодеков.Очистить();
	Для Каждого СтрокаТЧ из СофтФон.Codecs Цикл
		Если Счетчик = 0 Тогда
			НоваяСтрока = ТаблицаКодеков.Добавить();
			НоваяСтрока.Кодек = СтрокаТЧ;
			НоваяСтрока.Индекс = Индекс;
			Индекс = Индекс + 1;
		Иначе
			ТаблицаКодеков[ТаблицаКодеков.Количество() -1].Флаг = ?(СтрокаТЧ = "True", Истина, Ложь);
			Счетчик = - 1;
		КонецЕсли;
		Счетчик = Счетчик + 1;
	КонецЦикла;

	
КонецПроцедуры

