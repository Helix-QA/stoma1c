Функция ПолучитьСуммуОказанныхУслугПоПолису(СтраховойПолис)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЕСТЬNULL(СУММА(ПродажиОбороты.СтоимостьОборот), 0) КАК СтоимостьОборот
	               |ИЗ
	               |	РегистрНакопления.Продажи.Обороты(
	               |			,
	               |			,
	               |			Авто,
	               |			ДокументПродажи ССЫЛКА Документ.Прием
	               |				И ДокументПродажи.ПолисМедСтрахования = &ПолисМедСтрахования) КАК ПродажиОбороты";
	
	Запрос.УстановитьПараметр("ПолисМедСтрахования", СтраховойПолис);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда 
		Сумма = Результат.Выбрать();
		Сумма.Следующий();
		Возврат Сумма.СтоимостьОборот;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
КонецФункции


// Функция - Заполнить процент выполнения плана лечения
//
// Параметры:
//  ВыборкаПоУслугам - 	 - 
//  Макет			 - 	 - 
//  ОбластьДокумента - 	 - 
//  ПоСумме			 - 	 - 
//  ПоУслугам		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаполнитьПроцентВыполненияПланаЛечения(ВыборкаПоУслугам, Макет = Неопределено, ОбластьДокумента = Неопределено, ПоСумме = Истина, ПоУслугам = Истина) Экспорт 
	
	ОбщаяСумма 					= 0;
	СуммаВыполненных 			= 0;
	ОбщееКоличествоУслуг 		= 0;
	КоличествоВыполненныхУслуг 	= 0;
	ПроцентВыполнения           = Неопределено;
	
	Пока ВыборкаПоУслугам.Следующий() Цикл					
		Если ТипЗнч(ВыборкаПоУслугам.Услуга) = Тип("СправочникСсылка.Номенклатура") Тогда
			ОбщаяСумма 					= ОбщаяСумма + ВыборкаПоУслугам.СуммаИтого;
			СуммаВыполненных 			= ?(ЗначениеЗаполнено(ВыборкаПоУслугам.Прием), СуммаВыполненных + ВыборкаПоУслугам.СуммаИтого, СуммаВыполненных);
			ОбщееКоличествоУслуг 		= ОбщееКоличествоУслуг + 1;
			КоличествоВыполненныхУслуг 	= ?(ЗначениеЗаполнено(ВыборкаПоУслугам.Прием), КоличествоВыполненныхУслуг + 1, КоличествоВыполненныхУслуг);			
		КонецЕсли;					
	КонецЦикла;
	
	Если ПоСумме И НЕ ПоУслугам и ОбщаяСумма <> 0 Тогда
		ПроцентВыполнения = ?(ОбщаяСумма = 0, Формат(0, "ЧЦ=3; ЧН=0"), Формат(СуммаВыполненных / (ОбщаяСумма / 100), "ЧЦ=3; ЧН=0")) + "%";
		
	ИначеЕсли ПоУслугам И НЕ ПоСумме и ОбщееКоличествоУслуг <> 0 Тогда
		ПроцентВыполнения = ?(ОбщееКоличествоУслуг = 0, Формат(0, "ЧЦ=3; ЧН=0"), Формат(КоличествоВыполненныхУслуг / (ОбщееКоличествоУслуг / 100), "ЧЦ=3; ЧН=0")) + "%";
	ИначеЕсли ПоСумме И ПоУслугам и ОбщаяСумма <> 0 и ОбщееКоличествоУслуг <> 0 Тогда 
		ПроцентВыполненияПоСумме 	= ?(ОбщаяСумма = 0, 0, СуммаВыполненных / (ОбщаяСумма / 100));
		ПроцентВыполненияПоУслугам 	= ?(ОбщееКоличествоУслуг = 0, 0, КоличествоВыполненныхУслуг / (ОбщееКоличествоУслуг / 100));
		ПроцентВыполнения = Формат((ПроцентВыполненияПоСумме + ПроцентВыполненияПоУслугам) / 2, "ЧЦ=3; ЧН=0") + "%";
	КонецЕсли;
	
	Если ОбластьДокумента <> Неопределено Тогда 
		ОбластьДокумента.Параметры.ПроцентВыполнения = ПроцентВыполнения;
	КонецЕсли;
	
	Возврат ПроцентВыполнения; 
	
КонецФункции
