// Процедура - Подключаемый шаблон начало выбора
//
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура Получатель_Шаблон_НачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	НомерСимвола = СтрНайти(Элемент.Имя, "с_") + 1; 
	ИндексСтроки = ?(НомерСимвола > 0, Число(Прав(Элемент.Имя, СтрДлина(Элемент.Имя) - НомерСимвола)), Неопределено);
	Если Объект.Действия[ИндексСтроки].ВидАдресата = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.Сотрудник") Тогда	
		СтандартнаяОбработка = Ложь; 
		ОписаниеОповещения = Новый ОписаниеОповещения("Получатель_Шаблон_НачалоВыбораЗавершение", ЭтаФорма, Новый Структура("Индекс, Элемент, ЭлементИмя", ИндексСтроки, Элемент, Элемент.Имя));
		ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора", Новый Структура("БезОтбораПоРолям", Истина),,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);			
	КонецЕсли;	
	
КонецПроцедуры

