// Функция ПолучитьЗначениеРеквизита возвращает значение.
// реквизита, прочитанного из информационной базы по ссылке на объект.
// 
//  Если доступа к реквизиту нет, возникнет исключение прав доступа.
//  Если необходимо зачитать реквизит независимо от прав текущего пользователя,
//  то следует использовать предварительный переход в привилегированный режим.
// 
// Параметры:
//  Ссылка       - ссылка на объект, - элемент справочника, документ, ...
//  ИмяРеквизита - Строка, например, "Код".
// 
// Возвращаемое значение:
//  Произвольный    - зависит от типа значения прочитанного реквизита.
// 
Функция ПолучитьЗначениеРеквизитаСотрудника(Ссылка, СтруктурнаяЕдиница, ИмяРеквизита) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	НастройкиСотрудников."+ИмяРеквизита+"
	                      |ИЗ
	                      |	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	                      |ГДЕ
	                      |	НастройкиСотрудников.Сотрудник = &Сотрудник
	                      |	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
	Запрос.УстановитьПараметр("Сотрудник", Ссылка);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Выборка = Запрос.Выполнить().Выбрать();
	Результат = Новый Структура(ИмяРеквизита);
	Если Выборка.Следующий() Тогда		
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
	Иначе
		Результат.Вставить(ИмяРеквизита, Неопределено);
	КОнецЕсли;
	
	Возврат Результат[ИмяРеквизита];
	
КонецФункции 

// Функция - Получить значения реквизитов сотрудника
//
// Параметры:
//  Ссылка				 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  ИменаРеквизитов		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗначенияРеквизитовСотрудника(Сотрудник, СтруктурнаяЕдиница, ИменаРеквизитов) Экспорт

	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	" + ИменаРеквизитов + "
	                      |ИЗ
	                      |	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	                      |ГДЕ
	                      |	НастройкиСотрудников.Сотрудник = &Сотрудник
	                      |	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Результат = Новый Структура(ИменаРеквизитов);
	ЗаполнитьЗначенияСвойств(Результат, Выборка);
	
	Возврат Результат;
	
КонецФункции

//
