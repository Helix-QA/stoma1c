Процедура ВыводОбщейИнформацииПоКонтрагенту(ОбластьЗаголовок, Контрагент, Адрес, Телефон, Емайл)
	
	Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач Тогда		
		ОбластьEmailКонтрагента = ОбластьЗаголовок.НайтиТекст("EmailКонтрагента");
		ОбластьEmailКонтрагента.Гиперссылка = Ложь;
		ОбластьEmailКонтрагента.ЦветТекста = Новый Цвет(0,0,0);
		ОбластьEmailКонтрагента.Шрифт = Новый Шрифт(ОбластьEmailКонтрагента.Шрифт, "НовыйШрифт", , , , Ложь);
		
		ОбластьЗаголовок.Параметры.Адрес        	= "<Недоступно>";
		ОбластьЗаголовок.Параметры.Телефон      	= "<Недоступно>";		
		ОбластьЗаголовок.Параметры.EmailКонтрагента	= "<Недоступно>";
		ОбластьЗаголовок.Параметры.СтруктураEmail 	= "<Недоступно>";
		ОбластьЗаголовок.Параметры.Другое       	= "<Недоступно>";
		ОбластьЗаголовок.Параметры.ДатаРождения 	= Контрагент.ДатаРожденияКлиента;		
	Иначе		
		ОбластьЗаголовок.Параметры.Адрес        	= Адрес;
		ОбластьЗаголовок.Параметры.Телефон      	= Телефон;
		ОбластьЗаголовок.Параметры.EmailКонтрагента	= Емайл;
		ОбластьЗаголовок.Параметры.СтруктураEmail 	= Новый Структура("СсылкаНаEmail", Емайл);
		ОбластьЗаголовок.Параметры.Другое       	= Контрагент.Комментарий;
		ОбластьЗаголовок.Параметры.ДатаРождения 	= Контрагент.ДатаРожденияКлиента;
	КонецЕсли;
	                      
КонецПроцедуры 

#КонецОбласти