&НаСервере
// Функция - Сформировать блок заказы
//
// Параметры:
//  ВыводитьБлок		 - 	 - 
//  ВыборкаНарядЗаказы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокЗаказы(ВыводитьБлок = Ложь, ВыборкаНарядЗаказы)	
	
	СтрокаНарядЗаказа = 	
	"<tr>
	|                <td colspan='3' style='height: 8px;'></td>
	|            </tr>
	|            <tr valign='middle' style='padding: 5px;'>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{Дата}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <a title='' class='author' href='{НавигационнаяСсылка}'>{НарядЗаказ}</a>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{Статус}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td> 
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{СуммаАванса}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|            </tr>
	|{СтрокаУслуга}"; 
	
	СтрокаУслуга = 
	"<tr valign='middle'>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <a title='' class='author' style='text-decoration: none;'>{Услуга}</a>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{ДатаЗаказа}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{ДатаВыполнения}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{Статус}</p>
	|                </td>
	|            </tr>"; 	
	
	Строка = СтрЗаменить(СтрокаНарядЗаказа, "{СтрокаУслуга}", СтрокаУслуга );
	Услуги = "";
	ИтоговаяСтрокаНарядЗаказа = "";
	
	Если ЗначениеЗаполнено(Контрагент) И ВыборкаНарядЗаказы.Количество() > 0 Тогда 
		
		ВыводитьБлок = Истина;
		
		Пока ВыборкаНарядЗаказы.СледующийПоЗначениюПоля("Ссылка") Цикл
			
			Дата 		      = ВыборкаНарядЗаказы.Дата;
			Расшифровка       = ВыборкаНарядЗаказы.Ссылка;
			НарядЗаказ	      = Формат(ВыборкаНарядЗаказы.Дата, "ДФ=HH:mm") + ", Врач: " + Строка(ВыборкаНарядЗаказы.Сотрудник);		
			СтатусНарядЗаказа = Формат(ВыборкаНарядЗаказы.СтатусНарядЗаказа, "БЛ=Открыт; БИ=Закрыт");
			
			Пока ВыборкаНарядЗаказы.СледующийПоЗначениюПоля("Номенклатура") Цикл
				Услуга          = ВыборкаНарядЗаказы.НомерЗаказа + ":  " + ?(ЗначениеЗаполнено(ВыборкаНарядЗаказы.Зуб), Строка(ВыборкаНарядЗаказы.Зуб) + ", ", "") + Строка(ВыборкаНарядЗаказы.Номенклатура);
				ДатаЗаказа      = Формат(ВыборкаНарядЗаказы.ДатаЗаказа    , "ДЛФ=Д");
				ДатаВыполнения  = Формат(ВыборкаНарядЗаказы.ДатаВыполнения, "ДЛФ=Д");
				Статус          = ВыборкаНарядЗаказы.Статус;
				
				НоваяСтрокаУслуги = СтрЗаменить(СтрокаУслуга     , "{Услуга}", Услуга);
				НоваяСтрокаУслуги = СтрЗаменить(НоваяСтрокаУслуги, "{ДатаЗаказа}",ДатаЗаказа);
				НоваяСтрокаУслуги = СтрЗаменить(НоваяСтрокаУслуги, "{ДатаВыполнения}",ДатаВыполнения);
				НоваяСтрокаУслуги = СтрЗаменить(НоваяСтрокаУслуги, "{Статус}",Статус);
				Услуги = Услуги + НоваяСтрокаУслуги;
				
			КонецЦикла;				
			
			НоваяСтрокаНарядЗаказа = СтрЗаменить(СтрокаНарядЗаказа	   , "{Дата}"	             , Формат(Дата, "ДЛФ=Д"));
			НоваяСтрокаНарядЗаказа = СтрЗаменить(НоваяСтрокаНарядЗаказа, "{НарядЗаказ}"          , НарядЗаказ);
			НоваяСтрокаНарядЗаказа = СтрЗаменить(НоваяСтрокаНарядЗаказа, "{НавигационнаяСсылка}" , ПолучитьНавигационнуюСсылку(ВыборкаНарядЗаказы.Ссылка));			
			НоваяСтрокаНарядЗаказа = СтрЗаменить(НоваяСтрокаНарядЗаказа, "{Статус}"              , СтатусНарядЗаказа);
			НоваяСтрокаНарядЗаказа = СтрЗаменить(НоваяСтрокаНарядЗаказа, "{СуммаАванса}"         , РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуВнесенногоАвансПоДокументу(ВыборкаНарядЗаказы.Ссылка));
			НоваяСтрокаНарядЗаказа = СтрЗаменить(НоваяСтрокаНарядЗаказа, "{СтрокаУслуга}"        , Услуги);
			
			ИтоговаяСтрокаНарядЗаказа = ИтоговаяСтрокаНарядЗаказа + НоваяСтрокаНарядЗаказа; 			
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ИтоговаяСтрокаНарядЗаказа;
	
КонецФункции

&НаСервере
// Функция - Получить сумму оказанных услуг по полису
//
// Параметры:
//  СтраховойПолис	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСуммуОказанныхУслугПоПолису(СтраховойПолис)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(СУММА(ПродажиОбороты.СтоимостьОборот), 0) КАК СтоимостьОборот
	|ИЗ
	|	РегистрНакопления.Продажи.Обороты(
	|			,
	|			,
	|			Авто,
	|			ДокументПродажи ССЫЛКА Документ.Прием
	|				И ДокументПродажи.ПолисМедСтрахования = &ПолисМедСтрахования) КАК ПродажиОбороты";
	
	Запрос.УстановитьПараметр("ПолисМедСтрахования", СтраховойПолис);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда 
		Сумма = Результат.Выбрать();
		Сумма.Следующий();
		Возврат Сумма.СтоимостьОборот;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
КонецФункции

