	МенеджерЗаписи.АвторБлокировки 			= ПараметрыСеанса.ТекущийСотрудник;	
	МенеджерЗаписи.Записать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервере
// Процедура - Установить видимость элементов формы
//
Процедура УстановитьВидимостьЭлементовФормы()   
		
	Элементы.НомерВБазеНайден.Видимость 							= ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов);
	Элементы.НомерВБазеНеНайденПоле.Видимость 						= НЕ ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов);
	Элементы.ПерезвонитьКлиенту.Видимость 							= ОткрытаИзСписка;
	Элементы.ПерезвонитьКлиенту.Заголовок 							= ?(ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка = 2, "Перезвонить", "Позвонить");;
	Элементы.ГруппаПерезвонитьПереадресовать.ЦветФона 				= ?(ОткрытаИзСписка, Новый Цвет(25, 116, 206), Новый Цвет(0, 112, 210));
	
	Элементы.ГруппаСоздатьПациентаИСделку.Видимость 				= НЕ ЭтоГородской И (НЕ ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) ИЛИ (ЗначениеЗаполнено(ЗаявкаОснование) И ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Сделки") И ЗаявкаОснование.ЭтапСделки.НомерЭтапа = 1));
	Элементы.ЗвонокНеСвязанСприемом.Видимость 						= ЗначениеЗаполнено(ЗаявкаОснование) И ((ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Сделки") И ЗаявкаОснование.ЭтапСделки.НомерЭтапа = 1) ИЛИ НЕ ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов)); 
	Элементы.НекачественнаяЗаявка.Видимость 						= ЗначениеЗаполнено(ЗаявкаОснование) И (ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Заявки") ИЛИ (ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Сделки") И ЗаявкаОснование.ЭтапСделки.НомерЭтапа = 1)); 
		
	Элементы.ВнестиВЧерныйСписок.Видимость 							= НЕ ЭтоГородской И (НЕ ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) ИЛИ НЕ ПациентыСуществуют(СтруктураКлиента.СписокКонтрагентов));
	
	Элементы.ГруппаЗаписатьПациента.Видимость 						= ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) И НЕ ЭтоГородской;
	Элементы.ГруппаЗаписатьПациентаВЛистОжидания.Видимость			= ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) И НЕ ЭтоГородской;
	Если ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) И СтруктураКлиента.СписокКонтрагентов.Количество() > 1 Тогда
		Элементы.ЗаписатьПациента.Картинка = БиблиотекаКартинок.СтрелкаВнизСплошная;
		Элементы.ЗаписатьПациентаВЛистОжидания.Картинка = БиблиотекаКартинок.СтрелкаВнизСплошная;
	Иначе
		Элементы.ЗаписатьПациента.Картинка = Новый Картинка;
	КонецЕсли;
    Элементы.ГруппаСоздатьПациентаИЗаписать.Видимость 				= НЕ ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов);
	Элементы.ПрослушатьЗапись.Доступность                           = ЗаписьРазговораДоступна;
	Элементы.ГруппаЗарегистрированныеЗаявки.Видимость               = ОткрытаИзСписка;
	Элементы.ГруппаДвеКолонки.Видимость               				= СтруктураБлокировкиНомера = Неопределено; 
	Элементы.ГруппаУдалитьИзЧерногоСписка.Видимость               	= НЕ СтруктураБлокировкиНомера = Неопределено;
	
	ОтобразитьСделкиИЗаписи();
	ВывестиИнформациюПоКлиенту();

	Элементы.ГруппаЗаметки.Видимость               					= СтруктураБлокировкиНомера = Неопределено; 
	Элементы.ГруппаФИО.Видимость               						= НЕ ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) И СтруктураБлокировкиНомера = Неопределено И НЕ ЭтоГородской; 
	Элементы.ДекорацияПричинаБлокировки.Видимость               	= НЕ СтруктураБлокировкиНомера = Неопределено;
	Элементы.ДекорацияПричинаБлокировки.Заголовок                   = Заметка;
	
КонецПроцедуры

&НаСервере
// Процедура - Вывести информацию по клиенту
//
Процедура ВывестиИнформациюПоКлиенту();
	
	ВывестиИнформациюПоБлокировкеНомера();
			
	// Выводим дату и время звонка
	Элементы.ДекорацияНадписьДатаВремяЗвонка.Заголовок 		= Формат(ПараметрыТелефонногоЗвонка.ДатаВремяЗвонка, "ДФ='dd.MM.yy'' - ''HH:mm'");
	
	// Выведем продолжительность звонка
	ВывестиПродолжительностьЗвонка();
	
	// Выводим гиперссылку для прослушивания записи
	ОтобразитьГиперссылкуПрослушиванияЗаписи();
	
	// Выводим пиктограмму звонка	
	Элементы.ДекорацияКартинкаЗвонок.Картинка 				= ?(ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка = 0, БиблиотекаКартинок.ТелефонныйЗвонокВходящийБольшой, ?(ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка = 1, БиблиотекаКартинок.ТелефонныйЗвонокИсходящийБольшой, БиблиотекаКартинок.ТелефонныйЗвонокПропущенныйБольшой));	
	
	Элементы.ПолеНомерТелефонаНайден.ПодсказкаВвода 		= ПреобразованныйНомерТелефона;	
	Элементы.ПолеНомерТелефонаНеНайден.ПодсказкаВвода 		= ПреобразованныйНомерТелефона;
	
	// Сформируем заголовок формы
	ЭтаФорма.Заголовок = ?(ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка = 0, НСтр("ru = 'Входящий звонок: '; en = 'Incoming call: '"), 
	?(ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка = 1, НСтр("ru = 'Исходящий звонок: '; en = 'Outgoing call:'"), НСтр("ru = 'Пропущенный звонок: '; en = 'Missed call:'")))
	+ Формат(ПараметрыТелефонногоЗвонка.ДатаВремяЗвонка, "ДФ=HH:mm") 
	+ ?(ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов), НСтр("ru = ', от '; en = ', from '"), "") 
	+ ?(ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов), СокрЛП(СтруктураКлиента.СписокКонтрагентов[0].Значение.Наименование), "");				
	
	СформироватьПредставленияКонтрагентов();
	
	// Отобразим заявку если сформирована
	СформироватьПредставлениеЗаявки();
	
	МассивАктивныхПользователей = ТаблицаАктивныхПользователей.НайтиСтроки(Новый Структура("ВнутреннийНомер", СНомерТелефона));
	Если МассивАктивныхПользователей.Количество() <> 0 Тогда 
		Элементы.ДекорацияПереадресованноОт.Видимость = Истина;
		Элементы.ДекорацияПереадресованноОт.Заголовок = НСтр("ru = 'Переадресованно от: '; en = 'Redirected from: '") + СокрЛП(Строка(МассивАктивныхПользователей[0].Пользователь));
	Иначе 
		Элементы.ДекорацияПереадресованноОт.Видимость = Ложь;
	КонецЕсли;	
	
	ОтобразитьЗаметкиПользователей();
	
КонецПроцедуры

&НаСервере
// Процедура - Вывести информацию по блокировке номера
//
Процедура ВывестиИнформациюПоБлокировкеНомера()
	
	Элементы.ГруппаИнформацияОБлокировке.Видимость 					= НЕ СтруктураБлокировкиНомера = Неопределено;			
	Если НЕ СтруктураБлокировкиНомера = Неопределено Тогда
		Если ТипЗнч(СтруктураБлокировкиНомера) = Тип("Структура") И СтруктураБлокировкиНомера.Свойство("АвторБлокировки") И ЗначениеЗаполнено(СтруктураБлокировкиНомера.АвторБлокировки) Тогда 
			Элементы.ДекорацияИнформацияОБлокировке.Заголовок 		= НСтр("ru = 'Номер заблокирован ('; en = 'Number is blocked ('") + СокрЛП(Строка(СтруктураБлокировкиНомера.АвторБлокировки)) + ")";
		Иначе 
			Элементы.ДекорацияИнформацияОБлокировке.Заголовок 		= НСтр("ru = 'Номер заблокирован'; en = 'Number is blocked'");
		КонецЕсли; 
	КонецЕсли;	

КонецПроцедуры

&НаСервере
// Процедура - Вывести продолжительность звонка
//
Процедура ВывестиПродолжительностьЗвонка()
	
	Элементы.ДекорацияПродолжительностьЗвонка.Видимость = Ложь;	
	Если ОткрытаИзСписка = Истина Тогда 
		Если ЗначениеЗаполнено(ПараметрыТелефонногоЗвонка.НачалоРазговора) И ЗначениеЗаполнено(ПараметрыТелефонногоЗвонка.ОкончаниеЗвонка) Тогда 
			Если ПараметрыТелефонногоЗвонка.НачалоРазговора <= ПараметрыТелефонногоЗвонка.ОкончаниеЗвонка Тогда 
				Элементы.ДекорацияПродолжительностьЗвонка.Видимость = Истина;				
				ПродолжительностьЗвонка = Дата(1,1,1) + (ПараметрыТелефонногоЗвонка.ОкончаниеЗвонка - ПараметрыТелефонногоЗвонка.НачалоРазговора);
				Если ПродолжительностьЗвонка <= Дата('00010101000059') Тогда 
					Элементы.ДекорацияПродолжительностьЗвонка.Заголовок = Формат(ПродолжительностьЗвонка, СтрШаблон("ДФ='с ""%1""'", НСтр("ru = 'сек.'; en = 'sec.'")));
				ИначеЕсли ПродолжительностьЗвонка <= Дата('00010101005959') И ПродолжительностьЗвонка > Дата('00010101000059') Тогда
					Элементы.ДекорацияПродолжительностьЗвонка.Заголовок = Формат(ПродолжительностьЗвонка, СтрШаблон("ДФ='m ""%1"" с ""%2""'", НСтр("ru = 'мин.'; en = 'min.'"), НСтр("ru = 'сек.'; en = 'sec.'")));
				ИначеЕсли ПродолжительностьЗвонка <= Дата('00010101235959') И ПродолжительностьЗвонка > Дата('00010101005959') Тогда
					Элементы.ДекорацияПродолжительностьЗвонка.Заголовок = Формат(ПродолжительностьЗвонка, СтрШаблон("ДФ='h ""%1"" m ""%2"" с ""%3""'", НСтр("ru = 'ч.'; en = 'h.'"), НСтр("ru = 'мин.'; en = 'min.'"), НСтр("ru = 'сек.'; en = 'sec.'")));
				Иначе 	                                                                                  
					Элементы.ДекорацияПродолжительностьЗвонка.Заголовок = Формат(ПродолжительностьЗвонка, СтрШаблон("ДФ='d ""%1"" h ""%2"" m ""%3"" с ""%4""'", НСтр("ru = 'дней'; en = 'days'"), НСтр("ru = 'ч.'; en = 'h.'"), НСтр("ru = 'мин.'; en = 'min.'"), НСтр("ru = 'сек.'; en = 'sec.'")));
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	Элементы.ДекорацияРазделитель_1.Видимость = Элементы.ДекорацияПродолжительностьЗвонка.Видимость;
	
КонецПроцедуры

&НаСервере
// Процедура - Отобразить гиперссылку прослушивания записи
//
Процедура ОтобразитьГиперссылкуПрослушиванияЗаписи()
	
	Элементы.ПрослушатьЗапись.Видимость = Ложь;	
	Если ОткрытаИзСписка = Истина Тогда 
		Если ЗначениеЗаполнено(ПараметрыТелефонногоЗвонка.URLЗаписи) ИЛИ ЗначениеЗаполнено(ПараметрыТелефонногоЗвонка.ФайлЗаписи) Тогда 
			Элементы.ПрослушатьЗапись.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;	
	
	Элементы.ДекорацияРазделитель_2.Видимость = Элементы.ПрослушатьЗапись.Видимость;
	
КонецПроцедуры

&НаСервере
// Процедура - Сформировать представления партнеров и контактных лиц
//
Процедура СформироватьПредставленияКонтрагентов()
	
	// Определяем родительские группы
	ГруппаРазмещенияКонтрагентов 					= Элементы.Найти("ГруппаСписокКонтрагентов");
	
	// Основной менеджер.
	ТекстКнопкиОсновногоМенеджера 					= "";
	
	// Формируем представление партнеров
	Если НЕ ГруппаРазмещенияКонтрагентов = Неопределено Тогда 
		// Очищаем родительские группы					
		УдалитьЭлементыГруппы(ГруппаРазмещенияКонтрагентов);
		// Создаем элементы
		Для Каждого ЭлементСписка Из СтруктураКлиента.СписокКонтрагентов Цикл
			
			Индекс 									= СтруктураКлиента.СписокКонтрагентов.Индекс(ЭлементСписка);
			
			Если Индекс > -1 Тогда
				
				// Группа контрагента
				Группа_Контрагент_НоваяСтрока                      = Элементы.Добавить("Группа_Контрагент_Строка" + Индекс, Тип("ГруппаФормы"), ГруппаРазмещенияКонтрагентов);
				Группа_Контрагент_НоваяСтрока.Вид                  = ВидГруппыФормы.ОбычнаяГруппа;
				Группа_Контрагент_НоваяСтрока.Отображение          = ОтображениеОбычнойГруппы.Нет;
				Группа_Контрагент_НоваяСтрока.Группировка          = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
				Группа_Контрагент_НоваяСтрока.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
				Группа_Контрагент_НоваяСтрока.ОтображатьЗаголовок  = Ложь;
				
				// Добавим группу с пациентом и куратором
				Группа_Пациент_НоваяСтрока                      = Элементы.Добавить("Группа_Пациент_Строка" + Индекс, Тип("ГруппаФормы"), Группа_Контрагент_НоваяСтрока);
				Группа_Пациент_НоваяСтрока.Вид                  = ВидГруппыФормы.ОбычнаяГруппа;
				Группа_Пациент_НоваяСтрока.Отображение          = ОтображениеОбычнойГруппы.Нет;
				Группа_Пациент_НоваяСтрока.Группировка          = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
				Группа_Пациент_НоваяСтрока.ОтображатьЗаголовок  = Ложь;

				// Добавим кнопку контрагента
				НовыйЭлемент_Кнопка 					= Элементы.Добавить("Кнопка_ОткрытьКонтрагента_" + Индекс, Тип("КнопкаФормы"), Группа_Пациент_НоваяСтрока);
				ПредставлениеДРСтрокой					= ОбщегоНазначенияСтоматология.ВозвратитьВозрастСтрокой(ЭлементСписка.Значение.ДатаРожденияКлиента);
				ПолныхЛет = ?(ЗначениеЗаполнено(ЭлементСписка.Значение.ДатаРожденияКлиента), ", " + Формат(ЭлементСписка.Значение.ДатаРожденияКлиента, "ДФ=dd.MM.yyyy") 
														+ " (" + ПредставлениеДРСтрокой + ")",
														"");
				ЭлементСписка.Значение.ПредставлениеДатыРожденияСтрокой = ПредставлениеДРСтрокой;
				
				НовыйЭлемент_Кнопка.Заголовок 			= ?(ЗначениеЗаполнено(ЭлементСписка.Значение.Наименование), СокрЛП(ЭлементСписка.Значение.Наименование) + ПолныхЛет, "Не заполнено ФИО"); 
													//+ ", " + Формат(ЭлементСписка.Значение.ДатаРожденияКлиента, "ДФ=dd.MM.yyyy") 
													//	+ " (" + ОбщегоНазначенияСтоматология.ВозвратитьВозрастСтрокой(ЭлементСписка.Значение.ДатаРожденияКлиента) + ")";
				НовыйЭлемент_Кнопка.ЦветТекста 			= Новый Цвет(51, 51, 51);
				НовыйЭлемент_Кнопка.Шрифт 				= Новый Шрифт("Arial", 18);
				НовыйЭлемент_Кнопка.ОтображениеФигуры 	= ОтображениеФигурыКнопки.Нет;
				
				// Добавим команду
				НоваяКоманда 							= Команды.Найти("Кнопка_ОткрытьКонтрагента_" + Индекс);
				Если НоваяКоманда = Неопределено Тогда 
					НоваяКоманда 						= Команды.Добавить("Кнопка_ОткрытьКонтрагента_" + Индекс);
					НоваяКоманда.Действие 				= "Подключаемый_ОткрытьКонтрагента";				
				КонецЕсли;
				НовыйЭлемент_Кнопка.ИмяКоманды 			= НоваяКоманда.Имя;
				
				
				// Добавим кнопку куратора
				Если ЗначениеЗаполнено(ЭлементСписка.Значение.Куратор) Тогда
					ФИОСокращенное = Справочники.Сотрудники.ПолучитьСокращенноеНаименованиеСотрудника(, ЭлементСписка.Значение.Куратор);
				КонецЕсли;
					
				ТекстКнопкиОсновногоМенеджера = ?(ЗначениеЗаполнено(ЭлементСписка.Значение.Куратор), НСтр("ru = 'Куратор: '; en = 'Curator: '") + СокрЛП(ФИОСокращенное), "");
				
				Если ЗначениеЗаполнено(ТекстКнопкиОсновногоМенеджера) Тогда
					НовыйЭлемент_Кнопка 					= Элементы.Добавить("Кнопка_ОткрытьКуратора_" + Индекс, Тип("КнопкаФормы"), Группа_Пациент_НоваяСтрока);
