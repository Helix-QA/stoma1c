// Функция - Зарегистрировать ключ пользователя
// 
// Параметры:
//  НомерТелефона	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ЗарегистрироватьКлючПользователя(НомерТелефона, ОписаниеОшибки = "") Экспорт
		
	Попытка
		
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("login", НомерТелефона);
		
		ТекстЗапроса = СобратьJson(ПараметрыЗапроса);
		
		РезультатЗапроса  = ВыполнитьPOSTЗапрос("director_app/auth", ТекстЗапроса);
		Если ЗначениеЗаполнено(РезультатЗапроса.errors.message) Тогда		
			ОписаниеОшибки = РезультатЗапроса.errors.message;
		ИначеЕсли РезультатЗапроса.parameters.Свойство("sent_sms") Тогда
			Возврат Истина;
		КонецЕсли;
		
	Исключение	
		ОписаниеОшибки = "Ошибка обращения к серверу: " + ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Ложь;
	
КонецФункции

// Функция - Обновить список салонов внешней системы в CRM
//
// Параметры:
//  ВнешняяСистема			 - 	 - 
//  ТекущаяСессия			 - 	 - 
//  СтруктурнаяЕдиница		 - 	 - 
//  Использовать			 - 	 - 
//  ФлагИспользованияЗаписи	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОбновитьСписокСалоновВнешнейСистемыВ_CRM(ВнешняяСистема, ТекущаяСессия, СтруктурнаяЕдиница, ТаблицаДанных, ФлагИспользованияЗаписи = Неопределено) Экспорт

	РезультатаОперции = Неопределено;
		
	Попытка 
			
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("session", ТекущаяСессия);	
		ЗаголовкиHTTP.Вставить("apikey" , ВнешняяСистема.КлючПриложения);
		
		МассивДанных = Новый Массив;
		Для Каждого СтрокаТ ИЗ ТаблицаДанных Цикл
			
			Использовать = ?(ФлагИспользованияЗаписи <> Неопределено, ФлагИспользованияЗаписи И СотрудникНеУволенИзСЕ(СтрокаТ.Клиент, СтруктурнаяЕдиница), СтрокаТ.Использовать);	
			
			СтруктураДанных = Новый Структура;
			СтруктураДанных.Вставить("phone"	 , СтрокаТ.НомерТелефона);
			СтруктураДанных.Вставить("user_token", СтрокаТ.КлючКлиента);
			СтруктураДанных.Вставить("use"		 , Использовать);
			СтруктураДанных.Вставить("clinic_id"	 , Строка(СтруктурнаяЕдиница.УникальныйИдентификатор()));
			СтруктураДанных.Вставить("clinic_name" , СтруктурнаяЕдиница.Наименование);
			
			МассивДанных.Добавить(СтруктураДанных);
			
		КонецЦикла;
		
		ТекстЗапроса = СобратьJson(МассивДанных);
				
		РезультатЗапроса  = ВыполнитьPOSTЗапрос("director_app/director", ТекстЗапроса, ЗаголовкиHTTP);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
	Исключение		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());		
	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

