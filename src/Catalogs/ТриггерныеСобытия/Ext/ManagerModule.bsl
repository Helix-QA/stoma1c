// Функция - Варианты срабатываемые исключительно по подписке
// 
// Возвращаемое значение:
//   - 
//
Функция ВариантыСрабатываемыеИсключительноПоПодписке() Экспорт
	
	МассивВариантовТриггерныхСобытий = Новый Массив;
	
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.КартыУстановкаКартыWalletНовомуКлиенту);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетВзнос);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетСписание);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетКритическийОстатокСредств);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.Продажа);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ПродажаОплатаПолная);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ПродажаОплатаЧастичная);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаСотрудникомКлиники);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаПациентом);	
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеПереносДатыВремени);
	МассивВариантовТриггерныхСобытий.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеЗаменаИнструктора);
	
	Возврат МассивВариантовТриггерныхСобытий;
	
КонецФункции

// Процедура - Инициализировать виртуальную группу событий
//
// Параметры:
//  ВиртуальнаяГруппаСобытий		 - 	 - 
//  ВариантУсловияТриггерногоСобытия - 	 - 
//
Процедура ИнициализироватьВиртуальнуюГруппуСобытий(ВиртуальнаяГруппаСобытий, ВариантУсловияТриггерногоСобытия, ЭлементГруппы = Неопределено) Экспорт
	
	ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	
	Если НЕ ЭлементГруппы = Неопределено Тогда
		МассивНеАктуальныхГрупп = Новый Массив;
		Для Каждого ЭлементКоллекции Из ЭлементГруппы.СписокВыбора Цикл 
			Если ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВиртуальнаяГруппаСобытий", ЭлементКоллекции.Значение)).Количество() = 0 Тогда 
				МассивНеАктуальныхГрупп.Добавить(ЭлементКоллекции);
			КонецЕсли;	
		КонецЦикла;
		Для Каждого ЭлементКоллекции Из МассивНеАктуальныхГрупп Цикл 
			ЭлементГруппы.СписокВыбора.Удалить(ЭлементКоллекции);
		КонецЦикла;	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВариантУсловияТриггерногоСобытия) Тогда 
		Возврат;
	КонецЕсли;
	
	СтрокаВариантУсловияТриггерногоСобытия = ТаблицаВсехВариантовУсловийТриггерныхСобытий.Найти(ВариантУсловияТриггерногоСобытия, "ВариантыУсловийТриггерныхСобытий");
	Если СтрокаВариантУсловияТриггерногоСобытия = Неопределено Тогда 
		Возврат;
	Иначе 
		ВиртуальнаяГруппаСобытий = СтрокаВариантУсловияТриггерногоСобытия.ВиртуальнаяГруппаСобытий;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Инициализировать список триггеров
//
// Параметры:
//  СписокВыбора					 - 	 - 
//  ВиртуальнаяГруппаСобытий		 - 	 - 
//  ВариантУсловияТриггерногоСобытия - 	 - 
//
Процедура ИнициализироватьСписокТриггеров(СписокВыбора, ВиртуальнаяГруппаСобытий = "", ВариантУсловияТриггерногоСобытия = Неопределено, ТаблицаАктуализацииТриггеров = Неопределено, ИнициализироватьТаблицу = Ложь) Экспорт
	
	ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	
	Если ИнициализироватьТаблицу И ТаблицаАктуализацииТриггеров <> Неопределено Тогда
		ТаблицаЗначенийПараметровАктуализации = ТаблицаАктуализацииТриггеров.Выгрузить();
		Для Каждого СтрокаТаблицаВсеТриггеры Из ТаблицаВсехВариантовУсловийТриггерныхСобытий Цикл 
			СтрокаПараметровАктуализации = ТаблицаЗначенийПараметровАктуализации.Найти(СтрокаТаблицаВсеТриггеры.ВариантыУсловийТриггерныхСобытий, "ВариантУсловияТриггерногоСобытия");
			Если СтрокаПараметровАктуализации = Неопределено Тогда 
				СтрокаПараметровАктуализации 									= ТаблицаЗначенийПараметровАктуализации.Добавить();
				СтрокаПараметровАктуализации.ВариантУсловияТриггерногоСобытия 	= СтрокаТаблицаВсеТриггеры.ВариантыУсловийТриггерныхСобытий;
			КонецЕсли;	
			СтрокаПараметровАктуализации.ДатаДобавления 					= ?(СтрокаТаблицаВсеТриггеры.БазовыйВариант, Дата(1, 1, 1), ?(ЗначениеЗаполнено(СтрокаПараметровАктуализации.ДатаДобавления), СтрокаПараметровАктуализации.ДатаДобавления, НачалоДня(ТекущаяДатаСеанса())));
			СтрокаПараметровАктуализации.Новый 								= ?(НачалоДня(ТекущаяДатаСеанса()) < СтрокаПараметровАктуализации.ДатаДобавления + 3 * 86400, Истина, Ложь);
		КонецЦикла;
		ТаблицаАктуализацииТриггеров.Загрузить(ТаблицаЗначенийПараметровАктуализации);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВариантУсловияТриггерногоСобытия) Тогда 
		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	
	КартинкаВыбранное 							= БиблиотекаКартинок.РассылкаРазрешена;
	КартинкаПустая 								= БиблиотекаКартинок.Пустая;
	
	СписокВыбора.Очистить();
	Если ЗначениеЗаполнено(ВиртуальнаяГруппаСобытий) Тогда 
		КоллекцияВариантовУсловийТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВиртуальнаяГруппаСобытий", ВиртуальнаяГруппаСобытий));
	Иначе 
		КоллекцияВариантовУсловийТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий;
	КонецЕсли;
	
	ЕстьНовыеТриггеры = Ложь;
	Если ТаблицаАктуализацииТриггеров <> Неопределено Тогда 
		Если ТаблицаАктуализацииТриггеров.НайтиСтроки(Новый Структура("Новый", Истина)).Количество() <> 0 Тогда 
			ЕстьНовыеТриггеры = Истина;
		КонецЕсли;	
	КонецЕсли;

	Для Каждого ЭлементКоллекции Из КоллекцияВариантовУсловийТриггерныхСобытий Цикл 
		НовыйЭлементСписка 							= СписокВыбора.Добавить();
		НовыйЭлементСписка.Значение 				= ЭлементКоллекции.ВариантыУсловийТриггерныхСобытий;
		Если ЕстьНовыеТриггеры Тогда //И НЕ ВариантУсловияТриггерногоСобытия = ЭлементКоллекции.ВариантыУсловийТриггерныхСобытий Тогда
			Если ТаблицаАктуализацииТриггеров.НайтиСтроки(Новый Структура("ВариантУсловияТриггерногоСобытия, Новый", ЭлементКоллекции.ВариантыУсловийТриггерныхСобытий, Истина)).Количество() <> 0 Тогда 
				МассивСтрок = Новый Массив;
				МассивСтрок.Добавить(Новый ФорматированнаяСтрока(Строка(ЭлементКоллекции.ВариантыУсловийТриггерныхСобытий) + "  "));
				МассивСтрок.Добавить(Новый ФорматированнаяСтрока("(Новинка)", Новый Шрифт("Arial", , Истина), Новый Цвет(0, 112, 210)));
				НовыйЭлементСписка.Представление 	= Новый ФорматированнаяСтрока(МассивСтрок);
			КонецЕсли;
		КонецЕсли;	
		НовыйЭлементСписка.Пометка 					= ВариантУсловияТриггерногоСобытия = ЭлементКоллекции.ВариантыУсловийТриггерныхСобытий;
		НовыйЭлементСписка.Картинка 				= ?(ВариантУсловияТриггерногоСобытия = ЭлементКоллекции.ВариантыУсловийТриггерныхСобытий, КартинкаВыбранное, КартинкаПустая);
	КонецЦикла;	
	
КонецПроцедуры

// Процедура - Инициализировать список моментов активации
//
// Параметры:
//  СписокВыбора					 - 	 - 
//  ВариантУсловияТриггерногоСобытия - 	 - 
//  МоментАктивации					 - 	 - 
//
Процедура ИнициализироватьСписокМоментовАктивации(СписокВыбора, ВариантУсловияТриггерногоСобытия = Неопределено, МоментАктивации) Экспорт 
	
	ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	
	Если НЕ ЗначениеЗаполнено(ВариантУсловияТриггерногоСобытия) Тогда 
		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	
	СписокВыбора.Очистить();
	
	КоллекцияВариантовУсловийТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий", ВариантУсловияТриггерногоСобытия));
	
	Если КоллекцияВариантовУсловийТриггерныхСобытий.Количество() <> 0 Тогда 
		Для Каждого ЭлементКоллекции Из КоллекцияВариантовУсловийТриггерныхСобытий[0].СписокМоментовАктивации Цикл
			НовыйЭлементСписка 						= СписокВыбора.Добавить();
			НовыйЭлементСписка.Значение 			= ЭлементКоллекции.Значение;
			НовыйЭлементСписка.Представление 		= ЭлементКоллекции.Представление;
			НовыйЭлементСписка.Пометка 				= МоментАктивации = ЭлементКоллекции.Значение;
		КонецЦикла;	
	Иначе 
		СписокВыбора.Добавить(Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия		, , МоментАктивации = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия);
		СписокВыбора.Добавить(Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия, , МоментАктивации = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия);
		СписокВыбора.Добавить(Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия	, , МоментАктивации = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия);		
	КонецЕсли;

КонецПроцедуры

// Процедура - Инициализировать список структурных единиц
//
// Параметры:
//  СписокВыбора					 - 	 - 
//  ВариантУсловияТриггерногоСобытия - 	 - 
//  СтруктурнаяЕдиница				 - 	 - 
//
Процедура ИнициализироватьСписокСтруктурныхЕдиниц(СписокВыбора, ВариантУсловияТриггерногоСобытия = Неопределено, СтруктурнаяЕдиница) Экспорт
	
	ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	
	Если НЕ ЗначениеЗаполнено(ВариантУсловияТриггерногоСобытия) Тогда 
		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	
	СписокВыбора.Очистить();
	КоллекцияВариантовУсловийТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий, ИспользуетсяОтборПоСтруктурнойЕдинице", ВариантУсловияТриггерногоСобытия, Истина));
	
	Если КоллекцияВариантовУсловийТриггерныхСобытий.Количество() <> 0 ИЛИ ВариантУсловияТриггерногоСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка() Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	СтруктурныеЕдиницы.Ссылка КАК Ссылка,
		               |	СтруктурныеЕдиницы.Представление КАК Представление
		               |ИЗ
		               |	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		               |ГДЕ
		               |	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
		               |	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ";
		
		ТаблицаСтруктурныхЕдиниц = Запрос.Выполнить().Выгрузить();
		
		СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), "Проданных в любой клинике", Справочники.СтруктурныеЕдиницы.ПустаяСсылка() = СтруктурнаяЕдиница);
		Для Каждого СтрокаТЗ Из ТаблицаСтруктурныхЕдиниц Цикл 
			СписокВыбора.Добавить(СтрокаТЗ.Ссылка, "Проданных в """ + СокрЛП(СтрокаТЗ.Представление) + """", СтрокаТЗ.Ссылка = СтруктурнаяЕдиница);
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

