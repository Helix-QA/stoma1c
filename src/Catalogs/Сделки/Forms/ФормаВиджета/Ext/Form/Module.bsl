		//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
		КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
		КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
		КартинкаВида.Ширина					 				= 2;
		КартинкаВида.Высота					 				= 1;
		КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить элементы выбора этапа генерируемой сделки
//
Процедура ОбновитьЭлементыВыбораЭтапаГенерируемойСделки();
	
	ТаблицаЭтапов = Неопределено;
	МассивСтрок = ТаблицаДоступныхВидовСделок.НайтиСтроки(Новый Структура("ВидСделки", ВыбранныйВидСделки));
	Если МассивСтрок.Количество() > 0 Тогда 
		ТаблицаЭтапов = МассивСтрок[0].ТаблицаЭтапов;
		ИндексВиджета = ТаблицаДоступныхВидовСделок.Индекс(МассивСтрок[0]);		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТаблицаЭтапов) Тогда 
		Возврат;
	КонецЕсли;
	
	ГруппаРодитель 		= Элементы.ГруппаЭтапы;
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   		, "ГруппаЭтапы_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("ГруппаЭлемента"		, ГруппаРодитель);	
	ПараметрыГруппы.Вставить("Группировка"   		, ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ГруппаЭтапы = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
	ГруппаЭтапы.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	
	МассивСтрокВыбранногоЭтапа = ТаблицаЭтапов.НайтиСтроки(Новый Структура("Выбран", Истина));
	Если НЕ МассивСтрокВыбранногоЭтапа.Количество() = 0 Тогда 
		НомерЭтапа = МассивСтрокВыбранногоЭтапа[0].НомерЭтапа;
	Иначе 
		НомерЭтапа = 0;
	КонецЕсли;
	
	Для Каждого СтрокаТЗ Из ТаблицаЭтапов Цикл
		
		Если СтрокаТЗ.Предопределенный Тогда 
			Продолжить;
		КонецЕсли;
		
		Индекс = ТаблицаЭтапов.Индекс(СтрокаТЗ);
		
		Если НЕ Индекс = 0 Тогда 
