// Процедура - Упаковка по умолчанию создание
//
// Параметры:
//  Элемент				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура УпаковкаПоУмолчаниюСоздание(Элемент, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() Тогда
		
		СтандартнаяОбработка = Ложь;
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗаписатьОбъект", ЭтотОбъект, "Упаковка");
		ПоказатьВопрос(ОписаниеОповещения, 
					   "Номенклатура не записана." + Символы.ПС + "Выбор упаковки возможен после записи данных."+ Символы.ПС + "Записать?",
					   РежимДиалогаВопрос.ОКОтмена); 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Записать объект
//
// Параметры:
//  РезультатВопроса - 	 - 
//  Параметры		 - 	 - 
//
Процедура ЗаписатьОбъект(РезультатВопроса, Параметры)  Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.ОК  Тогда
		Если ЭтаФорма.Записать() Тогда
			Если Параметры = "Упаковка" Тогда 
				
				СтруктураЗаполнения = Новый Структура;
				СтруктураЗаполнения.Вставить("ЗначенияЗаполнения",  Новый Структура("Владелец", Объект.Ссылка));
				
				ОткрытьФорму("Справочник.УпаковкиНоменклатуры.Форма.ФормаЭлемента", 
							 СтруктураЗаполнения, 
							 ЭтаФорма); 
				
			КонецЕсли; 
		КонецЕсли;
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

