
#Область ОбработчикиСобытийЭлементовФормы

&НаСервере
// Обработка создания формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СписокПлана.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	ЭтоЗаписьНаПрием = Ложь;
	ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	Параметры.Свойство("ЭтоЗаписьНаПрием", ЭтоЗаписьНаПрием);
	Параметры.Свойство("Старт", Старт);
	Параметры.Свойство("Финиш", Финиш);
	Параметры.Свойство("Сотрудник", Сотрудник);	
	Параметры.Свойство("Помещение", Помещение);
	
	Если Параметры.Свойство("ТолькоВОчереди") Тогда 
		Параметры.Свойство("ТолькоВОчереди", 		ОтборВидОсмотра); 
		Параметры.Свойство("Сотрудник", 			ОтборСотрудник);
		Параметры.Свойство("ДатаЗапланированная", 	ОтборНачалоПериода);
		ОтборКоннецПериода = ТекущаяДатаСеанса();
	   	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокПлана, "ВидОсмотра", ОтборВидОсмотра, ЗначениеЗаполнено(ОтборВидОсмотра), ВидСравненияКомпоновкиДанных.Равно);
	   	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокПлана, "Сотрудник", ОтборСотрудник, ЗначениеЗаполнено(ОтборСотрудник), ВидСравненияКомпоновкиДанных.Равно);
	Иначе 	
		// Установка периода отбоора по умолчанию
		ОтборКоннецПериода      = ТекущаяДатаСеанса(); 
	КонецЕсли;  
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокПлана, "СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница, ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница), ВидСравненияКомпоновкиДанных.Равно);

	ОтборыСписковКлиентСервер.УстановитьДиапазонДатДляСписка(СписокПлана, "ДатаЗапланированная", ОтборНачалоПериода, ВернутьКонецДняДаты(ОтборКоннецПериода), Истина);
		
	//ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокПлана, "ДатаЗапланированная", ОтборКоннецПериода, ЗначениеЗаполнено(ОтборКоннецПериода), ВидСравненияКомпоновкиДанных.МеньшеИлиРавно);	
	//ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокПлана, "ДатаЗапланированная", ОтборНачалоПериода, ЗначениеЗаполнено(ОтборНачалоПериода), ВидСравненияКомпоновкиДанных.БольшеИлиРавно);
	
	Элементы.СписокТелефонКонтрагента.Видимость = НЕ (ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач);
	
КонецПроцедуры

&НаКлиенте
// Обработчик оповещений формы
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_СПИСОК_ПРОФОСМОТРОВ" Тогда
		Элементы.СписокПлана.Обновить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиРеквизитовОтбора

