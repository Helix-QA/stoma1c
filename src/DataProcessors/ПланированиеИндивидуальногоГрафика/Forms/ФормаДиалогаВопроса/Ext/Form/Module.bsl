
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	Параметры.Свойство("Вопрос", Вопрос);	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаДа(Команда)
	ЭтаФорма.Закрыть(Новый Структура("Ответ,ДляВсех", КодВозвратаДиалога.Да, ДляВсех));
КонецПроцедуры

&НаКлиенте
Процедура КомандаНет(Команда)
	ЭтаФорма.Закрыть(Новый Структура("Ответ,ДляВсех", КодВозвратаДиалога.Нет, ДляВсех));
КонецПроцедуры

#КонецОбласти
