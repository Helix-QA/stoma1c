&НаКлиенте
// Процедура - Поиск контрагента создание
//
// Параметры:
//  Элемент				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПоискКонтрагентаСоздание(Элемент, СтандартнаяОбработка)
	
	ГруппаКлиентов = ОбщегоНазначенияСтоматология.ВернутьГруппуКлиентов();
	ТекущийРодитель = ?(ЗначениеЗаполнено(ГруппаКлиентов), ГруппаКлиентов, ГруппаКонтрагентов);
	
	СтандартнаяОбработка = Ложь;
	ЗначениеЗаполнения = Новый Структура();
	ЗначениеЗаполнения.Вставить("ДобавитьНомерТелефона"			, Истина);
	ЗначениеЗаполнения.Вставить("ТекстЗаполнения"				, Элемент.ТекстРедактирования);
	ЗначениеЗаполнения.Вставить("НомерТелефона"					, ПреобразованныйНомерТелефона);
	ЗначениеЗаполнения.Вставить("ТекущийРодитель"				, ТекущийРодитель);
	
	ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", Новый Структура("ЗначенияЗаполнения", ЗначениеЗаполнения), ЭтаФорма);
		
КонецПроцедуры

&НаКлиенте
// Процедура - Поиск контрагента обработка выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПоискКонтрагентаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда 
		СтандартнаяОбработка = Ложь;
		ЗначениеЗаполнения = Новый Структура();
		ЗначениеЗаполнения.Вставить("ДобавитьНомерТелефона"			, Истина);
		ЗначениеЗаполнения.Вставить("НомерТелефона"					, ПреобразованныйНомерТелефона);
		
		ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", Новый Структура("Ключ, ЗначенияЗаполнения", ВыбранноеЗначение, ЗначениеЗаполнения), ЭтаФорма);
	КонецЕсли;
	
КонецПроцедуры

