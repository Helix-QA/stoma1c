	// Спр. Номенклатура
	
	// НормыСписанияМатериалов перегоняли из ТЧ в Регистр в 47 релизе.
	// Сейчас нет смысла дозаполнять ТЧ, а потом еще раз регистр.
	// Изменил поле в процедуре обновления ПеренестиДанныеИзТЧВРегистрСведенийНормыСписанияМатериалов,
	// откуда берется информация по несовпадающему реквизиту
	
#КонецОбласти

#Область Обработка_Документов

	// Выравнивание.

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПланЛеченияЛечение.Ссылка КАК Ссылка,
	|	ПланЛеченияЛечение.КлючСтроки КАК КлючСтроки,
	|	ПланЛеченияЛечение.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Документ.ПланЛечения.Лечение КАК ПланЛеченияЛечение
	|ГДЕ
	|	НЕ ПланЛеченияЛечение.СуммаРучнойСкидки_OLD = 0
	|
	|ИТОГИ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриемМатериалы.Ссылка КАК Ссылка,
	|	ПриемМатериалы.ВключатьВСтоимость_OLD КАК ВключатьВСтоимость_OLD,
	|	ПриемМатериалы.ВидЦен_OLD КАК ВидЦен_OLD,
	|	ПриемМатериалы.КлючСтроки КАК КлючСтроки,
	|	ПриемМатериалы.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Документ.Прием.Материалы КАК ПриемМатериалы
	|ГДЕ
	|	НЕ ПриемМатериалы.ВидЦен_OLD.Ссылка ЕСТЬ NULL
	|ИТОГИ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СписаниеДенежныхСредств.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|ГДЕ
	|	НЕ СписаниеДенежныхСредств.Выгодоприобретатель_OLD.Ссылка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекКоррекции_OLD.Ссылка КАК Ссылка,
	|	ЧекКоррекции_OLD.ВерсияДанных КАК ВерсияДанных,
	|	ЧекКоррекции_OLD.ПометкаУдаления КАК ПометкаУдаления,
	|	ЧекКоррекции_OLD.Номер КАК Номер,
	|	ЧекКоррекции_OLD.Дата КАК Дата,
	|	ЧекКоррекции_OLD.Проведен КАК Проведен,
	|	ЧекКоррекции_OLD.АвторДокумента КАК АвторДокумента,
	|	ЧекКоррекции_OLD.ВидОперации КАК ВидОперации,
	|	ЧекКоррекции_OLD.ДатаКоррекции КАК ДатаКоррекции,
	|	ЧекКоррекции_OLD.ДокументРасчетов КАК ДокументРасчетов,
	|	ЧекКоррекции_OLD.ДополнительныйРеквизит КАК ДополнительныйРеквизит,
	|	ЧекКоррекции_OLD.Касса КАК Касса,
	|	ЧекКоррекции_OLD.Кассир КАК Кассир,
	|	ЧекКоррекции_OLD.КассирИНН КАК КассирИНН,
	|	ЧекКоррекции_OLD.КассоваяСмена КАК КассоваяСмена,
	|	ЧекКоррекции_OLD.Комментарий КАК Комментарий,
	|	ЧекКоррекции_OLD.НеприменениеККТ КАК НеприменениеККТ,
	|	ЧекКоррекции_OLD.НомерПредписания КАК НомерПредписания,
	|	ЧекКоррекции_OLD.НомерСмены КАК НомерСмены,
	|	ЧекКоррекции_OLD.НомерЧекаККМ КАК НомерЧекаККМ,
	|	ЧекКоррекции_OLD.ОписаниеКоррекции КАК ОписаниеКоррекции,
	|	ЧекКоррекции_OLD.Организация КАК Организация,
	|	ЧекКоррекции_OLD.Покупатель КАК Покупатель,
	|	ЧекКоррекции_OLD.ПокупательEmail КАК ПокупательEmail,
	|	ЧекКоррекции_OLD.ПокупательИНН КАК ПокупательИНН,
	|	ЧекКоррекции_OLD.ПокупательНомер КАК ПокупательНомер,
	|	ЧекКоррекции_OLD.ПризнакАгента КАК ПризнакАгента,
	|	ЧекКоррекции_OLD.ПробитЧек КАК ПробитЧек,
	|	ЧекКоррекции_OLD.СистемаНалогообложения КАК СистемаНалогообложения,
	|	ЧекКоррекции_OLD.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЧекКоррекции_OLD.СуммаВключаетНДС КАК СуммаВключаетНДС,
	|	ЧекКоррекции_OLD.ТипКоррекции КАК ТипКоррекции,
	|	ЕСТЬNULL(ЧекКоррекции_OLD.ТипРасчета.Порядок, НЕОПРЕДЕЛЕНО) КАК ТипРасчетаПорядок,
	|	ЧекКоррекции_OLD.ЭтоСторно КАК ЭтоСторно,
	|	ЧекКоррекции_OLD.Оплата.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		Сумма КАК Сумма,
	|		ТипОплаты КАК ТипОплаты
	|	) КАК Оплата,
	|	ЧекКоррекции_OLD.ПозицииЧека.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		ДанныеПоставщикаИНН КАК ДанныеПоставщикаИНН,
	|		ДанныеПоставщикаНаименование КАК ДанныеПоставщикаНаименование,
	|		ДанныеПоставщикаТелефон КАК ДанныеПоставщикаТелефон,
	|		Количество КАК Количество,
	|		НаименованиеПредметаРасчета КАК НаименованиеПредметаРасчета,
	|		НомерСекции КАК НомерСекции,
	|		ПризнакАгентаПоПредметуРасчета КАК ПризнакАгентаПоПредметуРасчета,
	|		ПризнакПредметаРасчета КАК ПризнакПредметаРасчета,
	|		ПризнакСпособаРасчета КАК ПризнакСпособаРасчета,
	|		СтавкаНДС КАК СтавкаНДС,
	|		СуммаНДС КАК СуммаНДС,
	|		СуммаСкидок КАК СуммаСкидок,
	|		СуммаСоСкидками КАК СуммаСоСкидками,
	|		ЦенаСоСкидками КАК ЦенаСоСкидками,
	|		Штрихкод КАК Штрихкод
	|	) КАК ПозицииЧека,
	|	ЧекКоррекции_OLD.ТаблицаОснований.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		ДокументОснование КАК ДокументОснование
	|	) КАК ТаблицаОснований,
	|	ЕСТЬNULL(ФискальныеОперацииДокументы_OLD.ИдентификаторЗаписи, НЕОПРЕДЕЛЕНО) КАК ИдентификаторФискальнойЗаписи
	|ИЗ
	|	Документ.ЧекКоррекции_OLD КАК ЧекКоррекции_OLD
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперацииДокументы_OLD КАК ФискальныеОперацииДокументы_OLD
	|		ПО ЧекКоррекции_OLD.Ссылка = ФискальныеОперацииДокументы_OLD.ДокументОснование
	|ГДЕ
	|	ЧекКоррекции_OLD.Проведен");
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
		
	// Документ ПланЛечения	
	ВыборкаПланЛечения = РезультатыЗапроса[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПланЛечения.Следующий() Цикл
		
		ПланЛеченияОбъект = ВыборкаПланЛечения.Ссылка.ПолучитьОбъект();	
		
		Если ПланЛеченияОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТабличнаяЧастьЛечение = ПланЛеченияОбъект.Лечение;		
		ВыборкаТЧДокумента = ВыборкаПланЛечения.Выбрать();
		
		Пока ВыборкаТЧДокумента.Следующий() Цикл
			ИзменяемаяСтрока = ТабличнаяЧастьЛечение[ВыборкаТЧДокумента.НомерСтроки-1];
			Если ИзменяемаяСтрока.КлючСтроки = ВыборкаТЧДокумента.КлючСтроки Тогда
				ИзменяемаяСтрока.СуммаРучнойСкидки = ИзменяемаяСтрока.СуммаРучнойСкидки_OLD;
			КонецЕсли;
		КонецЦикла;
		
		Попытка			
			ПланЛеченияОбъект.Записать(РежимЗаписиДокумента.Запись);				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка документов ПланЛечения."
			, УровеньЖурналаРегистрации.Ошибка
			,, ПланЛеченияОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
			
	КонецЦикла;
	
	// Документ Прием	
	ВыборкаПрием = РезультатыЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПрием.Следующий() Цикл
		
		ПриемОбъект = ВыборкаПрием.Ссылка.ПолучитьОбъект();	
		
		Если ПриемОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТабличнаяЧастьМатериалы = ПриемОбъект.Материалы;		
		ВыборкаТЧДокумента = ВыборкаПрием.Выбрать();
		
		Пока ВыборкаТЧДокумента.Следующий() Цикл
			ИзменяемаяСтрока = ТабличнаяЧастьМатериалы[ВыборкаТЧДокумента.НомерСтроки-1];
			Если ИзменяемаяСтрока.КлючСтроки = ВыборкаТЧДокумента.КлючСтроки Тогда				
				ИзменяемаяСтрока.ВключатьВСтоимость = ИзменяемаяСтрока.ВключатьВСтоимость_OLD;
				ИзменяемаяСтрока.ВидЦен = ИзменяемаяСтрока.ВидЦен_OLD;
			КонецЕсли;
		КонецЦикла;
		
		Попытка			
			ПриемОбъект.Записать(РежимЗаписиДокумента.Запись);				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка документов Прием."
			, УровеньЖурналаРегистрации.Ошибка
			,, ПриемОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
			
	КонецЦикла;
	
	// Документ СписаниеДенежныхСредств	
	ВыборкаСписаниеДенежныхСредств = РезультатыЗапроса[2].Выбрать();
	Пока ВыборкаСписаниеДенежныхСредств.Следующий() Цикл
		
		СписаниеДСОбъект = ВыборкаСписаниеДенежныхСредств.Ссылка.ПолучитьОбъект();	
		
		Если СписаниеДСОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СписаниеДСОбъект.Выгодоприобретатель = СписаниеДСОбъект.Выгодоприобретатель_OLD;
		
		Попытка			
			СписаниеДСОбъект.Записать(РежимЗаписиДокумента.Запись);				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка документов СписаниеДенежныхСредств."
			, УровеньЖурналаРегистрации.Ошибка
			,, СписаниеДСОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
			
	КонецЦикла;	
	
	// Документ ЧекКоррекции	
	ВыборкаЧекКоррекции = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаЧекКоррекции.Следующий() Цикл
		
		ЧекКоррекцииОбъект = Документы.ЧекКоррекции.СоздатьДокумент();		
		ЗаполнитьЗначенияСвойств(ЧекКоррекцииОбъект, ВыборкаЧекКоррекции);
		
		Если ЗначениеЗаполнено(ВыборкаЧекКоррекции.ТипРасчетаПорядок) Тогда
			ЧекКоррекцииОбъект.ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами[ВыборкаЧекКоррекции.ТипРасчетаПорядок];
		КонецЕсли;	
		ЧекКоррекцииОбъект.Номер = "00" + ВыборкаЧекКоррекции.Номер;		
		ЧекКоррекцииОбъект.Оплата.Загрузить(ВыборкаЧекКоррекции.Оплата.Выгрузить());
		ЧекКоррекцииОбъект.ПозицииЧека.Загрузить(ВыборкаЧекКоррекции.ПозицииЧека.Выгрузить());
		ЧекКоррекцииОбъект.ТаблицаОснований.Загрузить(ВыборкаЧекКоррекции.ТаблицаОснований.Выгрузить());
		
		ОбновитьЗаписьВРегистреФискальныеОперацииДокументы = Ложь;
		ОбновитьЗаписьВРегистреФискальныеОперацииКорДокументы = Ложь;
		Если ЗначениеЗаполнено(ВыборкаЧекКоррекции.ИдентификаторФискальнойЗаписи) Тогда
						
			СсылкаНового = Документы.ЧекКоррекции.ПолучитьСсылку();
			ЧекКоррекцииОбъект.УстановитьСсылкуНового(СсылкаНового);
			
			МенеджерЗаписиФискОперацииДокументы = РегистрыСведений.ФискальныеОперацииДокументы_OLD.СоздатьМенеджерЗаписи();
			МенеджерЗаписиФискОперацииДокументы.ИдентификаторЗаписи = ВыборкаЧекКоррекции.ИдентификаторФискальнойЗаписи;
			МенеджерЗаписиФискОперацииДокументы.ДокументОснование = ВыборкаЧекКоррекции.Ссылка;
			МенеджерЗаписиФискОперацииДокументы.Прочитать();
			Если МенеджерЗаписиФискОперацииДокументы.Выбран() Тогда
				ОбновитьЗаписьВРегистреФискальныеОперацииДокументы = Истина;
				МенеджерЗаписиФискОперацииДокументы.ДокументОснование = СсылкаНового;						
			КонецЕсли; 
			
			МенеджерЗаписиФискОперацииКорДокументы = РегистрыСведений.ФискальныеОперацииКорректируемыеДокументы_OLD.СоздатьМенеджерЗаписи();
			МенеджерЗаписиФискОперацииКорДокументы.ИдентификаторЗаписи = ВыборкаЧекКоррекции.ИдентификаторФискальнойЗаписи;
			МенеджерЗаписиФискОперацииКорДокументы.ДокументОснование = ВыборкаЧекКоррекции.Ссылка;
			МенеджерЗаписиФискОперацииКорДокументы.Прочитать();
			Если МенеджерЗаписиФискОперацииКорДокументы.Выбран() Тогда
				ОбновитьЗаписьВРегистреФискальныеОперацииКорДокументы = Истина;
				МенеджерЗаписиФискОперацииКорДокументы.ДокументОснование = СсылкаНового;						
			КонецЕсли;
			
		КонецЕсли;
				
		ЧекКоррекцииОбъект.ОбменДанными.Загрузка = Истина;
		
		Попытка			
			ЧекКоррекцииОбъект.Записать();
			
			Если ОбновитьЗаписьВРегистреФискальныеОперацииДокументы Тогда
				МенеджерЗаписиФискОперацииДокументы.Записать(Истина);					
			КонецЕсли;
			Если ОбновитьЗаписьВРегистреФискальныеОперацииКорДокументы Тогда
				МенеджерЗаписиФискОперацииКорДокументы.Записать(Истина);					
			КонецЕсли;
	
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка документов Чеки коррекции."
			, УровеньЖурналаРегистрации.Ошибка
			,, ВыборкаЧекКоррекции.Ссылка, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
			
	КонецЦикла;
				
#КонецОбласти

#Область Обработка_РегистровСведений	

	// Выравнивание.

	МассивОбрабатываемыхРегистров = Новый Массив;
	МассивОбрабатываемыхРегистров.Добавить(Новый Структура("Приемник, Источник", "ФискальныеОперацииДокументы", "ФискальныеОперацииДокументы_OLD"));
	МассивОбрабатываемыхРегистров.Добавить(Новый Структура("Приемник, Источник", "ФискальныеОперацииКорректируемыеДокументы", "ФискальныеОперацииКорректируемыеДокументы_OLD"));
	МассивОбрабатываемыхРегистров.Добавить(Новый Структура("Приемник, Источник", "АдресныеОбъекты", "АдресныеОбъекты_OLD"));
	МассивОбрабатываемыхРегистров.Добавить(Новый Структура("Приемник, Источник", "БезопасноеХранилищеДанных", "БезопасноеХранилищеДанных_OLD"));
	МассивОбрабатываемыхРегистров.Добавить(Новый Структура("Приемник, Источник", "ЗагруженныеВерсииАдресныхСведений", "ЗагруженныеВерсииАдресныхСведений_OLD"));
	
	Запрос = Новый Запрос;
	
	Для Каждого ОбрабатываемыеРегистр ИЗ МассивОбрабатываемыхРегистров Цикл
		
		Запрос.Текст = Запрос.Текст +   
		"ВЫБРАТЬ 
		|	*	
		|ИЗ
		|	РегистрСведений."+ ОбрабатываемыеРегистр.Источник +" КАК "+ ОбрабатываемыеРегистр.Источник+ "
		|;
		|
		|";
		
	КонецЦикла;
	
    Запрос.Текст = Запрос.Текст +
	"ВЫБРАТЬ
	|	ЗначенияПараметровОбследований.Документ КАК Документ,
	|	ЗначенияПараметровОбследований.ШаблонОбследования КАК ШаблонОбследования,
