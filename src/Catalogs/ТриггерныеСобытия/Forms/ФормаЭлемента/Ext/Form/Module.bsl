&НаСервере
// Процедура - Установить свойства элементам действий
//
Процедура УстановитьСвойстваЭлементамДействий(ЭлементФормы = Неопределено, ИндексРедактируемойСтроки = Неопределено, ПараметрыОтображенияЭлементов = Неопределено) Экспорт
	
	ОбновлятьПараметрыСтроки = Ложь;
	ПоискЭлемента = ЭлементФормы = Неопределено;
	
	// Актуализируем параметры отрисовки
	Если ПараметрыОтображенияЭлементов = Неопределено Тогда 
		ПараметрыОтображенияЭлементов 	= ИнициализироватьСтруктуруПараметровОтрисовки();
		МассивАктуальныхСтрок 			= Объект.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь));		
		ОбновлятьПараметрыСтроки 		= Истина;
	КонецЕсли;
	
	Для Каждого СтрокаДействие ИЗ Объект.Действия Цикл
		Если СтрокаДействие.Удалено Тогда 
			Продолжить;
		КонецЕсли;
		Если НЕ ИндексРедактируемойСтроки = Неопределено Тогда 
			Если ИндексРедактируемойСтроки = Объект.Действия.Индекс(СтрокаДействие) Тогда
				ИндексСтроки = ИндексРедактируемойСтроки;
			Иначе 	
				Продолжить;
			КонецЕсли;
		Иначе 
			ИндексСтроки = Объект.Действия.Индекс(СтрокаДействие);
		КонецЕсли;
		
		// Актуализируем параметр конкретной строки
		Если ОбновлятьПараметрыСтроки Тогда 
			ПараметрыОтображенияЭлементов.Вставить("ЭтоПерваяАктуальнаяСтрока", ?(МассивАктуальныхСтрок.Количество() = 0, Истина, ИндексСтроки = Объект.Действия.Индекс(МассивАктуальныхСтрок[0])));
		КонецЕсли;
		
		// Настраиваем элементы строки
		УстановитьСвойстваЭлементамСтрокиДействий(, ИндексСтроки, ПараметрыОтображенияЭлементов);
		Если НЕ ИндексРедактируемойСтроки = Неопределено ИЛИ СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки ИЛИ СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота Тогда
			Если ЗначениеЗаполнено(СтрокаДействие.ВидДействия) Тогда
				Если СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру Тогда 
					УстановитьСвойстваЭлементамИсполнителей(, ИндексСтроки, ПараметрыОтображенияЭлементов);
					УстановитьСвойстваЭлементамШаблона(, ИндексСтроки, ПараметрыОтображенияЭлементов);
			    ИначеЕсли СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение ИЛИ СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
					УстановитьСвойстваЭлементамПолучателяСообщения(, ИндексСтроки, ПараметрыОтображенияЭлементов);
					УстановитьСвойстваЭлементамАккаунтаСообщения(, ИндексСтроки, ПараметрыОтображенияЭлементов);
					УстановитьСвойстваЭлементамШаблона(, ИндексСтроки, ПараметрыОтображенияЭлементов);					
				//ИначеЕсли СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
				//	УстановитьСвойстваЭлементамПолучателяСообщения(, ИндексРедактируемойСтроки, ПараметрыОтображенияЭлементов);					
				//	УстановитьСвойстваЭлементамАккаунтаСообщения(, ИндексРедактируемойСтроки, ПараметрыОтображенияЭлементов);
				//	УстановитьСвойстваЭлементамШаблона(, ИндексРедактируемойСтроки, ПараметрыОтображенияЭлементов);					
			    ИначеЕсли СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки ИЛИ СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.СменитьЭтапСделки Тогда 
					УстановитьСвойстваЭлементамДействийПоСделкам(, ИндексСтроки, ПараметрыОтображенияЭлементов);
				ИначеЕсли СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота Тогда 
					УстановитьСвойстваЭлементамДействийПоЧатБотам(, ИндексСтроки, ПараметрыОтображенияЭлементов);
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить свойства элементам строки действий
//
// Параметры:
//  ЭлементФормы					 - 	 - 
//  ИндексРедактируемойСтроки		 - 	 - 
//  ПараметрыОтображенияЭлементов	 - 	 - 
//
Процедура УстановитьСвойстваЭлементамСтрокиДействий(ЭлементФормы = Неопределено, ИндексСтроки, ПараметрыОтображенияЭлементов = Неопределено) Экспорт

	// Актуализируем параметры отрисовки
	Если ПараметрыОтображенияЭлементов = Неопределено Тогда 
		ПараметрыОтображенияЭлементов 	= ИнициализироватьСтруктуруПараметровОтрисовки(Ложь);
		МассивАктуальныхСтрок 			= Объект.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь));		
		ПараметрыОтображенияЭлементов.Вставить("ЭтоПерваяАктуальнаяСтрока", ?(МассивАктуальныхСтрок.Количество() = 0, Истина, ИндексСтроки = Объект.Действия.Индекс(МассивАктуальныхСтрок[0])));
		//Если НЕ ПараметрыОтображенияЭлементов.Свойство("ЦветСтроки") Тогда 
		//	 ПараметрыОтображенияЭлементов.Вставить("ЦветСтроки", ОпределитьЦветСтроки(ИндексСтроки));
		//КонецЕсли;	 
	КонецЕсли;
	
	ПоискЭлемента = ЭлементФормы = Неопределено;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ГруппаСтрока_ТЧ_Действия_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;	
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ГруппаСтрока_ТЧ_Действия_Индекс_" + Строка(ИндексСтроки) Тогда 		
			ЭлементФормы.Доступность = Объект.Активно;
			Если НЕ ПоискЭлемента Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ИспользованиеДействия_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;			
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ИспользованиеДействия_Индекс_" + Строка(ИндексСтроки) Тогда
			ЭлементФормы.Видимость 		= ЗначениеЗаполнено(Объект.Действия[ИндексСтроки].ВидДействия) ИЛИ ПараметрыОтображенияЭлементов.ТабличнаяЧастьСодержитОднуАктуальнуюСтроку ИЛИ ПараметрыОтображенияЭлементов.ЭтоПерваяАктуальнаяСтрока;
			ЭлементФормы.Доступность 	= Объект.Активно; // И ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия);			
			Если НЕ ПоискЭлемента Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;				
	КонецЕсли;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ВидДействия_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;					
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ВидДействия_Индекс_" + Строка(ИндексСтроки) Тогда
			ЭлементФормы.Доступность = Объект.Активно И (Объект.Действия[ИндексСтроки].Использование ИЛИ НЕ (ЗначениеЗаполнено(Объект.Действия[ИндексСтроки].ВидДействия) ИЛИ ПараметрыОтображенияЭлементов.ТабличнаяЧастьСодержитОднуАктуальнуюСтроку ИЛИ ПараметрыОтображенияЭлементов.ЭтоПерваяАктуальнаяСтрока) ИЛИ ПараметрыОтображенияЭлементов.ТабличнаяЧастьСодержитОднуАктуальнуюСтроку);
			// Актуализируем список выбора
			ЭлементФормы.СписокВыбора.Очистить();
			ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение	, , Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение);			
			ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо		, , Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо);			
			ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру		, , Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру);
			//ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВариантыДействийТриггерныхСобытий.СообщениеSMS			, , Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.СообщениеSMS);
			//ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВариантыДействийТриггерныхСобытий.СообщениеВМесенджер	, , Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.СообщениеВМесенджер);
			Если ПараметрыОтображенияЭлементов.РазрешенаРаботаСоСделками Тогда 	
				ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки, , Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки);
				//ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВариантыДействийТриггерныхСобытий.СменитьЭтапСделки, , Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.СменитьЭтапСделки);
