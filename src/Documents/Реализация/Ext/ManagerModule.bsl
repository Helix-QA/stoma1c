
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

#Область Проведение

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылкаРеализация, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
		
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияТоваров.Ссылка КАК Документ,
	|	РеализацияТоваров.Ссылка.Дата КАК Период,
	|	РеализацияТоваров.Ссылка.Склад КАК Склад,
	|	РеализацияТоваров.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	РеализацияТоваров.Ссылка.Контрагент КАК Контрагент,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	РеализацияТоваров.НомерСтроки КАК НомерСтроки,
	|	РеализацияТоваров.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА РеализацияТоваров.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	РеализацияТоваров.Количество КАК Количество,
	|	РеализацияТоваров.СтавкаНДС КАК СтавкаНДС,
	|	РеализацияТоваров.Сумма КАК Сумма,
	|	РеализацияТоваров.Ссылка.КартаКонтрагента КАК КартаКонтрагента
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасы
	|ИЗ
	|	(ВЫБРАТЬ
	|		РеализацияТоваровЗапасы.Ссылка КАК Ссылка,
	|		РеализацияТоваровЗапасы.НомерСтроки КАК НомерСтроки,
	|		РеализацияТоваровЗапасы.Номенклатура КАК Номенклатура,
	|		РеализацияТоваровЗапасы.Партия КАК Партия,
	|		РеализацияТоваровЗапасы.Количество КАК Количество,
	|		РеализацияТоваровЗапасы.СтавкаНДС КАК СтавкаНДС,
	|		РеализацияТоваровЗапасы.Всего КАК Сумма
	|	ИЗ
	|		Документ.Реализация.Запасы КАК РеализацияТоваровЗапасы
	|	ГДЕ
	|		РеализацияТоваровЗапасы.Ссылка = &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РеализацияТоваровПодарки.Ссылка,
	|		РеализацияТоваровПодарки.НомерСтроки,
	|		РеализацияТоваровПодарки.Номенклатура,
	|		РеализацияТоваровПодарки.Партия,
	|		РеализацияТоваровПодарки.Количество,
	|		ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.БезНДС),
	|		0
	|	ИЗ
	|		Документ.Реализация.Подарки КАК РеализацияТоваровПодарки
	|	ГДЕ
	|		РеализацияТоваровПодарки.Ссылка = &Ссылка
	|		И РеализацияТоваровПодарки.Использование = ИСТИНА) КАК РеализацияТоваров
	|ГДЕ
	|	РеализацияТоваров.Ссылка = &Ссылка
	|	И РеализацияТоваров.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияТоваровПродажи.Ссылка КАК ДокументПродажи,
	|	РеализацияТоваровПродажи.Ссылка.Дата КАК Период,
	|	РеализацияТоваровПродажи.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	РеализацияТоваровПродажи.Ссылка.Сотрудник КАК Сотрудник,
	|	РеализацияТоваровПродажи.Ссылка.Контрагент КАК Контрагент,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровПродажи.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|		ИНАЧЕ РеализацияТоваровПродажи.Ссылка.Склад
	|	КОНЕЦ КАК Склад,
	|	РеализацияТоваровПродажи.НомерСтроки КАК НомерСтроки,
	|	РеализацияТоваровПродажи.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА РеализацияТоваровПродажи.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	РеализацияТоваровПродажи.Количество КАК Количество,
	|	РеализацияТоваровПродажи.СтоимостьБезСкидки КАК СтоимостьБезСкидки,
	|	РеализацияТоваровПродажи.Стоимость КАК Стоимость,
	|	РеализацияТоваровПродажи.Ссылка.КартаКонтрагента КАК КартаКонтрагента
	|ПОМЕСТИТЬ ВременнаяТаблицаПродажи
	|ИЗ
	|	(ВЫБРАТЬ
	|		РеализацияТоваровЗапасы.Ссылка КАК Ссылка,
	|		РеализацияТоваровЗапасы.НомерСтроки КАК НомерСтроки,
	|		РеализацияТоваровЗапасы.Номенклатура КАК Номенклатура,
	|		РеализацияТоваровЗапасы.Партия КАК Партия,
	|		РеализацияТоваровЗапасы.Количество КАК Количество,
	|		РеализацияТоваровЗапасы.Сумма + РеализацияТоваровЗапасы.СуммаАвтоматическойСкидкиНаценки + РеализацияТоваровЗапасы.Цена * РеализацияТоваровЗапасы.КоличествоУпаковок * РеализацияТоваровЗапасы.ПроцентСкидкиНаценки / 100 КАК СтоимостьБезСкидки,
	|		РеализацияТоваровЗапасы.Сумма КАК Стоимость
	|	ИЗ
	|		Документ.Реализация.Запасы КАК РеализацияТоваровЗапасы
	|	ГДЕ
	|		РеализацияТоваровЗапасы.Ссылка = &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РеализацияТоваровПодарки.Ссылка,
	|		РеализацияТоваровПодарки.НомерСтроки,
	|		РеализацияТоваровПодарки.Номенклатура,
	|		РеализацияТоваровПодарки.Партия,
	|		РеализацияТоваровПодарки.КоличествоУпаковок * РеализацияТоваровПодарки.Упаковка.Коэффициент,
	|		0,
	|		0
	|	ИЗ
	|		Документ.Реализация.Подарки КАК РеализацияТоваровПодарки
	|	ГДЕ
	|		РеализацияТоваровПодарки.Ссылка = &Ссылка
	|		И РеализацияТоваровПодарки.Использование = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РеализацияУслуги.Ссылка,
	|		РеализацияУслуги.НомерСтроки,
	|		РеализацияУслуги.Номенклатура,
	|		РеализацияУслуги.Партия,
	|		РеализацияУслуги.Количество,
	|		РеализацияУслуги.Цена * РеализацияУслуги.КоличествоУпаковок,
	|		РеализацияУслуги.Сумма
	|	ИЗ
	|		Документ.Реализация.Услуги КАК РеализацияУслуги
	|	ГДЕ
	|		РеализацияУслуги.Ссылка = &Ссылка) КАК РеализацияТоваровПродажи
	|ГДЕ
	|	РеализацияТоваровПродажи.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияТоваровВзаморасчетыКонрагентов.НомерСтроки КАК НомерСтроки,
	|	РеализацияТоваровВзаморасчетыКонрагентов.Ссылка КАК Документ,
	|	РеализацияТоваровВзаморасчетыКонрагентов.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	РеализацияТоваровВзаморасчетыКонрагентов.Ссылка.Контрагент КАК Контрагент,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровВзаморасчетыКонрагентов.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА РеализацияТоваровВзаморасчетыКонрагентов.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ РеализацияТоваровВзаморасчетыКонрагентов.Ссылка.Организация
	|	КОНЕЦ КАК Организация,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	РеализацияТоваровВзаморасчетыКонрагентов.Ссылка.Дата КАК Период,
	|	РеализацияТоваровВзаморасчетыКонрагентов.Сумма КАК Сумма,
	|	РеализацияТоваровВзаморасчетыКонрагентов.Ссылка.Договор КАК Договор
	|ПОМЕСТИТЬ ВременнаяТаблицаВзаиморасчетыКонтрагентов
	|ИЗ
	|	Документ.Реализация.Запасы КАК РеализацияТоваровВзаморасчетыКонрагентов
	|ГДЕ
	|	РеализацияТоваровВзаморасчетыКонрагентов.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияУслуги.НомерСтроки,
	|	РеализацияУслуги.Ссылка,
	|	РеализацияУслуги.Ссылка.СтруктурнаяЕдиница,
	|	РеализацияУслуги.Ссылка.Контрагент,
	|	ВЫБОР
	|		КОГДА РеализацияУслуги.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА РеализацияУслуги.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ РеализацияУслуги.Ссылка.Организация
	|	КОНЕЦ,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	РеализацияУслуги.Ссылка.Дата,
	|	РеализацияУслуги.Сумма,
	|	РеализацияУслуги.Ссылка.Договор
	|ИЗ
	|	Документ.Реализация.Услуги КАК РеализацияУслуги
	|ГДЕ
	|	РеализацияУслуги.Ссылка = &Ссылка
	|
	|;
	|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	//|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	//|	РеализацияСкидкиНаценки.Ссылка.Дата КАК Период,
	//|	РеализацияСкидкиНаценки.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	//|	РеализацияСкидкиНаценки.Ссылка.Контрагент КАК Контрагент,
	//|	ВЫБОР
	//|		КОГДА РеализацияСкидкиНаценки.СкидкаНаценка.ВидЛицевогоСчета = ЗНАЧЕНИЕ(Справочник.ВидыЛицевыхСчетов.ПустаяСсылка)
	//|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет)
	//|		ИНАЧЕ РеализацияСкидкиНаценки.СкидкаНаценка.ВидЛицевогоСчета
	//|	КОНЕЦ КАК ВидСчета,
	//|	ВЫБОР
	//|		КОГДА РеализацияСкидкиНаценки.Ссылка.СуммаОплачено < РеализацияСкидкиНаценки.Ссылка.СуммаДокумента
	//|			ТОГДА РеализацияСкидкиНаценки.Сумма * РеализацияСкидкиНаценки.Ссылка.СуммаОплачено / РеализацияСкидкиНаценки.Ссылка.СуммаДокумента
	//|		ИНАЧЕ РеализацияСкидкиНаценки.Сумма
	//|	КОНЕЦ КАК Сумма
	//|ПОМЕСТИТЬ ТаблицаДенежныеСредстваНаЛицевыхСчетах
	//|ИЗ
	//|	Документ.Реализация.СкидкиНаценки КАК РеализацияСкидкиНаценки
	//|ГДЕ
	//|	РеализацияСкидкиНаценки.Ссылка = &Ссылка
	//|	И РеализацияСкидкиНаценки.НачислениеНаЛицевойСчетУдалить = ИСТИНА
	//|	И РеализацияСкидкиНаценки.Использование = ИСТИНА
	//|
	//|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияТоваровПродажи.Ссылка.Дата КАК Период,
	|	РеализацияТоваровПродажи.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	РеализацияТоваровПродажи.НомерСтроки КАК НомерСтроки,
	|	РеализацияТоваровПродажи.Номенклатура КАК Сертификат,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА РеализацияТоваровПродажи.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	РеализацияТоваровПродажи.Количество КАК Количество,
	|	РеализацияТоваровПродажи.Сумма КАК Сумма,
	|	РеализацияТоваровПродажи.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ВременнаяТаблицаСертификатыПродажи
	|ИЗ
	|	(ВЫБРАТЬ
	|		РеализацияТоваровЗапасы.Ссылка КАК Ссылка,
	|		РеализацияТоваровЗапасы.НомерСтроки КАК НомерСтроки,
	|		РеализацияТоваровЗапасы.Номенклатура КАК Номенклатура,
	|		РеализацияТоваровЗапасы.Партия КАК Партия,
	|		РеализацияТоваровЗапасы.КоличествоУпаковок КАК Количество,
	|		ВЫБОР
	|			КОГДА РеализацияТоваровЗапасы.Номенклатура.ВидНоминала
	|				ТОГДА РеализацияТоваровЗапасы.Цена * РеализацияТоваровЗапасы.КоличествоУпаковок
	|			ИНАЧЕ РеализацияТоваровЗапасы.Номенклатура.Номинал
	|		КОНЕЦ КАК Сумма,
	|		ВЫБОР
	|			КОГДА РеализацияТоваровЗапасы.Номенклатура.ЭтоИменнойСертификат
	|				ТОГДА РеализацияТоваровЗапасы.Ссылка.Контрагент
	|		КОНЕЦ КАК Контрагент
	|	ИЗ
	|		Документ.Реализация.Запасы КАК РеализацияТоваровЗапасы
	|	ГДЕ
	|		РеализацияТоваровЗапасы.Ссылка = &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РеализацияТоваровПодарки.Ссылка,
	|		РеализацияТоваровПодарки.НомерСтроки,
	|		РеализацияТоваровПодарки.Номенклатура,
	|		РеализацияТоваровПодарки.Партия,
	|		РеализацияТоваровПодарки.КоличествоУпаковок,
	|		ВЫБОР
	|			КОГДА РеализацияТоваровПодарки.Номенклатура.ВидНоминала = ИСТИНА
	|				ТОГДА РеализацияТоваровПодарки.СуммаПодарочногоСертификата
	|			ИНАЧЕ РеализацияТоваровПодарки.Номенклатура.Номинал
	|		КОНЕЦ,
	|		РеализацияТоваровПодарки.Контрагент
	|	ИЗ
	|		Документ.Реализация.Подарки КАК РеализацияТоваровПодарки
	|	ГДЕ
	|		РеализацияТоваровПодарки.Ссылка = &Ссылка
	|		И РеализацияТоваровПодарки.Использование = ИСТИНА) КАК РеализацияТоваровПродажи
	|ГДЕ
	|	РеализацияТоваровПродажи.Ссылка = &Ссылка
	|	И РеализацияТоваровПродажи.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияСкидкиНаценки.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	РеализацияСкидкиНаценки.Ссылка.Ссылка КАК ДокументПродажи,
	|	РеализацияСкидкиНаценки.Ссылка.Дата КАК Период,
	|	ВЫБОР
