// Возвращает имя формы настройки обработчика драйвера
// При первом обращении возвращает сформированное на сервере имя.
//
Функция ПолучитьИмяФормыНастройкиПараметров(НаименованиеОбработчикаДрайвера) Экспорт

	НаименованиеФормыНастройки = 
	    СтрЗаменить(МенеджерОборудованияВызовСервера.ПолучитьИмяДрайвераЭкземпляра(НаименованиеОбработчикаДрайвера),
	                "Обработчик",
	                "ФормаНастройки");
    Если НаименованиеОбработчикаДрайвера = "TRPOS: Эквайринговые терминалы" 
		Или НаименованиеОбработчикаДрайвера = "ИНПАС: Эквайринговые терминалы UNIPOS"
		Или НаименованиеОбработчикаДрайвера = "ARCUS2: Эквайринговые терминалы Ingenico"
		Или НаименованиеОбработчикаДрайвера = "UCS-EFTPOS: Эквайринговые терминалы"
		Или НаименованиеОбработчикаДрайвера = "Кристалл Сервис: Фискальные регистраторы Pirit"
		Или НаименованиеОбработчикаДрайвера = "АТОЛ: Фискальные регистраторы (Универсальный)"
		Или НаименованиеОбработчикаДрайвера = "АТОЛ: Фискальные регистраторы 8.Х" 
		Или НаименованиеОбработчикаДрайвера = "Штрих-М:ККТ с передачей данных в ОФД (54-ФЗ)"
		Или НаименованиеОбработчикаДрайвера = "АТОЛ:ККТ с передачей данных в ОФД (54-ФЗ)" 
		Или НаименованиеОбработчикаДрайвера = "ГАЗПРОМБАНК:Эквайринговые терминалы" 
		ИЛИ НаименованиеОбработчикаДрайвера = "Дримкас:Фискальные регистраторы VikiPrint" 
		ИЛИ НаименованиеОбработчикаДрайвера = "АТОЛ:ККТ с передачей данных в ОФД (54-ФЗ) 9.Х"
		ИЛИ НаименованиеОбработчикаДрайвера = "АТОЛ:ККТ с передачей данных в ОФД (54-ФЗ) 10.Х"
		ИЛИ НаименованиеОбработчикаДрайвера = "Дримкас: драйвер VikiPrint для 1С с ОФД и ЕГАИС"
		ИЛИ НаименованиеОбработчикаДрайвера = "RightScan:Терминалы сбора данных (ПО RS:Mobile ACS)" 
		ИЛИ НаименованиеОбработчикаДрайвера = "Дримкас:ККТ с передачей данных в ОФД Вики Принт (54-ФЗ)" 
		ИЛИ НаименованиеОбработчикаДрайвера = "Версия-Т:ККТ K1-Ф с передачей данных в ОФД (54-ФЗ)" 
		ИЛИ НаименованиеОбработчикаДрайвера = "АТОЛ:Терминалы сбора данных MobileLogistics 8.Х" 
		ИЛИ НаименованиеОбработчикаДрайвера = "MSTAR:ККТ с передачей данных в ОФД (54-ФЗ)" 
		ИЛИ НаименованиеОбработчикаДрайвера = "Инкотекс:ККТ с передачей данных в ОФД (54-ФЗ)" Тогда
		
		НаименованиеФормыНастройки = "ФормаНастройкиУниверсальныйДрайвер";
	КонецЕсли;
	
	Возврат НаименованиеФормыНастройки;

КонецФункции

