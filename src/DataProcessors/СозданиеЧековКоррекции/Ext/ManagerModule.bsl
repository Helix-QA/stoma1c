	ТаблицаИдентификаторов			= ПакетЗапроса[8 + 2].Выгрузить();
	ТаблицаДанных					= ПакетЗапроса[9 + 2].Выгрузить();
	ТаблицаДанныеФискальныхОпераций	= ПакетЗапроса[10 + 2].Выгрузить();
	ТаблицаДатаРасчетов 			= ПакетЗапроса[11 + 2].Выгрузить();
	ТаблицаУчтенныеАвансы 			= ПакетЗапроса[12 + 2].Выгрузить();
	
	Результат = Новый Массив;	
	
	Для Каждого СтрокаИдентификатор Из ТаблицаИдентификаторов Цикл
		МассивСтрокТаблицыДанных = ТаблицаДанных.НайтиСтроки(Новый Структура("ИдентификаторЗаписи", СтрокаИдентификатор.ИдентификаторЗаписи));
		
		СтруктураРезультата = Новый Структура;
		СтруктураРезультата.Вставить("ИдентификаторЗаписи"		, СтрокаИдентификатор.ИдентификаторЗаписи);
		
		ТаблицаДанныеФискальныхОперацийВременная = ТаблицаДанныеФискальныхОпераций.НайтиСтроки(Новый Структура("ИдентификаторЗаписи", СтрокаИдентификатор.ИдентификаторЗаписи));
		
		ФискальнаяОперация = Неопределено;
		
		Если ТаблицаДанныеФискальныхОперацийВременная.Количество() > 0 Тогда
			
			Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЧекКоррекции") Тогда
				РеквизитыОснования = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОснование, "НеприменениеККТ, ДокументРасчетов"); 			
				Если РеквизитыОснования.НеприменениеККТ Тогда
					ДокументРасчетов = ДокументОснование;
				Иначе
					ДокументРасчетов = РеквизитыОснования.ДокументРасчетов;
				КонецЕсли;    			
			Иначе          			
				ДокументРасчетов = ДокументОснование; 			
			КонецЕсли;    
			
			ФискальнаяОперация = Новый Структура;
			ФискальнаяОперация.Вставить("ФискальныйПризнак");
			ФискальнаяОперация.Вставить("Организация");
			ФискальнаяОперация.Вставить("ДокументОснование");
			ФискальнаяОперация.Вставить("СтруктурнаяЕдиница");
			ФискальнаяОперация.Вставить("ТипРасчета");
			ФискальнаяОперация.Вставить("ДанныеXML");
			ФискальнаяОперация.Вставить("ЕстьКорректирующийДокумент");
			
			ФискальнаяОперация.Вставить("ЧекКоррекции");   	
			ФискальнаяОперация.Вставить("ЧекКоррекцииПробитЧек");   	
			ФискальнаяОперация.Вставить("ЧекКоррекцииНомерЧекаККМ"); 
			
			ФискальнаяОперация.Вставить("ЧекКоррекцииСторно");   	
			ФискальнаяОперация.Вставить("ЧекКоррекцииСторноНомерЧекаККМ");   	
			ФискальнаяОперация.Вставить("ЧекКоррекцииСторноПробитЧек");   	
			
			ФискальнаяОперация.Вставить("ОплатаПредоплата");
			ФискальнаяОперация.Вставить("ОплатаНаличные");
			ФискальнаяОперация.Вставить("ОплатаЭлектронно");
			ФискальнаяОперация.Вставить("ОплатаПостоплата"); 
			ФискальнаяОперация.Вставить("ОплатаВстречноеПредоставление");   
			ФискальнаяОперация.Вставить("Сумма");            
			ФискальнаяОперация.Вставить("НомерЧекаККМ");    
			ФискальнаяОперация.Вставить("ПолнаяПостоплата");
			
			ЗаполнитьЗначенияСвойств(ФискальнаяОперация, ТаблицаДанныеФискальныхОперацийВременная[0]);
			ФискальнаяОперация.ПолнаяПостоплата = Истина;
			
			РеквизитыДокументаОснования = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ФискальнаяОперация.ДокументОснование, "СтруктурнаяЕдиница");
			РеквизитыДокументаОснования.Вставить("Организация", РеквизитыДокументаОснования.СтруктурнаяЕдиница.Организация);
			ЗаполнитьЗначенияСвойств(ФискальнаяОперация, РеквизитыДокументаОснования);
			
			ТаблицаДатаРасчетовВременная = ТаблицаДатаРасчетов.НайтиСтроки(Новый Структура("ИдентификаторЗаписи", СтрокаИдентификатор.ИдентификаторЗаписи));
			ФискальнаяОперация.Вставить("ДатаРасчета"		, ?(ТаблицаДатаРасчетовВременная.Количество() > 0, ТаблицаДатаРасчетовВременная[0].ДатаРасчетов, Неопределено));
			ФискальнаяОперация.Вставить("ДокументРасчетов"	, ДокументРасчетов);
			
			ФискальнаяОперация.Вставить("МассивОснований");
			МассивОснований = Новый Массив;
			Для Каждого ЭлементМ Из МассивСтрокТаблицыДанных Цикл
				СтруктураДанных = Новый Структура;
				СтруктураДанных.Вставить("ДокументОснование", ЭлементМ.ДокументОснование);
				СтруктураДанных.Вставить("ПолнаяПостоплата"	, ЭлементМ.ПолнаяПостоплата);
				МассивОснований.Добавить(СтруктураДанных);
			КонецЦикла;  			
			ФискальнаяОперация.МассивОснований = МассивОснований;
			
			// учтенные авансы
			МассивУчтенныеАвансы = Новый Массив;			
			МассивСтрокУчтенныеАвансы = ТаблицаУчтенныеАвансы.НайтиСтроки(Новый Структура("ИдентификаторЗаписи", СтрокаИдентификатор.ИдентификаторЗаписи));
			Для Каждого ЭлементМ Из МассивСтрокУчтенныеАвансы Цикл
				СтруктураДанных = Новый Структура("Аванс, ДатаПлатежа, СуммаАванса, ИдентификаторЗаписи");
				ЗаполнитьЗначенияСвойств(СтруктураДанных, ЭлементМ);
				МассивУчтенныеАвансы.Добавить(СтруктураДанных);	
			КонецЦикла;
			ФискальнаяОперация.Вставить("МассивУчтенныеАвансы", МассивУчтенныеАвансы);			
			
		КонецЕсли;    
		
		СтруктураРезультата.Вставить("ДанныеФискальнойОперации", ФискальнаяОперация);
		
		Результат.Добавить(СтруктураРезультата);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Функция создает чек коррекции сторно.
//
Функция ЧекКоррекцииСторно(Контекст)
	
	Результат = Новый Структура("ЧекКоррекцииСторно, ЧекПроведен");
	
	ЧекОбъект 	= Документы.ЧекКоррекции.СоздатьДокумент();
	ЧекПроведен = Ложь;
	
	ОбщиеПараметры = МенеджерОборудованияВызовСервера.ЗагрузитьДанныеФискализацииИзXML(Контекст.ДанныеXMLКорректируемогоЧека);
	
	ЗаполнитьЗначенияСвойств(ЧекОбъект, Контекст, "Дата,
												 | ДатаКоррекции,
												 | ДокументРасчетов, 
												 | ДополнительныйРеквизит,
												 | Касса,
												 | НомерПредписания,
												 | ОписаниеКоррекции,
												 | Организация,
												 | СтруктурнаяЕдиница,
												 | АвторДокумента,
												 | ТипКоррекции,
												 | Комментарий,
												 | Кассир,
												 | КассирИНН");
	
	ЗаполнитьЗначенияСвойств(ЧекОбъект, ОбщиеПараметры, "
													   | ПокупательEmail,
													   | ПокупательНомер,
													   | ПризнакАгента,
													   | СистемаНалогообложения");
	
	Для Каждого СтрокаТЗ Из Контекст.ТаблицаОснований Цикл
		ЗаполнитьЗначенияСвойств(ЧекОбъект.ТаблицаОснований.Добавить(), СтрокаТЗ);
	КонецЦикла;

	ЧекОбъект.ЭтоСторно		= Истина;
	ЧекОбъект.Покупатель 	= Контекст.Контрагент;
	Если ТипЗнч(Контекст.Контрагент) = Тип("СправочникСсылка.Контрагенты")
		И ЗначениеЗаполнено(Контекст.Контрагент) Тогда
		ЧекОбъект.ПокупательИНН = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Контекст.Контрагент, "ИНН");
	КонецЕсли;
	ЧекОбъект.ТипРасчета 	= ТипРасчетаСторно(ОбщиеПараметры.ТипРасчета);
	Если ЧекОбъект.ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств Или 
		ЧекОбъект.ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.РасходДенежныхСредств Тогда
		ЧекОбъект.ВидОперации = "Возврат"; // Перечисления.ВидыОперацийЧекККМ.Возврат;
	Иначе
		ЧекОбъект.ВидОперации = "Продажа"; // Перечисления.ВидыОперацийЧекККМ.Продажа;
	КонецЕсли;
	
	// Основание = Контекст.ДокументОснование;
	
	ЗаполнитьПозицииЧекаПоОбщимПараметрам(ЧекОбъект, ОбщиеПараметры.ПозицииЧека);
	
	// Оплаты
	Для Каждого СтрокаОплаты Из ОбщиеПараметры.ТаблицаОплат Цикл
		ЗаполнитьЗначенияСвойств(ЧекОбъект.Оплата.Добавить(), СтрокаОплаты); 
	КонецЦикла;
	
	// Запись чека
	Попытка
		ЧекОбъект.Записать(РежимЗаписиДокумента.Запись);
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		СтрокаОшибки = НСтр("ru = 'Не удалось записать чек коррекции сторно по причине:'") + Символы.ПС + ОписаниеОшибки;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаОшибки);
		Возврат Неопределено;
	КонецПопытки;
	
	// Потом чек проводится
	Попытка
		Если ЧекОбъект.ПроверитьЗаполнение() Тогда
			ЧекОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
			ЧекПроведен = Истина;
		Иначе
			СтрокаОшибки = НСтр("ru = 'Не удалось провести чек коррекции сторно по причине проверки заполнения'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаОшибки);
		КонецЕсли;
	Исключение
		СтрокаОшибки = НСтр("ru = 'Не удалось провести чек коррекции сторно по причине:'") + Символы.ПС + ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаОшибки);
	КонецПопытки;
	
	Результат.ЧекКоррекцииСторно 	= ЧекОбъект.Ссылка;
	Результат.ЧекПроведен 			= ЧекПроведен;
	
	Возврат Результат;
	
КонецФункции

// Функция создает чек коррекции.
//
Функция ЧекКоррекции(Контекст)
	
	Результат = Новый Структура("ЧекСкорректированный, ЧекПроведен");
	
	ЧекОбъект 	= Документы.ЧекКоррекции.СоздатьДокумент();
	ЧекПроведен = Ложь;
	
	ЗаполнитьЗначенияСвойств(ЧекОбъект, Контекст);
		
	ЧекОбъект.Покупатель 	= Контекст.Контрагент;
	ЧекОбъект.ПокупательИНН = Контекст.КонтрагентИНН;
	
	Если ЧекОбъект.ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств
		ИЛИ ЧекОбъект.ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.РасходДенежныхСредств Тогда
		ЧекОбъект.ВидОперации = "Возврат";// Перечисления.ВидыОперацийЧекККМ.Возврат;
	Иначе
		ЧекОбъект.ВидОперации = "Продажа";// Перечисления.ВидыОперацийЧекККМ.Продажа;
	КонецЕсли;
	
	// основания
	Для Каждого СтрокаТЗ Из Контекст.ТаблицаОснований Цикл
		ЗаполнитьЗначенияСвойств(ЧекОбъект.ТаблицаОснований.Добавить(), СтрокаТЗ);
	КонецЦикла;
	
	// Позиции чека
	Для Каждого ПозицияЧека Из Контекст.ПозицииЧека Цикл  		
		ЗаполнитьЗначенияСвойств(ЧекОбъект.ПозицииЧека.Добавить(), ПозицияЧека);		
	КонецЦикла;
		
	// Оплаты
	Для Каждого СтрокаОплаты Из Контекст.Оплата Цикл      		
		ЗаполнитьЗначенияСвойств(ЧекОбъект.Оплата.Добавить(), СтрокаОплаты);   		
	КонецЦикла;
	
	// Запись чека
	Попытка
		ЧекОбъект.Записать(РежимЗаписиДокумента.Запись);
	Исключение
		ОписаниеОшибки	= ОписаниеОшибки();
		СтрокаОшибки	= НСтр("ru = 'Не удалось записать чек коррекции сторно по причине:'") + Символы.ПС + ОписаниеОшибки;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаОшибки);
		Возврат Неопределено;
	КонецПопытки;
	
	// Потом чек проводится
	Попытка
		Если ЧекОбъект.ПроверитьЗаполнение() Тогда
			ЧекОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
			ЧекПроведен = Истина;
		Иначе
			СтрокаОшибки = НСтр("ru = 'Не удалось провести чек коррекции по причине проверки заполнения'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаОшибки);
		КонецЕсли;
	Исключение
		СтрокаОшибки = НСтр("ru = 'Не удалось провести чек коррекции по причине:'") + Символы.ПС + ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаОшибки);
	КонецПопытки;
	
	Результат.ЧекСкорректированный 	= ЧекОбъект.Ссылка;
	Результат.ЧекПроведен 			= ЧекПроведен;
	
	Возврат Результат;
	
КонецФункции

// Функция - возвращает тип расчета сторно.
//
Функция ТипРасчетаСторно(ТипРасчета)
	
	Если ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.ПриходДенежныхСредств Тогда
		Возврат Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств
	ИначеЕсли ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств Тогда
		Возврат Перечисления.ТипыРасчетаДенежнымиСредствами.ПриходДенежныхСредств
	ИначеЕсли ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.РасходДенежныхСредств Тогда
		Возврат Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратРасходаДенежныхСредств
	ИначеЕсли ТипРасчета = Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратРасходаДенежныхСредств Тогда
		Возврат Перечисления.ТипыРасчетаДенежнымиСредствами.РасходДенежныхСредств
	КонецЕсли;
	
КонецФункции

// Процедура заполняет позиции чека согласно общим параметрам.
//
Процедура ЗаполнитьПозицииЧекаПоОбщимПараметрам(ЧекОбъект, ОбщиеПараметрыПозицииЧека)
	
	Для Каждого СтрокаПозицииЧека Из ОбщиеПараметрыПозицииЧека Цикл    		
		НоваяСтрока = ЧекОбъект.ПозицииЧека.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПозицииЧека);
		
		НоваяСтрока.ДанныеПоставщикаИНН				= СтрокаПозицииЧека.ДанныеПоставщика.ИНН;
		НоваяСтрока.ДанныеПоставщикаНаименование	= СтрокаПозицииЧека.ДанныеПоставщика.Наименование;
		НоваяСтрока.ДанныеПоставщикаТелефон			= СтрокаПозицииЧека.ДанныеПоставщика.Телефон;
		
		НоваяСтрока.НаименованиеПредметаРасчета		= СтрокаПозицииЧека.Наименование;
		НоваяСтрока.СуммаСоСкидками					= СтрокаПозицииЧека.Сумма;
		НоваяСтрока.СтавкаНДС						= ПолучитьСтавкуНДСПоЗначениюСтавки(СтрокаПозицииЧека.СтавкаНДС);   		
	КонецЦикла;
	
КонецПроцедуры     

// Функция получает структуру данных.
//
Функция ПолучитьСтруктуруДанных()
	
	Структура = Новый Структура;
	Структура.Вставить("АвторДокумента");
	Структура.Вставить("АдресЭП");
	Структура.Вставить("ДанныеXMLКорректируемогоЧека");
	Структура.Вставить("Дата");
	Структура.Вставить("ДатаКоррекции");
	Структура.Вставить("ДокументРасчетов");
	Структура.Вставить("ДополнительныйРеквизит");
	Структура.Вставить("Касса");
	Структура.Вставить("Кассир");
	Структура.Вставить("КассирИНН");
	Структура.Вставить("Комментарий");
	Структура.Вставить("Контрагент");
	Структура.Вставить("КонтрагентИНН");
	Структура.Вставить("НомерПредписания");
	Структура.Вставить("ОписаниеКоррекции");
	Структура.Вставить("Организация");
