	ЭтоНарядЗаказ = ТипЗнч(ДокументОбъект.Ссылка) = Тип("ДокументСсылка.НарядЗаказ");

	СтрокаОбъединение = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|";	
	
	СтрокаРазделение = "
	|
	|;
	|///////////////////////////////////////////
	|";   	
	
	СтрокаПоместить = "	
	|ПОМЕСТИТЬ ТаблицаТовары
	|";	 
	
	МассивТекст = Новый Массив;
	
	// добавляем во временные таблицы. 	
	Если ТаблицаЗапасов <> Неопределено Тогда
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаЗапасы.НомерСтроки,
		|	ТаблицаЗапасы.Номенклатура,
		|	ТаблицаЗапасы.КоличествоУпаковок,
		|	ТаблицаЗапасы.Упаковка,
		|	ТаблицаЗапасы.Количество,
		|	ТаблицаЗапасы.ВидЦен,"
		+ ?(ЭтоНарядЗаказ = Истина, 
			" ТаблицаЗапасы.ЦенаПродажи КАК Цена,", 
			" ТаблицаЗапасы.Цена КАК Цена,")	
		+ ?(ЭтоНарядЗаказ = Истина, 
			" ТаблицаЗапасы.СуммаПродажи КАК Сумма", 
			" ТаблицаЗапасы.Сумма КАК Сумма")	
		+ "
		|ПОМЕСТИТЬ ТаблицаЗапасы
		|ИЗ
		|	&ТаблицаЗапасы КАК ТаблицаЗапасы";	
		
		МассивТекст.Добавить(Текст);
	КонецЕсли;
	
	Если ТаблицаЛечения <> Неопределено Тогда
		
		Если ТаблицаЗапасов <> Неопределено Тогда
			МассивТекст.Добавить(СтрокаРазделение);
		КонецЕсли;             		
		
		Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
		|	ТаблицаЛечения.НомерСтроки,
		|	ТаблицаЛечения.Номенклатура,"
		+ ?(ЕстьКолонкаКоличествоУпаковокТЧЛечение = Истина, 
			" ТаблицаЛечения.КоличествоУпаковок КАК КоличествоУпаковок,", 
			" ТаблицаЛечения.Количество КАК КоличествоУпаковок,")	
		+ "
		|	ТаблицаЛечения.Упаковка,
		|	ТаблицаЛечения.Количество,
		|	ТаблицаЛечения.ВидЦен,
		|	ТаблицаЛечения.Цена,
		|	ТаблицаЛечения.Сумма 
		|ПОМЕСТИТЬ ТаблицаЛечения
		|ИЗ
		|	&ТаблицаЛечения КАК ТаблицаЛечения";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;
	
	Если ТаблицаУслуг <> Неопределено Тогда
		
		Если ТаблицаЗапасов <> Неопределено 
			Или ТаблицаЛечения <> Неопределено Тогда
			
			МассивТекст.Добавить(СтрокаРазделение);
		КонецЕсли;     
		
		Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаУслуг.НомерСтроки,
		|	ТаблицаУслуг.Номенклатура,
