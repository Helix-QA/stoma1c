	ПарамФормы = Новый Структура("ДатаДня,ИнтервалыРаботы", СтрокаДанных.Дата, СтрокаДанных.ИнтервалыРаботы);
	Оповещение = Новый ОписаниеОповещения("ПолеВремя_ОкончаниеВыбора", ЭтотОбъект, Новый Структура("СтрокаДанных", СтрокаДанных));
	ОткрытьФорму("Обработка.ПланированиеИндивидуальногоГрафика.Форма.ФормаПодбораИнтерваловВремени",ПарамФормы, ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
