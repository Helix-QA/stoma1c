// Сформировать план занятий на сервере
// 
Процедура ОбновитьОтображениеПланирования(ПерезаполнитьБуфер, Сотрудник = Неопределено, МассивИзмененныхДней = Неопределено)
	
	//Helix = ЗащитаСервер.СоздатьОбъект("Helix");
	//Helix.ОбновитьОтображениеПланирования(ПерезаполнитьБуфер, Сотрудник, МассивИзмененныхДней, ЭтаФорма); 
	
	СформироватьТекстПериода();
		
