&НаКлиенте
Процедура Ответить(Команда)
	
	Если не СофтФон  = Неопределено и СофтФон.LineRegister() Тогда 		
		НайденныеСтроки = АктивныеВходящиеЗвонки.НайтиСтроки(Новый Структура("ИдОтображаемогоЭлемента", "1"));
		Если НайденныеСтроки.Количество() > 0 Тогда						
			Если СофтФон.HelixSetCurrentCall(НайденныеСтроки[0].Ид) Тогда				
				Если Элементы.Ответить1.Заголовок = "Ответить" Тогда
					 СофтФон.HelixCall();
					 Элементы.Ответить1.Картинка = Элементы.КартинкаПереадресация.Картинка;
					 Элементы.Ответить1.Заголовок = "Переадр";
				 Иначе
					 ПоказатьВводСтроки(Новый ОписаниеОповещения("ОтветитьЗавершение", ЭтотОбъект), "", "Введите номер тефона");
				 КонецЕсли;                                               							 
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;	
	
