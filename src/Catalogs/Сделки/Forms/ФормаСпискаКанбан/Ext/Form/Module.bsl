КонецФункции

&НаКлиенте
// Процедура - ОткрытиеФильтровЗавершение.
//
Процедура ОткрытиеФильтровЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытиеФильтровНаСервере(Результат);
	
КонецПроцедуры

&НаСервере
// Процедура - ОткрытиеФильтровНаСервере.
//
Процедура ОткрытиеФильтровНаСервере(Результат)
	
	ПараметрыОтбора = ПолучитьИзВременногоХранилища(Результат);
	ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора, Истина);	
	
	// Сбрасываем фильтр по задачам после изменения фильтра.
	УстановитьОтображениеФильтровПоЗадачам(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить свойства разделов фильтра.
//
// Параметры:
//  АктуализироватьФлаги - 	 - 
//
Процедура ОбновитьСвойстваРазделовФильтра(АктуализироватьФлаги = Ложь, ИмяСтраницыЗначенийФильтра = Неопределено) Экспорт
	
	Если ИмяСтраницыЗначенийФильтра <> Неопределено Тогда 
		Элементы.СтраницыЗначенийФильтров.ТекущаяСтраница = Элементы[ИмяСтраницыЗначенийФильтра];
	КонецЕсли;		
	УправлениеИнтерфейсамиСервер.ОбновитьСвойстваРазделовФильтра(ЭтаФорма, АктуализироватьФлаги);
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить группу значений фильтра.
//
// Параметры:
//  ИдентификаторСтрокиФильтра	 - 	 - 
//
Процедура ОбновитьГруппуЗначенийФильтра(ИдентификаторСтрокиФильтра, ИнициализироватьВыбранноеЗначение = Ложь, ВыбранноеЗначение = Неопределено) Экспорт
	
	СтрокаФильтра = ТаблицаФильтров.НайтиПоИдентификатору(ИдентификаторСтрокиФильтра);
	УправлениеИнтерфейсамиСервер.ОбновитьГруппуЗначенийФильтра(ЭтаФорма, СтрокаФильтра, ИнициализироватьВыбранноеЗначение, ВыбранноеЗначение);
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить свойства элемента значения.
//
// Параметры:
//  ДанныеЭлементаФильтрации - 	 - 
//
Процедура ОбновитьСвойстваЭлементаЗначения(ДанныеЭлементаФильтрации) Экспорт
	
	УправлениеИнтерфейсамиСервер.ОбновитьСвойстваЭлементаЗначения(ЭтаФорма, , , ДанныеЭлементаФильтрации);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор стандартного периода.
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборСтандартногоПериода(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если НЕ РезультатВыбора = Неопределено И НЕ ДополнительныеПараметры = Неопределено Тогда
		ЭлементВариантСтандартногоПериода = ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы].НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторФильтра).СписокЗначений[0].Значение.СписокСтандартныхПериодов.НайтиПоЗначению(РезультатВыбора.Значение);
		Если НЕ ЭлементВариантСтандартногоПериода = Неопределено Тогда
			ДополнительныеПараметры.Вставить("ИдентификаторЗначения", ЭлементВариантСтандартногоПериода.ПолучитьИдентификатор());
			ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы].НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторФильтра).СписокЗначений[0].Значение.СписокСтандартныхПериодов.ЗаполнитьПометки(Ложь);
			ЭлементВариантСтандартногоПериода.Пометка = Истина;
			РезультатОбновления = УправлениеИнтерфейсамиКлиент.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, "УстановитьСтандартныйПериод_ЗначениеФильтра_Идентификатор_" + ДополнительныеПараметры.ИдентификаторФильтра, ДополнительныеПараметры);
		КонецЕсли;	
	КонецЕсли;	

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Процедура, устанавливает заголовки дополнительных отборов.
//
Процедура УстановитьЗаголовкиДополнительныхОтборов(Форма, СтруктураОтбора, ДанныеКоличества = Неопределено)
	
	Если ДанныеКоличества = Неопределено Тогда
		ДанныеКоличества = ПолучитьКоличествоСделокПоДополнительнымОтборам(СтруктураОтбора);
	КонецЕсли;
	
	ЦветРамкиНаличиеЗадач	 = Новый Цвет(208, 53, 86);
	ЦветРамкиОтсутствиеЗадач = Новый Цвет(160, 160, 160);
	
	ЦветТекстаНаличиеЗадач		 = Новый Цвет(208, 53, 86);
	ЦветТекстаОтсутствиеЗадач	 = Новый Цвет(77, 77, 77);
	
	КоличествоБезАктивности = ДанныеКоличества.КоличествоБезАктивности;
	
	Форма.БезЗадачКоличество				 	 = КоличествоБезАктивности;
	Форма.Элементы.БезЗадачКоличество.Ширина 	 = СтрДлина(КоличествоБезАктивности) / 2 + 1;
	Форма.Элементы.БезЗадачКоличество.ЦветРамки	 = ?(КоличествоБезАктивности = 0, ЦветРамкиОтсутствиеЗадач, ЦветРамкиНаличиеЗадач);
	Форма.Элементы.БезЗадачКоличество.ЦветТекста = ?(КоличествоБезАктивности = 0, ЦветТекстаОтсутствиеЗадач, ЦветТекстаНаличиеЗадач);
	
	КоличествоПросроченныхЗадач = ДанныеКоличества.КоличествоПросроченныхЗадач;
	
	Форма.ПросроченныеЗадачиКоличество						 = КоличествоПросроченныхЗадач;
	Форма.Элементы.ПросроченныеЗадачиКоличество.Ширина		 = СтрДлина(КоличествоПросроченныхЗадач) / 2 + 1;
	Форма.Элементы.ПросроченныеЗадачиКоличество.ЦветРамки	 = ?(КоличествоПросроченныхЗадач = 0, ЦветРамкиОтсутствиеЗадач, ЦветРамкиНаличиеЗадач);
	Форма.Элементы.ПросроченныеЗадачиКоличество.ЦветТекста	 = ?(КоличествоПросроченныхЗадач = 0, ЦветТекстаОтсутствиеЗадач, ЦветТекстаНаличиеЗадач);
	
	КоличествоСЗадачамиНаСегодня = ДанныеКоличества.КоличествоСЗадачамиНаСегодня;
	
	Форма.ЗадачиНаСегодняКоличество						 = КоличествоСЗадачамиНаСегодня;
	Форма.Элементы.ЗадачиНаСегодняКоличество.Ширина		 = СтрДлина(КоличествоСЗадачамиНаСегодня) / 2 + 1;
	Форма.Элементы.ЗадачиНаСегодняКоличество.ЦветРамки	 = ?(КоличествоСЗадачамиНаСегодня = 0, ЦветРамкиОтсутствиеЗадач, ЦветРамкиНаличиеЗадач);
	Форма.Элементы.ЗадачиНаСегодняКоличество.ЦветТекста	 = ?(КоличествоСЗадачамиНаСегодня = 0, ЦветТекстаОтсутствиеЗадач, ЦветТекстаНаличиеЗадач);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает количество сделок в дополнительных отборах "кол-во без сделок" и "кол-во с просроченными задачами".
//
Функция ПолучитьКоличествоСделокПоДополнительнымОтборам(СтруктураОтборов)
	
	СписокМенеджеров = СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения();
	Если НЕ ЗначениеЗаполнено(СписокМенеджеров) Тогда
		 СписокМенеджеров = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения.ВыгрузитьЗначения();
	КонецЕсли;
	
	СписокКлиник = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения();
	Если НЕ ЗначениеЗаполнено(СписокКлиник) Тогда
		СписокКлиник = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.ВыгрузитьЗначения();
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЭтапыСделок.Ссылка КАК ЭтапСделки
	|ПОМЕСТИТЬ ЭтапыСделок
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ВидСделки В(&ВидСделки)
	|	И НЕ ЭтапыСделок.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ИмяПредопределенныхДанных = ""Отказ""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ИмяПредопределенныхДанных = ""Успех""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Ссылка КАК Сделка
	|ПОМЕСТИТЬ ТаблицаСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЭтапыСделок КАК ЭтапыСделок
	|		ПО Сделки.ЭтапСделки = ЭтапыСделок.ЭтапСделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Сделки.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	Сделки.ВидСделки = &ВидСделки
	|	И ВЫБОР
	|			КОГДА &СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КонтрагентыСведенияДляСписка.Статус = &СтатусПациента
	|		КОНЕЦ
	|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
	|	И Сделки.СтруктурнаяЕдиница В(&СписокКлиник)
	|	И Сделки.Менеджер В(&СписокМенеджеров)
	|	И Сделки.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(СделкиСведенияДляСписка.Сделка) КАК КоличествоБезАктивности
	|ИЗ
	|	РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|ГДЕ
	|	СделкиСведенияДляСписка.Сделка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Сделка
	|			ИЗ
	|				ТаблицаСделок)
	|	И СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	|	И СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Сделка КАК Сделка,
	|	СделкиСведенияДляСписка.ЗапланированнаяЗадача КАК ЗапланированнаяЗадача
	|ПОМЕСТИТЬ СделкиЗапланированнаяЗадача
	|ИЗ
	|	ТаблицаСделок КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|		ПО Сделки.Сделка = СделкиСведенияДляСписка.Сделка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СделкиЗапланированнаяЗадача.Сделка КАК Ссылка,
	|	СделкиЗапланированнаяЗадача.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата
	|ПОМЕСТИТЬ СделкиЗадачаНазначеннаяДата
	|ИЗ
	|	СделкиЗапланированнаяЗадача КАК СделкиЗапланированнаяЗадача
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(СделкиЗадачаНазначеннаяДата.Ссылка) КАК КоличествоПросроченныхЗадач
	|ИЗ
	|	СделкиЗадачаНазначеннаяДата КАК СделкиЗадачаНазначеннаяДата
	|ГДЕ
	|	СделкиЗадачаНазначеннаяДата.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(СделкиЗадачаНазначеннаяДата.Ссылка) КАК КоличествоЗадач
	|ИЗ
	|	СделкиЗадачаНазначеннаяДата КАК СделкиЗадачаНазначеннаяДата
	|ГДЕ
	|	СделкиЗадачаНазначеннаяДата.ЗадачаНазначеннаяДата МЕЖДУ &НачалоДня И &КонецДня";
	
	Запрос.УстановитьПараметр("СписокМенеджеров"					, СписокМенеджеров);
	Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"		, Дата(1,1,1));
	Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи"	, КонецДня(ТекущаяДатаСеанса() - 86400));
	Запрос.УстановитьПараметр("НачалоДня"							, НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("КонецДня"							, КонецДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("СписокКлиник"						, СписокКлиник);
	Запрос.УстановитьПараметр("ВидСделки"							, СтруктураОтборов.ВидСделки);
	Запрос.УстановитьПараметр("СтатусПациента"						, СтруктураОтборов.ОтборСтатусПациента);
	
	РезультатЗапроса 				   	= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваБезАктивности 		= РезультатЗапроса[2].Выбрать();	
	ВыборкаКоличествоПросроченныхЗадач 	= РезультатЗапроса[5].Выбрать();
	ВыборкаКоличествоЗадачиНаСегодня 	= РезультатЗапроса[6].Выбрать();
	
	ДанныеКоличества = Новый Структура;
	ДанныеКоличества.Вставить("КоличествоБезАктивности", ?(ВыборкаКоличестваБезАктивности.Следующий(), ВыборкаКоличестваБезАктивности.КоличествоБезАктивности, 0));
	ДанныеКоличества.Вставить("КоличествоПросроченныхЗадач", ?(ВыборкаКоличествоПросроченныхЗадач.Следующий(), ВыборкаКоличествоПросроченныхЗадач.КоличествоПросроченныхЗадач, 0));
	ДанныеКоличества.Вставить("КоличествоСЗадачамиНаСегодня", ?(ВыборкаКоличествоЗадачиНаСегодня.Следующий(), ВыборкаКоличествоЗадачиНаСегодня.КоличествоЗадач, 0));
	
	Возврат ДанныеКоличества;
	
КонецФункции

#КонецОбласти

#КонецОбласти

&НаКлиентеНаСервереБезКонтекста
// Возвращает значение свойства структуры.
//
// Параметры:
//   Структура - Структура
//             - ФиксированнаяСтруктура - объект, из которого необходимо прочитать значение ключа.
//   Ключ - Строка - имя свойства структуры, для которого необходимо прочитать значение.
//   ЗначениеПоУмолчанию - Произвольный - необязательный. Возвращается когда в структуре нет значения по указанному
//                                        ключу.
//       Для скорости рекомендуется передавать только быстро вычисляемые значения (например примитивные типы),
//       а инициализацию более тяжелых значений выполнять после проверки полученного значения (только если это
//       требуется).
//
// Возвращаемое значение:
//   Произвольный - значение свойства структуры. ЗначениеПоУмолчанию если в структуре нет указанного свойства.
//
Функция СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено)
	
	Возврат ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию);
	
КонецФункции

#КонецОбласти
