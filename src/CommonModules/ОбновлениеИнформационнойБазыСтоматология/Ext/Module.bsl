// Процедура - Перенести реквизиты в договоры контрагентов
//
Процедура ПеренестиРеквизитыВДоговорыКонтрагентов() Экспорт 

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Контрагент,
		|	Контрагенты.ДатаДоговора_Удалить КАК ДатаДоговора,
		|	Контрагенты.НомерДоговора_Удалить КАК НомерДоговора,
		|	Контрагенты.СтраховаяКоманияСегментУслугПоСогласованию_Удалить КАК СтраховаяКоманияСегментУслугПоСогласованию,
		|	Контрагенты.СегментНоменклатуры_Удалить КАК СегментНоменклатуры,
		|	Контрагенты.ВидЦен_Удалить КАК ВидЦен
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ТипКонтрагента <> ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		|	И НЕ Контрагенты.ЭтоГруппа
		|	И НЕ Контрагенты.ПометкаУдаления";

	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		
		Договор 					  = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
		Договор.Контрагент 			  = Выборка.Контрагент;
		Договор.НомерДоговора 		  = Выборка.НомерДоговора;
		Договор.ДатаДоговора 		  = ?(ЗначениеЗаполнено(Выборка.ДатаДоговора), Выборка.ДатаДоговора, ТекущаяДатаСеанса());
		Договор.УслугиПоСогласованию  = Выборка.СтраховаяКоманияСегментУслугПоСогласованию;
		Договор.УслугиБезСогласования = Выборка.СегментНоменклатуры;
		Договор.ВидЦен 				  = Выборка.ВидЦен;
		Договор.НомерДоговора         = "1";
		
		ТекстНаименования = НСтр("ru = 'Основной Договор № %НомерДоговора% от %ДатаДоговора% c %Контрагент%'");   
		ТекстНаименования = СтрЗаменить(ТекстНаименования, "%НомерДоговора%", СокрЛП(Договор.НомерДоговора));
		ТекстНаименования = СтрЗаменить(ТекстНаименования, "%ДатаДоговора%", ?(ЗначениеЗаполнено(Договор.ДатаДоговора), 
		СокрЛП(Строка(Формат(Договор.ДатаДоговора, "ДФ=dd.MM.yyyy"))), ""));
		ТекстНаименования = СтрЗаменить(ТекстНаименования, "%Контрагент%", СокрЛП(Договор.Контрагент));
		
		Договор.Наименование = ТекстНаименования;
		
		Договор.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

