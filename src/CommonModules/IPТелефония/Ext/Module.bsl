////// / MANGO ////// /

// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_ТестированиеСервера(Сервер, Порт, КодПродукта, Ключ, ОписаниеОшибки = "") Экспорт
	
	СтруктураПараметров = Новый Структура;
	
	СтруктураПараметров.Вставить("date_from" , "1072915200");
	СтруктураПараметров.Вставить("date_to"	 , "1072997812");
	СтруктураПараметров.Вставить("call_party", Новый Структура("number", "74956496783"));
	СтруктураПараметров.Вставить("request_id", "Test_Connection");
	
	JSONText = КодироватьВJSON(СтруктураПараметров, Ложь);
	MSXMLЗапрос = "vpbx_api_key=" + КодПродукта + "&"
					+ "sign=" + SHA256(КодПродукта + JSONText + Ключ) + "&"
					+ "json=" + JSONText;
	
	СайтАдрес = ПреобразоватьАдресСервера(Сервер);
	
	Попытка

		Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		HTTPЗапрос = Новый HTTPЗапрос("/vpbx/stats/request", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
		
		// Отправка POST-запроса и получение ответа.
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда
				ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
				ОписаниеОшибки = ОписаниеОшибки + " (" + ПараметрыJSON.Message + ")";
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - MANGO событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_СобытиеЗвонок(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= ПараметрыJSON.entry_id;
	УнифицированнаяСтруктураСобытия.IDПлеча 					= ПараметрыJSON.call_id;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Ложь;
	
	УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= ?(ПараметрыJSON.From.Свойство("extension") И ЗначениеЗаполнено(ПараметрыJSON.From.Extension), ПараметрыJSON.From.Extension, ПараметрыJSON.From.Number);
	УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= ?(ПараметрыJSON.To.Свойство("extension"), ПараметрыJSON.To.Extension, ПараметрыJSON.To.Number);
	
	Если ПараметрыJSON.call_state = "Appeared" ИЛИ ПараметрыJSON.call_state = "Connected" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= ?(НЕ (ПараметрыJSON.from.Свойство("extension") И ПараметрыJSON.to.Свойство("number")), Перечисления.ВариантыНаправленияВызова.Входящий, Перечисления.ВариантыНаправленияВызова.Исходящий);
	Иначе
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= ?(НЕ (ПараметрыJSON.Свойство("command_id") И ПараметрыJSON.command_id = "OutgoingCall" ИЛИ ПараметрыJSON.From.Свойство("extension") И НЕ ПараметрыJSON.To.Свойство("extension")), Перечисления.ВариантыНаправленияВызова.Входящий, Перечисления.ВариантыНаправленияВызова.Исходящий);
	КонецЕсли;
	
	// ПризнакВходящийЗвонок = НЕ (НРег(ПараметрыJSON.location) = "abonent" И ПараметрыJSON.call_state = "Appeared" И ПараметрыJSON.from.Свойство("extension") И ПараметрыJSON.to.Свойство("number"));
	
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= (ПараметрыJSON.Свойство("disconnect_reason") И
							  	 (СтрЗаменить(ПараметрыJSON.Disconnect_Reason," ","") = 1100 ИЛИ СтрЗаменить(ПараметрыJSON.Disconnect_Reason," ","") = 1131));
	Иначе 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;						
	КонецЕсли;
	
	//// Временно для дебага	
	// Если НЕ СтрНайти(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom, "sip:") = 0 ИЛИ НЕ СтрНайти(УнифицированнаяСтруктураСобытия.НомерТелефонаTo, "sip:") = 0 Тогда 
	// 	а = 0;
	// КонецЕсли;	
	
	// Если было перенаправление вызова - то находим первоначальный номер
	Если ПараметрыJSON.Свойство("taken_from_call_id") Тогда
		СтрокаТЗЗвонка = РегистрыСведений.ИсторияВызовов.ПолучитьПоIDЗвонка(ПараметрыJSON.taken_from_call_id);
		Если СтрокаТЗЗвонка <> Неопределено Тогда
			УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = СтрокаТЗЗвонка.НомерТелефона;
		КонецЕсли;
	КонецЕсли;
	
	Если ПараметрыJSON.Свойство("Call_State") = Ложь
			ИЛИ ПараметрыJSON.Свойство("Call_State") И ПараметрыJSON.Call_State = "OnHold"
			ИЛИ ПараметрыJSON.Свойство("Location") И ПараметрыJSON.Location = "ivr" И ПараметрыJSON.Call_State <> "Appeared"
			ИЛИ ПараметрыJSON.From.Свойство("extension") = Ложь И ПараметрыJSON.Свойство("command_id") И ПараметрыJSON.command_id = "OutgoingCall" Тогда
		Возврат Истина;
	
	ИначеЕсли ПараметрыJSON.Свойство("Location") Тогда 
		
		Если ПараметрыJSON.Call_State = "Appeared" И (НРег(ПараметрыJSON.location) = "queue" ИЛИ НРег(ПараметрыJSON.location) = "abonent") И ПараметрыJSON.To.Свойство("acd_group") И ЗначениеЗаполнено(ПараметрыJSON.To.acd_group) И УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда   // очередь дозвона на группу
			СтруктураЛичныйМенеджер = Ложь;// IPТелефония.ПолучитьЛичногоМенеджераДляПереадресации(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom, ОписаниеОшибки);
			Если СтруктураЛичныйМенеджер <> Ложь Тогда
				MANGO_ПереадресацияЗвонка(ПОIPТелефонии, ПараметрыJSON.call_id, "", ОписаниеОшибки);
				// MANGO_ПереадресацияЗвонка(ПОIPТелефонии, ПараметрыJSON.call_id, СтруктураЛичныйМенеджер.InternalNumberGroup, ОписаниеОшибки);
				Возврат Истина;
			ИначеЕсли ПараметрыJSON.Call_State = "Appeared" И НРег(ПараметрыJSON.location) = "abonent" Тогда
				УнифицированнаяСтруктураСобытия.СтатусЗвонка 			= Перечисления.СтатусыЗвонка.Вызов;							
				УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 	= МестноеВремя(Дата(1970, 01, 01) + ПараметрыJSON.timestamp, ПолучитьЧасовойПоясИнформационнойБазы());
				Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
			Иначе
				Возврат Истина;
			КонецЕсли;
			
		ИначеЕсли ПараметрыJSON.Call_State = "Appeared" И НРег(ПараметрыJSON.location) = "abonent" Тогда
			
			УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= Перечисления.СтатусыЗвонка.Вызов;			
			УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 		= МестноеВремя(Дата(1970, 01, 01) + ПараметрыJSON.timestamp, ПолучитьЧасовойПоясИнформационнойБазы());
			Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
			
		ИначеЕсли ПараметрыJSON.Call_State = "Connected" И НРег(ПараметрыJSON.location) = "abonent" Тогда
			
			УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= Перечисления.СтатусыЗвонка.Разговор;
			УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 			= МестноеВремя(Дата(1970, 01, 01) + ПараметрыJSON.timestamp, ПолучитьЧасовойПоясИнформационнойБазы());			
			Возврат СобытиеЗвонокСоединение(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
			
		ИначеЕсли ПараметрыJSON.Call_State = "Disconnected" И НРег(ПараметрыJSON.location) = "abonent" Тогда
			
			УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= ?(УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий И УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен, Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.Завершен);
			УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова		= МестноеВремя(Дата(1970, 01, 01) + ПараметрыJSON.timestamp, ПолучитьЧасовойПоясИнформационнойБазы());
			УнифицированнаяСтруктураСобытия.ПринятДругимАбонентомГруппы = УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий И ПараметрыJSON.Свойство("disconnect_reason") И СтрЗаменить(ПараметрыJSON.Disconnect_Reason," ","") = 1100;
			
			Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
			
		Иначе
			ОписаниеОшибки = "Функция не существует или не распознана.'";
			Возврат Истина;
			
		КонецЕсли;
	Иначе 
		ОписаниеОшибки = "Не передан ключевой параметр ""Location"".'";
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

// Функция - MANGO событие завершение звонка
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_СобытиеЗавершениеЗвонка(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= ПараметрыJSON.entry_id;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Истина;

	// Определяем направление вызова
	Если ПараметрыJSON.call_direction = 0 Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Внутренний;
	ИначеЕсли ПараметрыJSON.call_direction = 1 Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Входящий;
	ИначеЕсли ПараметрыJSON.call_direction = 2 Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Исходящий;
	Иначе 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= ?(ПараметрыJSON.From.Свойство("extension"), Перечисления.ВариантыНаправленияВызова.Исходящий, Перечисления.ВариантыНаправленияВызова.Входящий);
	КонецЕсли;	
	
	// Определяем результат вызова
	ПризнакЗвонокПропущен 	= Ложь;			
	Если ПараметрыJSON.entry_result = 0 Тогда 
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 			= Ложь;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка			= ?(УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий, Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.НеДозвон);
	ИначеЕсли ПараметрыJSON.entry_result = 1 Тогда 
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 			= Истина;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка			= Перечисления.СтатусыЗвонка.Завершен;		
	КонецЕсли;	
	
	// УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= ?(ПараметрыJSON.From.Свойство("extension") И ЗначениеЗаполнено(ПараметрыJSON.From.Extension), ПараметрыJSON.From.Extension, ПараметрыJSON.From.Number);
	// УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= ?(ПараметрыJSON.To.Свойство("extension"), ПараметрыJSON.To.Extension, ПараметрыJSON.To.Number);
	
	FromExtension 	= ?(ПараметрыJSON.From.Свойство("extension"), ПараметрыJSON.From.Extension	, "");
	FromNumber 		= ?(ПараметрыJSON.From.Свойство("Number")	, ПараметрыJSON.From.Number		, "");
	ToExtension 	= ?(ПараметрыJSON.To.Свойство("extension")	, ПараметрыJSON.To.Extension	, "");
	ToNumber 		= ?(ПараметрыJSON.To.Свойство("Number")		, ПараметрыJSON.To.Number		, "");
	
	Если ЗначениеЗаполнено(FromExtension) Тогда 
		Если СтрНайти(FromExtension, "sip:") = 0 Тогда 
			УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = FromExtension;
		ИначеЕсли ЗначениеЗаполнено(FromNumber) Тогда 
			УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = FromNumber;
		Иначе 
			УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = FromExtension;
		КонецЕсли;	
	Иначе 
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = FromNumber;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ToExtension) Тогда 
		Если СтрНайти(ToExtension, "sip:") = 0 Тогда 
			УнифицированнаяСтруктураСобытия.НомерТелефонаTo = ToExtension;
		ИначеЕсли ЗначениеЗаполнено(ToNumber) Тогда 
			УнифицированнаяСтруктураСобытия.НомерТелефонаTo = ToNumber;
		Иначе 
			УнифицированнаяСтруктураСобытия.НомерТелефонаTo = ToExtension;
		КонецЕсли;	
	Иначе 
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo = ToNumber;
	КонецЕсли;
	
	// Определяем время поступления вызова
	Если ПараметрыJSON.Свойство("create_time") Тогда 
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова = МестноеВремя(Дата(1970, 01, 01) + ПараметрыJSON.create_time, ПолучитьЧасовойПоясИнформационнойБазы());
	КонецЕсли;
	
	// Определяем время ответа на вызов (Если в звонке не состоялся разговор, то равно нулю)
	Если ПараметрыJSON.Свойство("talk_time") Тогда
		Если ПараметрыJSON.talk_time = 0 ИЛИ ПризнакЗвонокПропущен = Истина Тогда 
			УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 	= Неопределено;
		Иначе 	
			УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 	= МестноеВремя(Дата(1970, 01, 01) + ПараметрыJSON.talk_time, ПолучитьЧасовойПоясИнформационнойБазы());
		КонецЕсли;	
	КонецЕсли;
	
	// Определяем  время завершения всего разговора
	Если ПараметрыJSON.Свойство("end_time") Тогда 
		УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова 	= МестноеВремя(Дата(1970, 01, 01) + ПараметрыJSON.end_time, ПолучитьЧасовойПоясИнформационнойБазы());
	КонецЕсли;
	
	//// Временно для дебага
	// Если НЕ СтрНайти(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom, "sip:") = 0 ИЛИ НЕ СтрНайти(УнифицированнаяСтруктураСобытия.НомерТелефонаTo, "sip:") = 0 Тогда 
	// 	а = 0;
	// КонецЕсли;	
	
	Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
			
	
КонецФункции

// Функция - MANGO событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	Результат = Истина;
	ФайлСсылка = Неопределено;
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	Если ПараметрыJSON.Свойство("Recording_State") И ПараметрыJSON.Recording_State <> "Completed" Тогда
		Возврат Результат;
	КонецЕсли;
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= ПараметрыJSON.entry_id;
	УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка 		= IPТелефонияПараметры.Сервер + "/queries/recording/issa/" + ПараметрыJSON.Recording_ID + "/play";
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Ложь;
		
	ДобавитьОбновитьЗвонокВИсторию(ПараметрыJSON, УнифицированнаяСтруктураСобытия);
	
	Возврат Результат;
	
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_ИсходящийЗвонокОсуществить(ПОIPТелефонии, ВнутреннийНомерТелефона, ВнешнийНомерТелефона, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("КодПродукта")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("command_id", "OutgoingCall");
	СтруктураПараметров.Вставить("from"		 , Новый Структура("extension", ВнутреннийНомерТелефона));
	СтруктураПараметров.Вставить("to_number" , ВнешнийНомерТелефона);
	
	JSONText 	= КодироватьВJSON(СтруктураПараметров, Ложь);
	MSXMLЗапрос = ПолучитьJSONСтрокуЗапроса(IPТелефонияПараметры, JSONText);
	СайтАдрес 	= ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
	
	Попытка
			   		
		Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		HTTPЗапрос = Новый HTTPЗапрос("/vpbx/commands/callback", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
		
		// Отправка POST-запроса и получение ответа.
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ОтветHTTP 		= СтруктураОтвета.ПолучитьТелоКакСтроку();
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			
			Если ОтветHTTP <> "" Тогда
				ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
				ОписаниеОшибки = ОписаниеОшибки + " : " + ПараметрыJSON.Message;
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
		ПараметрыJSON = ДекодироватьИзJSON(ОтветHTTP);
		Если ПараметрыJSON.result <> 1000 Тогда
		    ОписаниеОшибки = "Ошибка при выполнении операции сервиса IP-телефонии: " + ПараметрыJSON.result;
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_ПереадресацияЗвонка(ПОIPТелефонии, IDЗвонка, НаНомерТелефона, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("КодПродукта")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура("call_id, to_number", IDЗвонка, НаНомерТелефона);
	
	JSONText 	= КодироватьВJSON(СтруктураПараметров, Ложь);
	MSXMLЗапрос = ПолучитьJSONСтрокуЗапроса(IPТелефонияПараметры, JSONText);
	СайтАдрес 	= ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
	
	Попытка
		
		Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		HTTPЗапрос = Новый HTTPЗапрос("/vpbx/commands/route", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
		
		// Отправка POST-запроса и получение ответа.
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ОтветHTTP 		= СтруктураОтвета.ПолучитьТелоКакСтроку();
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии " + СтруктураОтвета.КодСостояния;
			
			Если ОтветHTTP <> "" Тогда
				ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
				ОписаниеОшибки = ОписаниеОшибки + " : " + ПараметрыJSON.Message;
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
		ПараметрыJSON = ДекодироватьИзJSON(ОтветHTTP);
		Если ОтветHTTP.result <> 1000 Тогда
		    ОписаниеОшибки = "Ошибка при выполнении операции сервиса IP-телефонии: " + ПараметрыJSON.result;
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - MANGO перевод текущего звонка
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  IDПлеча			 - 	 - 
//  СНомерТелефона	 - 	 - 
//  НаНомерТелефона	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_ПереводТекущегоЗвонка(ПОIPТелефонии, IDПлеча, СНомерТелефона, НаНомерТелефона, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	Если IPТелефонияПараметры = Неопределено ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
			ИЛИ IPТелефонияПараметры.Свойство("Сервер") = Ложь ИЛИ IPТелефонияПараметры.Свойство("КодПродукта") = Ложь ИЛИ IPТелефонияПараметры.Свойство("Ключ") = Ложь Тогда
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура("call_id, method, to_number, initiator", IDПлеча, "blind", НаНомерТелефона, СНомерТелефона);
	JSONText = КодироватьВJSON(СтруктураПараметров, Ложь);
	MSXMLЗапрос = "vpbx_api_key=" + IPТелефонияПараметры.КодПродукта + "&"
					+ "sign=" + SHA256(IPТелефонияПараметры.КодПродукта + JSONText + IPТелефонияПараметры.Ключ, "SHA_low_case") + "&"
					+ "json=" + JSONText;
	
	Попытка
			   
	   НомерШага = 1; // Создание КОМ объекта для отправки запроса
		MSXML = Новый COMОбъект("MSXML2.ServerXMLHTTP"); 
		MSXML.open("POST", IPТелефонияПараметры.Сервер + "/commands/transfer", 0);
		MSXML.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
		MSXML.setRequestHeader("Content-Charset", "utf-8");
		MSXML.setRequestHeader("outputencoding", "utf-8");
		
	   НомерШага = 2; // Отправка XML запроса на сервер и получение ответа
	    MSXML.send(MSXMLЗапрос);
		Если MSXML.status <> 200 Тогда
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии " + MSXML.status + " - " + MSXML.statusText;
			Если MSXML.responseText <> "" Тогда
				ПараметрыJSON = ДекодироватьИзJSON(MSXML.responseText);
				ОписаниеОшибки = ОписаниеОшибки + " : " + ПараметрыJSON.Message;
			КонецЕсли;
			Возврат Ложь;
		КонецЕсли;	

	   НомерШага = 3; // Разбор XML ответа	
		MSXMLОтвет = ДекодироватьИзJSON(MSXML.ResponseText);
		Если MSXMLОтвет.result <> 1000 Тогда
			ОписаниеОшибки = "Ошибка при выполнении операции сервиса IP-телефонии: " + MSXMLОтвет.result;
			Возврат Ложь;
		КонецЕсли; 
				
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
		
	Возврат Истина;
	
КонецФункции

// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_ПолучениеФайлаЗаписиРазговора(ПОIPТелефонии, IDЗаписи, ОписаниеОшибки = "", СтруктураПереадресации = Неопределено) Экспорт
	
	АдресВоВременномХранилище = "";
	               
	Если СтруктураПереадресации = Неопределено Тогда // 1 запрос
		IPТелефонияПараметры 		= ПОIPТелефонии.Параметры.Получить();
		СтруктураПараметров 		= Новый Структура("recording_id, action", IDЗаписи, "download");
		JSONText 					= КодироватьВJSON(СтруктураПараметров, Ложь);
		
		MSXMLЗапрос 				= "vpbx_api_key=" + IPТелефонияПараметры.КодПродукта + "&"
									+ "sign=" + SHA256(IPТелефонияПараметры.КодПродукта + JSONText + IPТелефонияПараметры.Ключ) + "&"
									+ "json=" + JSONText;
		
		СайтАдрес 					= ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
		
		Попытка
			HTTP_Соединение 		= Новый HTTPСоединение(СайтАдрес,,,,,, Новый ЗащищенноеСоединениеOpenSSL());		
			HTTP_Запрос 			= Новый HTTPЗапрос("/vpbx/queries/recording/post", ПолучитьЗаголовкиPOSTЗапроса());
			HTTP_Запрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
			
			// Отправка POST-запроса и получение ответа
			СтруктураОтвета 		= HTTP_Соединение.ОтправитьДляОбработки(HTTP_Запрос);
		Исключение
			ИнформацияОбОшибке 		= ИнформацияОбОшибке();
			ОписаниеОшибки 			= ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
			Возврат Неопределено;
		КонецПопытки;
	Иначе                                          // запрос после переадресации
		АдресПереадресации 			= СтруктураПереадресации.СтруктураОтвета.Заголовки.Получить("Location"); // https://files.mango-office.ru/storage/api/1831ed2f38ca96f884797ee2fec18835
		Если АдресПереадресации = Неопределено Тогда
			ОписаниеОшибки 			= ВернутьОписаниеОшибки(СтруктураПереадресации.СтруктураОтвета, НСтр("ru = 'Ошибка переадресации. Сервер не сообщил адрес ресурса!'"));
			Возврат Неопределено;
		Иначе 	
			СтруктураURI 			= ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресПереадресации);
			Попытка
				HTTP_Соединение 	= Новый HTTPСоединение(СтруктураURI.Хост,,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
				HTTP_Запрос 		= Новый HTTPЗапрос(СтруктураURI.ПутьНаСервере);
				// HTTP_Запрос.УстановитьТелоИзСтроки(СтруктураПереадресации.MSXMLЗапрос);
				
				// Отправка GET-запроса и получение ответа
				СтруктураОтвета 	= HTTP_Соединение.Получить(HTTP_Запрос);
			Исключение
				ИнформацияОбОшибке 	= ИнформацияОбОшибке();
				ОписаниеОшибки 		= ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
				Возврат Неопределено;
			КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
	Если СтруктураОтвета.КодСостояния >= 400 И СтруктураОтвета.КодСостояния < 600  Тогда
		ОписаниеОшибки = ВернутьОписаниеОшибки(СтруктураОтвета);
		Возврат Неопределено;
	ИначеЕсли СтруктураОтвета.КодСостояния = 301 ИЛИ СтруктураОтвета.КодСостояния = 302 Тогда  // перенаправление
		Если НЕ СтруктураПереадресации = Неопределено И СтруктураПереадресации.КоличествоПеренаправлений > 20 Тогда
			ОписаниеОшибки = ВернутьОписаниеОшибки(СтруктураОтвета, НСтр("ru = 'Ошибка переадресации. Обнаружена циклическая переадресация.'"));
			Возврат Неопределено;			
		КонецЕсли;		
		НоваяСтруктураПереадресации = Новый Структура;
		НоваяСтруктураПереадресации.Вставить("СайтАдрес"					, СайтАдрес);
		НоваяСтруктураПереадресации.Вставить("MSXMLЗапрос"					, MSXMLЗапрос);
		НоваяСтруктураПереадресации.Вставить("СтруктураОтвета"				, СтруктураОтвета);
		НоваяСтруктураПереадресации.Вставить("КоличествоПеренаправлений"	, ?(СтруктураПереадресации = Неопределено, 1, СтруктураПереадресации.КоличествоПеренаправлений + 1));
		Возврат MANGO_ПолучениеФайлаЗаписиРазговора(ПОIPТелефонии, IDЗаписи, ОписаниеОшибки = "", НоваяСтруктураПереадресации)
	ИначеЕсли СтруктураОтвета.КодСостояния = 200 Тогда 
		ДвоичныеДанныеФайла = СтруктураОтвета.ПолучитьТелоКакДвоичныеДанные();
		АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла);
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат АдресВоВременномХранилище;
	
КонецФункции

// Процедура - Коллтрекинг mango
// 
Процедура MANGO_Коллтрекинг(Дата) Экспорт
	
	Попытка
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ПодключаемоеОборудование.Параметры КАК Параметры
		|ИЗ
		|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
		|ГДЕ
		|	ПодключаемоеОборудование.УстройствоИспользуется
		|	И НЕ ПодключаемоеОборудование.ПометкаУдаления
		|	И ПодключаемоеОборудование.ДрайверОборудования.ИмяПредопределенныхДанных = ""ДрайверХеликсMANGO""";
		
		Результат = Запрос.Выполнить();
		Если Результат.Пустой() Тогда
			Возврат;
		КонецЕсли; 
		
		Выборка = Результат.Выбрать();
		Если Выборка.Следующий() Тогда
			
			Параметры = Выборка.Параметры.Получить();
			Если Не Параметры.Свойство("ИспользоватьКоллтрекинг") Или Не Параметры.ИспользоватьКоллтрекинг Тогда
				Возврат;
			КонецЕсли; 
			
		КонецЕсли; 
		
		КоллтрекингАдресСервера = СтрЗаменить(Параметры.КоллтрекингАдресСервера, "https://", "");
		КоллтрекингНомерВиджета = Параметры.КоллтрекингНомерВиджета;
		КоллтрекингToken        = Параметры.КоллтрекингToken;
		
		ДатаНачала    = НачалоДня(Дата);
		ДатаОкончания = КонецДня(Дата);
		dateStart  = Формат(ДатаНачала   , "ДФ=yyyy-MM-ddTHH:mmZ");
		dateEnd    = Формат(ДатаОкончания, "ДФ=yyyy-MM-ddTHH:mmZ");

		ЗапросHTTP = "v1/calltracking/"+ КоллтрекингНомерВиджета + "/calls?dateStart=" + dateStart + "&dateEnd=" 
		+  dateEnd + "&access_token=" + КоллтрекингToken;
		
		Соединение = Новый HTTPСоединение(КоллтрекингАдресСервера,,,,,, Новый ЗащищенноеСоединениеOpenSSL);
		
		HTTPЗапрос = Новый HTTPЗапрос(ЗапросHTTP);
		ВозвращаемыйРезультат = Соединение.Получить(HTTPЗапрос);	        
		
		ТекстJSON = ВозвращаемыйРезультат.ПолучитьТелоКакСтроку();	
		Результат = ДекодироватьИзJSON(ТекстJSON);
		
		Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("message") Тогда		
			ЗаписьЖурналаРегистрации("КоллтрекингMango", УровеньЖурналаРегистрации.Ошибка,,, Результат.message);
			Возврат;
		ИначеЕсли ТипЗнч(Результат) <> Тип("Массив") Тогда
			ЗаписьЖурналаРегистрации("КоллтрекингMango", УровеньЖурналаРегистрации.Ошибка,,, "Неверный формат ответа");
			Возврат;
		КонецЕсли;	
		
		Если Результат.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;	
		
		ТаблицаДанных = Новый ТаблицаЗначений;
		ТаблицаДанных.Колонки.Добавить("НомерТелефона");
		ТаблицаДанных.Колонки.Добавить("РекламныйИсточникСтрока");
		
		Для Каждого ДанныеСтруктура Из Результат Цикл
			
			Если ДанныеСтруктура.callType = 2 Тогда  // исходящие
				 Продолжить;
			КонецЕсли;

			РекламныйИсточникСтрока = ДанныеСтруктура.utmSource;
			НомерТелефона           = Число(ДанныеСтруктура.callerNumber);
			НомерТелефона           = Формат(НомерТелефона, "ЧГ=0");
			Если ЗначениеЗаполнено(РекламныйИсточникСтрока) И РекламныйИсточникСтрока <> "(undefined)" Тогда
				
				НоваяСтрока                         = ТаблицаДанных.Добавить();
				НоваяСтрока.НомерТелефона           = НомерТелефона;
				НоваяСтрока.РекламныйИсточникСтрока = РекламныйИсточникСтрока;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СтрокаТЧ Из ТаблицаДанных Цикл
			
			Запрос       = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ИсторияВызовов.ОборудованиеТелефонии КАК ОборудованиеТелефонии,
			|	ИсторияВызовов.IDЗвонка КАК IDЗвонка,
			|	ИсторияВызовов.Визит КАК Визит
			|ИЗ
			|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
			|ГДЕ
			|	ИсторияВызовов.НомерТелефона = &НомерТелефона
			|	И ИсторияВызовов.НачалоВызова >= &ДатаНачала
			|	И ИсторияВызовов.НачалоВызова <= &ДатаОкончания
			|	И НЕ ИсторияВызовов.ИсходящийЗвонок";
			
			Запрос.УстановитьПараметр("НомерТелефона", СтрокаТЧ.НомерТелефона);
			Запрос.УстановитьПараметр("ДатаНачала"   , ДатаНачала);
			Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				
				НаборЗаписей = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ОборудованиеТелефонии.Установить(Выборка.ОборудованиеТелефонии);
				НаборЗаписей.Отбор.IDЗвонка.Установить(Выборка.IDЗвонка);	
				НаборЗаписей.Прочитать();
				Визит = Неопределено;
				Для Каждого Запись Из НаборЗаписей Цикл
					
					РекламныйИсточник        = ПолучитьРекламныйИсточник(СтрокаТЧ.РекламныйИсточникСтрока);
					Запись.РекламныйИсточник = РекламныйИсточник;
					Визит                    = Запись.Визит;
					
				КонецЦикла;
				НаборЗаписей.Записать();   
				
				Если Не ЗначениеЗаполнено(Визит) Тогда
					Продолжить;
				КонецЕсли;
				
				ВизитОбъект                   = Визит.ПолучитьОбъект();
				ВизитОбъект.РекламныйИсточник = РекламныйИсточник;
				ВизитОбъект.Записать();
			
			КонецЦикла;
			
		КонецЦикла;
			
	Исключение
		
		ЗаписьЖурналаРегистрации("КоллтрекингMango", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
		
	КонецПопытки;
	
КонецПроцедуры

// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция MANGO_ТестированиеКоллтрекинга(КоллтрекингАдресСервера, КоллтрекингToken, КоллтрекингНомерВиджета, ОписаниеОшибки = "") Экспорт
	
	Попытка
		
		dateStart  = Формат(НачалоДня(ТекущаяДата()), "ДФ=yyyy-MM-ddTHH:mmZ");
		dateEnd    = Формат(КонецДня(ТекущаяДата()), "ДФ=yyyy-MM-ddTHH:mmZ");
		ЗапросHTTP = "v1/calltracking/"+ КоллтрекингНомерВиджета + "/calls?dateStart=" + dateStart + "&dateEnd=" 
		+  dateEnd + "&access_token=" + КоллтрекингToken;
		
		Соединение = Новый HTTPСоединение(КоллтрекингАдресСервера,,,,,, Новый ЗащищенноеСоединениеOpenSSL);
		
		HTTPЗапрос = Новый HTTPЗапрос(ЗапросHTTP);
		Результат = Соединение.Получить(HTTPЗапрос);	        
		
		Если Результат.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса коллтрекинг IP-телефонии: " + Результат.КодСостояния;
			ОтветHTTP      = Результат.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда
				ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
				ОписаниеОшибки = ОписаниеОшибки + " (" + ПараметрыJSON.Message + ")";
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки     = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " 
			+ ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - Получить рекламный источник
// 
Функция ПолучитьРекламныйИсточник(РекламныйИсточникСтрока)
	
	РекламныйИсточник = Справочники.РекламныеИсточники.НайтиПоНаименованию(РекламныйИсточникСтрока);
	
	Если Не ЗначениеЗаполнено(РекламныйИсточник) Тогда
		НовыйРекламныйИсточник              = Справочники.РекламныеИсточники.СоздатьЭлемент();
		НовыйРекламныйИсточник.Наименование = РекламныйИсточникСтрока;
		НовыйРекламныйИсточник.Записать();
		РекламныйИсточник = НовыйРекламныйИсточник.Ссылка;
	КонецЕсли;

	Возврат РекламныйИсточник;
	
КонецФункции

#КонецОбласти

#Область _________________________ITOOLABS__________________________

////// / ITOOLABS ////// /

// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ITOOLABS_ТестированиеСервера(Сервер, Порт, Ключ, ОписаниеОшибки = "") Экспорт	
	 		
	MSXMLЗапрос = "cmd=accounts"
	+ "&token=" + Ключ;
	
	Попытка
		
		СайтАдрес = ПреобразоватьАдресСервера(Сервер);
		
		Если СтрНайти(Сервер, "https://") = 1 Тогда  
			Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Иначе 
			Соединение = Новый HTTPСоединение(СайтАдрес, 80);
		КонецЕсли;		
		HTTPЗапрос = Новый HTTPЗапрос("/sys/crm_api.wcgp", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда
				ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
				ОписаниеОшибки = ОписаниеОшибки + ?(ПараметрыJSON.Свойство("message"), " (" + ПараметрыJSON.message + ")", "");
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ITOOLABS_СобытиеЗвонок(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 						  = ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 			  = ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 				  = ПараметрыJSON.callid;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 	  = Ложь;
	
	УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 		  = ?(ЗначениеЗаполнено(ПараметрыJSON.phone) И ПараметрыJSON.phone <> "null", ПараметрыJSON.phone, Неопределено); 
	УнифицированнаяСтруктураСобытия.НомерТелефонаTo   		  = ?(ПараметрыJSON.Свойство("diversion"), ПараметрыJSON.diversion, Неопределено);
	УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника = ПараметрыJSON.ext;
	УнифицированнаяСтруктураСобытия.НомерКонтрагента 		  = ?(ЗначениеЗаполнено(ПараметрыJSON.phone) И ПараметрыJSON.phone <> "null", ПараметрыJSON.phone, Неопределено); 
	
	IPТелефонияПараметры 									  = ПОIPТелефонии.Параметры.Получить();
	ТелефонныйАппарат 										  = Справочники.ТелефонныеАппараты.ПолучитьТелефонныйАппаратПоНомеру(ПараметрыJSON.ext);
	
	УнифицированнаяСтруктураСобытия.СтруктурнаяЕдиница        = ?(ЗначениеЗаполнено(ТелефонныйАппарат), ТелефонныйАппарат.СтруктурнаяЕдиница, IPТелефонияПараметры.СтруктурнаяЕдиница);

	
	Если ВРег(ПараметрыJSON.type) = "INCOMING" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;		
	ИначеЕсли ВРег(ПараметрыJSON.type) = "OUTGOING" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий;
	КонецЕсли;
	
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова    = Перечисления.ВариантыНаправленияВызова.Входящий Тогда 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен = ВРег(ПараметрыJSON.type) = "CANCELLED";
	Иначе 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен = Ложь;						
	КонецЕсли; 		
		
	Если ВРег(ПараметрыJSON.type) = "INCOMING"
		ИЛИ ВРег(ПараметрыJSON.type) = "OUTGOING" Тогда
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 		   = Перечисления.СтатусыЗвонка.Вызов;							
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова = ТекущаяДатаСеанса();
		Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
		
	ИначеЕсли ВРег(ПараметрыJSON.type) = "ACCEPTED" Тогда
		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка       = Перечисления.СтатусыЗвонка.Разговор;
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов = ТекущаяДатаСеанса();			
		Возврат СобытиеЗвонокСоединение(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	ИначеЕсли ВРег(ПараметрыJSON.type) = "COMPLETED" Тогда
		
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 		  = Истина;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен = Ложь;	
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 		  = Перечисления.СтатусыЗвонка.Завершен;
		УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова = ТекущаяДатаСеанса();
		// УнифицированнаяСтруктураСобытия.ПринятДругимАбонентомГруппы = 
		Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	ИначеЕсли ВРег(ПараметрыJSON.type) = "CANCELLED" Тогда
		
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен         = Ложь;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка          = Перечисления.СтатусыЗвонка.Пропущен;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен = УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;
		Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки); 		
		
	Иначе
		ОписаниеОшибки = "Функция не существует или не распознана.'";
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

// Функция - событие завершение звонка
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ITOOLABS_СобытиеЗавершениеЗвонка(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= ПараметрыJSON.callid;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Истина;

	// Определяем направление вызова
	Если ПараметрыJSON.type = "INCOMING" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Входящий;
	ИначеЕсли ПараметрыJSON.type = "OUTGOING" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Исходящий;
	КонецЕсли;
	
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= ПараметрыJSON.type = "CANCELLED";
	Иначе 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;						
	КонецЕсли;	
	
	// Определяем результат вызова
	ПризнакЗвонокПропущен 	= Ложь;			
	Если ПараметрыJSON.type = "CANCELLED" Тогда 
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 			= Ложь;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка			= ?(УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий, Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.НеДозвон);
	ИначеЕсли ПараметрыJSON.type = "COMPLETED" Тогда 
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 			= Истина;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка			= Перечисления.СтатусыЗвонка.Завершен;		
	КонецЕсли;	
			
	Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);			
	
КонецФункции

// Функция - событие запись разговора
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ITOOLABS_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 					  = ПолучитьУнифицированнуюСтруктуруСобытия();
	ВремяОтветаНаВызов 									  = ПрочитатьДатуJSON(ПараметрыJSON.start, ФорматДатыJSON.ISO);
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 		  = ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 			  = ПараметрыJSON.callid;
	УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка  = ?(ПараметрыJSON.Свойство("link"), ПараметрыJSON.link, "");
	
	Если ПараметрыJSON.Свойство("status") И НРег(ПараметрыJSON.status) = "missed" Тогда 
		
		Если НРег(ПараметрыJSON.type) = "in" Тогда 
			УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;		
		Иначе
			УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий;
		КонецЕсли;
		
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен          = Ложь;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка           = Перечисления.СтатусыЗвонка.Пропущен;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен  = УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 	   = ПараметрыJSON.phone; 
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo		   = ПараметрыJSON.diversion;
		УнифицированнаяСтруктураСобытия.НомерКонтрагента	   = ПараметрыJSON.phone;
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова = ВремяОтветаНаВызов;
		УнифицированнаяСтруктураСобытия.ФинализирующееСобытие  = Истина
		
	Иначе
		
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов        = ВремяОтветаНаВызов;
		УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова     = ВремяОтветаНаВызов + ПараметрыJSON.duration;	
		УнифицированнаяСтруктураСобытия.ФинализирующееСобытие     = Ложь;
		
	КонецЕсли;
	
	ДобавитьОбновитьЗвонокВИсторию(ПараметрыJSON, УнифицированнаяСтруктураСобытия);
	
	Возврат Истина;
		
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ITOOLABS_ИсходящийЗвонокОсуществить(ПОIPТелефонии, ВнутреннийНомерТелефона, ВнешнийНомерТелефона, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	MSXMLЗапрос = "cmd=makeCall"
					+ "&phone="  + ВнешнийНомерТелефона 
					+ "&user="   + ВнутреннийНомерТелефона
					+ "&token="  + IPТелефонияПараметры.Ключ;
					
	Попытка
		
		СайтАдрес = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
		
		Если СтрНайти(IPТелефонияПараметры.Сервер, "https://") = 1 Тогда  
			Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Иначе 
			Соединение = Новый HTTPСоединение(СайтАдрес, 80);
		КонецЕсли;
		HTTPЗапрос = Новый HTTPЗапрос("/sys/crm_api.wcgp", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда
				ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
				ОписаниеОшибки = ОписаниеОшибки + " (" + ПараметрыJSON.error + ")";
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки; 
		
	Возврат Истина;
	
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ITOOLABS_ПереадресацияЗвонка(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	ОбязательныйПараметр = "phone";
	Если Не ПараметрыJSON.Свойство(ОбязательныйПараметр) Тогда				
		ОписаниеОшибки = СтрШаблон(НСтр("ru='Отсутствует обязательный параметр %1.'"), ОбязательныйПараметр);
	КонецЕсли;
	
	// СтруктураЛичныйМенеджер = IPТелефония.ПолучитьЛичногоМенеджераДляПереадресации(ПараметрыJSON.phone, ОписаниеОшибки);
	СтруктураЛичныйМенеджер = Неопределено;
	ЗаписьJSON = Неопределено;
	Если СтруктураЛичныйМенеджер <> Неопределено Тогда
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет));
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		
		ЗаписьJSON.ЗаписатьИмяСвойства("contact_name");
		ЗаписьJSON.ЗаписатьЗначение(СтруктураЛичныйМенеджер.Представление);
		
		Если СтруктураЛичныйМенеджер.Свойство("InternalNumberGroup") Тогда
			ЗаписьJSON.ЗаписатьИмяСвойства("responsible");
			ЗаписьJSON.ЗаписатьЗначение(СтруктураЛичныйМенеджер.InternalNumberGroup);
		КонецЕсли;
		
		ЗаписьJSON.ЗаписатьКонецОбъекта();
		ПараметрыОтвета = ЗаписьJSON.Закрыть();
		
	КонецЕсли;
	
	Ответ = Новый HTTPСервисОтвет(200);
	Если ЗаписьJSON <> Неопределено Тогда
		Ответ.УстановитьТелоИзСтроки(ПараметрыОтвета);
	КонецЕсли;	
	
	Возврат Ответ;
	
КонецФункции

