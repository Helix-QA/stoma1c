// Функция - Получить оборудивание телефонного аппарата
// 
// Параметры:
//  Номер	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьОборудиваниеТелефонногоАппарата(ВнутреннийНомер) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТелефонныеАппараты.Оборудование КАК Оборудование
	|ИЗ
	|	Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|ГДЕ
	|	НЕ ТелефонныеАппараты.ПометкаУдаления
	|	И ТелефонныеАппараты.ВнутреннийНомер = &ВнутреннийНомер");
	
	Запрос.УстановитьПараметр("ВнутреннийНомер", ВнутреннийНомер);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Оборудование");
	
	Возврат  ?(Результат.Количество() > 0, Результат[0], Справочники.ПодключаемоеОборудование.ПустаяСсылка());	
	
КонецФункции

// Функция - Получить список оборудования IPТелефонии
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокОборудованияIPТелефонии()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПодключаемоеОборудование.Ссылка КАК Ссылка,
	|	ПодключаемоеОборудование.ДрайверОборудования.ОбработчикДрайвера КАК ОбработчикДрайвера
	|ИЗ
	|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
	|ГДЕ
	|	ПодключаемоеОборудование.УстройствоИспользуется
	|	И ПодключаемоеОборудование.ТипОборудования = ЗНАЧЕНИЕ(Перечисление.ТипыПодключаемогоОборудования.IPТелефония)
	|	И НЕ ПодключаемоеОборудование.ПометкаУдаления");
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Сформировать массив номеров телефонов по контрагенту
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьМассивНомеровТелефоновПоКонтрагентуИлиТелефону(Контрагент = Неопределено, Знач НомерТелефона = Неопределено) Экспорт
	
	// Либо передаем контрагента и по нему формируется список телефонов, либо передаем НомерТелефона и формируем список по конкретному номеру
	
	МассивНомеровТелефонов = Новый Массив;
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыКонтактнаяИнформация.Представление КАК НомерТелефонаПредставление
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
		|	И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)");
		
		Запрос.УстановитьПараметр("Контрагент", Контрагент);    
		
		Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("НомерТелефонаПредставление");	
		
		Для Каждого НомерТелефона Из Результат Цикл  								
			ДобавитьНомераТелефоновВМассив(НомерТелефона, МассивНомеровТелефонов);			
		КонецЦикла;
		
	ИначеЕсли ЗначениеЗаполнено(НомерТелефона) Тогда		
		ДобавитьНомераТелефоновВМассив(НомерТелефона, МассивНомеровТелефонов, Истина);				
	КонецЕсли;
	
	Возврат МассивНомеровТелефонов;
	
КонецФункции

// Процедура - Добавить номера телефонов в массив
//
// Параметры:
//  НомерТелефона			 - 	 - 
//  МассивНомеровТелефонов	 - 	 - 
//
Процедура ДобавитьНомераТелефоновВМассив(НомерТелефона, МассивНомеровТелефонов, ПреобразоватьНомерТелефона = Ложь)
	
	МассивНомеровТелефонов.Добавить(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(НомерТелефона));
	
	Если ПреобразоватьНомерТелефона Тогда
		УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(НомерТелефона, Новый СписокЗначений);
	КонецЕсли;
	
	Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(СокрЛП(НомерТелефона), Перечисления.ТипыКонтактнойИнформации.Телефон);
	
	Если Объект_XDTO_Телефон <> Неопределено Тогда
		
		МассивНомеровТелефонов.Добавить(Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
		МассивНомеровТелефонов.Добавить(Объект_XDTO_Телефон.Представление);
		
		КодСтраны = Константы.СтранаУчета.Получить().Код;
		
		Если КодСтраны = "804" Тогда
			МассивНомеровТелефонов.Добавить("38"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			МассивНомеровТелефонов.Добавить("+38" + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
		ИначеЕсли КодСтраны = "051" Тогда
			МассивНомеровТелефонов.Добавить("374"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			МассивНомеровТелефонов.Добавить("+374" + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);	
		Иначе
			МассивНомеровТелефонов.Добавить("0"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			МассивНомеровТелефонов.Добавить("8"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			МассивНомеровТелефонов.Добавить("7"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			МассивНомеровТелефонов.Добавить("+7" + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Функция, преобразует строку в дату.
//
Функция ПолучитьДату(СтроковаяДата)
	
	Попытка
		
		СтроковаяДата = СтрЗаменить(СтроковаяДата , "-","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата , ":","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата , " ","");
		
		Возврат Дата(СтроковаяДата);
		
	Исключение
		Возврат Неопределено;		
	КонецПопытки;
	
КонецФункции

