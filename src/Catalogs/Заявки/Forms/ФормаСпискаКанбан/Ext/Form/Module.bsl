	|				<div class='client-name' id='" + ИдентификаторКлиента + "'>" + ПредставлениеКлиента + "</div>
	|				<div class='request-eval' title='" + ПредставлениеОценкиЗаявки + "'>" + ПредставлениеОценкиЗаявки + "</div>
	|				<div class='name'>" + НаименованиеЗаявки + "</div>" +
	БлокНомеров + "
	|				<div class='email'>" + АдресаЭП + "</div>
	|				<div class='deal' style='" + СтилиСделки + "' id='" + ИдентификаторСделки + "' title='" + ТекстПоляСделки + "'>" + ТекстПоляСделки + "</div>
	|				<div class='manager' id='" + ИдентификаторСотрудника + "'>" + ПредставлениеСотрудника + "</div>
	|				<div class='ad-source'>" + ПредставлениеРекламногоИсточника + "</div>
	|				<div class='channel'>" + ПредставлениеКаналаПривлечения + "</div>
	|				<div class='external-system'>" + ПредставлениеВнешнейСистемы + "</div>
	|				<div class='comment' title='" + Комментарий + "'>" + Комментарий + "</div>
	|			</div>";
	
	Возврат БлокЗаявки;
	
