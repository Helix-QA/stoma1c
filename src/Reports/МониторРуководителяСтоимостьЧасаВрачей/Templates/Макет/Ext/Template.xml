		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Прием.Ссылка КАК Прием,
	Прием.ВерсияДанных КАК ВерсияДанных,
	Прием.ПометкаУдаления КАК ПометкаУдаления,
	Прием.Номер КАК Номер,
	Прием.Дата КАК Дата,
	Прием.Проведен КАК Проведен,
	Прием.АвторДокумента КАК АвторДокумента,
	Прием.Ассистент КАК Ассистент,
	Прием.ВидНалога КАК ВидНалога,
	Прием.ВидЦен КАК ВидЦен,
	Прием.ВидыОплат КАК ВидыОплат,
	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
	Прием.ВремяОкончанияПриема КАК ВремяОкончанияПриема,
	Прием.ДокументОснование КАК ДокументОснование,
	Прием.Долговой КАК Долговой,
	Прием.ИзмененПослеОплаты КАК ИзмененПослеОплаты,
	Прием.ИнтервалПередПриемом КАК ИнтервалПередПриемом,
	Прием.КартаКонтрагента КАК КартаКонтрагента,
	Прием.Касса КАК Касса,
	Прием.КодСинхронизации КАК КодСинхронизации,
	Прием.Комментарий КАК Комментарий,
	Прием.Контрагент КАК Контрагент,
	Прием.КурсЛечения КАК КурсЛечения,
	Прием.ЛечениеВрача КАК ЛечениеВрача,
	Прием.Организация КАК Организация,
	Прием.ПовторныйПриемИнтервал КАК ПовторныйПриемИнтервал,
	Прием.ПовторныйПриемИспользовать КАК ПовторныйПриемИспользовать,
	Прием.ПолисМедСтрахования КАК ПолисМедСтрахования,
	Прием.ПредварительнаяЗаписьНаСледующийПрием КАК ПредварительнаяЗаписьНаСледующийПрием,
	Прием.ПрофосмотрИнтервал КАК ПрофосмотрИнтервал,
	Прием.ПрофосмотрИспользовать КАК ПрофосмотрИспользовать,
	Прием.ПроцентЗаполненияОбследования КАК ПроцентЗаполненияОбследования,
	Прием.РезультатПриема КАК РезультатПриема,
	Прием.Рекламация КАК Рекламация,
	Прием.РекламацияПрием КАК РекламацияПрием,
	Прием.Сделка КАК Сделка,
	Прием.Склад КАК Склад,
	Прием.Сотрудник КАК Врач,
	Прием.СтатусПациента КАК СтатусПациента,
	Прием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	Прием.СуммаДокумента КАК СуммаДокумента,
	Прием.СуммаОплачено КАК СуммаОплачено,
	Прием.ШаблонОбследования КАК ШаблонОбследования,
	Прием.ЭтоПервичныйПациентДляВрача КАК ЭтоПервичныйПациентДляВрача,
	Прием.Промокод КАК Промокод
ИЗ
	Документ.Прием КАК Прием
ГДЕ
	Прием.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
	И ВЫБОР
			КОГДА Прием.ВремяНачалаПриема = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА Прием.Дата
			ИНАЧЕ Прием.ВремяНачалаПриема
		КОНЕЦ МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И Прием.ПометкаУдаления = ЛОЖЬ
	И Прием.Проведен = ИСТИНА
	И Прием.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)</query>
