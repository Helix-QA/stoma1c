// Процедура - Установить цвет группы кнопки
//
Процедура УстановитьЦветГруппыКнопки()
	
	Если Элементы.День.Пометка Тогда 
		
		ГруппаКоманднойПанели          = Элементы.ГруппаКоманднаяПанельДни;
		
		Элементы.День.ЦветТекста       = ЭтотОбъект.ЦветаЭлементов.ЦветТекстаВыбранного;
		Элементы.ГруппаДень.ЦветФона   = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного;
		Элементы.Неделя.ЦветТекста     = ЭтотОбъект.ЦветаЭлементов.ЦветТекста;
		Элементы.ГруппаНеделя.ЦветФона = ЭтотОбъект.ЦветаЭлементов.ЦветФона;  
		
	Иначе
		
		ГруппаКоманднойПанели          = Элементы.ГруппаКоманднаяПанельНедели;
		
		Элементы.День.ЦветТекста       = ЭтотОбъект.ЦветаЭлементов.ЦветТекста;
		Элементы.ГруппаДень.ЦветФона   = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
		Элементы.Неделя.ЦветТекста     = ЭтотОбъект.ЦветаЭлементов.ЦветТекстаВыбранного;
		Элементы.ГруппаНеделя.ЦветФона = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного;
		
	КонецЕсли;
	
	Для Каждого Группа Из ГруппаКоманднойПанели.ПодчиненныеЭлементы Цикл
		
		Если Группа.ПодчиненныеЭлементы[0].Пометка Тогда 
			Группа.ЦветФона                          = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного; 
			Группа.ПодчиненныеЭлементы[0].ЦветТекста = ЭтотОбъект.ЦветаЭлементов.ЦветТекстаВыбранного;
		Иначе
			Группа.ЦветФона                          = ЭтотОбъект.ЦветаЭлементов.ЦветФона; 			
			Группа.ПодчиненныеЭлементы[0].ЦветТекста = ЭтотОбъект.ЦветаЭлементов.ЦветТекста;
		КонецЕсли;  		
		
	КонецЦикла;	
		
КонецПроцедуры

&НаСервере
// Процедура - Получить разрешение монитора клиента.
// 
Процедура ПолучитьРазрешениеМонитораКлиента()
		
	ЭкраныКлиента = ПолучитьИнформациюЭкрановКлиента();
	ЭтотОбъект.ИнформацияЭкранаКлиента = ?(ЭкраныКлиента <> Неопределено, ЭкраныКлиента[0], Неопределено);
	
	Если ЭтотОбъект.ИнформацияЭкранаКлиента <> Неопределено Тогда
		
		ШиринаЭкрана = ЭтотОбъект.ИнформацияЭкранаКлиента.Ширина;
		
		Если ШиринаЭкрана < 1920 Тогда
			
			МасштабФормы = (ШиринаЭкрана / 1920) * 1.2 * 100;
			ЭтаФорма.Масштаб = ?(МасштабФормы >= 80, МасштабФормы, 80);
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте 
// Процедура, Обработчик события "ОтборСотрудникНачалоВыбора"
//
Процедура ОтборСотрудникНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)  
	
	СтандартнаяОбработка = Ложь;  
	
	ДанныеВыбора = Новый СписокЗначений;
	ДанныеВыбора.Очистить();
	ДанныеВыбора.ЗагрузитьЗначения(ПолучитьМассивВрачейПоСпециализации(СпециализацияВрача));
	Если ЗначениеЗаполнено(СпециализацияВрача) Тогда
		ОткрытьФорму("Справочник.Сотрудники.Форма.ФормаВыбора", Новый Структура("Специализация", СпециализацияВрача), Элемент,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	КонецЕсли;
	
КонецПроцедуры     

&НаСервереБезКонтекста
// Функция - Получить массив врачей по специализации
//
// Параметры:
//  Специализация	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивВрачейПоСпециализации(Специализация)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СотрудникиСпецилазацииСотрудника.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|ГДЕ
	|	СотрудникиСпецилазацииСотрудника.Специализация = &Специализация
	|	И НЕ СотрудникиСпецилазацииСотрудника.Ссылка.ПометкаУдаления
	|	И НЕ СотрудникиСпецилазацииСотрудника.Ссылка.ЭтоГруппа");
	
	Запрос.УстановитьПараметр("Специализация", Специализация);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции


