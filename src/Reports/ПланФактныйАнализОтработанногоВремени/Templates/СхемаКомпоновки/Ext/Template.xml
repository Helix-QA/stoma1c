		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаВремяНачала_ПЛАН</dataPath>
			<field>ДатаВремяНачала_ПЛАН</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата время начала ПЛАН</v8:content>
				</v8:item>
