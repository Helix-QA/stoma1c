Процедура УстановитьОтборПоТипуЗвонка()
	
	Для Каждого КнопкиТипаЗвонка Из Элементы.ГруппаКнопокНаправленияЗвонков.ПодчиненныеЭлементы Цикл 
		Если ТипЗнч(КнопкиТипаЗвонка) = Тип("КнопкаФормы") Тогда
			Если КнопкиТипаЗвонка.Имя = "Отбор_Все" Тогда 
				КнопкиТипаЗвонка.Пометка = ОтборТипЗвонка = 3;
			ИначеЕсли КнопкиТипаЗвонка.Имя = "Отбор_Входящие" Тогда
				КнопкиТипаЗвонка.Пометка = ОтборТипЗвонка = 0;
			ИначеЕсли КнопкиТипаЗвонка.Имя = "Отбор_Исходящие" Тогда
				КнопкиТипаЗвонка.Пометка = ОтборТипЗвонка = 1;
			ИначеЕсли КнопкиТипаЗвонка.Имя = "Отбор_Пропущенные" Тогда
				КнопкиТипаЗвонка.Пометка = ОтборТипЗвонка = 2;
			ИначеЕсли КнопкиТипаЗвонка.Имя = "Отбор_БезОтвета" Тогда
				КнопкиТипаЗвонка.Пометка = ОтборТипЗвонка = 4;				
			КонецЕсли;	
