&НаСервере
// Процедура - Обновить значения фильтрации данных.
//
// Параметры:
//  ПараметрыОтбора				 - 	 - 
//  ОчиститьВсеФильтры			 - 	 - 
//  МассивИменОчищаемыхФильтров	 - 	 - 
//
Процедура ОбновитьЗначенияФильтрацииДанных(ПараметрыОтбора, ОчиститьВсеФильтры = Истина, МассивИменОчищаемыхФильтров = Неопределено)
	
	Если ОчиститьВсеФильтры Тогда 
		МассивИменОчищаемыхФильтров = Новый Массив();
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ВидСделки");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Этап");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Менеджер");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Врач");		
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СотрудникРегистрации");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_РекламныйИсточник");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Тег");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Интерес");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПредварительнаяЗапись"); 		
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Задача"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_КаналПривлечения");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПризнакВыполненияСделки");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПометкаУдаленияСделки");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СозданаПериод");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ЗавершенаПериод"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПериодЗапланированнойЗадачи");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПричинаОтказа");		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивИменОчищаемыхФильтров) Тогда 
		УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);
	КонецЕсли;
	
	СписокСтатусовПометокУдаления = Новый СписокЗначений;
	СписокСтатусовПометокУдаления.Добавить(Истина, , Ложь);
	УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияСделки", СписокСтатусовПометокУдаления, Истина);		
	
	// Отбор статус.
	Если ПараметрыОтбора.Свойство("ОчиститьОтборПоСтатусу") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.ОчиститьОтборПоСтатусу);
	КонецЕсли;
	
	// Отбор структурная единица.
	Если ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц);		
	Иначе 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	КонецЕсли;
	
	// Отбор вид сделки.
	Если ПараметрыОтбора.Свойство("МассивВидовСделок") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок);		
	КонецЕсли;

	// Отбор этапы сделки.
	Если ПараметрыОтбора.Свойство("МассивЭтапов") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов);		
	КонецЕсли;	
	
	// Отбор причина отказа.
	Если ПараметрыОтбора.Свойство("МассивПричинОтказов") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПричинаОтказа", ПараметрыОтбора.МассивПричинОтказов);		
	КонецЕсли;	
	
	// Отбор признак наличия назначенного приема.
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияПредварительнойЗаписи") ИЛИ ПараметрыОтбора.Свойство("СписокСтатусовНаличияПредварительнойЗаписи") Тогда 
		Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияПредварительнойЗаписи") Тогда 
			МассивСтатусовНаличияПредварительнойЗаписи = Новый Массив();
			Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияПредварительнойЗаписи) 
				И ПараметрыОтбора.МассивСтатусовНаличияПредварительнойЗаписи[0] = "Нет назначенного приема" Тогда
				
				МассивСтатусовНаличияПредварительнойЗаписи.Добавить(Ложь);
			Иначе
				МассивСтатусовНаличияПредварительнойЗаписи.Добавить(Истина);		
			КонецЕсли;
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПредварительнаяЗапись", МассивСтатусовНаличияПредварительнойЗаписи);
		ИначеЕсли ЗначениеЗаполнено(ПараметрыОтбора.СписокСтатусовНаличияПредварительнойЗаписи) 
				И ПараметрыОтбора.СписокСтатусовНаличияПредварительнойЗаписи[0].Значение = Ложь Тогда
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПредварительнаяЗапись", ПараметрыОтбора.СписокСтатусовНаличияПредварительнойЗаписи); 
		КонецЕсли;
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор признак наличия задач.
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач") Тогда 
		
		МассивСтатусовНаличияЗадач = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияЗадач) 
			И ПараметрыОтбора.МассивСтатусовНаличияЗадач[0] = "Нет задач" Тогда
			
			МассивСтатусовНаличияЗадач.Добавить(Ложь);
		Иначе
			МассивСтатусовНаличияЗадач.Добавить(Истина);		
		КонецЕсли;

		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Задача", МассивСтатусовНаличияЗадач);
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор статусов сделки.
	Если ПараметрыОтбора.Свойство("МассивСтатусовСделок") Тогда
		
		МассивСтатусовСделок = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовСделок) 
			И ПараметрыОтбора.МассивСтатусовСделок[0] = "Нет" Тогда
			
			МассивСтатусовСделок.Добавить(Ложь);
		Иначе
			МассивСтатусовСделок.Добавить(Истина);		
		КонецЕсли;
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПризнакВыполненияСделки", МассивСтатусовСделок);
	
	КонецЕсли;

	// Отбор менеджеров.
	Если ПараметрыОтбора.Свойство("МассивМенеджеров") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Менеджер", ПараметрыОтбора.МассивМенеджеров);
	КонецЕсли;	
	
	// Отбор врач.
	Если ПараметрыОтбора.Свойство("МассивВрачей") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Врач", ПараметрыОтбора.МассивВрачей);
	КонецЕсли;	
	
	// Отбор период запланированной задачи
	Если ПараметрыОтбора.Свойство("ПериодПланирования") Тогда    	
		
		МассивПериодаЗапланированнойЗадачи = Новый Массив();
		МассивПериодаЗапланированнойЗадачи.Добавить(ПараметрыОтбора.ПериодПланирования);
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПериодЗапланированнойЗадачи", МассивПериодаЗапланированнойЗадачи);

	КонецЕсли;	
	
	// Отбор периода завершения сделки.
	Если ПараметрыОтбора.Свойство("ПериодСделки") Тогда    
		
		МассивПериодаЗавершенияСделки = Новый Массив();
		МассивПериодаЗавершенияСделки.Добавить(ПараметрыОтбора.ПериодСделки);
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ЗавершенаПериод", МассивПериодаЗавершенияСделки);
		
	КонецЕсли;
	
	СформироватьКанбан();
	
КонецПроцедуры

