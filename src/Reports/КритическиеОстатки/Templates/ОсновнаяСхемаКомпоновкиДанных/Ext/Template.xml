		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	КритическиеОстатки.Номенклатура КАК Номенклатура,
	КритическиеОстатки.Партия КАК Партия,
	КритическиеОстатки.Склад КАК Склад,
	КритическиеОстатки.Количество * ЕСТЬNULL(КритическиеОстатки.Упаковка.Коэффициент, 1) КАК Количество,
	КритическиеОстатки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ЗапасыОстатки.КоличествоОстаток КАК КоличествоОстаток,
	ВЫБОР
		КОГДА КритическиеОстатки.Количество * ЕСТЬNULL(КритическиеОстатки.Упаковка.Коэффициент, 1) - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) &lt; 0
			ТОГДА 0
		ИНАЧЕ КритическиеОстатки.Количество * ЕСТЬNULL(КритическиеОстатки.Упаковка.Коэффициент, 1) - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0)
	КОНЕЦ КАК Обеспечение,
	ВЫБОР
		КОГДА КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию.Коэффициент &gt; 0
			ТОГДА КритическиеОстатки.Количество * ЕСТЬNULL(КритическиеОстатки.Упаковка.Коэффициент, 1) / КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию.Коэффициент
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокКритическихОстатков,
	ВЫБОР
		КОГДА КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию.Коэффициент &gt; 0
			ТОГДА ЗапасыОстатки.КоличествоОстаток / КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию.Коэффициент
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокОстатков,
	ВЫБОР
		КОГДА КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию.Коэффициент &gt; 0
			ТОГДА ВЫБОР
					КОГДА КритическиеОстатки.Количество * ЕСТЬNULL(КритическиеОстатки.Упаковка.Коэффициент, 1) - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) &lt; 0
						ТОГДА 0
					ИНАЧЕ КритическиеОстатки.Количество * ЕСТЬNULL(КритическиеОстатки.Упаковка.Коэффициент, 1) - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0)
				КОНЕЦ / КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию.Коэффициент
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокОбеспечения,
	ВЫБОР
		КОГДА КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию.Коэффициент &gt; 0
			ТОГДА КритическиеОстатки.Номенклатура.УпаковкаПоУмолчанию
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	КОНЕЦ КАК Упаковка
ИЗ
	РегистрСведений.КритическиеОстатки КАК КритическиеОстатки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыНаСкладах.Остатки(, ) КАК ЗапасыОстатки
		ПО КритическиеОстатки.Номенклатура = ЗапасыОстатки.Номенклатура
			И КритическиеОстатки.Склад = ЗапасыОстатки.Склад
			И КритическиеОстатки.Партия = ЗапасыОстатки.Партия

УПОРЯДОЧИТЬ ПО
	КритическиеОстатки.Номенклатура.Наименование</query>
