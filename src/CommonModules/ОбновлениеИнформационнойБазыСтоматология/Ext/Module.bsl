// Процедура, заполняет реквизит "ДатаОкончания" в документах "Событие".
//
Процедура ЗаполнитьДатыОкончанияСобытий(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СобытиеУслуги.Ссылка КАК Ссылка,
	|	МАКСИМУМ(СобытиеУслуги.ДатаОкончания) КАК ДатаОкончания
	|ИЗ
	|	Документ.Событие.Услуги КАК СобытиеУслуги
	|ГДЕ
	|	СобытиеУслуги.ДатаНачала > &ДатаНачала
	|	И НЕ СобытиеУслуги.Ссылка.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	СобытиеУслуги.Ссылка");
	
	Запрос.УстановитьПараметр("ДатаНачала", ТекущаяДатаСеанса() - 3600 * 24 * 365);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			СобытиеОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			Если Не ЗначениеЗаполнено(СобытиеОбъект.ДатаОкончания) Тогда
				СобытиеОбъект.ДатаОкончания	 = Выборка.ДатаОкончания;
				СобытиеОбъект.Записать();
			КонецЕсли;
			
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Создает документ "Закрытие месяца" за прошлые период
//
Процедура ЗакрытиеМесяцаСоздатьЗаПрошлыеПериоды(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	
	#Область ТекстЗапроса
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Прием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НАЧАЛОПЕРИОДА(МИНИМУМ(Прием.Дата), МЕСЯЦ) КАК ДатаНачала,
	|	КОНЕЦПЕРИОДА(&ТекущаяДата, МЕСЯЦ) КАК ДатаОкончания
	|ПОМЕСТИТЬ ВТ_ПериодСЕ
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Проведен = ИСТИНА
	|
	|СГРУППИРОВАТЬ ПО
	|	Прием.СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(ВТ_ПериодСЕ.ДатаНачала) КАК ДатаНачала,
	|	МАКСИМУМ(ВТ_ПериодСЕ.ДатаОкончания) КАК ДатаОкончания
	|ПОМЕСТИТЬ ВТ_Период
	|ИЗ
	|	ВТ_ПериодСЕ КАК ВТ_ПериодСЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	0 КАК Цифра
	|ПОМЕСТИТЬ ТабЦифр
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	1
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	2
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	3
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	4
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	5
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	6
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	7
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	8
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	9
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДОБАВИТЬКДАТЕ(ВТ_Период.ДатаНачала, МЕСЯЦ, ТабЦифр1.Цифра + 10 * ТабЦифр2.Цифра + 100 * ТабЦифр3.Цифра + 1000 * ТабЦифр4.Цифра) КАК День
	|ПОМЕСТИТЬ ТабДней
	|ИЗ
	|	ТабЦифр КАК ТабЦифр1,
	|	ТабЦифр КАК ТабЦифр2,
	|	ТабЦифр КАК ТабЦифр3,
	|	ТабЦифр КАК ТабЦифр4,
	|	ВТ_Период КАК ВТ_Период
	|ГДЕ
	|	ДОБАВИТЬКДАТЕ(ВТ_Период.ДатаНачала, МЕСЯЦ, ТабЦифр1.Цифра + 10 * ТабЦифр2.Цифра + 100 * ТабЦифр3.Цифра + 1000 * ТабЦифр4.Цифра) <= ВТ_Период.ДатаОкончания
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	День
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабДней.День КАК День,
	|	ВТ_ПериодСЕ.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ПОМЕСТИТЬ СЕТабДней
	|ИЗ
	|	ВТ_ПериодСЕ КАК ВТ_ПериодСЕ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТабДней КАК ТабДней
	|		ПО (ТабДней.День >= ВТ_ПериодСЕ.ДатаНачала)
	|			И (ТабДней.День <= ВТ_ПериодСЕ.ДатаОкончания)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СЕТабДней.День КАК День,
	|	СЕТабДней.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	СЕТабДней КАК СЕТабДней
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗакрытиеМесяца КАК ЗакрытиеМесяца
	|		ПО СЕТабДней.День = ЗакрытиеМесяца.МесяцРаспределения
	|			И СЕТабДней.СтруктурнаяЕдиница = ЗакрытиеМесяца.СтруктурнаяЕдиница
	|ГДЕ
	|	ЗакрытиеМесяца.Ссылка ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	День";
	#КонецОбласти
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда 
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл  
			
			ЗакрытиеМесяцаОбъект = Документы.ЗакрытиеМесяца.СоздатьДокумент();
			
			ЗакрытиеМесяцаОбъект.СтруктурнаяЕдиница = Выборка.СтруктурнаяЕдиница;
			ЗакрытиеМесяцаОбъект.Дата               = Выборка.День;
			ЗакрытиеМесяцаОбъект.МесяцРаспределения = Выборка.день;
			
			Попытка
				ЗакрытиеМесяцаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
				,УровеньЖурналаРегистрации.Ошибка
				,
				,
				,СтрШаблон("Документ ""Закрытие месяца"" за %1, клиника %2, не удалось провести: ", Формат(Выборка.День, "ДФ='ММММ гггг'"), Выборка.СтруктурнаяЕдиница) + ОписаниеОшибки());						
			КонецПопытки;
			
		КонецЦикла; 
		
	КонецЕсли; 
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;	
	
КонецПроцедуры 

// Процедура - Заполняет реквизит УИД в событиях с датой больше текущей.
//
Процедура ЗаполнитьРеквизитУИДВБудущихСобытиях(Параметры = Неопределено) Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Событие.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Событие КАК Событие
	|ГДЕ
	|	Событие.Дата > &Дата");
	
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			
			СобытиеОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			Если НЕ СобытиеОбъект = Неопределено Тогда
				
				СобытиеОбъект.УИД = "" + Выборка.Ссылка.УникальныйИдентификатор();	
				
				СобытиеОбъект.ДополнительныеСвойства.Вставить("ОбменДаннымиЗагрузка", Истина);			
				СобытиеОбъект.Записать(РежимЗаписиДокумента.Запись);
				
			КонецЕсли;
			
		Исключение 
			
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Заполнение реквизита УИД в будущих событиях."
																	, УровеньЖурналаРегистрации.Ошибка, 
																	, Выборка.Ссылка
																	, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
		КонецПопытки;
				
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, заполняет аватары сотрудников в регистре "АктивныеПользователиМессенджер".
//
Процедура АктуализироватьАватарыСотрудников(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.ФайлКартинки КАК ФайлКартинки
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ФайлКартинки <> ЗНАЧЕНИЕ(Справочник.Файлы.ПустаяСсылка)
	|	И НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.Служебный
	|	И НЕ Сотрудники.ЭтоГруппа");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		РегистрыСведений.АктивныеПользователиМессенджер.ОбновитьАватарСотрудника(Выборка.Ссылка, Выборка.ФайлКартинки);
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, Обновляет внешнюю систему IP-Телефонии в CRM, дозаписывая Оператора IP-телефонии (Для статистики).
//
Процедура ОбновитьИДозаполнитьВнешниеСистемыIPТелефонииВCRM(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Попытка
	
		МассивИсключаемыхДрайверов = Новый Массив;
		МассивИсключаемыхДрайверов.Добавить(Справочники.ДрайверыОборудования.ДрайверВедисофтПростыеЗвонки);
		МассивИсключаемыхДрайверов.Добавить(Справочники.ДрайверыОборудования.ДрайверХеликсOKTELL);
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ВнешниеСистемы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
		|ГДЕ
		|	НЕ ВнешниеСистемы.ПометкаУдаления
		|	И ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.IPТелефония)
		|	И ВнешниеСистемы.Используется
		|	И ВнешниеСистемы.Синхронизирована
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПодключаемоеОборудование.ДрайверОборудования.ИмяПредопределенныхДанных КАК НаименованиеДрайвера
		|ИЗ
		|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
		|ГДЕ
		|	НЕ ПодключаемоеОборудование.ПометкаУдаления
		|	И ПодключаемоеОборудование.ТипОборудования = ЗНАЧЕНИЕ(Перечисление.ТипыПодключаемогоОборудования.IPТелефония)
		|	И ПодключаемоеОборудование.УстройствоИспользуется		
		|	И НЕ ПодключаемоеОборудование.ДрайверОборудования В (&МассивИсключаемыхДрайверов)");
		
		Запрос.УстановитьПараметр("МассивИсключаемыхДрайверов", МассивИсключаемыхДрайверов);
		
		РезультатЗапроса = Запрос.ВыполнитьПакет();	
		ВыборкаВС = РезультатЗапроса[0].Выбрать();
		ВыборкаОборудование = РезультатЗапроса[1].Выгрузить(); 
		
		ОператорIPТелефонии = "";
		
		Если ЗначениеЗаполнено(ВыборкаОборудование) Тогда
			
			НаименованиеДрайвера = ВыборкаОборудование[0].НаименованиеДрайвера;			
			ОператорIPТелефонии = СтрЗаменить(НаименованиеДрайвера, "ДрайверХеликс", "");
			
		КонецЕсли;	
		
		Если НЕ ЗначениеЗаполнено(ОператорIPТелефонии) Тогда
			Возврат;
		КонецЕсли;
		
		УИДТекущейСессии = ЛичныйКабинет.УидТекущейСессии();
		
		ДопПараметры = Новый Структура("operator_IP_telephony", ОператорIPТелефонии); 
		
		Пока ВыборкаВС.Следующий() Цикл			
			ЛичныйКабинет.ОбновитьДанныеПубликацииВнешнейСистемы(ВыборкаВС.Ссылка, Истина, УИДТекущейСессии, ДопПараметры);	
		КонецЦикла;
	
	Исключение
		
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Обновление внешней системы IP-Телефонии в CRM."
															    , УровеньЖурналаРегистрации.Предупреждение
																,,, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры  

// Процедура, Перезаписывает значения диагнозов строкового типа.
//
Процедура ПерезаписатьЗначенияДиагнозовВПараметрахОбследований(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗначенияПараметровОбследований.Значение КАК Значение,
	|	ЗначенияПараметровОбследований.Документ КАК Документ,
	|	ЗначенияПараметровОбследований.Зуб КАК Зуб,
	|	ЗначенияПараметровОбследований.ШаблонОбследования КАК ШаблонОбследования,
	|	ЗначенияПараметровОбследований.Параметр КАК Параметр
	|ИЗ
	|	РегистрСведений.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ЗначенияПараметровОбследований.Значение) <> ТИП(Справочник.Диагнозы)
	|	И ЗначенияПараметровОбследований.Значение В
	|			(ВЫБРАТЬ
	|				Диагнозы.Наименование КАК Наименование
	|			ИЗ
	|				Справочник.Диагнозы КАК Диагнозы)
	|	И ЗначенияПараметровОбследований.Параметр = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ПараметрыОбследований.Диагноз)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Документ"); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		НаборЗаписей = РегистрыСведений.ЗначенияПараметровОбследований.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Параметр.Значение                = Выборка.Параметр;
		НаборЗаписей.Отбор.Параметр.Использование           = Истина; 
		НаборЗаписей.Отбор.Документ.Значение                = Выборка.Документ;
		НаборЗаписей.Отбор.Документ.Использование           = Истина;
		НаборЗаписей.Отбор.Зуб.Значение                     = Выборка.Зуб;
		НаборЗаписей.Отбор.Зуб.Использование                = Истина;
		НаборЗаписей.Отбор.ШаблонОбследования.Значение      = Выборка.ШаблонОбследования;
		НаборЗаписей.Отбор.ШаблонОбследования.Использование = Истина; 
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() > 0 Тогда
			Диагноз                  = Справочники.Диагнозы.НайтиПоНаименованию(Выборка.Значение);
			НаборЗаписей[0].Значение = ?(ЗначениеЗаполнено(Диагноз), Диагноз, Выборка.Значение); 		
			Попытка 
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
			Исключение 
				ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Не удалось перезаписать значение параметра обследования " + 
				                                                         Выборка.Значение + " документа " + Строка(Выборка.Документ)    
															             , УровеньЖурналаРегистрации.Ошибка
																         ,,, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));

			КонецПопытки;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Обновление параметров закрытия диалогов внешних систем мессенджеров
//
Процедура ОбновлениеПараметровЗакрытияДиалоговВнешнихСистемМессенджеров() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Параметры КАК Параметры
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы В (ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Telegram), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Viber))");
	
	ВыборкаМессенджеров = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаМессенджеров.Следующий() Цикл
		ПараметрыВнешнейСистемы = ВыборкаМессенджеров.Параметры.Получить();
		Если НЕ ЗначениеЗаполнено(ПараметрыВнешнейСистемы) ИЛИ НЕ ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура") Тогда 
			Продолжить;
		КонецЕсли;
		ВремяЗакрытияОткрытогоДиалога = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВнешнейСистемы, "ВремяЗакрытияОткрытогоДиалога", 0);	
		ВремяЗакрытияОтложенногоДиалога = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВнешнейСистемы, "ВремяЗакрытияОтложенногоДиалога", 0);
		НеобходимоЗаписать = Истина;
		Если ВремяЗакрытияОткрытогоДиалога = 0 Тогда 
			ПараметрыВнешнейСистемы.Вставить("ВремяЗакрытияОткрытогоДиалога", 4*60*60);
		ИначеЕсли ВремяЗакрытияОткрытогоДиалога < (2*60*60) Тогда
			ПараметрыВнешнейСистемы.Вставить("ВремяЗакрытияОткрытогоДиалога", (2*60*60));
		ИначеЕсли ВремяЗакрытияОткрытогоДиалога > (4*60*60) Тогда
			ПараметрыВнешнейСистемы.Вставить("ВремяЗакрытияОткрытогоДиалога", (4*60*60));
		Иначе 
			НеобходимоЗаписать = Ложь;
		КонецЕсли;	
		Если ВремяЗакрытияОтложенногоДиалога = 0 Тогда 
			ПараметрыВнешнейСистемы.Вставить("ВремяЗакрытияОтложенногоДиалога", 24*60*60);
		ИначеЕсли ВремяЗакрытияОтложенногоДиалога < (2*60*60) Тогда
			ПараметрыВнешнейСистемы.Вставить("ВремяЗакрытияОтложенногоДиалога", (2*60*60));
		ИначеЕсли ВремяЗакрытияОтложенногоДиалога > (24*60*60) Тогда
			ПараметрыВнешнейСистемы.Вставить("ВремяЗакрытияОтложенногоДиалога", (24*60*60));
		Иначе 
			НеобходимоЗаписать = ?(НеобходимоЗаписать, НеобходимоЗаписать, Ложь);
		КонецЕсли;	

		Если НЕ НеобходимоЗаписать Тогда 
			Продолжить;
		КонецЕсли;
		
		ВнешняяСистемаОбъект = ВыборкаМессенджеров.Ссылка.ПолучитьОбъект();
		ВнешняяСистемаОбъект.Параметры = Новый ХранилищеЗначения(ПараметрыВнешнейСистемы);
		Попытка		
			ВнешняяСистемаОбъект.Записать();
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
			ЗаписьЖурналаРегистрации(
			"ОбновлениеПараметровВнешнихСистемWhatsApp",
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.ВнешниеСистемы,
			ВыборкаМессенджеров.Ссылка,
			НСтр("ru = 'Не удалось обновить параметры внешней системы WhatsApp. Текст ошибки: '") + ОписаниеОшибки
			);
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

// Процедура - заполнение реквизита для кассы.
//
Процедура ЗаполнениеРеквизитаДляКассы(Параметры = Неопределено) Экспорт
	
	// Были добавлены 4 вида операции и 4 вида статей доходов и расходов,
	// для каждого из них необходимо прописать соответствие.

	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	СтатьяОбъект                        = Справочники.СтатьиДоходовИРасходов.ВыбытиеВОперационнуюКассу.ПолучитьОбъект();
	СтатьяОбъект.ПоУмолчаниюДляОперации = Перечисления.ВидыОпераций.ВыбытиеВОперационнуюКассу;                          	
	СтатьяОбъект.Записать();
	
	СтатьяОбъект                        = Справочники.СтатьиДоходовИРасходов.СдачаРозничнойВыручкиВКассуПредприятия.ПолучитьОбъект();
	СтатьяОбъект.ПоУмолчаниюДляОперации = Перечисления.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия;	
	СтатьяОбъект.Записать();
	
	СтатьяОбъект                        = Справочники.СтатьиДоходовИРасходов.ПоступлениеИзКассыПредприятия.ПолучитьОбъект();
	СтатьяОбъект.ПоУмолчаниюДляОперации = Перечисления.ВидыОпераций.ПоступлениеИзКассыПредприятия;
	СтатьяОбъект.Записать();
	
	СтатьяОбъект                        = Справочники.СтатьиДоходовИРасходов.ПоступлениеРозничнойВыручкиИзОперационнойКассы.ПолучитьОбъект();
	СтатьяОбъект.ПоУмолчаниюДляОперации = Перечисления.ВидыОпераций.ПоступлениеРозничнойВыручкиИзОперационнойКассы;
	СтатьяОбъект.Записать();           
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Кассы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	НЕ Кассы.ЭтоГруппа
	|	И НЕ Кассы.ПометкаУдаления";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл   
		
		КассаСсылка = Выборка.Ссылка.ПолучитьОбъект();
		КассаСсылка.ВыемкаИзКассы = Перечисления.ВидыОпераций.СдачаНаличныхВБанк;
		КассаСсылка.ТипКассы = Перечисления.ТипыКасс.ОперационнаяКасса;
		
		Попытка 
			КассаСсылка.Записать();
		Исключение   
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Заполнение реквизита для кассы."
																	, УровеньЖурналаРегистрации.Ошибка, 
																	, Выборка.Ссылка
																	, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;


КонецПроцедуры               

// Процедура - Обновить настройки дат приема и увольнения сотрудников.
//
// Параметры:
//  Параметры	 - 	 - 
//
Процедура ОбновитьНастройкиДатПриемаИУвольненияСотрудников(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НастройкиПользователей.Пользователь КАК Пользователь,
	|	НастройкиПользователей.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ДатаПриема)
	|			ТОГДА НастройкиПользователей.Значение
	|	КОНЕЦ КАК ДатаПриема,
	|	ВЫБОР
	|		КОГДА НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ДатаУвольнения)
	|			ТОГДА НастройкиПользователей.Значение
	|	КОНЕЦ КАК ДатаУвольнения
	|ПОМЕСТИТЬ ВТДатыПриемаИУвольнений
	|ИЗ
	|	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
	|ГДЕ
	|	НастройкиПользователей.Настройка В (ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ДатаПриема), ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ДатаУвольнения))
	|	И НастройкиПользователей.Значение <> ДАТАВРЕМЯ(1, 1, 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ВТДатыПриемаИУвольнений.Пользователь ССЫЛКА Справочник.Сотрудники
	|			ТОГДА ВТДатыПриемаИУвольнений.Пользователь
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВЫРАЗИТЬ(ВТДатыПриемаИУвольнений.Пользователь КАК Справочник.Пользователи).Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|					ТОГДА ВЫРАЗИТЬ(ВТДатыПриемаИУвольнений.Пользователь КАК Справочник.Пользователи).Сотрудник
	|			КОНЕЦ
	|	КОНЕЦ КАК Сотрудник,
	|	ВТДатыПриемаИУвольнений.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	МАКСИМУМ(ВТДатыПриемаИУвольнений.ДатаПриема) КАК ДатаПриема,
	|	МАКСИМУМ(ВТДатыПриемаИУвольнений.ДатаУвольнения) КАК ДатаУвольнения
	|ИЗ
	|	ВТДатыПриемаИУвольнений КАК ВТДатыПриемаИУвольнений
	|ГДЕ
	|	НЕ ВЫБОР
	|				КОГДА ВТДатыПриемаИУвольнений.Пользователь ССЫЛКА Справочник.Сотрудники
	|					ТОГДА ВТДатыПриемаИУвольнений.Пользователь
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ВЫРАЗИТЬ(ВТДатыПриемаИУвольнений.Пользователь КАК Справочник.Пользователи).Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|							ТОГДА ВЫРАЗИТЬ(ВТДатыПриемаИУвольнений.Пользователь КАК Справочник.Пользователи).Сотрудник
	|					КОНЕЦ
	|			КОНЕЦ ЕСТЬ NULL
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА ВТДатыПриемаИУвольнений.Пользователь ССЫЛКА Справочник.Сотрудники
	|			ТОГДА ВТДатыПриемаИУвольнений.Пользователь
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВЫРАЗИТЬ(ВТДатыПриемаИУвольнений.Пользователь КАК Справочник.Пользователи).Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|					ТОГДА ВЫРАЗИТЬ(ВТДатыПриемаИУвольнений.Пользователь КАК Справочник.Пользователи).Сотрудник
	|			КОНЕЦ
	|	КОНЕЦ,
	|	ВТДатыПриемаИУвольнений.СтруктурнаяЕдиница";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.НастройкиСотрудников.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Сотрудник = Выборка.Сотрудник; 
		МенеджерЗаписи.СтруктурнаяЕдиница = Выборка.СтруктурнаяЕдиница;
		
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			
			МенеджерЗаписи.ДатаПриема 		= Выборка.ДатаПриема;
			МенеджерЗаписи.ДатаУвольнения 	= Выборка.ДатаУвольнения;
				
		Иначе 
			
			МенеджерЗаписи = РегистрыСведений.НастройкиСотрудников.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка); 			
		КонецЕсли;
		
		Попытка 
			МенеджерЗаписи.Записать();
		Исключение     	
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Обновление настроек сотрудников."
			, УровеньЖурналаРегистрации.Ошибка, 
			, Выборка.Ссылка
			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Перенести данные из ТЧВРегистр сведений нормы списания материалов
//
Процедура ПеренестиДанныеИзТЧВРегистрСведенийНормыСписанияМатериалов(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка) КАК СтруктурнаяЕдиница,
		|	НоменклатураНормыСписанияМатериалов_Удалить.Ссылка КАК Номенклатура,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМНоменклатура КАК Материал,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМПартия КАК Партия,
		|	ЛОЖЬ КАК НормыСписанияНеИспользуются,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМВключатьВСтоимость КАК ВключатьВСтоимостьУслуги,
		|	ИСТИНА КАК НеЗависитОтКоличестваУслуг,
		|	НЕОПРЕДЕЛЕНО КАК СкладСписания,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМВидЦен КАК ВидЦен,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМУпаковка КАК Упаковка,
		|	СУММА(НоменклатураНормыСписанияМатериалов_Удалить.НСМКоличество) КАК Количество
		|ИЗ
		|	Справочник.Номенклатура.НормыСписанияМатериалов_Удалить КАК НоменклатураНормыСписанияМатериалов_Удалить
		|
		|СГРУППИРОВАТЬ ПО
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМВключатьВСтоимость,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМНоменклатура,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМПартия,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМВидЦен,
		|	НоменклатураНормыСписанияМатериалов_Удалить.Ссылка,
		|	НоменклатураНормыСписанияМатериалов_Удалить.НСМУпаковка";
	
	// Для корректного перехода со старой версии на новую.
	// Добавлено на всякий случай!
	Если НЕ Метаданные.Справочники.Номенклатура.ТабличныеЧасти.НормыСписанияМатериалов_Удалить.Реквизиты.Найти("НСМВидЦен_OLD") = Неопределено Тогда
		
		ПодстрокаЗамены = "ЕСТЬNULL(НоменклатураНормыСписанияМатериалов_Удалить.НСМВидЦен_OLD.Ссылка, НоменклатураНормыСписанияМатериалов_Удалить.НСМВидЦен)";		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "НоменклатураНормыСписанияМатериалов_Удалить.НСМВидЦен", ПодстрокаЗамены);
		
	КонецЕсли;
		
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(РезультатЗапроса);                                                  
	
	Попытка
		
		НаборЗаписей.Записать();
		
	Исключение
		
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Обновление настроек сотрудников."
																 , УровеньЖурналаРегистрации.Ошибка, ,
																 , ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, синхронизирует структурные единицы задач.
//
Процедура СинхронизироватьСтруктурныеЕдиницыЗадач(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Взаимодействие.Ссылка КАК Задача,
	|	Взаимодействие.Сделка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.СтруктурнаяЕдиница <> Взаимодействие.Сделка.СтруктурнаяЕдиница
	|	И НЕ Взаимодействие.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Взаимодействие.Ссылка,
	|	Взаимодействие.ЗадачаПредмет.СтруктурнаяЕдиница
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.ЗадачаПредмет ССЫЛКА Справочник.Заявки
	|	И Взаимодействие.СтруктурнаяЕдиница <> ВЫРАЗИТЬ(Взаимодействие.ЗадачаПредмет КАК Справочник.Заявки).СтруктурнаяЕдиница
	|	И Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|	И НЕ Взаимодействие.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Взаимодействие.Ссылка,
	|	Взаимодействие.ЗадачаПредмет.СтруктурнаяЕдиница
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.ЗадачаПредмет ССЫЛКА Документ.Реализация
	|	И Взаимодействие.СтруктурнаяЕдиница <> ВЫРАЗИТЬ(Взаимодействие.ЗадачаПредмет КАК Документ.Реализация).СтруктурнаяЕдиница
	|	И Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|	И НЕ Взаимодействие.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Взаимодействие.Ссылка,
	|	Взаимодействие.ЗадачаПредмет.СтруктурнаяЕдиница
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.ЗадачаПредмет ССЫЛКА Документ.Прием
	|	И Взаимодействие.СтруктурнаяЕдиница <> ВЫРАЗИТЬ(Взаимодействие.ЗадачаПредмет КАК Документ.Прием).СтруктурнаяЕдиница
	|	И Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|	И НЕ Взаимодействие.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Взаимодействие.Ссылка,
	|	Взаимодействие.ЗадачаПредмет.СтруктурнаяЕдиница
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.ЗадачаПредмет ССЫЛКА Документ.ПланЛечения
	|	И Взаимодействие.СтруктурнаяЕдиница <> ВЫРАЗИТЬ(Взаимодействие.ЗадачаПредмет КАК Документ.ПланЛечения).СтруктурнаяЕдиница
	|	И Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|	И НЕ Взаимодействие.ПометкаУдаления");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			ЗадачаОбъект					 = Выборка.Задача.ПолучитьОбъект();
			ЗадачаОбъект.СтруктурнаяЕдиница	 = Выборка.СтруктурнаяЕдиница;
			ЗадачаОбъект.ДополнительныеСвойства.Вставить("НеСинхронизироватьСтруктурнуюЕдиницу", Истина);
			ЗадачаОбъект.Записать();
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обновить эквайринги и кассы
//
Процедура ОбновитьЭквайрингиИКассы() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(                              
	"ВЫБРАТЬ
	|	Кассы.Ссылка КАК Ссылка,
	|	Кассы.СтруктурнаяЕдиница.Организация КАК Организация
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Кассы.ПометкаУдаления = ЛОЖЬ");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.Организация) Тогда
			
			ОбъектКасса = Выборка.Ссылка.ПолучитьОбъект(); 
			
			Если ОбъектКасса <> Неопределено Тогда
				
				ОбъектКасса.Организация = Выборка.Организация;
				
				Попытка
					ОбъектКасса.Записать();
				Исключение
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	МенеджерОборудованияВызовСервераПереопределяемый.ОбновитьПоставляемыеДрайвера();
			
	Запрос = Новый Запрос(                              
	"ВЫБРАТЬ
	|	Кассы.Ссылка КАК СсылкаКасса,
	|	Кассы.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Кассы.ПометкаУдаления = ЛОЖЬ
	|	И Кассы.ЭквайринговыйТерминал <> ЗНАЧЕНИЕ(Справочник.ЭквайринговыеТерминалы.ПустаяСсылка)");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		КассаОбъект = Выборка.СсылкаКасса.ПолучитьОбъект();
		
		КассаОбъект.ЭквайринговыеТерминалы.Очистить();
		
		НоваяСтрока							= КассаОбъект.ЭквайринговыеТерминалы.Добавить();
		НоваяСтрока.ЭквайринговыйТерминал	= Выборка.ЭквайринговыйТерминал;
		НоваяСтрока.Основной				= Истина;
		
		Попытка	
			КассаОбъект.Записать();			
		Исключение 
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());			
		КонецПопытки;
		
	КонецЦикла;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЭквайринговыеТерминалы.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ЭквайринговыеТерминалы.ТипБанка <> ЗНАЧЕНИЕ(Перечисление.ПлатежныеШлюзы.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыЭквайринговыхТерминалов.Онлайн)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыЭквайринговыхТерминалов.Торговый)
	|	КОНЕЦ КАК ТипЭквайринга
	|ИЗ
	|	Справочник.ЭквайринговыеТерминалы КАК ЭквайринговыеТерминалы");
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЗ Из РезультатЗапроса Цикл
		
		ОбъектЭТ				= СтрокаТЗ.Ссылка.ПолучитьОбъект();
		ОбъектЭТ.ТипЭквайринга	= СтрокаТЗ.ТипЭквайринга;
		
		ЭтоОнлайн	= ОбъектЭТ.ТипЭквайринга = ПредопределенноеЗначение("Перечисление.ТипыЭквайринговыхТерминалов.Онлайн");
		ЭтоТорговый	= ОбъектЭТ.ТипЭквайринга = ПредопределенноеЗначение("Перечисление.ТипыЭквайринговыхТерминалов.Торговый"); 
		
		Если ОбъектЭТ.ТипЭквайринга = Перечисления.ТипыЭквайринговыхТерминалов.Онлайн Тогда
			ОбъектЭТ.ПодключаемоеОборудование				= Неопределено;	
		    ОбъектЭТ.ИспользоватьБезПодключенияОборудования = Истина;      
		Иначе
			ОбъектЭТ.ТипФискализации			= Перечисления.ТипыФискализации.НеФискализировать;
			ОбъектЭТ.ТипБанка					= Неопределено;
			ОбъектЭТ.ИспользоватьОплатуПоСсылке = Ложь;
			ОбъектЭТ.КассовыйСервер				= Неопределено;
		КонецЕсли;

		Попытка
			ОбъектЭТ.Записать();
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, обновляет содержание шаблонов сообщений для мессенджера.
//
Процедура ОбновитьСодержаниеШаблоновСообщенийМессенджера() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ШаблоныСообщений.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	НЕ ШаблоныСообщений.ПометкаУдаления
	|	И НЕ ШаблоныСообщений.ЭтоГруппа");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			ШаблонОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ШаблонОбъект.ДополнительныеСвойства.Вставить("ОбновитьСодержаниеМессенджер", Истина);
			ШаблонОбъект.Записать();
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, обновляет предопределенные элементы плана видов характеристик "ПараметрыОбследований".
//
Процедура ИспарвитьЗаписиРегистраСведенийДокументыФизическихЛиц(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли; 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументыФизическихЛиц.Физлицо КАК Физлицо,
	|	ДокументыФизическихЛиц.ВидДокумента КАК ВидДокумента,
	|	ДокументыФизическихЛиц.Серия КАК Серия,
	|	ДокументыФизическихЛиц.Номер КАК Номер,
	|	ДокументыФизическихЛиц.ДатаВыдачи КАК ДатаВыдачи,
	|	ДокументыФизическихЛиц.СрокДействия КАК СрокДействия,
	|	ДокументыФизическихЛиц.КемВыдан КАК КемВыдан,
	|	ДокументыФизическихЛиц.КодПодразделения КАК КодПодразделения,
	|	ДокументыФизическихЛиц.ЯвляетсяДокументомУдостоверяющимЛичность КАК ЯвляетсяДокументомУдостоверяющимЛичность,
	|	ДокументыФизическихЛиц.Представление КАК Представление,
	|	ДокументыФизическихЛиц.УдалитьВидДокумента КАК УдалитьВидДокумента
	|ИЗ
	|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
	|ГДЕ
	|	НЕ ДокументыФизическихЛиц.ЯвляетсяДокументомУдостоверяющимЛичность
	|	И (ДокументыФизическихЛиц.ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ПаспортРФ)
	|			ИЛИ ДокументыФизическихЛиц.ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.СНИЛС))");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи              = РегистрыСведений.ДокументыФизическихЛиц.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Физлицо      = Выборка.Физлицо; 
		МенеджерЗаписи.ВидДокумента = Выборка.ВидДокумента;		
		МенеджерЗаписи.Прочитать();		
		
		Если МенеджерЗаписи.Выбран() Тогда 		
			
			МенеджерЗаписи.ЯвляетсяДокументомУдостоверяющимЛичность	= Истина;		
			
			Попытка
				МенеджерЗаписи.Записать();
			Исключение	
				ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Не удалось перезаписать значение регистра сведений ""Документы физических лиц""", УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));	
			КонецПопытки;
																	 
		КонецЕсли;
		
	КонецЦикла;	
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
		
КонецПроцедуры  

// Процедура, заполняет регистр СтатусыСообщений на основе регистра СтатусыСообщений_Удалить.
//
Процедура ЗаполнитьРегистрСтатусыСообщений(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СтатусыСообщений_УДАЛИТЬ.КлючСтроки КАК КлючСтроки,
	|	СтатусыСообщений_УДАЛИТЬ.РассылкаСообщений КАК РассылкаСообщений,
	|	СтатусыСообщений_УДАЛИТЬ.СтатусДействия КАК СтатусДействия,
	|	СтатусыСообщений_УДАЛИТЬ.СтатусСообщения КАК СтатусСообщения,
	|	СтатусыСообщений_УДАЛИТЬ.ТекстСообщения КАК ТекстСообщения,
	|	СтатусыСообщений_УДАЛИТЬ.СтадияДоставки КАК СтадияДоставки,
	|	СтатусыСообщений_УДАЛИТЬ.СервисРассылки КАК СервисРассылки,
	|	СтатусыСообщений_УДАЛИТЬ.ДатаУстановкиСтатуса КАК ДатаУстановкиСтатуса,
	|	СтатусыСообщений_УДАЛИТЬ.ДатаОтправки КАК ДатаОтправки,
	|	СтатусыСообщений_УДАЛИТЬ.IDСообщения КАК IDСообщения,
	|	СтатусыСообщений_УДАЛИТЬ.НомерТелефона КАК НомерТелефона,
	|	СтатусыСообщений_УДАЛИТЬ.Получатель КАК Получатель
	|ИЗ
	|	РегистрСведений.СтатусыСообщений_УДАЛИТЬ.СрезПоследних(, НЕ РассылкаСообщений.Ссылка ЕСТЬ NULL) КАК СтатусыСообщений_УДАЛИТЬ");
		
	Попытка
		
		ИтоговаяТЗ = Запрос.Выполнить().Выгрузить();
		
		Если ЗначениеЗаполнено(ИтоговаяТЗ) Тогда
			
			НаборЗаписей = РегистрыСведений.СтатусыСообщений.СоздатьНаборЗаписей();						
			НаборЗаписей.Загрузить(ИтоговаяТЗ);
			НаборЗаписей.ОбменДанными.Загрузка = Истина;
			НаборЗаписей.Записать();
			
		КонецЕсли;
		
	Исключение
		
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
		"Заполнение регистра СтатусыСообщений из регистра СтатусыСообщий_Удалить"
		, УровеньЖурналаРегистрации.Ошибка
		,,, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));
		
	КонецПопытки;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;

КонецПроцедуры

// Процедура, осуществляет копирование данных из реквизитов и объектов с префиксом "_OLD" в аналогичные без префикса.
//
Процедура ОбновитьДанныеПриПереходеСоСтаройВерсииНаНовую(Параметры = Неопределено) Экспорт 

	// При обновлении часть реквизитов и объектов в старой стоматологии
	// не сопоставляются с объектами новой стоматологии.
	// Для этого были скопированы проблемные реквизиты и объекты и помечены префиксом "_OLD".
	// Так же некоторые объекты сопоставляются неправильно.
	// Для решения проблемы эти объекты были скопированы, а прежние помечены префиксом "_УДАЛИТЬ".
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

#Область Обработка_Ролей

	// Выравнивание.
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Пользователи.Ссылка КАК Ссылка,
	|	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	НЕ Пользователи.ПометкаУдаления
	|	И Пользователи.ЭтоПользовательИБ
	|	И НЕ Пользователи.Служебный");
		
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗначениеЗаполнено(Выборка.ИдентификаторПользователяИБ) Тогда
			Продолжить;
		КонецЕсли;
		
		СвойстваПользователя = Пользователи.СвойстваПользователяИБ(Выборка.ИдентификаторПользователяИБ);		
		
		ВозвращенаСтруктура = (ТипЗнч(СвойстваПользователя) = Тип("Структура"));
		Если НЕ ВозвращенаСтруктура ИЛИ (ВозвращенаСтруктура И НЕ СвойстваПользователя.Свойство("Роли")) Тогда
			Продолжить;	
		КонецЕсли;
		
		ЭтоПользовательИБ = (НЕ СвойстваПользователя.Роли.Найти("БазовыеПрава") = Неопределено
							И НЕ СвойстваПользователя.Роли.Найти("БазовыеПраваБСП") = Неопределено);
		
		ЭтоАдминБД  = (НЕ СвойстваПользователя.Роли.Найти("Администрирование") = Неопределено 
					  И НЕ СвойстваПользователя.Роли.Найти("ПолныеПрава") = Неопределено);
					  
		Если ЭтоПользовательИБ ИЛИ ЭтоАдминБД Тогда
			
			ПользовательОбъект = Выборка.Ссылка.ПолучитьОбъект();						
			
			СвойстваПользователя.Вставить("ВходВПрограммуРазрешен", ИСТИНА);		
			
			Если ЭтоПользовательИБ Тогда
				СвойстваПользователя.Роли.Добавить("БазовыеПрава");
			Иначе
				СвойстваПользователя.Роли.Добавить("АдминистраторСистемы");	
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Выборка.ИдентификаторПользователяИБ) Тогда
				СвойстваПользователя.Вставить("УникальныйИдентификатор", Выборка.ИдентификаторПользователяИБ);
			КонецЕсли;
			СвойстваПользователя.Вставить("Действие", "Записать");
			
			ПользовательОбъект.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", СвойстваПользователя);
			
			Попытка			
				ПользовательОбъект.Записать();				
			Исключение
				ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
				"Обновление данных при переходе с версии 1.0 на 2.1, обработка ролей пользователей"
				, УровеньЖурналаРегистрации.Ошибка
				,, Выборка.Ссылка, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
			КонецПопытки;	
			
		КонецЕсли;
		
	КонецЦикла;
	
#КонецОбласти	
		
#Область Обработка_Констант

	// Выравнивание.
	
	Если ЗначениеЗаполнено(Константы.ВерсияКлассификатораБанковРФ_OLD.Получить())
		И НЕ ЗначениеЗаполнено(Константы.ВерсияКлассификатораБанков.Получить().Получить()) Тогда
		
		СведенияОКлассификаторе = Новый Структура;
		СведенияОКлассификаторе.Вставить("ДатаМодификации", ТекущаяУниверсальнаяДата());
		СведенияОКлассификаторе.Вставить("ДатаЗагрузки", ТекущаяДатаСеанса());
		
		Попытка
			Константы.ВерсияКлассификатораБанков.Установить(Новый ХранилищеЗначения(СведенияОКлассификаторе));
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка константы ВерсияКлассификатораБанковРФ_OLD"
			, УровеньЖурналаРегистрации.Ошибка
			,, Выборка.Ссылка, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));	
		КонецПопытки;
		
	КонецЕсли;

#КонецОбласти

#Область Обработка_Справочников

	// Выравнивание.
	
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ
	|	ВидыКонтактнойИнформации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыКонтактнойИнформации КАК ВидыКонтактнойИнформации
	|ГДЕ
	|	(ВидыКонтактнойИнформации.ХранитьИсториюИзменений_OLD = ИСТИНА
	|			ИЛИ ВидыКонтактнойИнформации.ТолькоНациональныйАдрес_OLD = ИСТИНА
	|			ИЛИ ВидыКонтактнойИнформации.ПроверятьКорректность_OLD = ИСТИНА
	|			ИЛИ ВидыКонтактнойИнформации.ВключатьСтрануВПредставление_OLD = ИСТИНА
	|			ИЛИ ВидыКонтактнойИнформации.ВидРедактирования_OLD <> """")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Кассы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	НЕ Кассы.ФорматТелефонногоНомераДляОтправкиЭлектронныхЧековККМ_OLD = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Организации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	(НЕ Организации.СистемаНалогообложенияДляАвансов_OLD = ЗНАЧЕНИЕ(Перечисление.ТипыСистемНалогообложенияККТ.ПустаяСсылка)
	|			ИЛИ НЕ Организации.СистемаНалогообложенияДляТоваров_OLD = ЗНАЧЕНИЕ(Перечисление.ТипыСистемНалогообложенияККТ.ПустаяСсылка)
	|			ИЛИ НЕ Организации.СтавкаНДСДляАвансов_OLD = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.ПустаяСсылка))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Специализации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Специализации КАК Специализации
	|ГДЕ
	|	Специализации.СтоматологическиеУслуги_OLD = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтраныМира.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтраныМира КАК СтраныМира
	|ГДЕ
	|	(СтраныМира.УчастникЕАЭС_OLD = ИСТИНА
	|			ИЛИ СтраныМира.МеждународноеНаименование_OLD <> """")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПодключаемоеОборудование.Ссылка КАК Ссылка,
	|	ПодключаемоеОборудование.УстройствоОтключено КАК УстройствоОтключено,
	|	ПодключаемоеОборудование.ОбработчикДрайвера_Удалить КАК ОбработчикДрайвера_Удалить,
	|	ЕСТЬNULL(ПодключаемоеОборудование.ТипОборудования, ЗНАЧЕНИЕ(Перечисление.ТипыПодключаемогоОборудования.ПустаяСсылка)) КАК ТипОборудования,
	|	ПодключаемоеОборудование.ОбработчикДрайвера_Удалить.Порядок КАК ОбработчикДрайвера_УдалитьПорядок
	|ИЗ
	|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
	|ГДЕ
	|	ПодключаемоеОборудование.ДрайверОборудования.Ссылка ЕСТЬ NULL
	|	И НЕ ПодключаемоеОборудование.ОбработчикДрайвера_Удалить = ЗНАЧЕНИЕ(Перечисление.ОбработчикиДрайверовПодключаемогоОборудования.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыМедицинскихКарт.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыМедицинскихКарт КАК ВидыМедицинскихКарт
	|ГДЕ
	|	(ВидыМедицинскихКарт.ПечатнаяФорма = ЗНАЧЕНИЕ(Перечисление.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_СССР_А4_OLD)
	|			ИЛИ ВидыМедицинскихКарт.ПечатнаяФорма = ЗНАЧЕНИЕ(Перечисление.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_СССР_А5_OLD)
	|			ИЛИ ВидыМедицинскихКарт.ПечатнаяФорма = ЗНАЧЕНИЕ(Перечисление.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_СССР_А4_ДОИ_OLD)
	|			ИЛИ ВидыМедицинскихКарт.ПечатнаяФорма = ЗНАЧЕНИЕ(Перечисление.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_СССР_А5_ДОИ_OLD))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СкидкиНаценки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СкидкиНаценки КАК СкидкиНаценки
	|ГДЕ
	|	НЕ СкидкиНаценки.ЭтоГруппа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШаблоныТекстаРеквизитовОбследований.Ссылка КАК Ссылка,
	|	Диагнозы.Ссылка КАК Диагноз
	|ИЗ
	|	Справочник.ШаблоныТекстаРеквизитовОбследований КАК ШаблоныТекстаРеквизитовОбследований
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Диагнозы КАК Диагнозы
	|		ПО ШаблоныТекстаРеквизитовОбследований.ПодчиненДиагнозу_УДАЛИТЬ.Наименование = Диагнозы.Наименование
	|			И ШаблоныТекстаРеквизитовОбследований.ПодчиненДиагнозу_УДАЛИТЬ.Код = Диагнозы.Код
	|ГДЕ
	|	НЕ ШаблоныТекстаРеквизитовОбследований.ПодчиненДиагнозу_УДАЛИТЬ.Ссылка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВариантыОтчетов.Ссылка КАК Ссылка,
	|	ВариантыОтчетов.Администратор.Сотрудник КАК АдминистраторСотрудник
	|ИЗ
	|	Справочник.ВариантыОтчетов КАК ВариантыОтчетов
	|ГДЕ
	|	НЕ ВариантыОтчетов.ПометкаУдаления
	|	И ВариантыОтчетов.Автор.Ссылка ЕСТЬ NULL
	|	И ВариантыОтчетов.Администратор ССЫЛКА Справочник.Пользователи
	|	И НЕ ВариантыОтчетов.Администратор.Ссылка ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПрофилиГруппДоступаРоли.Ссылка КАК Ссылка,
	|	ПрофилиГруппДоступаРоли.Роль КАК Роль
	|ИЗ
	|	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ПрофилиГруппДоступаРоли.Роль) = ТИП(СТРОКА)
	|ИТОГИ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ЭтоГруппа
	|	И (Контрагенты.СоциальныйСтатус.Ссылка ЕСТЬ NULL
	|		И НЕ Контрагенты.СоциальныйСтатус_Удалить.Ссылка ЕСТЬ NULL)");
	
	//| (Контрагенты.ГруппаКрови = ЗНАЧЕНИЕ(Перечисление.ГруппыКрови.ПустаяСсылка)
	//|		И НЕ ДЛИНАСТРОКИ(Контрагенты.ГруппаКрови_Удалить) = 0) ИЛИ
		
	РезультатыЗапроса = Запрос.ВыполнитьПакет();

	// Спр. ВидыКонтактнойИнформации	
	ВыборкаВидыКИ = РезультатыЗапроса[0].Выбрать();
	Пока ВыборкаВидыКИ.Следующий() Цикл
		
		ВидКИОбъект = ВыборкаВидыКИ.Ссылка.ПолучитьОбъект();	
		
		Если ВидКИОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		// В ТолькоНациональныйАдрес (новой стомы) попадает информация из реквизита АдресТолькоРоссийский (старой стомы).
		// Чтоб не создавать еще один реквизит и перегонять данные сделаем по другому.
		// Реквизит ТолькоНациональныйАдрес мы всеравно перезапишем ниже!
		
		ВидКИОбъект.АдресТолькоРоссийский = ВидКИОбъект.ТолькоНациональныйАдрес;
		
		ВидКИОбъект.ХранитьИсториюИзменений = ВидКИОбъект.ХранитьИсториюИзменений_OLD;
		ВидКИОбъект.ТолькоНациональныйАдрес = ВидКИОбъект.ТолькоНациональныйАдрес_OLD;
		ВидКИОбъект.ПроверятьКорректность = ВидКИОбъект.ПроверятьКорректность_OLD;
		ВидКИОбъект.ВключатьСтрануВПредставление =  ВидКИОбъект.ВключатьСтрануВПредставление_OLD;
		ВидКИОбъект.ВидРедактирования = ВидКИОбъект.ВидРедактирования_OLD;
		
		ВидКИОбъект.ОбменДанными.Загрузка = Истина;
		
		Попытка			
			ВидКИОбъект.Записать();				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка Справочника ВидыКонтактнойИнформации."
			, УровеньЖурналаРегистрации.Ошибка
			,, ВидКИОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
	
	КонецЦикла;
	
	// Спр. Кассы	
	ВыборкаКассы = РезультатыЗапроса[1].Выбрать();
	Пока ВыборкаКассы.Следующий() Цикл
		
		КассаОбъект = ВыборкаКассы.Ссылка.ПолучитьОбъект();	
		
		Если КассаОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		КассаОбъект.ФорматТелефонногоНомераДляОтправкиЭлектронныхЧековККМ = КассаОбъект.ФорматТелефонногоНомераДляОтправкиЭлектронныхЧековККМ_OLD;
		
		КассаОбъект.ОбменДанными.Загрузка = Истина;
		
		Попытка			
			КассаОбъект.Записать();				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка Справочника Кассы."
			, УровеньЖурналаРегистрации.Ошибка
			,, КассаОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
	
	КонецЦикла;
	
	// Спр. Организации	
	ВыборкаОрганизации = РезультатыЗапроса[2].Выбрать();
	Пока ВыборкаОрганизации.Следующий() Цикл
		
		ОрганизацияОбъект = ВыборкаОрганизации.Ссылка.ПолучитьОбъект();	
		
		Если ОрганизацияОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		ОрганизацияОбъект.СистемаНалогообложенияДляАвансов = ОрганизацияОбъект.СистемаНалогообложенияДляАвансов_OLD;
		ОрганизацияОбъект.СистемаНалогообложенияДляТоваров = ОрганизацияОбъект.СистемаНалогообложенияДляТоваров_OLD;
		ОрганизацияОбъект.СПриоритетомНоменклатуры = ОрганизацияОбъект.СПриоритетомНоменклатуры_OLD;
		ОрганизацияОбъект.СтавкаНДСДляАвансов = ОрганизацияОбъект.СтавкаНДСДляАвансов_OLD;
		
		ОрганизацияОбъект.ОбменДанными.Загрузка = Истина;
		
		Попытка			
			ОрганизацияОбъект.Записать();				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка Справочника Организации."
			, УровеньЖурналаРегистрации.Ошибка
			,, ОрганизацияОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
	
	КонецЦикла;
	
	// Спр. Специализации	
	ВыборкаСпециализации = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаСпециализации.Следующий() Цикл
		
		СпециализацияОбъект = ВыборкаСпециализации.Ссылка.ПолучитьОбъект();	
		
		Если СпециализацияОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		СпециализацияОбъект.СтоматологическиеУслуги = СпециализацияОбъект.СтоматологическиеУслуги_OLD;
		
		СпециализацияОбъект.ОбменДанными.Загрузка = Истина;
		
		Попытка			
			СпециализацияОбъект.Записать();				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка Справочника Специализации."
			, УровеньЖурналаРегистрации.Ошибка
			,, СпециализацияОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
	
	КонецЦикла;
		
	// Спр. СтраныМира	
	ВыборкаСтраныМира = РезультатыЗапроса[4].Выбрать();
	Пока ВыборкаСтраныМира.Следующий() Цикл
		
		СтранаМираОбъект = ВыборкаСтраныМира.Ссылка.ПолучитьОбъект();	
		
		Если СтранаМираОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		СтранаМираОбъект.УчастникЕАЭС = СтранаМираОбъект.УчастникЕАЭС_OLD;
		СтранаМираОбъект.МеждународноеНаименование = СтранаМираОбъект.МеждународноеНаименование_OLD;
		
		СтранаМираОбъект.ОбменДанными.Загрузка = Истина;
		
		Попытка			
			СтранаМираОбъект.Записать();				
		Исключение
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"Обновление данных при переходе с версии 1.0 на 2.1, обработка Справочника СтраныМира."
			, УровеньЖурналаРегистрации.Ошибка
			,, СтранаМираОбъект, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));		
		КонецПопытки;
	
	КонецЦикла;
	
	// Спр. ПодключаемоеОборудование
	МассивДрайверов = Метаданные.Справочники.ДрайверыОборудования.ПолучитьИменаПредопределенных();
	КоллекцияЗначенийПеречисления = Метаданные.Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ЗначенияПеречисления;	
	
	ВыборкаПодклОборудование = РезультатыЗапроса[5].Выбрать();
	Пока ВыборкаПодклОборудование.Следующий() Цикл
		
		ПодклОборудованиеОбъект = ВыборкаПодклОборудование.Ссылка.ПолучитьОбъект();	
		
		Если ПодклОборудованиеОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		
		//ТипОборудования.Телефония -> ТипОборудования.IPТелефония
