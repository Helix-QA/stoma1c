
#Область ОбработчикиСобытий

// Процедура - Обработка заполнения
//
// Параметры:
//  ДанныеЗаполнения	 - 	 - 
//  ТекстЗаполнения		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если НЕ ЭтоГруппа Тогда 
		ДатаСоздания 	= ТекущаяДатаСеанса();
		Автор 			= ПараметрыСеанса.ТекущийСотрудник;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обработка проверки заполнения
//
// Параметры:
//  Отказ				 - 	 - 
//  ПроверяемыеРеквизиты - 	 - 
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если НЕ ОбменДанными.Загрузка = Истина Тогда 
		ПроверяемыеРеквизиты.Добавить("SMSВремяНачалаОтправки"); 
		ПроверяемыеРеквизиты.Добавить("SMSВремяОкончанияОтправки"); 
	КонецЕсли;
	
	ПроверитьКорректностьУказанныхПараметров(Отказ);
	
КонецПроцедуры

// Процедура - Перед записью
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПередЗаписью(Отказ)
	
	Если НЕ ЭтоГруппа Тогда
		Если НЕ ЗначениеЗаполнено(Автор) Тогда 
			Автор = ПараметрыСеанса.ТекущийСотрудник;
		КонецЕсли;
	КонецЕсли;
	
	ОбновитьСодержаниеШаблонаМессенджер();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура - Проверить корректность указанных параметров
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПроверитьКорректностьУказанныхПараметров(Отказ, Сообщать = Истина, ОчищатьНеКорректныеПараметры = Ложь)

	Если Справочники.ШаблоныСообщений.ШаблонИспользуетсяВТриггерныхСобытиях(Ссылка) Тогда 
		ТаблицаВсехПараметров 			= ОбщегоНазначенияПовтИсп.ПолучитьТаблицуПараметровВсехПодставляемыхРеквизитов();
		Содержание_Проверочное 			= Содержание;
		ПарсерHTML 						= Новый ЧтениеHTML;
		ПарсерHTML.УстановитьСтроку(ТекстHTML);
		ПостроительDOM 					= Новый ПостроительDOM;
		ДокументHTML 					= ПостроительDOM.Прочитать(ПарсерHTML);
		Если ДокументHTML.Тело = Неопределено Тогда 
			ТекстHTML_Проверочное 		= "";
		Иначе 	
			ТекстHTML_Проверочное 		= ДокументHTML.Тело.ТекстовоеСодержимое;
		КонецЕсли;	
		ЗадачаОписание_Проверочное 		= ЗадачаОписание;
		
		Для Каждого СтрокаТаблицы Из ТаблицаВсехПараметров Цикл
			Содержание_Проверочное 		= СтрЗаменить(Содержание_Проверочное	, СтрокаТаблицы.НаименованиеПараметра, ""); 
			ТекстHTML_Проверочное 		= СтрЗаменить(ТекстHTML_Проверочное		, СтрокаТаблицы.НаименованиеПараметра, ""); 
			ЗадачаОписание_Проверочное 	= СтрЗаменить(ЗадачаОписание_Проверочное, СтрокаТаблицы.НаименованиеПараметра, ""); 
		КонецЦикла;	
		
		Если ЗначениеЗаполнено(СокрЛП(Содержание_Проверочное)) Тогда 
			МассивНеКорректныхПараметров = Справочники.ШаблоныСообщений.ВернутьМассивНекорректныхПараметров(Содержание_Проверочное);
			Если МассивНеКорректныхПараметров.Количество() <> 0 Тогда 
				Отказ = Истина;
				СообщениеоНекорректныхПараметрах = НСтр("ru='В содержании сообщения указан некорректный параметр(ы) или символ(ы):';en='The message contains an invalid parameter or characters:'") + Символы.ПС + СтрСоединить(МассивНеКорректныхПараметров, Символы.ПС);
				Если Сообщать Тогда 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеоНекорректныхПараметрах, ЭтотОбъект, "Содержание");
				КонецЕсли;
				Если ОчищатьНеКорректныеПараметры Тогда 
					
				Иначе 	
					Возврат;
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СокрЛП(ТекстHTML_Проверочное)) Тогда 
			МассивНеКорректныхПараметров = Справочники.ШаблоныСообщений.ВернутьМассивНекорректныхПараметров(ТекстHTML_Проверочное);
			Если МассивНеКорректныхПараметров.Количество() <> 0 Тогда 
				Отказ = Истина;
				СообщениеоНекорректныхПараметрах = НСтр("ru='В содержании электронного письма указан некорректный параметр(ы) или символ(ы):';en='The email contains an invalid parameter or characters:'") + Символы.ПС + СтрСоединить(МассивНеКорректныхПараметров, Символы.ПС);
				Если Сообщать Тогда 				
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеоНекорректныхПараметрах, ЭтотОбъект, "ТекстHTML");
				КонецЕсли;
				Если ОчищатьНеКорректныеПараметры Тогда 
					
				Иначе 					
					Возврат;
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СокрЛП(ЗадачаОписание_Проверочное)) Тогда 
			МассивНеКорректныхПараметров = Справочники.ШаблоныСообщений.ВернутьМассивНекорректныхПараметров(ЗадачаОписание_Проверочное);
			Если МассивНеКорректныхПараметров.Количество() <> 0 Тогда 
				Отказ = Истина;
				СообщениеоНекорректныхПараметрах = НСтр("ru='В содержании описания задачи указан некорректный параметр(ы) или символ(ы):';en='The problem description contains an invalid parameter or characters:'") + Символы.ПС + СтрСоединить(МассивНеКорректныхПараметров, Символы.ПС);
				Если Сообщать Тогда 				
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеоНекорректныхПараметрах, ЭтотОбъект, "ЗадачаОписание");
				КонецЕсли;
				Если ОчищатьНеКорректныеПараметры Тогда 
					
				Иначе 					
					Возврат;
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обновляет содержание шаблона сообщения в мессенджер.
//
Процедура ОбновитьСодержаниеШаблонаМессенджер()
	
	Если ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СодержаниеМессенджерHTML) Тогда
		СодержаниеМессенджер = "";
		Возврат;
	КонецЕсли;
	
	Если Не ОбщегоНазначенияКлиентСервер.ПолучитьЗначениеИзСтруктуры(ДополнительныеСвойства, "ОбновитьСодержаниеМессенджер", Ложь)
		И ОбщегоНазначения.ПолучитьЗначениеРеквизита(Ссылка, "СодержаниеМессенджерHTML") = СодержаниеМессенджерHTML Тогда
		
		// Параметр принудительного обновления не передан, содержание не изменилось - ничего не делаем.
		Возврат;
	КонецЕсли;
	
	СодержаниеМессенджер = Справочники.ШаблоныСообщений.ПолучитьТекстИзHTMLКода(СодержаниеМессенджерHTML);
	
КонецПроцедуры

#КонецОбласти
