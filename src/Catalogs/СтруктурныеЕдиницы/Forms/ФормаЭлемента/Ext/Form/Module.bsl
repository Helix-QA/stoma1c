// Процедура, открывает картинку.
//
Процедура ОткрытьКартинку(ФайлКартинки)
	
	ДанныеФайла = ПолучитьДанныеФайла(ФайлКартинки); // ЭтаФорма.УникальныйИдентификатор);
	
	Если ДанныеФайла <> Неопределено Тогда 
		Попытка
			РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла); 
		Исключение  
			ЗаписатьВЖурналРегистрации("ОткрытиеЛоготипаВиджета");
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

