// Процедура - Обработка оповещения об успешности оплаты
//
// Параметры:
//  ЭтаФорма	 - 	 - 
//  Параметры	 - 	 - 
//  Объект		 - 	 - 
//
Процедура ОбработкаОповещенияОбУспешностиОплатыСБП(ЭтаФорма, Параметры, ЭтоВозврат = Ложь) Экспорт
	
	ОповеститьПользователя = Ложь;
	Если ТипЗнч(Параметры) <> Тип("Структура") ИЛИ Не Параметры.Свойство("ОснованиеОплаты") ИЛИ Не ЗначениеЗаполнено(Параметры.ОснованиеОплаты) ИЛИ ЭтаФорма.Открыта() = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	Если (ЭтаФорма.ИмяФормы = "Обработка.ПомощникПроведенияОплаты.Форма.ФормаОплаты" 
		ИЛИ ЭтаФорма.ИмяФормы = "Обработка.ПомощникПроведенияОплаты.Форма.ДиалогВзносаНаЛицевойСчет") 
		И ЭтаФорма.Контрагент = Параметры.Контрагент Тогда
		
		ЭтаФорма.Закрыть();
		ОповеститьПользователя = Истина;						
		
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтаФорма, "Объект")
		И (ТипЗнч(ЭтаФорма.Объект.Ссылка) = Тип("ДокументСсылка.Реализация") 
		ИЛИ ТипЗнч(ЭтаФорма.Объект.Ссылка) = Тип("ДокументСсылка.ВозвратОтПокупателя")
		ИЛИ ТипЗнч(ЭтаФорма.Объект.Ссылка) = Тип("ДокументСсылка.Прием")
		ИЛИ ТипЗнч(ЭтаФорма.Объект.Ссылка) = Тип("ДокументСсылка.ПланЛечения")
		ИЛИ ТипЗнч(ЭтаФорма.Объект.Ссылка) = Тип("ДокументСсылка.НарядЗаказ"))
		И СтрРазделить(Параметры.СтрокаОснований, ",", Ложь).Найти(Строка(ЭтаФорма.Объект.Ссылка.УникальныйИдентификатор())) <> Неопределено Тогда
		
		ЭтаФорма.Закрыть();					
		
	КонецЕсли;
	
	Если ОповеститьПользователя И ЭтоВозврат = Ложь Тогда		
		ПоказатьОповещениеПользователя("Система быстрых платежей", ПолучитьНавигационнуюСсылку(Параметры.ОснованиеОплаты), "Оплата по СБП успешно проведена",,, "СБП_УспешнаяОплата" + Параметры.transaction_id);	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти