// Функция - Получить вид лицевого счета
//
// Параметры:
//  ТипОплаты						 - 	 - 
//  ТаблицаВидовЛицевыхСчетовВБазе	 - 	 - 
//  Организация						 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВидЛицевогоСчета(ТипОплаты, ТаблицаВидовЛицевыхСчетовВБазе, Организация = Неопределено)
	
	СтруктураВидЛС = Неопределено;
	
	Если ТипОплаты = 4 Тогда
		СтрокаВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Найти("Бартер", "Наименование");
		Если НЕ СтрокаВидЛС = Неопределено Тогда
			СтруктураВидЛС = СтрокаВидЛС;
		КонецЕсли;	
	ИначеЕсли ТипОплаты = 6 Тогда
		СтрокаВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Найти("Бонусный", "Наименование");
		Если НЕ СтрокаВидЛС = Неопределено Тогда
			СтруктураВидЛС = СтрокаВидЛС;
		КонецЕсли;	
	Иначе
		СтрокаВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Найти(Справочники.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет, "Ссылка");
		Если НЕ СтрокаВидЛС = Неопределено Тогда
			СтруктураВидЛС = СтрокаВидЛС;
		КонецЕсли;	
	КонецЕсли;		
	
	Возврат СтруктураВидЛС;
	
КонецФункции

// Функция - Вернуть лицевой счет контрагента
//
// Параметры:
//  Контрагент		 - 	 - 
//  Дата			 - 	 - 
//  ВидЛицевогоСчета - 	 - 
//  Организация		 - 	 - 
//  НомерЛС			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьЛицевойСчетКонтрагента(Контрагент, Дата, ВидЛицевогоСчета = Неопределено, Организация = Неопределено, НомерЛС=Неопределено) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЛицевыеСчета.Ссылка КАК Ссылка,
	               |	ЛицевыеСчета.ВладелецЛицевогоСчета КАК ВладелецЛицевогоСчета
	               |ИЗ
	               |	Справочник.ЛицевыеСчета КАК ЛицевыеСчета
	               |ГДЕ
				   |    1=1
	               |	"+?(НомерЛС = Неопределено,"и ЛицевыеСчета.ВладелецЛицевогоСчета = &Контрагент","И ЛицевыеСчета.КодСинхронизации = &КодСинхронизации И ЛицевыеСчета.ПрефиксСинхронизации = &ПрефиксСинхронизации")+"
	               |	"+?(ВидЛицевогоСчета = Неопределено,"","И ЛицевыеСчета.ВидЛицевогоСчета = &ВидЛицевогоСчета")+"
				   |";
				   
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("КодСинхронизации", НомерЛС);
	Запрос.УстановитьПараметр("ПрефиксСинхронизации", ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Контрагент, "ПрефиксСинхронизации"));
	Запрос.УстановитьПараметр("ВидЛицевогоСчета", ВидЛицевогоСчета);
	        
	ТаблицаЛС = Запрос.Выполнить().Выгрузить();
	
	Если ТаблицаЛС.Количество() = 0 Тогда
		
		Возврат Неопределено;
		
	ИначеЕсли Контрагент = ТаблицаЛС[0].ВладелецЛицевогоСчета Тогда
		
		Возврат ТаблицаЛС[0].Ссылка;
		
	Иначе
		
		РодственнаяЗапись = РегистрыСведений.РодственныеСвязи.СоздатьНаборЗаписей();
		РодственнаяЗапись.ДополнительныеСвойства.Вставить("НеТребуетсяОбратнаяЗапись", Истина);
		РодственнаяЗапись.Отбор.Контрагент.Значение = Контрагент;
		РодственнаяЗапись.Отбор.Контрагент.Использование = Истина;
		РодственнаяЗапись.Отбор.Родственник.Значение = ТаблицаЛС[0].ВладелецЛицевогоСчета;
		РодственнаяЗапись.Отбор.Родственник.Использование = Истина;
		НоваяЗапись                    		= РодственнаяЗапись.Добавить();
		НоваяЗапись.Период		            = Дата("20010101000000");
		НоваяЗапись.Контрагент              = Контрагент;
		НоваяЗапись.Родственник             = ТаблицаЛС[0].ВладелецЛицевогоСчета;
		НоваяЗапись.СтепеньРодства          = ПолучитьСтепеньРодстваПрочее();
		НоваяЗапись.ОбщийЛицевойСчет        = Истина;
		НоваяЗапись.ОбщийНакопительныйСчет  = Истина;
		НоваяЗапись.ОбщийБонусныйСчет       = Истина;
		НоваяЗапись.ЗаконныйПредставитель   = Истина;
		РодственнаяЗапись.Записать(Истина);
		
		РодственнаяЗапись = РегистрыСведений.РодственныеСвязи.СоздатьНаборЗаписей();
		РодственнаяЗапись.ДополнительныеСвойства.Вставить("НеТребуетсяОбратнаяЗапись", Истина);
		РодственнаяЗапись.Отбор.Контрагент.Значение = ТаблицаЛС[0].ВладелецЛицевогоСчета;
		РодственнаяЗапись.Отбор.Контрагент.Использование = Истина;
		РодственнаяЗапись.Отбор.Родственник.Значение = Контрагент;
		РодственнаяЗапись.Отбор.Родственник.Использование = Истина;
		НоваяЗапись                    		= РодственнаяЗапись.Добавить();
		НоваяЗапись.Период		            = Дата("20010101000000");
		НоваяЗапись.Контрагент              = ТаблицаЛС[0].ВладелецЛицевогоСчета;
		НоваяЗапись.Родственник             = Контрагент;
		НоваяЗапись.СтепеньРодства          = ПолучитьСтепеньРодстваПрочее();
		НоваяЗапись.ОбщийЛицевойСчет        = Истина;
		НоваяЗапись.ОбщийНакопительныйСчет  = Истина;
		НоваяЗапись.ОбщийБонусныйСчет       = Истина;
		НоваяЗапись.ЗаконныйПредставитель   = Истина;
		РодственнаяЗапись.Записать(Истина);
		
		Возврат ТаблицаЛС[0].Ссылка;
		
	КонецЕсли;
		
КонецФункции

// Функция - Создать лицевой счет контрагента
//
// Параметры:
//  Контрагент		 - 	 - 
//  ВидЛицевогоСчета - 	 - 
//  Организация		 - 	 - 
//  ДатаОткрытия	 - 	 - 
//  НомерЛС			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьЛицевойСчетКонтрагента(Контрагент, ВидЛицевогоСчета, Организация = Неопределено, ДатаОткрытия = Неопределено, НомерЛС = Неопределено)
	
	ЛицевойСчетКонтрагентаОбъект 						= Справочники.ЛицевыеСчета.СоздатьЭлемент();
	ЛицевойСчетКонтрагентаОбъект.Заполнить(Новый Структура("СтруктураДанныхПриПроведенииДенежныхСредств", Новый Структура("Владелец, Сертификат, ВидЛицевогоСчета, ДатаОткрытия", Контрагент, Неопределено, ВидЛицевогоСчета, Неопределено)));				
	ЛицевойСчетКонтрагентаОбъект.УстановитьНовыйКод();																													
	ЛицевойСчетКонтрагентаОбъект.ОбменДанными.Загрузка 	= Истина;
	ЛицевойСчетКонтрагентаОбъект.КодСинхронизации 		= ?(НомерЛС = Неопределено, 0, НомерЛС);
	ЛицевойСчетКонтрагентаОбъект.ПрефиксСинхронизации 	= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Контрагент, "ПрефиксСинхронизации");
	ЛицевойСчетКонтрагентаОбъект.Комментарий 			= ЛицевойСчетКонтрагентаОбъект.ПрефиксСинхронизации + " - " + ЛицевойСчетКонтрагентаОбъект.КодСинхронизации;	
	ЛицевойСчетКонтрагентаОбъект.Записать();
	
	Возврат ЛицевойСчетКонтрагентаОбъект.Ссылка;
	
КонецФункции

// Функция - Получить степень родства прочее
// 
