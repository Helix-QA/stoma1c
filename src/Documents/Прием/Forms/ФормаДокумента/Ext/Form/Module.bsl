	Если ФормаРезультатПриема = 2 Тогда		
		ФормаПовторныйПриемИнтервал     = 1;
		ФормаИнтервалПередПриемом       = 2;
		ДлительностьПриема              = 60;
	КонецЕсли; 
	
	Элементы.ФормаКнопкаПровестиИЗакрытьРезультатПриема.Доступность    = НЕ ФормаРезультатПриема = 0;
	Элементы.ГруппаФормаКнопкаПровестиИЗакрытьРезультатПриема.ЦветФона = ?(ФормаРезультатПриема = 0, Новый Цвет(242, 242, 242), Новый Цвет(25, 116, 206));
	Элементы.ФормаКнопкаПровестиИЗакрытьРезультатПриема.ЦветТекста 	   = ?(ФормаРезультатПриема = 0, Новый Цвет(77, 77, 77)   , Новый Цвет(255, 255, 255));
	
