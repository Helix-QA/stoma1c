
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КлиентЗаполнен = Параметры.Свойство("Клиент", ЭтотОбъект.Клиент);
	
	Элементы.ГруппаСозданиеКлиента.Видимость = Не КлиентЗаполнен;
	
	Если ЗначениеЗаполнено(Клиент) Тогда
		ДоступныеВидыСделок = Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, ЭтотОбъект.Клиент,,,,, Истина);
	Иначе
		ДоступныеВидыСделок = Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Неопределено,,,, Истина, Истина);
	КонецЕсли;
	
	Для Каждого ВидСделки Из ДоступныеВидыСделок Цикл
		СоздатьЭлементыВариантаДействия(ВидСделки);
	КонецЦикла;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ЗаписатьНаПрием(Команда)
	
	Закрыть("ЗаписатьНаПрием");
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура СоздатьКлиента(Команда)
	
	Закрыть("СоздатьКлиента");
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ВыбратьКлиента(Команда)
	
	Закрыть("ВыбратьКлиента");
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ЗаписатьНаПриемПоВидуСделки(Команда)
	
	ТекущийЭлемент			 = ЭтотОбъект.ТекущийЭлемент;
	ИдентификаторВидаСделки	 = Новый УникальныйИдентификатор(СтрЗаменить(Сред(ТекущийЭлемент.Имя, СтрНайти(ТекущийЭлемент.Имя, "_") + 1), "_", "-"));
	
	Закрыть(ИдентификаторВидаСделки);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, создает элементы варианта действия.
//
Процедура СоздатьЭлементыВариантаДействия(ВидСделки)
	
	ИдентификаторВидаСделки = СтрЗаменить(Строка(ВидСделки.УникальныйИдентификатор()), "-", "_");
	
	ГруппаВарианта										 = Элементы.Добавить("ГруппаВида_" + ИдентификаторВидаСделки, Тип("ГруппаФормы"), Элементы.ГруппаДополнительныеВарианты);
	ГруппаВарианта.Вид									 = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаВарианта.ЦветФона								 = Новый Цвет(240, 240, 240);
	ГруппаВарианта.Высота								 = 3;
	ГруппаВарианта.Отображение							 = ОтображениеОбычнойГруппы.Нет;
	ГруппаВарианта.ОтображатьЗаголовок					 = Ложь;
	ГруппаВарианта.РастягиватьПоГоризонтали				 = Истина;
	ГруппаВарианта.ГоризонтальноеПоложениеПодчиненных	 = ГоризонтальноеПоложениеЭлемента.Центр;
	ГруппаВарианта.ВертикальноеПоложениеПодчиненных		 = ВертикальноеПоложениеЭлемента.Центр;
	
	КнопкаВарианта						 = Элементы.Добавить("КнопкаВида_" + ИдентификаторВидаСделки, Тип("КнопкаФормы"), ГруппаВарианта);
	КнопкаВарианта.ОтображениеФигуры	 = ОтображениеФигурыКнопки.Нет;
	КнопкаВарианта.Заголовок			 = НСтр("ru = 'Записать на прием + '") + ВидСделки;
	КнопкаВарианта.Шрифт				 = Новый Шрифт(, 16);
	КнопкаВарианта.МаксимальнаяШирина	 = 55;
	КнопкаВарианта.ИмяКоманды			 = "ЗаписатьНаПриемПоВидуСделки";
	
КонецПроцедуры

#КонецОбласти
