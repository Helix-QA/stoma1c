КонецПроцедуры

&НаКлиенте
// Процедура - Добавить и выбрать контрагента завершение
// 
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
// 
Процедура ДобавитьИВыбратьКонтрагентаЗавершение(Результат, Параметры) Экспорт
	
	Если Не Результат.Пустая() Тогда
		Объект.Контрагент = Результат;
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик события "ИсточникИнформацииКлиентНачалоВыбораЗавершение"
//
Процедура ИсточникИнформацииКлиентНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Объект.ИсточникИнформацииКлиент = Результат;		
	КонецЕсли;	

КонецПроцедуры  

&НаКлиенте
// Процедура, обработчик события "СтруктурнаяЕдиницаНадписьНажатиеЗавершение"
//
Процедура СтруктурнаяЕдиницаНадписьНажатиеЗавершение(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
	   Если Объект.СтруктурнаяЕдиница <> Результат Тогда
	     Объект.СтруктурнаяЕдиница = Результат;
	     Элементы.СтруктурнаяЕдиницаНадпись.Заголовок = Объект.СтруктурнаяЕдиница;
	   КонецЕсли;
   КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Вернет список клиентов по части телефонного номера 
//
Функция ПолучитьСписокТелефонныхНомеров(Номер)
	 
	// Получаем список клиентов по части телефонного номера
	НайденныеКлиенты = Справочники.МедицинскиеКарты.ПолучитьКонтрагентовПоНомеруТелефона(Номер, Истина);	
	СписокНомеров    = Новый СписокЗначений;
	
	Для Каждого Клиент Из НайденныеКлиенты Цикл
		
		СписокНомеров.Добавить(Новый Структура("Клиент,НомерТелефона",Клиент.Клиент, Клиент.НомерТелефона),Клиент.НомерТелефона+" " + Строка(Клиент.Клиент));
		
	КонецЦикла;

	Возврат СписокНомеров;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик команды ДобавитьИВыбратьКонтрагента
//
Процедура ДобавитьИВыбратьКонтрагента()
	
	ПараметрыОткрытия = Новый Структура;
	ГруппаКлиентов = ОбщегоНазначенияСтоматология.ВернутьГруппуКлиентов();
 
	ПараметрыОткрытия.Вставить("Родитель", ?(ЗначениеЗаполнено(ГруппаКлиентов), ГруппаКлиентов, ГруппаКонтрагентов));
	ПараметрыОткрытия.Вставить("ТекстЗаполнения", ИскомыйКлиент);  
	ПараметрыЗаполнения = Новый Структура("Основание", ПараметрыОткрытия);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьИВыбратьКонтрагентаЗавершение", ЭтаФорма);
	
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты", ПараметрыЗаполнения,,,,,ОписаниеОповещения);
	
КонецПроцедуры  

&НаСервере
// Веренет таблицу сохраняемых элементов
//
Функция ЭлементыДляСохранения()
	
	СохраняемыеЭлементы = Новый Структура("Контрагент,Задача",Объект.ЗадачаПредмет,Объект.Задача);
	
	Возврат СохранениеВводимыхЗначений.СформироватьТаблицуСохраненяемыхЭлементов(СохраняемыеЭлементы);
	
КонецФункции

&НаСервереБезконтекста
// Сформировать представление ссылки на ПЗ
//
Функция СформироватьПредставлениеПЗ(ДокСсылка)
	
	Если ДокСсылка.Услуги.Количество() > 0 Тогда
		Возврат "Запись на " + Формат(ДокСсылка.Услуги[0].ДатаНачала,"ДФ='dd MMMM yyyy H:mm'"); 
	Иначе
		Возврат Строка(ДокСсылка);
	КонецЕсли;

КонецФункции

&НаКлиенте
// Процедура, Обработчик события "ОбновитьТелефонныйНомерПоКлиенту".
//
Процедура ОбновитьТелефонныйНомерПоКлиенту()
	
	Если ТипЗнч(Объект.ЗадачаПредмет) = Тип("СправочникСсылка.Контрагенты") Тогда
		Если Не ЗначениеЗаполнено(Объект.ВходящийЗвонокНомерТелефона) Тогда 
			Объект.ВходящийЗвонокНомерТелефона = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.ЗадачаПредмет, "Телефон");
		КонецЕсли;
		Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийВзаимодействия.ТелефонныйЗвонокВходящий") И Не ЗначениеЗаполнено(Объект.ВходящийЗвонокАбонент) Тогда
			Объект.ВходящийЗвонокАбонент = Строка(Объект.ЗадачаПредмет);
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
                    


