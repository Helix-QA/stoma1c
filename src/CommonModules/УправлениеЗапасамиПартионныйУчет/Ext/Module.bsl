// Функция возвращает запрос по партиям товаров для списания
// Параметры:
// 		СпособОценкиМПЗ - Способ списания
//
Функция ПолучитьЗапросПартийДляСписания(СпособОценкиМПЗ)

	Запрос = Новый Запрос;
	Если  СпособОценкиМПЗ = Перечисления.СпособОценки.ПоСредней Тогда
    Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
                 |	х_ПартииТоваровОбороты.Номенклатура КАК Номенклатура,
                 |	х_ПартииТоваровОбороты.СтруктурнаяЕдиница,
				 |	х_ПартииТоваровОбороты.Склад,
                 |	х_ПартииТоваровОбороты.Партия,
                 |	СУММА(х_ПартииТоваровОбороты.КоличествоОборот) КАК Количество,
                 |	СУММА(х_ПартииТоваровОбороты.СтоимостьОборот) КАК Стоимость,
                 |	ВЫРАЗИТЬ(ЦенаНоменклатуры.ЦЕНА КАК ЧИСЛО(15, 2)) КАК Цена,
                 |	х_ПартииТоваровОбороты.ДокументПоступления КАК ДокументПоступления
                 |ИЗ
                 |	РегистрНакопления.ПартииТоваров.Обороты(
                 |			,
                 |			&Дата,
                 |			Регистратор,
                 |			(Номенклатура, СтруктурнаяЕдиница, Склад) В
                 |				(ВЫБРАТЬ
                 |					ТаблицаНоменклатуры.Номенклатура,
                 |					ТаблицаНоменклатуры.СтруктурнаяЕдиница,
				 |					ТаблицаНоменклатуры.Склад
                 |				ИЗ
                 |					ТаблицаНоменклатуры)) КАК х_ПартииТоваровОбороты
                 |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
                 |			х_ПартииТоваровОстаткиИОбороты.Номенклатура КАК Номенклатура,
                 |			х_ПартииТоваровОстаткиИОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
				 |			х_ПартииТоваровОстаткиИОбороты.Склад КАК Склад,
                 |			х_ПартииТоваровОстаткиИОбороты.Партия КАК Партия,
                 |			СУММА(х_ПартииТоваровОстаткиИОбороты.СтоимостьОборот) / ВЫБОР КОГДА ЕСТЬNULL(СУММА(х_ПартииТоваровОстаткиИОбороты.КоличествоОборот), 1)=0 ТОГДА 1 ИНАЧЕ  ЕСТЬNULL(СУММА(х_ПартииТоваровОстаткиИОбороты.КоличествоОборот), 1) КОНЕЦ КАК ЦЕНА
                 |		ИЗ
                 |			РегистрНакопления.ПартииТоваров.ОстаткиИОбороты(
                 |					,
                 |					&Дата,
                 |					Регистратор,
                 |					,
                 |					(Номенклатура, СтруктурнаяЕдиница, Склад) В
                 |						(ВЫБРАТЬ
                 |							ТаблицаНоменклатуры.Номенклатура,
				 |							ТаблицаНоменклатуры.СтруктурнаяЕдиница,				 
                 |							ТаблицаНоменклатуры.Склад
                 |						ИЗ
                 |							ТаблицаНоменклатуры)) КАК х_ПартииТоваровОстаткиИОбороты
                 |		ГДЕ
                 |			х_ПартииТоваровОстаткиИОбороты.Регистратор <> &Регистратор
                 |		
                 |		СГРУППИРОВАТЬ ПО
                 |			х_ПартииТоваровОстаткиИОбороты.Номенклатура,
                 |			х_ПартииТоваровОстаткиИОбороты.СтруктурнаяЕдиница,
				 |			х_ПартииТоваровОстаткиИОбороты.Склад,
                 |			х_ПартииТоваровОстаткиИОбороты.Партия) КАК ЦенаНоменклатуры
                 |		ПО х_ПартииТоваровОбороты.Номенклатура = ЦенаНоменклатуры.Номенклатура
				 |			И х_ПартииТоваровОбороты.СтруктурнаяЕдиница = ЦенаНоменклатуры.СтруктурнаяЕдиница
                 |			И х_ПартииТоваровОбороты.Склад = ЦенаНоменклатуры.Склад
                 |			И х_ПартииТоваровОбороты.Партия = ЦенаНоменклатуры.Партия
                 |ГДЕ
                 |	х_ПартииТоваровОбороты.Регистратор <> &Регистратор
                 |
                 |СГРУППИРОВАТЬ ПО
                 |	х_ПартииТоваровОбороты.ДокументПоступления,
                 |	х_ПартииТоваровОбороты.Номенклатура,
				 |	х_ПартииТоваровОбороты.СтруктурнаяЕдиница,
                 |	х_ПартииТоваровОбороты.Склад,
                 |	х_ПартииТоваровОбороты.Партия,
                 |	ВЫРАЗИТЬ(ЦенаНоменклатуры.ЦЕНА КАК ЧИСЛО(15, 2))
                 |
                 |УПОРЯДОЧИТЬ ПО
                 |	Номенклатура,
                 |	х_ПартииТоваровОбороты.ДокументПоступления.Дата,
                 |	ДокументПоступления";  	
		
	Иначе
	Запрос.Текст = "ВЫБРАТЬ
	             |	ПартииТоваровОстатки.ДокументПоступления КАК ДокументПоступления,
	             |	ПартииТоваровОстатки.Номенклатура КАК Номенклатура,
	             |	СУММА(ПартииТоваровОстатки.КоличествоОборот) КАК Количество,
	             |	СУММА(ПартииТоваровОстатки.СтоимостьОборот) КАК Стоимость,
	             |	ПартииТоваровОстатки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
				 |	ПартииТоваровОстатки.Склад КАК Склад,
	             |	ПартииТоваровОстатки.Партия
	             |ИЗ
	             |	РегистрНакопления.ПартииТоваров.ОстаткиИОбороты(, &Дата, Регистратор, , ) КАК ПартииТоваровОстатки
	             |ГДЕ
	             |	(ПартииТоваровОстатки.Номенклатура, ПартииТоваровОстатки.СтруктурнаяЕдиница, ПартииТоваровОстатки.Склад) В
	             |			(ВЫБРАТЬ
	             |				ТаблицаНоменклатуры.Номенклатура,
	             |				ТаблицаНоменклатуры.СтруктурнаяЕдиница,
				 |				ТаблицаНоменклатуры.Склад
	             |			ИЗ
	             |				ТаблицаНоменклатуры)
	             |	И ПартииТоваровОстатки.Регистратор <> &Регистратор
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ПартииТоваровОстатки.ДокументПоступления,
	             |	ПартииТоваровОстатки.Номенклатура,
	             |	ПартииТоваровОстатки.СтруктурнаяЕдиница,
				 |	ПартииТоваровОстатки.Склад,
	             |	ПартииТоваровОстатки.Партия          
			     |УПОРЯДОЧИТЬ ПО
			     |  Номенклатура,
			   	 |	ПартииТоваровОстатки.ДокументПоступления.Дата,
			     |	ПартииТоваровОстатки.ДокументПоступления";	
	КонецЕсли;

	Возврат Запрос;
	
КонецФункции // ПолучитьЗапросПартийДляСписания()

// Функция возвращает запрос по партиям товаров для возврата
// Параметры:
// 		СпособОценкиМПЗ - Способ списания
//
Функция ПолучитьЗапросПартийДляВозврата(СпособОценкиМПЗ)
	
	Запрос=новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ПартииТоваров.Регистратор КАК ОснованиеВозврата,
	             |	ПартииТоваров.Партия,
	             |	ПартииТоваров.ДокументПоступления,
	             |	ПартииТоваров.Номенклатура,
	             |	ПартииТоваров.Количество,
	             |	ПартииТоваров.Стоимость
	             |ИЗ
	             |	РегистрНакопления.ПартииТоваров КАК ПартииТоваров
	             |ГДЕ
	             |	(ПартииТоваров.Регистратор, ПартииТоваров.Номенклатура) В
	             |			(ВЫБРАТЬ
	             |				ТаблицаНоменклатуры.ОснованиеВозврата,
	             |				ТаблицаНоменклатуры.Номенклатура
	             |			ИЗ
	             |				ТаблицаНоменклатуры)"; 
	
	Возврат Запрос;

	
КонецФункции

// Процедура подготавливает табличную часть или таблицу к списанию, записывая результат в ТаблицаСписания
// Параметры:
// 		ТаблицаСписанияНоменклатуры - Таблица или табличная часть с номенклатурой;
// 		СтруктураДополнительныеСвойства - структура, дополнительные свойства.
//
Функция ПодготовитьТалицуКСписаниюОприходованиюПартий(ТаблицаСписанияНоменклатуры, СтруктураДополнительныеСвойства)
	
	СтруктураПолей = Новый Структура("Номенклатура, Склад, Количество, ОснованиеВозврата, Себестоимость, Партия, СтруктурнаяЕдиница", "Номенклатура", "ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)","Количество", """""", """""", "Партия", "ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)");
	СтруктураПолей.Вставить("ДокументПродажи", """""");
	СтруктураПолей.Вставить("ДокументПродажиСебестоимость", """""");
	СтруктураПолей.Вставить("Контрагент", "ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)");
	СтруктураПолей.Вставить("Сотрудник", "ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)");
	СтруктураПолей.Вставить("Ассистент", "ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)");
	СтруктураПолей.Вставить("ЗубнойТехник", "ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)");
	СтруктураПолей.Вставить("Услуга", "ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)");
	
	Если  СтруктураДополнительныеСвойства.Свойство("СтруктураПолейПерегрузка") и СтруктураДополнительныеСвойства.СтруктураПолейПерегрузка <> Неопределено Тогда
		Для каждого Реквизит Из СтруктураДополнительныеСвойства.СтруктураПолейПерегрузка Цикл
			Если СтруктураПолей.Свойство(Реквизит.Ключ) = Истина Тогда
				СтруктураПолей.Удалить(Реквизит.Ключ);
				СтруктураПолей.Вставить(Реквизит.Ключ, Реквизит.Значение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ВыбранныеПоляЗапроса = "";
	Для Каждого Реквизит Из СтруктураПолей Цикл
		ВыбранныеПоляЗапроса  = ВыбранныеПоляЗапроса + ",
			|	" + Реквизит.Значение + " КАК " + СокрЛП(Реквизит.Ключ);
	КонецЦикла;

	Запрос = Новый Запрос;	
	Запрос.Текст = "
		|ВЫБРАТЬ 
		|	0 КАК НомерСтроки" + ВыбранныеПоляЗапроса + "
		|ПОМЕСТИТЬ Таб
		|ИЗ &ТаблицаСписанияНоменклатуры КАК ТабНом";
	Запрос.УстановитьПараметр("ТаблицаСписанияНоменклатуры", ТаблицаСписанияНоменклатуры);
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
	Запрос.УстановитьПараметр("Склад", СтруктураДополнительныеСвойства.ДляПроведения.Склад);
	Если  ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.Реализация") или ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.Прием") Тогда
		Запрос.УстановитьПараметр("Сотрудник", СтруктураДополнительныеСвойства.ДляПроведения.Ссылка.Сотрудник);
	Иначе
		Запрос.УстановитьПараметр("Сотрудник", Справочники.Сотрудники.ПустаяСсылка());
	КонецЕсли;	
	Если  ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.ВозвратОтПокупателя") или ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.Прием") Тогда
		Запрос.УстановитьПараметр("Ассистент", СтруктураДополнительныеСвойства.ДляПроведения.Ссылка.Ассистент);
	Иначе
		Запрос.УстановитьПараметр("Ассистент", Справочники.Сотрудники.ПустаяСсылка());
	КонецЕсли;
	Если  ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.ПеремещениеЗапасов") или 
		  ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.СписаниеМатериалов") или
		  ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.СписаниеЗапасов")Тогда
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	Иначе
		Запрос.УстановитьПараметр("Контрагент", СтруктураДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент);
	КонецЕсли;
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктураДополнительныеСвойства.ДляПроведения.Ссылка.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДокументПродажи", СтруктураДополнительныеСвойства.ДляПроведения.Ссылка);
	Запрос.Текст = "
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ		
		|	Номенклатура 		КАК Номенклатура,
		|   ВЫБОР КОГДА Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка) ИЛИ Склад = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) ИЛИ Склад ЕСТЬ NULL ИЛИ Склад = НЕОПРЕДЕЛЕНО ТОГДА
		|   &Склад ИНАЧЕ Склад  КОНЕЦ КАК Склад,
		|   Количество          КАК Количество,
		|   ОснованиеВозврата   КАК ОснованиеВозврата,
		|   Себестоимость       КАК Себестоимость,
		|   Партия              КАК Партия,
		|   Услуга              КАК Услуга,
		|   ВЫБОР КОГДА СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка) ТОГДА
		|   &СтруктурнаяЕдиница ИНАЧЕ СтруктурнаяЕдиница КОНЕЦ КАК СтруктурнаяЕдиница,
		|   ВЫБОР КОГДА Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) ТОГДА
		|   &Контрагент ИНАЧЕ Контрагент КОНЕЦ КАК Контрагент,
		|   ВЫБОР КОГДА Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) ТОГДА
		|   &Сотрудник ИНАЧЕ Сотрудник КОНЕЦ КАК Сотрудник,
		|   ВЫБОР КОГДА Ассистент = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|		ТОГДА " + ?(ТипЗнч(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка) = Тип("ДокументСсылка.СписаниеМатериалов"), "ДокументПродажи.Ассистент", "&Ассистент") + " 
		|	ИНАЧЕ Ассистент Конец КАК Ассистент,
		|   ЗубнойТехник КАК ЗубнойТехник,
		|   ВЫБОР КОГДА ДокументПродажи = """" ТОГДА &ДокументПродажи 
		|   ИНАЧЕ ДокументПродажи КОНЕЦ КАК ДокументПродажи,
		|   ВЫБОР КОГДА ДокументПродажиСебестоимость = """" ТОГДА
		|   ВЫБОР КОГДА ДокументПродажи = """" ТОГДА &ДокументПродажи 
		|   ИНАЧЕ ДокументПродажи КОНЕЦ
		|   ИНАЧЕ ДокументПродажиСебестоимость КОНЕЦ КАК ДокументПродажиСебестоимость
		|ИЗ Таб КАК ТабСпис
		|ГДЕ Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас) ИЛИ Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Материал) ИЛИ Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат) ИЛИ Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество) 
		|";
	Таблица = Запрос.Выполнить().Выгрузить();
	
	Возврат Таблица;
	
КонецФункции

// Функция загружает Табличную часть во временную таблицу
// Параметры:
// 		ТаблицаЗначений - Таблица значений для загрузки во временную таблицу
// 		ИмяТаблицы - Строка, Имя ттаблицы в которую следует загрузить таблицу значений
// Возвращаемое значение:
//		МенеджерВременныхТаблиц, Менеджер временных таблиц с временной таблицой
//
Функция ВыбратьТЗВВременнуюТаблицу(ТаблицаЗначений, ИмяТаблицы) Экспорт

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаЗначений", ТаблицаЗначений);
	Запрос.Текст = "
		|ВЫБРАТЬ ТаблицаЗначений.*
		|ПОМЕСТИТЬ " + ИмяТаблицы + "
		|ИЗ &ТаблицаЗначений КАК ТаблицаЗначений";
	Запрос.Выполнить();
	
	Возврат(Запрос.МенеджерВременныхТаблиц);
	
КонецФункции // ВыбратьТЗВВременнуюТаблицу()

// Функция возвращает запрос по партиям товаров для перемещения
// Параметры:
Функция ПолучитьЗапросПартийДляПеремещения()
	
	Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	        |	ТаблицаДвижений.Период,
	        |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	        |	ТаблицаДвижений.ДокументПоступления,
	        |	ТаблицаДвижений.Номенклатура,
	        |	ТаблицаДвижений.СтруктурнаяЕдиница,
			|	ТаблицаДвижений.Склад,
	        |	ТаблицаДвижений.Партия,
	        |	ТаблицаДвижений.Количество,
	        |	ТаблицаДвижений.Стоимость
	        |ИЗ
	        |	ТаблицаДвижений КАК ТаблицаДвижений
	        |
	        |ОБЪЕДИНИТЬ ВСЕ
	        |
	        |ВЫБРАТЬ
	        |	ТаблицаДвижений.Период,
	        |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	        |	ТаблицаДвижений.ДокументПоступления,
	        |	ТаблицаДвижений.Номенклатура,
			|	&СтруктурнаяЕдиницаПолучатель,
			|	&СкладПолучатель,
	        |	ТаблицаДвижений.Партия,
	        |	ТаблицаДвижений.Количество,
	        |	ТаблицаДвижений.Стоимость
	        |ИЗ
	        |	ТаблицаДвижений КАК ТаблицаДвижений";
	Возврат Текст;
	
КонецФункции

// Функция - Контроль отрицательных остатков
//
// Параметры:
//  ЭтотОбъект	 - 	 - 
//  ТекстОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция КонтрольОтрицательныхОстатков(ЭтотОбъект) Экспорт

	Если ЭтотОбъект.Дата > ТекущаяДатаСеанса() Или НачалоДня(ЭтотОбъект.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда
		ДатаОстатков			= ТекущаяДатаСеанса();
		ИсключитьРегистратор	= ЭтотОбъект.Проведен;
	Иначе
		ДатаОстатков			= Новый Граница(ЭтотОбъект.Дата, ВидГраницы.Исключая);
		ИсключитьРегистратор	= Ложь;
	КонецЕсли;

		
	НеКонтролироватьОстатки  = Константы.НеКонтроллироватьОстатки.Получить();
	Запрос       			 = Новый Запрос;
    ТекстЗапроса 			 = ПолучитьТекстЗапроса(ЭтотОбъект, ИсключитьРегистратор);
	Запрос.Текст 			 = ТекстЗапроса; 
	ТаблицаЗапасы 			 = ЭтотОбъект.Запасы.Выгрузить();
	
	ТаблицаЗапасы.Колонки.Добавить("ТипНоменклатуры");
	
	Если ТаблицаЗапасы.Колонки.Найти("Склад") = Неопределено Тогда
		
		ТаблицаЗапасы.Колонки.Добавить("Склад");
		
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из ТаблицаЗапасы Цикл
		
		СтрокаТЧ.ТипНоменклатуры  = СтрокаТЧ.Номенклатура.ТипНоменклатуры;
		
		Если Не ЗначениеЗаполнено(СтрокаТЧ.Склад) Тогда
			
			СтрокаТЧ.Склад = ЭтотОбъект.Склад;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница" 				   , ЭтотОбъект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Склад"              				   , ЭтотОбъект.Склад);
	Запрос.УстановитьПараметр("Дата"              				   , ДатаОстатков);
	Запрос.УстановитьПараметр("ТаблицаЗапасы"      				   , ТаблицаЗапасы);
	Запрос.УстановитьПараметр("НеКонтролироватьОстаткиЗапасов"     , НеКонтролироватьОстатки);
	Запрос.УстановитьПараметр("Регистратор"                        , ЭтотОбъект.Ссылка);
	
	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		//СтрокаПартия = ?(ЗначениеЗаполнено(Выборка.Партия), " <"+Выборка.Партия+">", "");
		СтрокаПартия = "";
		ЕИ           = Справочники.КлассификаторЕдиницИзмерения.ПолучитьНаименованиеЕдиницыИзмеренияНоменклатуры(Выборка.Номенклатура, "шт");
		ТекстОшибки  = "Остатка """ + Выборка.Номенклатура + """" + СтрокаПартия + 
			?(ЗначениеЗаполнено(Выборка.Склад), ?(ТипЗнч(Выборка.Склад) = Тип("СправочникСсылка.Склады"),
			" на складе ", " у сотрудника ") + Выборка.Склад, "") + " в клинике " + ЭтотОбъект.СтруктурнаяЕдиница + " недостаточно.
			|Остаток " + Выборка.КоличествоДосупнойНоменклатуры + " " + ЕИ + "; Требуется " + Выборка.Количество + " " + ЕИ + "; 
			|Не хватает " + (Выборка.ОсталосьСписать) + " "+ ЕИ;						
		
		Если Выборка.НомерСтроки > 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, ЭтотОбъект, "Запасы["+(Выборка.НомерСтроки - 1)+"].КоличествоУпаковок", "Объект");
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат Не Результат.Пустой();
	
КонецФункции

// Функция - Получить текст запроса
//
// Параметры:
//  ЭтотОбъект			 - 	 - 
//  ИсключитьРегистратор - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТекстЗапроса(ЭтотОбъект, ИсключитьРегистратор)
	
	Если ТипЗнч(ЭтотОбъект) = Тип("ДокументОбъект.ПеремещениеЗапасов") Тогда
		
		Текст  = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	&Склад КАК Склад,
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Партия КАК Партия,
		|	Запасы.Количество КАК Количество,
		|	Запасы.НомерСтроки КАК НомерСтроки
		|ПОМЕСТИТЬ ТаблицаНоменклатурыБезГруппировки
		|ИЗ
		|	&ТаблицаЗапасы КАК Запасы
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &НеКонтролироватьОстаткиЗапасов = ЛОЖЬ
		|				ТОГДА Запасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
		|						ИЛИ Запасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество)
		|						ИЛИ Запасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Материал)
		|						ИЛИ Запасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Запасы.Склад КАК Склад,
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Партия КАК Партия,
		|	СУММА(Запасы.Количество) КАК Количество,
		|	МАКСИМУМ(Запасы.НомерСтроки) КАК НомерСтроки
		|ПОМЕСТИТЬ ТаблицаНоменклатуры
		|ИЗ
		|	ТаблицаНоменклатурыБезГруппировки КАК Запасы
		|
		|СГРУППИРОВАТЬ ПО
		|	Запасы.Номенклатура,
		|	Запасы.Склад,
		|	Запасы.Партия";
		
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТаблицаНоменклатуры.Склад КАК Склад,
	|	ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ТаблицаНоменклатуры.Партия КАК Партия,
	|	ТаблицаНоменклатуры.Количество КАК Количество,
	|	ЕСТЬNULL(ТаблицаОстатки.Количество, 0) КАК КоличествоДосупнойНоменклатуры,
	|	ТаблицаНоменклатуры.Количество - ЕСТЬNULL(ТаблицаОстатки.Количество, 0) КАК ОсталосьСписать,
	|	ТаблицаНоменклатуры.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОстатки КАК ТаблицаОстатки
	|		ПО ТаблицаНоменклатуры.Номенклатура = ТаблицаОстатки.Номенклатура
	|			И ТаблицаНоменклатуры.Склад = ТаблицаОстатки.Склад
	|			И ТаблицаНоменклатуры.Партия = ТаблицаОстатки.Партия
	|ГДЕ
	|	ТаблицаНоменклатуры.Количество > ЕСТЬNULL(ТаблицаОстатки.Количество, 0)";	
	
	Если Не ИсключитьРегистратор Тогда
		
		ТекстЗапросаОстатков =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыОстатки.Склад КАК Склад,
		|	ЗапасыОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыОстатки.Партия КАК Партия,
		|	СУММА(ЗапасыОстатки.КоличествоОстаток) КАК Количество
		|ПОМЕСТИТЬ ТаблицаОстатки
		|ИЗ
		|	РегистрНакопления.ЗапасыНаСкладах.Остатки(
		|			&Дата,
		|			(Номенклатура, Склад) В
		|					(ВЫБРАТЬ
		|						ТаблицаНоменклатуры.Номенклатура,
		|						ТаблицаНоменклатуры.Склад
		|					ИЗ
		|						ТаблицаНоменклатуры)
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ЗапасыОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОстатки.Партия,
		|	ЗапасыОстатки.Номенклатура,
		|	ЗапасыОстатки.Склад";

	Иначе
		
		ТекстЗапросаОстатков =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
