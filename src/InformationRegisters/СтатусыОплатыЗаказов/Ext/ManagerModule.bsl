// Процедура, создаёт или обновляет запись регистра сведений.
//
Процедура СоздатьИлиОбновитьЗапись(
	Основание 			  = Неопределено,
	Сумма 				  = Неопределено,
	ИдЗаказа 			  = Неопределено,
	СсылкаОплаты 		  = Неопределено,
	Оплачено 			  = Неопределено,
	ЭквайринговыйТерминал = Неопределено,
	НомерЗаказа 		  = Неопределено,
	ПараметрыJSON 		  = Неопределено,
	ПроверятьОснование 	  = Истина,
	Контрагент 			  = Неопределено,
	ВидЦены 			  = Неопределено,
	СтруктурнаяЕдиница 	  = Неопределено,
	ДатаРегистрацииЗаказа = Неопределено,
	ОписаниеСтатуса 	  = Неопределено,
	ТипСсылкиНаОплату 	  = Неопределено,
	Сотрудник 	  		  = Неопределено,
	ДатаОкончанияДействияСсылки = Неопределено,
	ИдентификаторQRКода = Неопределено,
	ЭтоВозврат = Ложь,
	ДобавитьДатуОбработки = Ложь,
	ДобавитьПопытку = Ложь) Экспорт
	
	МенеджерЗаписи = РегистрыСведений.СтатусыОплатыЗаказов.СоздатьМенеджерЗаписи();
	Если ПроверятьОснование Тогда 
		МенеджерЗаписи.Основание = Основание;
	КонецЕсли;
	МенеджерЗаписи.НомерЗаказа = НомерЗаказа;
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.ЭквайринговыйТерминал 		= ?(ЗначениеЗаполнено(ЭквайринговыйТерминал)		, ЭквайринговыйТерминал					, МенеджерЗаписи.ЭквайринговыйТерминал);
	МенеджерЗаписи.СтруктурнаяЕдиница    		= ?(ЗначениеЗаполнено(СтруктурнаяЕдиница)   		, СтруктурнаяЕдиница   					, МенеджерЗаписи.СтруктурнаяЕдиница);
	МенеджерЗаписи.ДатаРегистрацииЗаказа 		= ?(ЗначениеЗаполнено(ДатаРегистрацииЗаказа)		, ДатаРегистрацииЗаказа					, МенеджерЗаписи.ДатаРегистрацииЗаказа);
	МенеджерЗаписи.НомерЗаказа     		 		= ?(ЗначениеЗаполнено(НомерЗаказа)    	 	 		, НомерЗаказа    						, МенеджерЗаписи.НомерЗаказа);
	МенеджерЗаписи.Основание       		 		= ?(ЗначениеЗаполнено(Основание)      	 	 		, Основание      						, МенеджерЗаписи.Основание);
	МенеджерЗаписи.Сумма           		 		= ?(ЗначениеЗаполнено(Сумма)          	 	 		, Сумма          						, МенеджерЗаписи.Сумма);
	МенеджерЗаписи.ИдЗаказа        		 		= ?(ЗначениеЗаполнено(ИдЗаказа)       	 	 		, ИдЗаказа       						, МенеджерЗаписи.ИдЗаказа);
	МенеджерЗаписи.Статус          		 		= ?(ЗначениеЗаполнено(Оплачено)       	 	 		, Оплачено       						, МенеджерЗаписи.Статус);
	МенеджерЗаписи.СсылкаОплаты    		 		= ?(ЗначениеЗаполнено(СсылкаОплаты)   	 	 		, СсылкаОплаты   						, МенеджерЗаписи.СсылкаОплаты); 
	МенеджерЗаписи.ПараметрыJSON   		 		= ?(ЗначениеЗаполнено(ПараметрыJSON)  	 	 		, ПараметрыJSON  						, МенеджерЗаписи.ПараметрыJSON);
	МенеджерЗаписи.Контрагент      		 		= ?(ЗначениеЗаполнено(Контрагент)     	 	 		, Контрагент     						, МенеджерЗаписи.Контрагент);
	МенеджерЗаписи.ВидЦены        		 		= ?(ЗначениеЗаполнено(ВидЦены)        	 	 		, ВидЦены        						, МенеджерЗаписи.ВидЦены);
	МенеджерЗаписи.ОписаниеСтатуса 	 	 		= ?(ЗначениеЗаполнено(ОписаниеСтатуса)	 	 		, ОписаниеСтатуса						, МенеджерЗаписи.ОписаниеСтатуса);
	МенеджерЗаписи.Сотрудник 	 	 	 		= ?(ЗначениеЗаполнено(Сотрудник)	 	 	 		, Сотрудник								, МенеджерЗаписи.Сотрудник);
	МенеджерЗаписи.ДатаОкончанияДействияСсылки	= ?(ЗначениеЗаполнено(ДатаОкончанияДействияСсылки)	, ДатаОкончанияДействияСсылки			, МенеджерЗаписи.ДатаОкончанияДействияСсылки);
	МенеджерЗаписи.ИдентификаторQRКода			= ?(ЗначениеЗаполнено(ИдентификаторQRКода)			, ИдентификаторQRКода					, МенеджерЗаписи.ИдентификаторQRКода);
    МенеджерЗаписи.ЭтоВозврат					= ?(ЭтоВозврат = Истина								, ЭтоВозврат							, МенеджерЗаписи.ЭтоВозврат);
	МенеджерЗаписи.ДатаПоследнейОбработки		= ?(ДобавитьДатуОбработки = Истина					, ТекущаяДатаСеанса()					, МенеджерЗаписи.ДатаПоследнейОбработки);
	МенеджерЗаписи.КоличествоПопыток			= ?(ДобавитьПопытку = Истина						, МенеджерЗаписи.КоличествоПопыток + 1	, МенеджерЗаписи.КоличествоПопыток);
			

	Если ЗначениеЗаполнено(ТипСсылкиНаОплату) Тогда
		МенеджерЗаписи.ТипСсылкиНаОплату = ТипСсылкиНаОплату;
	ИначеЕсли Не ЗначениеЗаполнено(МенеджерЗаписи.ТипСсылкиНаОплату) Тогда
		МенеджерЗаписи.ТипСсылкиНаОплату = Перечисления.ТипыСсылокНаОплату.Сбербанк;
	КонецЕсли;
	
	МенеджерЗаписи.Записать();
	
КонецПроцедуры	

// Процедура, создаёт или обновляет запись регистра сведений.
//
Процедура СоздатьИлиОбновитьЗаписьПоИдЗаказа(
	Основание 			  = Неопределено,
	Сумма 				  = Неопределено,
	ИдЗаказа 			  = Неопределено,
	СсылкаОплаты 		  = Неопределено,
	Оплачено 			  = Неопределено,
	ЭквайринговыйТерминал = Неопределено,
	НомерЗаказа 		  = Неопределено,
	ПараметрыJSON 		  = Неопределено,
	ПроверятьОснование 	  = Истина,
	Контрагент 			  = Неопределено,
	ВидЦены 			  = Неопределено,
	СтруктурнаяЕдиница 	  = Неопределено,
	ДатаРегистрацииЗаказа = Неопределено,
	ОписаниеСтатуса 	  = Неопределено,
	ТипСсылкиНаОплату 	  = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа
		|ИЗ
		|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
		|ГДЕ
		|	СтатусыОплатыЗаказов.ИдЗаказа = &ИдЗаказа";
	
	Запрос.УстановитьПараметр("ИдЗаказа", ИдЗаказа);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		НомерЗаказа = Выборка.НомерЗаказа;
		
		МенеджерЗаписи = РегистрыСведений.СтатусыОплатыЗаказов.СоздатьМенеджерЗаписи();
		Если ПроверятьОснование Тогда 
			МенеджерЗаписи.Основание = Основание;
		КонецЕсли;
		МенеджерЗаписи.НомерЗаказа = НомерЗаказа;
		МенеджерЗаписи.Прочитать();
		
		МенеджерЗаписи.ЭквайринговыйТерминал = ?(ЗначениеЗаполнено(ЭквайринговыйТерминал), ЭквайринговыйТерминал, МенеджерЗаписи.ЭквайринговыйТерминал);
		МенеджерЗаписи.СтруктурнаяЕдиница    = ?(ЗначениеЗаполнено(СтруктурнаяЕдиница)   , СтруктурнаяЕдиница   , МенеджерЗаписи.СтруктурнаяЕдиница   );
		МенеджерЗаписи.ДатаРегистрацииЗаказа = ?(ЗначениеЗаполнено(ДатаРегистрацииЗаказа), ДатаРегистрацииЗаказа, МенеджерЗаписи.ДатаРегистрацииЗаказа);
		
		МенеджерЗаписи.НомерЗаказа     		 = ?(ЗначениеЗаполнено(НомерЗаказа)    	 	 , НомерЗаказа    		, МенеджерЗаписи.НомерЗаказа);
		МенеджерЗаписи.Основание       		 = ?(ЗначениеЗаполнено(Основание)      	 	 , Основание      		, МенеджерЗаписи.Основание);
		МенеджерЗаписи.Сумма           		 = ?(ЗначениеЗаполнено(Сумма)          	 	 , Сумма          		, МенеджерЗаписи.Сумма);
		МенеджерЗаписи.ИдЗаказа        		 = ?(ЗначениеЗаполнено(ИдЗаказа)       	 	 , ИдЗаказа       		, МенеджерЗаписи.ИдЗаказа);
		МенеджерЗаписи.Статус          		 = ?(ЗначениеЗаполнено(Оплачено)       	 	 , Оплачено       		, МенеджерЗаписи.Статус);
		МенеджерЗаписи.СсылкаОплаты    		 = ?(ЗначениеЗаполнено(СсылкаОплаты)   	 	 , СсылкаОплаты   		, МенеджерЗаписи.СсылкаОплаты); 
		МенеджерЗаписи.ПараметрыJSON   		 = ?(ЗначениеЗаполнено(ПараметрыJSON)  	 	 , ПараметрыJSON  		, МенеджерЗаписи.ПараметрыJSON);
		МенеджерЗаписи.Контрагент      		 = ?(ЗначениеЗаполнено(Контрагент)     	 	 , Контрагент     		, МенеджерЗаписи.Контрагент);
		МенеджерЗаписи.ВидЦены        		 = ?(ЗначениеЗаполнено(ВидЦены)        	 	 , ВидЦены        		, МенеджерЗаписи.ВидЦены);
		МенеджерЗаписи.ОписаниеСтатуса 	 	 = ?(ЗначениеЗаполнено(ОписаниеСтатуса)	 	 , ОписаниеСтатуса		, МенеджерЗаписи.ОписаниеСтатуса);
		
		Если ЗначениеЗаполнено(ТипСсылкиНаОплату) Тогда
			МенеджерЗаписи.ТипСсылкиНаОплату = ТипСсылкиНаОплату;
		ИначеЕсли Не ЗначениеЗаполнено(МенеджерЗаписи.ТипСсылкиНаОплату) Тогда
			МенеджерЗаписи.ТипСсылкиНаОплату = Перечисления.ТипыСсылокНаОплату.Сбербанк;
		КонецЕсли;
		
		МенеджерЗаписи.Записать();
	КонецЕсли;

КонецПроцедуры	

// Функция, возвращает ТЗ не оплаченных заказов.
//
Функция ПолучитьНеОплаченныеЗаказы() Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОплатыЗаказов.ИдЗаказа КАК ИдЗаказа,
	|	СтатусыОплатыЗаказов.Основание КАК Основание,
	|	СтатусыОплатыЗаказов.Сумма КАК Сумма,
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.Организация КАК ЭквайринговыйТерминалОрганизация,
	|	СтатусыОплатыЗаказов.Контрагент КАК Контрагент,
	|	СтатусыОплатыЗаказов.ПараметрыJSON КАК ПараметрыJSON,
	|	СтатусыОплатыЗаказов.ВидЦены КАК ВидЦены,
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка КАК ТипБанка,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза КАК ПараметрыПлатежногоШлюза,
	|	ВЫБОР
	|		КОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, МЕСЯЦ, 1) <= &ТекущаяДата
	|		ИНАЧЕ СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки <= &ТекущаяДата
	|	КОНЕЦ КАК Истекший
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)
	|	И НЕ СтатусыОплатыЗаказов.Основание.ПометкаУдаления
	|	И СтатусыОплатыЗаказов.ТипСсылкиНаОплату <> ЗНАЧЕНИЕ(Перечисление.ТипыСсылокНаОплату.ВиджетЛК)
	|	И (СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка = ЗНАЧЕНИЕ(Перечисление.ПлатежныеШлюзы.Сбербанк)
	|			ИЛИ СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка = ЗНАЧЕНИЕ(Перечисление.ПлатежныеШлюзы.Paymo)
	|			ИЛИ СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка = ЗНАЧЕНИЕ(Перечисление.ПлатежныеШлюзы.ЮКасса))
	|	И (СтатусыОплатыЗаказов.ДатаПоследнейОбработки = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ &ТекущаяДата < ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ЧАС, 1)
	|				И РАЗНОСТЬДАТ(СтатусыОплатыЗаказов.ДатаПоследнейОбработки, &ТекущаяДата, СЕКУНДА) >= 60
	|			ИЛИ &ТекущаяДата >= ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ЧАС, 1)
	|				И &ТекущаяДата < ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ДЕНЬ, 1)
	|				И РАЗНОСТЬДАТ(СтатусыОплатыЗаказов.ДатаПоследнейОбработки, &ТекущаяДата, МИНУТА) >= 60
	|			ИЛИ &ТекущаяДата >= ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ДЕНЬ, 1)
	|				И РАЗНОСТЬДАТ(СтатусыОплатыЗаказов.ДатаПоследнейОбработки, &ТекущаяДата, ЧАС) >= 24)
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтруктурнаяЕдиница");
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

// Функция, формирует номер заказа.
//
Функция СофрмироватьНомерЗаказа(Знач НомерДокумента, ДатаЗаказа)
	
	// Сервис может получить только "Цифры и буквы латиницы".
	Если КодСимвола(НомерДокумента) >= 1040 И КодСимвола(НомерДокумента) <= 1103 Тогда
		НомерДокумента = СтроковыеФункцииКлиентСервер.ТранслитерацияРусАнгл(НомерДокумента);
	КонецЕсли;

	Возврат НомерДокумента + " " + ДатаЗаказа;
	
КонецФункции

// Функция, возвращает максимальный номер заказа.
//
Функция ПолучитьМассимальныйНомерЗаказа(ТипСсылкиНаОплату) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(СтатусыОплатыЗаказов.НомерЗаказа) КАК НомерЗаказа
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.ТипСсылкиНаОплату = &ТипСсылкиНаОплату
	|	И Не СтатусыОплатыЗаказов.ЭтоВозврат");
	
	Запрос.УстановитьПараметр("ТипСсылкиНаОплату", ТипСсылкиНаОплату);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.НомерЗаказа) Тогда
		Возврат Выборка.НомерЗаказа;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции	

