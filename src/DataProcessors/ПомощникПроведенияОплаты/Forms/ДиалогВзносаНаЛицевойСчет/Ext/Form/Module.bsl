&НаКлиенте
// Процедура, обработчик нажатия кнопки "Наличные"
//
Процедура Наличные(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		ЭтаФорма.Заголовок                        = "Взнос на лицевой счет наличными";
		Элементы.Контрагент .ТолькоПросмотр       = Истина;
		Элементы.Сумма.ТолькоПросмотр             = Истина;
		Элементы.ВидЛицевогоСчета.ТолькоПросмотр  = Истина;
		Элементы.Наличными.Видимость              = Ложь;
		Элементы.ПлатежнойКартой.Видимость        = Ложь;
		Элементы.Внести.Видимость                 = Истина;
		ЭтаФорма.ТекущийЭлемент                   = Элементы.Внести;
		ТипДенежныхСредств                        = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные");
		Элементы.ГруппаПараметрыПечати.Видимость  = Истина;
		ПечатьКвитанцииПриИзменении(Неопределено);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик нажатия кнопки "ПлатежнаяКарта"
//
Процедура ПлатежнаяКарта(Команда)
	
	Если ПроверитьЗаполнение() Тогда 
		ЭтаФорма.Заголовок                        = "Взнос на лицевой счет платежной картой";
		Элементы.Контрагент .ТолькоПросмотр       = Истина;
		Элементы.Сумма.ТолькоПросмотр             = Истина;
		Элементы.ВидЛицевогоСчета.ТолькоПросмотр  = Истина;	
		Элементы.Наличными.Видимость              = Ложь;
		Элементы.ПлатежнойКартой.Видимость        = Ложь;
		Элементы.Внести.Видимость                 = Истина;
		ЭтаФорма.ТекущийЭлемент                   = Элементы.Внести;
		ТипДенежныхСредств                        = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта");
		Элементы.ГруппаПараметрыПечати.Видимость  = Ложь;	
		ПечатьКвитанции = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик нажатия кнопки "Отмена"
//
Процедура Отмена(Команда)
	
	Если ЗначениеЗаполнено(ТипДенежныхСредств) Тогда
		ЭтаФорма.Заголовок                        = "Взнос на лицевой счет";
		Элементы.Сумма.ТолькоПросмотр             = Ложь;
		Элементы.ВидЛицевогоСчета.ТолькоПросмотр  = Ложь;		
		Элементы.Наличными.Видимость              = Истина;
		Элементы.ПлатежнойКартой.Видимость        = Истина;
		Элементы.Внести.Видимость                 = Ложь;
		ТипДенежныхСредств                        = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПустаяСсылка");
		Элементы.ГруппаПараметрыПечати.Видимость  = Ложь;
	Иначе 
		ЭтаФорма.Закрыть();	
	КонецЕсли;
	
КонецПроцедуры
 
&НаКлиенте
// Процедура, обработчик нажатия кнопки "Внести"
//
Процедура ВнестиНаЛС(Команда)
	
	МассивСтрок = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей"));
	Если МассивСтрок.Количество() > 0 Тогда
		ЗавершитьВводСуммыОплатыСБП(МассивСтрок[0]);
	ИначеЕсли ПроверитьЗаполнение() Тогда 
		Оплатить();     
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик нажатия кнопки "Внести".
//
Процедура Оплатить()
	
	ОписаниеОшибки             		    = Неопределено;
	ПараметрыИспользованияКассовойСмены = Новый Структура();
	РозничныеПродажиКлиент.ВыполнитьКонтрольИспользованияКассовойСмены(ЭтотОбъект, ЭтотОбъект.Касса, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки);
	
КонецПроцедуры

#Область ОбработчикиРаботыСКассовойСменой

&НаКлиенте
// Процедура - После контроля использования кассовой смены.
//
Процедура ПослеКонтроляИспользованияКассовойСмены(ИспользованиеКассовойСменыРазрешено, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки) Экспорт
	
	Если ИспользованиеКассовойСменыРазрешено = Ложь Тогда
		ПоказатьПредупреждение(, Нстр("ru='Оплата запрещена: ';en='Payment is prohibited:'") + ОписаниеОшибки);
		Возврат;
	КонецЕсли;

	СтруктураЗаполнения = Новый Структура;
	СтруктураЗаполнения.Вставить("Контрагент"           , Контрагент);
	СтруктураЗаполнения.Вставить("Сумма"                , Сумма);
	СтруктураЗаполнения.Вставить("ВидЛицевогоСчета"     , ВидЛицевогоСчета);
	СтруктураЗаполнения.Вставить("ТипДенежныхСредств"   , ТипДенежныхСредств);
	СтруктураЗаполнения.Вставить("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
	СтруктураЗаполнения.Вставить("Касса"			    , Касса);
	СтруктураЗаполнения.Вставить("ЭквайрингВидПлатежнойКарты", ВидКарты);	
	
	ДокументыОплаты = ОперацияОплатыСервер(СтруктураЗаполнения, ОписаниеОшибки);
	
	ПроведениеДокументовОтменено = Ложь;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда          
		
		ОтменитьПроведениеДокументов(ДокументыОплаты);
		
		ПоказатьПредупреждение(, ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	Если ВыполнятьОперациюПоПлатежнойКарте() = Истина Тогда
		
		ДанныеПлатежаПоКарте = ВыполнитьОперациюПоПлатежнойКарте(ОписаниеОшибки);
		
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда			
			ОтменитьПроведениеДокументов(ДокументыОплаты);
			ПроведениеДокументовОтменено = Истина;
			ПоказатьПредупреждение(, ОписаниеОшибки);
			Возврат;			
		КонецЕсли;
		
	КонецЕсли;
		
	Если НЕ ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭтотОбъект.Касса, "ИспользоватьБезПодключенияОборудования")
		И ДокументыОплаты.МассивДокОплаты.Количество() > 0 Тогда
		
		Если ЭтотОбъект.ТекущаяКассаИспользуетсяККТ Тогда
			ПараметрыЧека = ПодготовитьПараметрыФискальногоЧекаВзносаНаЛицСчетДляККТ(ДокументыОплаты.МассивДокОплаты);      
		Иначе
			ПараметрыЧека = ПодготовитьПараметрыФискальногоЧекаВзносаНаЛицСчетДляФР(ДокументыОплаты.МассивДокОплаты); 
		КонецЕсли;
		
		Если ПараметрыЧека.Результат Тогда
			
			ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ЭтотОбъект.Касса);
			
			Если ПараметрыЧека.Свойство("ФискальныйЧек") Тогда    
				
				Контекст = Новый Структура();
				Контекст.Вставить("ТипЧека", Истина);      
				Оповещение            = Новый ОписаниеОповещения("ПробитьЧекЗавершение"            , ЭтотОбъект, Контекст);
				ПослеОткрытияЧека     = Новый ОписаниеОповещения("ПечатьЧека_ПослеОткрытияЧека"    , ЭтотОбъект, Контекст);
				ПослеОшибкиПечатиЧека = Новый ОписаниеОповещения("ПечатьЧека_ПослеОшибкиПечатиЧека", ЭтотОбъект, Контекст);
				
				ОбщиеПараметры = ПараметрыЧека.ФискальныйЧек;
				МенеджерОборудованияКлиент.НачатьФискализациюЧекаНаФискальномУстройстве(Оповещение, УникальныйИдентификатор, ОбщиеПараметры, ИдентификаторУстройстваФР, , ПослеОткрытияЧека, ПослеОшибкиПечатиЧека);    
				
			КонецЕсли;
			
			// Если был фискальный чек, то нефискальный чек напечатается после завершения фискального.
			Если ПараметрыЧека.Свойство("НефискальныйЧек") Тогда
				
				ТекстЧека  = ПараметрыЧека.НефискальныйЧек;
				Контекст   = Новый Структура();
				Контекст.Вставить("ТипЧека", Ложь);
				Оповещение = Новый ОписаниеОповещения("ПробитьЧекЗавершение", ЭтотОбъект, Контекст);
				
				МенеджерОборудованияКлиент.НачатьПечатьТекста(Оповещение, УникальныйИдентификатор, ТекстЧека, ИдентификаторУстройстваФР);
				
			КонецЕсли;        
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru='Ошибка Фискализации взноса на ЛС: ';en='Mistake Fiscalization contribution on drugs:'") +  ПараметрыЧека.ОписаниеОшибки);
			ОтменитьПроведениеДокументов(ДокументыОплаты);
			ПроведениеДокументовОтменено = Истина;
			
			Возврат;
			
		КонецЕсли;    
		
		Если ЗначениеЗаполнено(НомерНеФискальногоЧека) 
			ИЛИ ЗначениеЗаполнено(НомерФискальногоЧека)  Тогда
			
			ПрописатьНомерФискальногоЧекаИПлатежнойКарты(
				ДокументыОплаты.МассивДокОплаты, 
				НомерФискальногоЧека, 
				ДанныеПлатежаПоКарте);
			
			ВыполненоУспешно = Истина;
			
		Иначе
			
			// При печати чека произошла ошибка, отменить проведение документов оплаты
			ОписаниеОшибки = Нстр("ru='Ошибка пробития чека на ФР';en='Mistake penetration check on ph'");
			ПоказатьПредупреждение(, ОписаниеОшибки);
			ОтменитьПроведениеДокументов(ДокументыОплаты);
			ПроведениеДокументовОтменено = Истина;
			
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ПроведениеДокументовОтменено Тогда  
		СуммаВзноса = 0;
		СуммаВзноса = СуммаВзноса + ПолучитьСуммуВзноса(ДокументыОплаты.МассивДокОплаты); 
		СуммаВзноса = СуммаВзноса + ПолучитьСуммуВзноса(ДокументыОплаты.МассивДокОплатыСертификатом);
		 
		Структура = Новый Структура;
		Структура.Вставить("СуммаВзноса",СуммаВзноса); 
       	Оповестить("ПРОВЕДЕН_ВЗНОС_НА_ЛИЦЕВОЙ_СЧЕТ", Структура, Контрагент);
		
	КонецЕсли;
	
	ЭтаФорма.Закрыть();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСуммуВзноса(МассивДокументовОплаты)
	
	СуммаВзноса = 0;
	
	Для Каждого ДокументОплаты Из МассивДокументовОплаты  Цикл 
		
		СуммаДокумента_ = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОплаты, "СуммаДокумента"); 
		СуммаДокумента = ?(СуммаДокумента_<>Неопределено, СуммаДокумента_, 0);		
		СуммаВзноса = СуммаВзноса + СуммаДокумента;
			
	КонецЦикла;	  
	
	Возврат СуммаВзноса;

КонецФункции 
	
