// Обработчик создания нового исходящего письма
//
Процедура Создать(Команда)
	
	ТекущиеДанные = Элементы.ПанельУправления.ТекущиеДанные;
	Результат = "";
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли; 		
	
	Результат = СоздатьПисьмо(ТекущиеДанные.УчетнаяЗапись); 	
	
	Если Результат = "" Тогда
		
		ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения", Новый Структура("ТекущаяУчетнаяЗапись", ТекущиеДанные.УчетнаяЗапись));
		ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента", ПараметрыОткрытия);
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат);
		
	КонецЕсли;
	
