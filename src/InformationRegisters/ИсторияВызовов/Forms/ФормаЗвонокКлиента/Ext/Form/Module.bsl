	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("IPТелефонияПодключаемоеОборудование"	, ПОIPТелефонии);		
	ПараметрыФормы.Вставить("IDЗвонка"								, IDЗвонка);
	ПараметрыФормы.Вставить("IDПлеча"								, IDПлеча);	
	ПараметрыФормы.Вставить("НаНомерТелефона"						, НаНомерТелефона);
	ПараметрыФормы.Вставить("НомерТелефонаКлиента"					, НомерТелефонаКлиента);
	ПараметрыФормы.Вставить("ПереводЗвонка"							, Истина);	
	// ПараметрыФормы.Вставить("ПереадресацияЗвонка"					, Ложь);
	ОткрытьФорму("Справочник.ТелефонныеАппараты.Форма.ФормаПереадресации", ПараметрыФормы,,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Внести в черный список
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВнестиВЧерныйСписок(Команда)

	ОписаниеОповещенияВводаСтроки = Новый ОписаниеОповещения("ПослеВводаПричиныБлокировки", ЭтотОбъект);
	ПоказатьВводСтроки(ОписаниеОповещенияВводаСтроки, Заметка, "Кто звонит?", , Истина);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - После ввода причины блокировки
//
// Параметры:
//  ВведенноеЗначение		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВводаПричиныБлокировки(ВведенноеЗначение, ДополнительныеПараметры = Неопределено) Экспорт 
	
	Если ЗначениеЗаполнено(СокрЛП(ВведенноеЗначение)) Тогда 
		ДобавитьНеобрабатываемыйНомер(НомерТелефонаКлиента, СокрЛП(ВведенноеЗначение));
		ПолучитьСтруктуруБлокировкиНомера(СтруктураБлокировкиНомера, СписокВариантовНомераТелефона);
		ПометитьНаУдалениеСвязанныеОбъекты(Истина);
		ВызвытьОповещение = Истина; 
		ЗаполнитьРезультатЗвонка(ПредопределенноеЗначение("Перечисление.РезультатыОбработкиЗвонка.ЗвонитНеПациент"));
		ЭтаФорма.Закрыть();
	КонецЕсли;                          
	
КонецПроцедуры

#КонецОбласти

