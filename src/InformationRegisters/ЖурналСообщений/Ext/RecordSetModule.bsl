
#Область СлужебныйПрограммныйИнтерфейс
  
// Процедура - Перед записью
//
// Параметры:
//  Отказ		 - 	 - 
//  Замещение	 - 	 - 
//
Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ЭтотОбъект.Количество() = 0 Тогда
		Возврат;		
	КонецЕсли;
	
	УстановкаФлагаПрочитано = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "УстановкаФлагаПрочитано", Ложь);
	
	Если УстановкаФлагаПрочитано Тогда 
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаЗаписьСообщения Из ЭтотОбъект Цикл 
		СтрокаЗаписьСообщения.ДатаРегистрации = ?(ЗначениеЗаполнено(СтрокаЗаписьСообщения.ДатаРегистрации), СтрокаЗаписьСообщения.ДатаРегистрации, ТекущаяДатаСеанса());
	КонецЦикла;	
		
КонецПроцедуры

// Процедура - При записи
//
// Параметры:
//  Отказ		 - 	 - 
//  Замещение	 - 	 - 
//
Процедура ПриЗаписи(Отказ, Замещение)

	Если ЭтотОбъект.Количество() = 0 Тогда
		Возврат;		
	КонецЕсли;
	
	ЗаписьСообщения = ЭтотОбъект[0];
	
	ДиалогID 				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ДиалогID"					, "");	
	УстановкаФлагаПрочитано = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "УстановкаФлагаПрочитано"	, Ложь);
	ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария", Ложь);
	
	Если УстановкаФлагаПрочитано Тогда 
		Возврат;
	КонецЕсли;
	
	Если ЗаписьСообщения.СлужебноеСообщение ИЛИ (ЗаписьСообщения.Триггер И НЕ ЗначениеЗаполнено(ДиалогID)) Тогда 
		Возврат;
	КонецЕсли;	
	                   
	Если ЗаписьСообщения.СообщениеОтКлиента И НЕ ЗаписьСообщения.ЭтоПересланноеСообщение Тогда
		Если НЕ ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария Тогда 
			Справочники.СценарииЧатБотов.ИнтерпретироватьСообщениеПользователя(ЗаписьСообщения, ЭтотОбъект.ДополнительныеСвойства);
		КонецЕсли;	
		Возврат;
	КонецЕсли;	
	
	Если ЭтотОбъект.ОбменДанными.Загрузка = Истина
		И НЕ ЗначениеЗаполнено(ДиалогID) Тогда 		
		Возврат;
	КонецЕсли;		
	
	Если НЕ ЗначениеЗаполнено(ДиалогID) Тогда
		Возврат;
	КонецЕсли;	
	
	СценарийЧатБота 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "СценарийЧатБота"		, Неопределено);
	ДанныеСценария 		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ДанныеСценария"		, Неопределено);
	КэшВариантовОтветов = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "КэшВариантовОтветов"	, Неопределено);
	
	//Для Каждого Запись Из ЭтотОбъект Цикл
	// Актуализируем данные сценария
	Если ЗначениеЗаполнено(СценарийЧатБота) И ЗначениеЗаполнено(ДанныеСценария) Тогда 
		Если ТипЗнч(ДанныеСценария) = Тип("ТаблицаЗначений") Тогда 
			МассивСтруктур = ТаблицуЗначенийВМассивСтруктур(ДанныеСценария);
			Если ЗначениеЗаполнено(МассивСтруктур) Тогда 
				ДанныеСценария = МассивСтруктур[0];	
			КонецЕсли;	
		КонецЕсли;
		Если ТипЗнч(ДанныеСценария) = Тип("Структура") Тогда 
			РегистрыСведений.ДанныеДиалоговЧатБотов.ЗаписатьДанныеДиалоговЧатБота(ДиалогID
																				, СценарийЧатБота
																				, ?(ДанныеСценария.Свойство("Контрагент"), ДанныеСценария.Контрагент, Неопределено)
																				, ДанныеСценария
																				,
																				, Истина);
		КонецЕсли;
	КонецЕсли;
	// Закэшируем варианты ответов	
	Если ЗначениеЗаполнено(КэшВариантовОтветов) Тогда 
		РегистрыСведений.КэшВариантовОтветов.ЗакэшироватьВариантыОтветов(ДиалогID, КэшВариантовОтветов);	
	КонецЕсли;	
	//	Прервать;
	//КонецЦикла;
	
КонецПроцедуры


#КонецОбласти
