// Процедура, обработчик события "ОбработкаПолученияФормы"
//
Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Если Параметры.Свойство("ЗначенияЗаполнения") 
			И Параметры.ЗначенияЗаполнения.Свойство("ТипКонтрагента") 
			И ТипЗнч(Параметры.ЗначенияЗаполнения.ТипКонтрагента) = Тип("ФиксированныйМассив")
			И Параметры.ЗначенияЗаполнения.ТипКонтрагента[0] = Перечисления.ТипыКонтрагентов.Клиенты Тогда
			
			ВыбраннаяФорма = "ФормаЭлементаКлиенты";
			
		ИначеЕсли Параметры.Свойство("ЗначенияЗаполнения") 
			И Параметры.ЗначенияЗаполнения.Свойство("ТипКонтрагента") 
			И НЕ Параметры.ЗначенияЗаполнения.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
			
			ВыбраннаяФорма = "ФормаЭлемента";
			
		ИначеЕсли Параметры.Свойство("ЗначенияЗаполнения") И Параметры.ЗначенияЗаполнения.Свойство("Родитель") Тогда  
			Если НЕ Параметры.ЗначенияЗаполнения.Родитель.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда // Новый Элемент
				
				ВыбраннаяФорма = "ФормаЭлемента";
				
			ИначеЕсли Параметры.ЗначенияЗаполнения.Родитель.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
				
				ВыбраннаяФорма = "ФормаЭлементаКлиенты";
				
			КонецЕсли;
		ИначеЕсли Параметры.Свойство("Ключ") Тогда // Существующий элемент
			
			// Статус = РегистрыСведений.СтатусыКонтрагентов.ПолучитьСтатусКлиента(Параметры.Ключ);
			Если Параметры.Ключ.Родитель.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
				ВыбраннаяФорма = "ФормаЭлементаКлиенты"; 
			Иначе
				ВыбраннаяФорма = "ФормаЭлемента";
			КонецЕсли;
			
		ИначеЕсли Параметры.Свойство("ЗначениеКопирования")	Тогда
			Если Параметры.ЗначениеКопирования.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
				ВыбраннаяФорма = "ФормаЭлементаКлиенты";		
			Иначе
				ВыбраннаяФорма = "ФормаЭлемента";	
			КонецЕсли;	
			
		Иначе
			ВыбраннаяФорма = "ФормаЭлементаКлиенты";
		КонецЕсли;
		
	ИначеЕсли ВидФормы = "ФормаВыбора" Тогда 
		
		// СтандартнаяОбработка = Ложь;
		// ВыбраннаяФорма = "ФормаВыбора";
		
	КонецЕсли;
	
КонецПроцедуры

// Функция создает папки справочника по умолчанию.
//
Процедура ЗаполнитьПоУмолчанию() Экспорт
	
	// Создаем группы элементов в справочнике "Контрагенты"
	ИскомыйЭлемент = Справочники.Контрагенты.НайтиПоНаименованию("Пациенты",Истина, Справочники.Контрагенты.ПустаяСсылка());
	Если ИскомыйЭлемент.Пустая() Тогда
		Клиенты                = Справочники.Контрагенты.СоздатьГруппу();
		Клиенты.Наименование   = "Пациенты";
		Клиенты.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты; 
		Клиенты.Автокоррекция  = 1;
		Клиенты.Записать();
	КонецЕсли;
	
	ИскомыйЭлемент = Справочники.Контрагенты.НайтиПоНаименованию("Поставщики",Истина, Справочники.Контрагенты.ПустаяСсылка());
	Если ИскомыйЭлемент.Пустая() Тогда
		Поставщики                = Справочники.Контрагенты.СоздатьГруппу();
		Поставщики.Наименование   = "Поставщики";
		Поставщики.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Поставщик;
		Поставщики.Записать();
	КонецЕсли;
	
	ИскомыйЭлемент = Справочники.Контрагенты.НайтиПоНаименованию("Страховые компании",Истина, Справочники.Контрагенты.ПустаяСсылка());
	Если ИскомыйЭлемент.Пустая() Тогда
		Страховые                 = Справочники.Контрагенты.СоздатьГруппу();
		Страховые.Наименование    = "Страховые компании";
		Страховые.ТипКонтрагента  = Перечисления.ТипыКонтрагентов.СтраховаяКомпания;
		Страховые.Записать();
	КонецЕсли;

КонецПроцедуры

// Функция определяет значения реквизитов выбранного контрагента.
//
// Параметры:
//  Контрагент - СправочникСсылка.Контрагенты - Ссылка на контрагента
//
// Возвращаемое значение:
//	Структура - реквизиты выбранного контрагента
//
Функция ПолучитьРеквизитыКонтрагента(Контрагент) Экспорт
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	Контрагенты.Наименование КАК Наименование,
	|	ВЫРАЗИТЬ(Контрагенты.НаименованиеПолное КАК Строка(1000)) КАК НаименованиеПолное,
	|	Контрагенты.ИНН КАК ИНН,
	|	Контрагенты.КПП КАК КПП,
	|	Контрагенты.КодПоОКПО КАК КодПоОКПО,
	|	Контрагенты.ЮрФизЛицо КАК ЮрФизЛицо,
	|	Контрагенты.ЗаконныйПредставитель.Наименование КАК ЗаконныйПредставитель
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка = &Контрагент
	|");
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Представление = Выборка.Наименование;
		Наименование = ?(Не ПустаяСтрока(Выборка.НаименованиеПолное), Выборка.НаименованиеПолное, Выборка.Наименование);
		ИНН = Выборка.ИНН;
		КПП = Выборка.КПП;
		КодПоОКПО = Выборка.КодПоОКПО;
		ЮрФизЛицо = Выборка.ЮрФизЛицо;
		ЗаконныйПредставитель = ?(ЗначениеЗаполнено(Выборка.ЗаконныйПредставитель), Выборка.ЗаконныйПредставитель, "") ;
	Иначе
		Представление = "";
		Наименование = "";
		ИНН = "";
		КПП = "";
		КодПоОКПО = "";
		ЮрФизЛицо = Перечисления.ЮрФизЛицо.ПустаяСсылка();
		ЗаконныйПредставитель = "";
	КонецЕсли;
	
	СтруктураРеквизитов = Новый Структура("Представление, Наименование, ИНН, КПП, КодПоОКПО, ЮрФизЛицо, ЗаконныйПредставитель",
		Представление,
		Наименование,
		ИНН,
		КПП,
		КодПоОКПО,
		ЮрФизЛицо,
		ЗаконныйПредставитель
	);
	
	Возврат СтруктураРеквизитов;

КонецФункции // ПолучитьРеквизитыКонтрагента()

