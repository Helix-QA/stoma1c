// Функция - Получить параметры открытия формы профосмотр
//
// Параметры:
//  СтрокаТЗ - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрыОткрытияФормыПрофосмотр(СтрокаТЗ)
		
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("СтруктурнаяЕдиница"	, СтрокаТЗ.СтруктурнаяЕдиница);
	СтруктураОтбора.Вставить("Сотрудник"			, СтрокаТЗ.Сотрудник);
	СтруктураОтбора.Вставить("ВидОсмотра"			, СтрокаТЗ.ВидОсмотра);
	СтруктураОтбора.Вставить("Контрагент"			, Объект.Ссылка);
	СтруктураОтбора.Вставить("Период"				, СтрокаТЗ.Начало);
	
	МассивСтруктураЗаписи = Новый Массив;
	МассивСтруктураЗаписи.Добавить(СтруктураОтбора);

	Возврат Новый("РегистрСведенийКлючЗаписи.Профосмотры", МассивСтруктураЗаписи);
	
