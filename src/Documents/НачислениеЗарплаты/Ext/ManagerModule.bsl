	                         |		ПО ПродажиСебестоимостьОбороты.Материал = ЦеныНоменклатурыСрезПоследних.Номенклатура
	                         |			И (ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка.Упаковка = ЦеныНоменклатурыСрезПоследних.Упаковка)
	                         |ГДЕ
	                         |	&УчитыватьМатериалы = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.УчитыватьСтоимостьМатериалов)
	                         |	И ПродажиСебестоимостьОбороты.СтоимостьОборот >= 0 // Убираем влияние возвратов что бы не дублировалось
	                         |
	                         |ОБЪЕДИНИТЬ ВСЕ
	                         |
	                         |ВЫБРАТЬ
	                         |	ПартииТоваровОбороты.ПериодСекунда,
	                         |	ПартииТоваровОбороты.Регистратор,
	                         |	NULL,
	                         |	ПартииТоваровОбороты.Номенклатура,
	                         |	-1 * ВЫБОР
	                         |		КОГДА &ТипЦен = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоЗакупочнойЦене)
	                         |			ТОГДА ЕСТЬNULL(ПартииТоваровОбороты.СтоимостьОборот, 0)
	                         |		ИНАЧЕ ПартииТоваровОбороты.КоличествоОборот * (ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) / ВЫБОР
	                         |				КОГДА ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 0) = 0
	                         |					ТОГДА 1
	                         |				ИНАЧЕ ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент
	                         |			КОНЕЦ)
	                         |	КОНЕЦ,
	                         |	ИСТИНА
	                         |ИЗ
	                         |	РегистрНакопления.ПартииТоваров.Обороты(
	                         |			&НачалоПериода,
	                         |			&КонецПериода,
	                         |			Авто,
							 |				ТИПЗНАЧЕНИЯ(Склад) = ТИП(Справочник.Сотрудники)
	                         |				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                         |				И ВЫБОР
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотруднику)
							 |							ИЛИ &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПродажиОформленныхСотрудником)
	                         |						ТОГДА Склад = &Сотрудник
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеВрача)
	                         |						ТОГДА Склад = &Сотрудник
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеАссистента)
	                         |						ТОГДА ЛОЖЬ
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеЗубногоТехника)
	                         |						ТОГДА ЛОЖЬ							 
	                         |					ИНАЧЕ ИСТИНА
	                         |				КОНЕЦ
	                         |				И ВЫБОР
	                         |					КОГДА &СегментПередаваемыхМатериалов <> ЗНАЧЕНИЕ(Справочник.СегментыНоменклатуры.ПустаяСсылка)
	                         |						ТОГДА Номенклатура В
	                         |								(ВЫБРАТЬ
	                         |									РегистрСведений.НоменклатураСегмента.Номенклатура
	                         |								ИЗ
	                         |									РегистрСведений.НоменклатураСегмента
	                         |								ГДЕ
	                         |									РегистрСведений.НоменклатураСегмента.Сегмент = &СегментПередаваемыхМатериалов)
	                         |					ИНАЧЕ ИСТИНА
	                         |				КОНЕЦ) КАК ПартииТоваровОбороты
	                         |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	                         |			ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка.Номенклатура КАК Номенклатура,
	                         |			МИНИМУМ(ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка.Упаковка) КАК Упаковка
	                         |		ИЗ
	                         |			РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	                         |					&КонецПериода,
	                         |					Актуальность = ИСТИНА
	                         |						И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                         |						И ВидЦен = &ВидЦен) КАК ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка
	                         |		
	                         |		СГРУППИРОВАТЬ ПО
	                         |			ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка.Номенклатура) КАК ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка
	                         |		ПО ПартииТоваровОбороты.Номенклатура = ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка.Номенклатура
	                         |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	                         |				&КонецПериода,
	                         |				Актуальность = ИСТИНА
	                         |					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                         |					И ВидЦен = &ВидЦен) КАК ЦеныНоменклатурыСрезПоследних
	                         |		ПО ПартииТоваровОбороты.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	                         |			И (ЦеныНоменклатурыСрезПоследнихПодобраннаяУпаковка.Упаковка = ЦеныНоменклатурыСрезПоследних.Упаковка)
	                         |ГДЕ
	                         |	&УчитыватьМатериалы = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ВычитатьСтоимостьПереданныхСотрудникуМатериалов)							 
							 |	И ТИПЗНАЧЕНИЯ(Регистратор) = ТИП(Документ.ПеремещениеЗапасов)
	                         |
	                         |УПОРЯДОЧИТЬ ПО
	                         |	Дата
		                     |;
		                     |
		                     |////////////////////////////////////////////////////////////////////////////////
							 |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                         |	ПродажиОбороты.ПериодСекунда КАК Дата,
	                         |	ПродажиОбороты.ДокументПродажи КАК Документ,
	                         |	ПродажиОбороты.Контрагент КАК Контрагент,
	                         |	ПродажиОбороты.Номенклатура КАК Номенклатура,
	                         |	ПродажиОбороты.СтоимостьОборот * (ВЫБОР 
						 	 |			КОГДА ЕСТЬNULL(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаРасход, 0) = 0 
						 	 |				ТОГДА 1 
						 	 |			ИНАЧЕ ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаПриход / ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаРасход 
							 |		КОНЕЦ) КАК Сумма
	                         |ИЗ
	                         |	РегистрНакопления.Продажи.Обороты(
	                         |			,
	                         |			,
	                         |			Авто,
	                         |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                         |				И ВЫБОР
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСтоматологии)
	                         |						ТОГДА ИСТИНА
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотруднику)
	                         |						ТОГДА Сотрудник = &Сотрудник ИЛИ Ассистент = &Сотрудник
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеВрача)
	                         |						ТОГДА Сотрудник = &Сотрудник
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеАссистента)
	                         |						ТОГДА Ассистент = &Сотрудник
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеЗубногоТехника)
	                         |						ТОГДА ЗубнойТехник = &Сотрудник							 
	                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПродажиОформленныхСотрудником)
	                         |						ТОГДА ВЫБОР 
							 |								КОГДА ТИПЗНАЧЕНИЯ(ДокументПродажи) В (ТИП(Документ.Реализация), ТИП(Документ.ВозвратОтПокупателя), ТИП(Документ.Прием))
	                         |							  		ТОГДА ДокументПродажи.Сотрудник = &Сотрудник
							 |								ИНАЧЕ ЛОЖЬ
							 |							  КОНЕЦ
	                         |					ИНАЧЕ ИСТИНА
	                         |				КОНЕЦ) КАК ПродажиОбороты
	                         |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ВзаиморасчетыСКонтрагентами.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, , , ) КАК ВзаиморасчетыСКонтрагентамиОстаткиИОбороты
	                         |		ПО (ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации = ПродажиОбороты.ДокументПродажи)
	                         |
	                         |УПОРЯДОЧИТЬ ПО
	                         |	ПродажиОбороты.ПериодСекунда";
	КонецЕсли;
	
	ЗапросПоПродажам.УстановитьПараметр("СтруктурнаяЕдиница", 				НачислениеУдержание.СтруктурнаяЕдиница);						 
	ЗапросПоПродажам.УстановитьПараметр("НачалоПериода", 					НачалоДня(ПериодС));
	ЗапросПоПродажам.УстановитьПараметр("КонецПериода", 					КонецДня(ПериодПо));
	ЗапросПоПродажам.УстановитьПараметр("УсловиеПоМедПолисамПриема", 		НачислениеУдержание.УсловиеПоМедПолисамПриема);
	ЗапросПоПродажам.УстановитьПараметр("ОтПродаж", 						НачислениеУдержание.ОтПродаж);
	ЗапросПоПродажам.УстановитьПараметр("Сотрудник", 						НачислениеУдержание.Владелец);
	ЗапросПоПродажам.УстановитьПараметр("УчитыватьМатериалы", 				НачислениеУдержание.УчитыватьМатериалы);
	ЗапросПоПродажам.УстановитьПараметр("ИспользоватьСкидки",				НачислениеУдержание.ОтСуммы); 
	ЗапросПоПродажам.УстановитьПараметр("ВидЦенСуммы", 						НачислениеУдержание.ВидЦенСуммы);
	ЗапросПоПродажам.УстановитьПараметр("СегментНоменклатуры", 				НачислениеУдержание.СегментНоменклатуры);
	ЗапросПоПродажам.УстановитьПараметр("СегментПередаваемыхМатериалов",	НачислениеУдержание.СегментПередаваемыхМатериалов);
	ЗапросПоПродажам.УстановитьПараметр("СегментКонтрагента", 				НачислениеУдержание.СегментКонтрагента);
	ЗапросПоПродажам.УстановитьПараметр("УчитываяТолькоОплаченныеПродажи", 	НачислениеУдержание.УчитываяТолькоОплаченныеПродажи);
	ЗапросПоПродажам.УстановитьПараметр("ВидЦен", 							НачислениеУдержание.ВидЦен);
	ЗапросПоПродажам.УстановитьПараметр("ТипЦен", 							НачислениеУдержание.ТипЦен);
	
	РезультатЗапроса = ЗапросПоПродажам.ВыполнитьПакет();
	
	СуммаПродаж = РезультатЗапроса[0].Выгрузить().Итог("Сумма");
	ОбщаяСуммаПродаж = РезультатЗапроса[1].Выгрузить().Итог("Сумма");
	Если НачислениеУдержание.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЕслиСуммаПродажи
			И НЕ (НачислениеУдержание.ТипСравнения = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Больше И СуммаПродаж >= НачислениеУдержание.СуммаПродаж
				ИЛИ НачислениеУдержание.ТипСравнения = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Меньше И СуммаПродаж < НачислениеУдержание.СуммаПродаж) Тогда
		Возврат;
	ИначеЕсли НачислениеУдержание.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЕслиОбщаяСуммаПродажи
			И НЕ (НачислениеУдержание.ТипСравнения = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Больше И ОбщаяСуммаПродаж >= НачислениеУдержание.СуммаПродаж
				ИЛИ НачислениеУдержание.ТипСравнения = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Меньше И ОбщаяСуммаПродаж < НачислениеУдержание.СуммаПродаж) Тогда				
		Возврат;
	КонецЕсли;
	
	БазаРассчитанная = РасчетБазыПоНачислению(НачислениеУдержание, СуммаПродаж);
	
	Если БазаРассчитанная <> 0 И БазаРассчитанная <> СуммаПродаж Тогда
		
		Коэффициент = СуммаПродаж / БазаРассчитанная;
		ТаблицаДляЗатрат = РезультатЗапроса[0].Выгрузить();	
		
		МаксимальнаяСумма = 0;
		Для Каждого СтрокаТЧ Из ТаблицаДляЗатрат Цикл
			СтрокаТЧ.Сумма = Окр(СтрокаТЧ.Сумма / Коэффициент, 2);
			Если СтрокаТЧ.Сумма > МаксимальнаяСумма Тогда
				МаксимальнаяСумма = СтрокаТЧ.Сумма;
			КонецЕсли;
		КонецЦикла;          		
		
		// В результате деления на коэффициент может возникать огромный хвост после запятой и в результате может давать ложные копейки. 
		// Их необходимо откруглить до той базы, на которую мы должны выйти.  
		// Если есть погрешность, то находим МаксимальнаяСумма в таблице, в строке с которой потом корректируем копейки в колонке База и Сумма.
		
		РазницаСуммы = БазаРассчитанная - ТаблицаДляЗатрат.Итог("Сумма");                                                                          	
		
		Если РазницаСуммы <> 0 Тогда                                       
			СтрокаТЗ = ТаблицаДляЗатрат.НайтиСтроки(Новый Структура("Сумма", МаксимальнаяСумма));
			
			Если ЗначениеЗаполнено(СтрокаТЗ) Тогда 			
				СтрокаТЗ[0].Сумма = СтрокаТЗ[0].Сумма + РазницаСуммы;
			КонецЕсли;
			
		КонецЕсли;  
		
		Для Каждого СтрокаТЧ Из ТаблицаДляЗатрат Цикл
			ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, СтрокаТЧ.Дата, СтрокаТЧ.Документ, СтрокаТЧ.Контрагент, СтрокаТЧ.Номенклатура,
			, , СтрокаТЧ.Сумма, НачислениеУдержание.Размер, СтрокаТЧ.Сумма * НачислениеУдержание.Размер / 100);				
		КонецЦикла;   		
		
		РазницаСуммыПоЗатратам = БазаРассчитанная * НачислениеУдержание.Размер / 100 - ТаблицаРасшифровкиНачислений.Итог("Сумма"); 
		Если РазницаСуммыПоЗатратам <> 0 Тогда		
			
			Если ЗначениеЗаполнено(СтрокаТЗ) Тогда
				СтрокаТЗЗатрат = ТаблицаРасшифровкиНачислений.НайтиСтроки(Новый Структура("Документ, Номенклатура", СтрокаТЗ[0].Документ, СтрокаТЗ[0].Номенклатура));
				Если ЗначениеЗаполнено(СтрокаТЗЗатрат) Тогда
					СтрокаТЗЗатрат[0].Сумма = СтрокаТЗЗатрат[0].Сумма + РазницаСуммыПоЗатратам;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли БазаРассчитанная = СуммаПродаж Тогда
		Выборка = РезультатЗапроса[0].Выбрать();
		Пока Выборка.Следующий() Цикл            			
			
			ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, Выборка.Дата, Выборка.Документ, Выборка.Контрагент, Выборка.Номенклатура,
			, , Выборка.Сумма, НачислениеУдержание.Размер, Выборка.Сумма * НачислениеУдержание.Размер / 100);
		КонецЦикла;    
	КонецЕсли;           
	
КонецПроцедуры // РасчетПоПроцентнойСтавке()

// Производится расчет ЗП при установленной виде начисления "Тариф"
//
Процедура РасчетыПоТарифу(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы = Неопределено)
	
	Если НачислениеУдержание.ТипТарифа	 = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.АвторуЗаПервичныйПрием Тогда
		
