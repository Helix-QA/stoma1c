// Функция - Получить таблицу интерсов
//
// Параметры:
//  Объект					 - 	 - 
//  ВыводитьРодственников	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуИнтересов(Знач СсылкаОбъекта)
	
	// Создаем таблицу
	ТаблицаИнтересов = Новый ТаблицаЗначений;
	ТаблицаИнтересов.Колонки.Добавить("Интерес"		, Новый ОписаниеТипов("СправочникСсылка.Интересы"));
	ТаблицаИнтересов.Колонки.Добавить("УИД_Интереса", Новый ОписаниеТипов("Строка"));
	
	// Возвращаемся если объект не заполнен
	Если ТипЗнч(СсылкаОбъекта) = Тип("ДанныеФормыСтруктура") Тогда 
		//Если НЕ ЗначениеЗаполнено(СсылкаОбъекта.Ссылка) Тогда 
		//	Возврат ТаблицаИнтересов;
		//КонецЕсли;
	Иначе 
		Если НЕ ЗначениеЗаполнено(СсылкаОбъекта) Тогда 
			Возврат ТаблицаИнтересов;
		КонецЕсли;	
	КонецЕсли;
	
	// Заполняем таблицу интересами
	Для Каждого СтрокаИнтересов Из СсылкаОбъекта.Интересы Цикл 
		НоваяСтрокаТЗ 				= ТаблицаИнтересов.Добавить();
	    НоваяСтрокаТЗ.Интерес 		= СтрокаИнтересов.Интерес;
		Если ТипЗнч(СтрокаИнтересов) = Тип("СправочникТабличнаяЧастьСтрока.Контрагенты.Интересы") Тогда
			НоваяСтрокаТЗ.УИД_Интереса = "ИнтересИД_" + СтрокаИнтересов.НомерСтроки;
		Иначе 
			НоваяСтрокаТЗ.УИД_Интереса = "ИнтересИД_" + СтрокаИнтересов.ПолучитьИдентификатор();
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат ТаблицаИнтересов;	
	
КонецФункции

