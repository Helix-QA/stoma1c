	|	let newElement = document.createElement('div');
	|	newElement.className = 'show-all';
	|	newElement.innerText = 'Показать все';
	|	newElement.dataset.count = child.querySelector('.item-count').dataset.count;
	|	newElement.dataset.status = child.dataset.id;
	|	
