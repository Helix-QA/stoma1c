// Функция - Обновление записи в случае успешного пробития вручную.
//
Процедура ЗаписатьПризнакПробитияЧекаВручную(ДокументОплаты, НомерФискальногоЧека) Экспорт    	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ОчередьКассовогоСервера.НомерФискальногоЧека, 0) КАК НомерФискальногоЧека
	|ИЗ
	|	РегистрСведений.ОчередьКассовогоСервера КАК ОчередьКассовогоСервера
	|ГДЕ
	|	ОчередьКассовогоСервера.ДокументОплаты = &ДокументОплаты";
	
	Запрос.УстановитьПараметр("ДокументОплаты", ДокументОплаты);
	Результат = Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда   	
		Выборка = Результат.Выбрать();
		
		Если Выборка.НомерФискальногоЧека = Неопределено Тогда
			
			НомерТекущегоСеанса = НомерСеансаИнформационнойБазы();
			
			Попытка   
				МенеджерЗаписи = РегистрыСведений.ОчередьКассовогоСервера.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.ДокументОплаты = ДокументОплаты;
				МенеджерЗаписи.Прочитать();   
				
				МенеджерЗаписи.НомерФискальногоЧека = НомерФискальногоЧека;
				МенеджерЗаписи.ОшибкаПробитияЧека   = "Пробит вручную";
				МенеджерЗаписи.ДатаПробития         = ТекущаяДата();
				МенеджерЗаписи.Статус               = Перечисления.СтатусыПробитияЧекаКассовымСервером.Пробит;
				МенеджерЗаписи.НомерСеансаИБ        = НомерТекущегоСеанса;
				
				МенеджерЗаписи.Записать();				
				
			Исключение  
				
				ОписаниеОшибки = ОписаниеОшибки();
				ВызватьИсключение ОписаниеОшибки;
				
			КонецПопытки;   
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры  

#КонецОбласти
