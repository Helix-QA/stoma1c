// Процедура - обработчик события "Выбор" поля формы "ВидыОплат"
// 
Процедура ОбработчикНажатияВидыОплатВыбор(Элемент, ВыбраннаяСтрока = Неопределено, Поле = Неопределено, СтандартнаяОбработка)
	
	ЭтоПродажа = ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа");
	
	СтрокаВыбраннойОплаты = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	МассивСтрокСВнесеннойОплатой = ПолучитьСтрокиСВнесеннойОплатой();
	
	Если НЕ ВозможенСмешанныйТипОплаты(СтрокаВыбраннойОплаты) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Смешанный тип оплаты 
		|недоступен для оплаты через систему быстрых платежей или ссылок на оплату");
		Возврат;
	КонецЕсли;
	
	Если СтрокаВыбраннойОплаты.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат")
		И НЕ ЗначениеЗаполнено(СтрокаВыбраннойОплаты.Сертификат) Тогда
		
		НачатьВводСерииСертификата(Элемент);
		
	ИначеЕсли СтрокаВыбраннойОплаты.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет")
		И НЕ ЗначениеЗаполнено(СтрокаВыбраннойОплаты.ВидЛицевогоСчета) Тогда
	
		НачатьВводВидаЛицевогоСчета(Элемент);
				
	ИначеЕсли СтрокаВыбраннойОплаты.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПустаяСсылка") Тогда
		
		ПроверитьВозможностьОплатыВКредит(Элемент);
		
	ИначеЕсли СтрокаВыбраннойОплаты.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей") Тогда
		
		ПроверитьВозможностьОплатыСБП(СтрокаВыбраннойОплаты, Элемент);
		
	ИначеЕсли СтрокаВыбраннойОплаты.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Аванс") Тогда
		
		Если НЕ УчитыватьАвансыВРазрезеДокументов Тогда
			Для Каждого ЭлементМ ИЗ ТаблицаЗадолженностей Цикл
				Если НЕ ТипЗнч(ЭлементМ.ДокументЗадолженности) = Тип("ДокументСсылка.Прием") и НЕ ТипЗнч(ЭлементМ.ДокументЗадолженности) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
					Предупреждение("Авансы используются только для оплаты приемов!");
					Возврат;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;               
		ВводСуммыОплаты(Элемент);
		
	Иначе
		
		ВводСуммыОплаты(Элемент);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте 
// Функция - Возможен смешанный тип оплаты
//
// Параметры:
//  СтрокаВыбраннойОплаты	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВозможенСмешанныйТипОплаты(СтрокаВыбраннойОплаты)
	
	МассивСтрокНеСовместимыхСБП = ПолучитьСтрокиСВнесеннойОплатой(ТДСНедоступныеДляСмешОплатыПоСБП());
	МассивИмеющихсяСБП = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей"));
	
	// СП - Смешанные платежи
	Возврат СтрокаВыбраннойОплаты.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.БонусныйСчет") // При вводе бонусов разрешены СП
	ИЛИ
	СтрокаВыбраннойОплаты.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей") 
	И (МассивИмеющихсяСБП.Количество() = 0 ИЛИ СтрокаВыбраннойОплаты.ЭквайринговыйТерминал = МассивИмеющихсяСБП[0].ЭквайринговыйТерминал) // Для СБП разрешены СП по бон. счетам 
	И МассивСтрокНеСовместимыхСБП.Количество() = 0 		
	ИЛИ СтрокаВыбраннойОплаты.ТипДенежныхСредств <> ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей") И МассивИмеющихсяСБП.Количество() = 0
	
КонецФункции

&НаСервереБезКонтекста
Функция ТДСНедоступныеДляСмешОплатыПоСБП()
	
	МассивТДС = Новый Массив;
	
	МассивТДС.Добавить(Перечисления.ТипыДенежныхСредств.Аванс);
	МассивТДС.Добавить(Перечисления.ТипыДенежныхСредств.Безналичные);
	МассивТДС.Добавить(Перечисления.ТипыДенежныхСредств.ЛицевойСчет);
	МассивТДС.Добавить(Перечисления.ТипыДенежныхСредств.Наличные);
	МассивТДС.Добавить(Перечисления.ТипыДенежныхСредств.ПереводыВПути);
	МассивТДС.Добавить(Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта);
	МассивТДС.Добавить(Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат);
	
	Возврат МассивТДС;
	
КонецФункции


&НаКлиенте
// Процедура, проверяет возможность оплаты в кредит.
//
Процедура ПроверитьВозможностьОплатыВКредит(Элемент)
	
	ОплатаРазрешена       = Истина;
	СтрокаВыбраннойОплаты = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	
	ПараметрыПроверки = ?(СтрокаВыбраннойОплаты <> Неопределено, Новый Структура("Внесено", СтрокаВыбраннойОплаты.Внесено), Неопределено);
	
	ОписаниеОграничения = ПроверитьВозможностьОплатыВКредитНаСервере(ПараметрыПроверки);
	 
	 Если ЗначениеЗаполнено(ОписаниеОграничения) Тогда
		 
		 ПоказатьОповещениеПользователя(
			 "Оплата",,
			 ОписаниеОграничения, 
			 БиблиотекаКартинок.Предупреждение32,
			 СтатусОповещенияПользователя.Важное);
		 
	 Иначе
		 
		 ВводСуммыОплаты(Элемент);
		 
	 КонецЕсли;	
	 
 КонецПроцедуры
 
 &НаСервере
 // Процедура, проверяет возможность оплаты в кредит на сервере.
//
 Функция ПроверитьВозможностьОплатыВКредитНаСервере(СтрокаВыбраннойОплаты)
	 
	 ОплатаРазрешена = Истина;
	 
	 Если ОплатаВнесено <> 0 Тогда
		 
		 Если СтрокаВыбраннойОплаты <> Неопределено Тогда
			 
			 ОплатаРазрешена = (СтрокаВыбраннойОплаты.Внесено = ОплатаВнесено);  			
		 Иначе
			 ОплатаРазрешена = Ложь;
		 КонецЕсли;	
		 
	 КонецЕсли;	
	 
	 Если ОплатаРазрешена = Ложь Тогда
		 
		 Возврат "Нельзя оплатить в кредит документ, если он был оплачен другим видом оплаты!";
		 
	 КонецЕсли;
	 
	 ДокументУжеПробит  = Ложь;
	 ДокументУжеОплачен = Ложь;
	 
	 Для Каждого СтрокаТЧ Из ТаблицаЗадолженностей Цикл
		 
		 Если СтрокаТЧ.ПризнакВыбора = Истина Тогда
			 
			 ДокументЗадолженности = СтрокаТЧ.ДокументЗадолженности;
			 
			 Если СтрокаТЧ.Оплачено <> 0 Тогда
				 ДокументУжеОплачен = Истина;
			 ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("НомерЧекаККМ", ДокументЗадолженности.Метаданные()) И ЗначениеЗаполнено(ДокументЗадолженности.НомерЧекаККМ) Тогда 
				 ДокументУжеПробит = Истина;		 
			 КонецЕсли;
			 
			 ОплатаРазрешена = НЕ (ДокументУжеОплачен Или ДокументУжеПробит);
			 
			 Если Не ОплатаРазрешена Тогда
				 Прервать;
			 КОнецЕсли;
			 
		 КонецЕсли;	
		 
	 КонецЦикла; 
	 
	 Если ОплатаРазрешена = Ложь Тогда
		 
		 Возврат
		 ?(ДокументУжеОплачен, 
		 СтрШаблон("Нельзя оплатить в кредит документы, которые были частично оплачены!
		 		   |%1", Строка(ДокументЗадолженности)), 
		 СтрШаблон("Документ %1 уже пробит на фискальном регистраторе", Строка(ДокументЗадолженности)));		 
		 
	 КонецЕсли;	
	 
 КонецФункции

// Процедура - Ввод суммы оплаты
// 
&НаКлиенте
Процедура ВводСуммыОплаты(Элемент)
	
	ЭтоПродажа = ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа");
	
	СтрокаВыбраннойОплаты = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	ЭтоПолеАванса	      = ЗначениеЗаполнено(СтрокаВыбраннойОплаты.ДокументАванса);
	
	ПрефиксПоля  = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);
	ПолеРедСуммы = ВидыОплатСтрокаПолеВводаСуммы(ПрефиксПоля);
	
	Заглушка = Элементы.Найти("ДекорацияЗаглушка_" + ПрефиксПоля);
	
	Если Заглушка <> Неопределено Тогда
		Заглушка.Видимость = Истина;	
	КонецЕсли;
	
	ОтключитьОбработчикОжидания("ОбработчикТаймераКонтроляПотериФокусаПоляВводаСуммы");
	
	Если ТекущееПолеВВодаСуммыОплаты = ПолеРедСуммы И Не ЭтоПолеАванса Тогда
		ЗавершитьРедактированиеПоляВводаСуммы(ПолеРедСуммы);
		Возврат;
	КонецЕсли;
	
	Если ПредПолеВВодаСуммыОплаты <> Неопределено Тогда	
		ЗавершитьРедактированиеПоляВводаСуммы(ПредПолеВВодаСуммыОплаты);		
	КонецЕсли;
	
	СуммаОжидаемогоПлатежа                = ЭтотОбъект.ОплатаСумма -  ЭтотОбъект.ОплатаВнесено;
	ОграничениеСуммыТипаДенежныхСредств   = Неопределено;
	СуммаПодтвержденногоПлатежа           = 0;
	ОплачиваемыеДокументы                 = ПолучитьВыбранныеДокументыЗадолженности();
	
	Если ОплачиваемыеДокументы.Количество() = 0  Тогда 				
		ПоказатьОповещениеПользователя("Оплата",,"Выберите оплачиваемые документы.", БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 			
		Возврат
	КонецЕсли;	
	
	Если ОплатаВнесено >= ОплатаСумма
		И СтрокаВыбраннойОплаты.Внесено = 0 Тогда 
		ПоказатьОповещениеПользователя("Оплата",,"Сумма оплаты полностью покрывает сумму документа. Новый вид оплаты не может быть добавлен.", БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 			
		Возврат
	КонецЕсли;		
					
	НачатьРедактированияПоляВводаСуммы(ПолеРедСуммы);
		
КонецПроцедуры

// Процедура - Обработчик нажатия кнопка представление суммы
