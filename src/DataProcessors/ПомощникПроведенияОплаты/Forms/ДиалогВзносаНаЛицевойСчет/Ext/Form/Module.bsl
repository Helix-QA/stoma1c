&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВидЛицевогоСчета                       		= Справочники.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет;
	
	Параметры.Свойство("Касса", Касса);	
	Если Не ЗначениеЗаполнено(Касса) Тогда
		Касса = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.ОсновнаяКасса;    		
	КонецЕсли;
	
	Если Параметры.Свойство("Контрагент") Тогда 		
		ЭтаФорма.Контрагент = Параметры.Контрагент; 		
	КонецЕсли;
	
	ИспользоватьБезПодключенияОборудования 		= ?(ЗначениеЗаполнено(Касса), Касса.ИспользоватьБезПодключенияОборудования, Ложь);	
	СостояниеКассовойСмены              		= РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Касса);
	КассоваяСмена                       		= ?(СостояниеКассовойСмены <> Неопределено,  СостояниеКассовойСмены.КассоваяСмена, Неопределено);   	
	ЭквайринговыйТерминал                  		= Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыйТерминалПоУмолчанию(Касса);
	ИспользоватьБезПодключенияОборудования_ЭТ   = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭквайринговыйТерминал, "ИспользоватьБезПодключенияОборудования");
	ФискальныйРегистратор                  		= ПолучитьСсылкиНаОборудование(Касса);
	СтруктурнаяЕдиница                          = Касса.СтруктурнаяЕдиница;
	Организация                                 = СтруктурнаяЕдиница.Организация;
	ККТ                                         = ФискальныйРегистратор.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ;
	Сотрудник                                   = ПараметрыСеанса.ТекущийПользователь.Сотрудник;
	ПроизошлаОшибкаПечатиЧека              		= Ложь;
	Элементы.ГруппаПараметрыПечати.Видимость 	= Истина;
	
	//
	// Настройка кассы оплаты.
	
	МассивДоступныхКасс = РозничныеПродажи.ПолучитьКассыДоступныеДляОплаты(Справочники.Кассы.ПолучитьКассыДляОплаты(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница), ПараметрыСеанса.РабочееМестоКлиента, Ложь);
	ОбновитьДоступныеКассыДляСсылокИСбп(МассивДоступныхКасс);
	
	// Последовательность касс уже упорядоченна по приоритету в функции: Справочники.Кассы.ПолучитьКассыДляОплаты.		
	Если МассивДоступныхКасс.Количество() > 0 Тогда
		ЭтотОбъект.Касса = МассивДоступныхКасс[0].Касса; 
	Иначе		
		Элементы.ГруппаВыборКассыДляОплаты.Видимость = Истина;
		// Доступна одна касса.  	
	КонецЕсли;
	
	Для Каждого ЭлементМассива Из МассивДоступныхКасс Цикл
		НоваяСтрока = ЭтотОбъект.ДоступныеКассы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
		Новаястрока.ИспользоватьБезПодключенияОборудования = НЕ ЭлементМассива.ФРИспользуется;
	КонецЦикла;
	
	ЭтотОбъект.ТекущаяКассаИспользуетсяККТ = ЭтотОбъект.Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ; 
	
	ПостроитьДинамическиеЭлементы("Касса");
	УстановитьВидыОплатСервер();
	РасставитьПриоритетПечатиЧека();
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
		
		КонтактнаяИнформация = МенеджерОборудованияВызовСервера.ПолучитьКонтактнуюИнформацию(ЭтотОбъект.Контрагент,, ЭтотОбъект.Касса);
		
		ЭтотОбъект.ЧекККТПочта   = КонтактнаяИнформация.Email;
		ЭтотОбъект.ЧекККТТелефон = КонтактнаяИнформация.Телефон;
		
	КонецЕсли;    
	
КонецПроцедуры

