// 
Функция ОбновитьВнешнююСистемуВ_CRM(ВнешняяСистема
								  , Используется = Истина
								  , ТекущаяСессия
								  , loginEvotor = Неопределено
								  , passwordEvotor =  Неопределено
								  , ДополнительныеПараметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Попытка 
		
		ПользовательПубликации = Константы.ВнешняяПубликацияПользователь.Получить();
		
		Если Не ЗначениеЗаполнено(ПользовательПубликации) Тогда
			
			СлужебныйПользователь = ПользователиСтоматология.СлужебныйПользовательAPI();
			
			Если Не ЗначениеЗаполнено(СлужебныйПользователь) Тогда			
				СлужебныйПользователь = ПользователиСтоматология.СоздатьСлужебногоПользователяAPI();				
			КонецЕсли;
			
			Константы.ВнешняяПубликацияПользователь.Установить(СлужебныйПользователь);
			
			ПользовательПубликации = СлужебныйПользователь;
			
		КонецЕсли;
		
		ПользовательСистемный = ПользователиСтоматология.ПолучитьПользователяПоУникальномуИдентификатору(ПользовательПубликации.ИдентификаторПользователяИБ);
		
		Если ПользовательСистемный = Неопределено Тогда				
			ПользователиСтоматология.СоздатьСлужебногоПользователяAPIДляСотрудника(ПользовательПубликации);
			ПользовательСистемный = ПользователиСтоматология.ПолучитьПользователяПоУникальномуИдентификатору(ПользовательПубликации.ИдентификаторПользователяИБ);				
		КонецЕсли;
		
		ЭтоОблачник 		  = ЛичныйКабинет.ЛиныйКабинетВМоделиСервиса();
		АдресПубликации       = Константы.ВнешняяПубликацияАдрес.Получить();
		КодПроверкиПубликации = Строка(Новый УникальныйИдентификатор);
		
		ЗаписатьКодПроверкиРубликации(КодПроверкиПубликации);
		
		ДанныеАнкеты = ЛичныйКабинет.ПолучитьДанныеРегистрационнойАнкеты();
		Если Не ЗначениеЗаполнено(ДанныеАнкеты) Тогда
			ВызватьИсключение "Данные регистрационной анкеты не заполнены";
		КонецЕсли;
		
		РегистрационныйНомерАнкеты = ДанныеАнкеты.ПродуктРегистрационныйНомер;
		
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("session", ТекущаяСессия);
		
		ПарамтерыЗапроса = Новый Структура;
		ПарамтерыЗапроса.Вставить("publication_address", АдресПубликации);
		ПарамтерыЗапроса.Вставить("publication_user"   , ПользовательСистемный.Имя);
		ПарамтерыЗапроса.Вставить("check_code"         , КодПроверкиПубликации);		
		ПарамтерыЗапроса.Вставить("registration_number", РегистрационныйНомерАнкеты);
		
		ТекстЗапроса = СобратьJson(ПарамтерыЗапроса);
		
		Попытка
			РезультатЗапроса = ВыполнитьPOSTЗапрос("products/publication_validate", ТекстЗапроса, ЗаголовкиHTTP);
		Исключение
			Возврат ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		КонецПопытки;
		
		РезультатПроверкиПубликации = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);	
		
		// Ошибка 1057 - в случае когда на стороне crm нет внешних систем по данной анкете.
		Если Не РезультатПроверкиПубликации.ВыполненоУспешно
			И РезультатПроверкиПубликации.КодОшибки <> 1057 Тогда
			
			Возврат РезультатПроверкиПубликации;
		КонецЕсли;
		
		ПроверкаПубликацииУспешна = (РезультатПроверкиПубликации.ВыполненоУспешно И РезультатПроверкиПубликации.ПараметрыРезультата.publication_valid = Истина);
		
		// Формирование запроса данных внешней системы для отправки в CRM.
		ПарамтерыЗапроса = Новый Структура;
		ПарамтерыЗапроса.Вставить("apikey"             , ВнешняяСистема.КлючПриложения);
		ПарамтерыЗапроса.Вставить("type_app"           , ПолучитьИмяПеречисления("ТипыВнешнихСистем", ВнешняяСистема.ТипВнешнейСистемы));
		ПарамтерыЗапроса.Вставить("publication_address", ?(Не ЭтоОблачник, АдресПубликации, Неопределено));
		ПарамтерыЗапроса.Вставить("check_code"         , ?(Не ЭтоОблачник, КодПроверкиПубликации, Неопределено));
		ПарамтерыЗапроса.Вставить("publication_user"   , ПользовательСистемный.Имя);
		ПарамтерыЗапроса.Вставить("loginEvotor"		   , loginEvotor);		
		ПарамтерыЗапроса.Вставить("passwordEvotor"     , passwordEvotor);
		ПарамтерыЗапроса.Вставить("secret_key"		   , ВнешняяСистема.КлючШифрованияОбратногоЗвонка);
		
		// Дополняем запрос доп. параметрами из структуры.
		Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ЗначениеЗаполнено(ДополнительныеПараметры) Тогда
			Для Каждого ЭлементСтруктуры Из ДополнительныеПараметры Цикл
				ПарамтерыЗапроса.Вставить(ЭлементСтруктуры.Ключ, ЭлементСтруктуры.Значение);
			КонецЦикла;
		КонецЕсли;
				
		УстановленНовыйПароль = Ложь;
		
		Если ПроверкаПубликацииУспешна Тогда
			ПарамтерыЗапроса.Вставить("registration_number", РегистрационныйНомерАнкеты);
		Иначе
			ПарольПользователя = ПолучитьПарольServiceUserAPI(ПользовательПубликации, УстановленНовыйПароль);
			ПарамтерыЗапроса.Вставить("publication_password", ПарольПользователя);
		КонецЕсли;
		
		ПарамтерыЗапроса.Вставить("used", Используется);
		
		ТекстЗапроса      = СобратьJson(ПарамтерыЗапроса);		
		РезультатЗапроса  = ВыполнитьPUTЗапрос("products/stoma", ТекстЗапроса, ЗаголовкиHTTP);	
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);	
		
		Если УстановленНовыйПароль Тогда
			ЗаписатьРеквизитВДанныеРегистрационнойАнкеты("ПарольServiceUserAPIВнесенВCRM", РезультатаОперции.ВыполненоУспешно);
		КонецЕсли;
		
	Исключение
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

// Функция - Обновить данные публикации внешней системы
// 
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  Используется	 - 	 - 
//  ТекущаяСессия	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ОбновитьДанныеПубликацииВнешнейСистемы(ВнешняяСистема = Неопределено
											 , Используется = Неопределено
											 , ТекущаяСессия
											 , СтруктураДополнительныхПараметров = Неопределено) Экспорт
	
	Попытка 
				
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("session", ТекущаяСессия);	
		
		ПользовательПубликации = Константы.ВнешняяПубликацияПользователь.Получить();
		
		Если НЕ ЗначениеЗаполнено(ПользовательПубликации) Тогда
			
			СлужебныйПользователь = ПользователиСтоматология.СлужебныйПользовательAPI();
			
			Если НЕ ЗначениеЗаполнено(СлужебныйПользователь) Тогда
				СлужебныйПользователь = ПользователиСтоматология.СоздатьСлужебногоПользователяAPI();
			КонецЕсли;
			
			Константы.ВнешняяПубликацияПользователь.Установить(СлужебныйПользователь);
			
		КонецЕсли;
				
		ПользовательСистемный = ПользователиСтоматология.ПолучитьПользователяПоУникальномуИдентификатору(ПользовательПубликации.ИдентификаторПользователяИБ);
		
		Если ПользовательСистемный = Неопределено Тогда
			ПользователиСтоматология.СоздатьСлужебногоПользователяAPIДляСотрудника(ПользовательПубликации);
			ПользовательСистемный = ПользователиСтоматология.ПолучитьПользователяПоУникальномуИдентификатору(ПользовательПубликации.ИдентификаторПользователяИБ);
		КонецЕсли;
		
		УстановленНовыйПароль = Ложь;
		ПарольПользователя 	  = ПолучитьПарольServiceUserAPI(ПользовательПубликации, УстановленНовыйПароль);
		КодПроверкиПубликации = Неопределено;
		ЭтоОблачник			  = ЛичныйКабинет.ЛиныйКабинетВМоделиСервиса();
		
		Если Не ЭтоОблачник Тогда
			КодПроверкиПубликации = Строка(Новый УникальныйИдентификатор);
			ЗаписатьКодПроверкиРубликации(КодПроверкиПубликации);
		КонецЕсли;
		
		ПарамтерыЗапроса = Новый Структура;
		ПарамтерыЗапроса.Вставить("apikey"				, ?(ЗначениеЗаполнено(ВнешняяСистема), ВнешняяСистема.КлючПриложения, Неопределено));
		ПарамтерыЗапроса.Вставить("publication_address"	, ?(Не ЭтоОблачник, Константы.ВнешняяПубликацияАдрес.Получить(), Неопределено));
		ПарамтерыЗапроса.Вставить("publication_user"	, ПользовательСистемный.Имя);
		ПарамтерыЗапроса.Вставить("publication_password", ПарольПользователя);
		ПарамтерыЗапроса.Вставить("used"				, Используется);
		ПарамтерыЗапроса.Вставить("check_code"			, КодПроверкиПубликации);
		
		// Дополняем запрос доп. параметрами из структуры.
		Если ЗначениеЗаполнено(СтруктураДополнительныхПараметров) Тогда
			Для Каждого СтрокаСтруктуры Из СтруктураДополнительныхПараметров Цикл
				ПарамтерыЗапроса.Вставить(СтрокаСтруктуры.Ключ, СтрокаСтруктуры.Значение);
			КонецЦикла;
		КонецЕсли;
		
		// В CRM обновляется пароль публикации в анкете, при обновлении внешней системы.
		// В этом методе - нет. Дописано чтоб обновлялся.
		Если УстановленНовыйПароль = Истина Тогда
			ПарамтерыЗапроса.Вставить("publication_password_update", Истина);	
		КонецЕсли;
		
		ТекстЗапроса = СобратьJson(ПарамтерыЗапроса);
		
		РезультатЗапроса  = ВыполнитьPUTЗапрос("external_app/publication", ТекстЗапроса, ЗаголовкиHTTP);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
		Если УстановленНовыйПароль Тогда
			ЗаписатьРеквизитВДанныеРегистрационнойАнкеты("ПарольServiceUserAPIВнесенВCRM", РезультатаОперции.ВыполненоУспешно);
		КонецЕсли;
		
	Исключение
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатаОперции;

КонецФункции

// Функция - Проверить публикацию внешней системы
// 
// Возвращаемое значение:
//   - 
// 
функция ПроверитьПубликациюВнешнейСистемы(знач ИмяПубликации) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка 
				
		Пользователь = Константы.ВнешняяПубликацияПользователь.Получить();
		
		Если НЕ ЗначениеЗаполнено(Пользователь) Тогда
			ВызватьИсключение "Пользователь внешней системы не настроен";
		КонецЕсли;
		
		ПользовательСситемный = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Пользователь.ИдентификаторПользователяИБ);
		
		УстановленНовыйПароль = Ложь;
		ПарольПользователя 	  = ПолучитьПарольServiceUserAPI(Пользователь, УстановленНовыйПароль);
		КодПроверкиПубликации = Строка(Новый УникальныйИдентификатор); 
		ЗаписатьКодПроверкиРубликации(КодПроверкиПубликации);
		
		ПарамтерыЗапроса = Новый Структура;
		ПарамтерыЗапроса.Вставить("publication_address" , ИмяПубликации);
		ПарамтерыЗапроса.Вставить("publication_user"    , ПользовательСситемный.Имя);
		ПарамтерыЗапроса.Вставить("publication_password", ПарольПользователя);
		ПарамтерыЗапроса.Вставить("check_code"          , КодПроверкиПубликации);
		
		ТекстЗапроса = СобратьJson(ПарамтерыЗапроса);
		
		РезультатЗапроса  = ВыполнитьPOSTЗапрос("products/publication_validate", ТекстЗапроса);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
		Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
			РезультатаОперции.Вставить("ПубликацияВерна", РезультатаОперции.ПараметрыРезультата.publication_valid);
		КонецЕсли;
		
		Если УстановленНовыйПароль Тогда
			ЗаписатьРеквизитВДанныеРегистрационнойАнкеты("ПарольServiceUserAPIВнесенВCRM", РезультатаОперции.ВыполненоУспешно);
		КонецЕсли;
		
	Исключение
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

// Функция - Обновить список сотрудников внешней системы в CRM
// 
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  ТекущаяСессия	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ОбновитьСписокСотрудниковВнешнейСистемыВ_CRM(ВнешняяСистема, ТекущаяСессия, Сотрудник, Использовать = Ложь, ФлагИспользованияЗаписи = Неопределено) Экспорт

	РезультатаОперции = Неопределено;
	
	Попытка 
			
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("session", ТекущаяСессия);	
		ЗаголовкиHTTP.Вставить("apikey" , ВнешняяСистема.КлючПриложения);
		
		ТаблицаДанных = РегистрыСведений.КлючиВнешнихСистем.ПолучитьСотрудниковВнешнейСистемыИМестаРаботы(ВнешняяСистема, Сотрудник, Использовать);
		
		Если ТаблицаДанных.Количество() = 0 Тогда
			Возврат Новый Структура("ВыполненоУспешно, ОписаниеОшибки", Ложь, "Данные для синхронизации с CRM отсутствуют");
		КонецЕсли;
		
		МассивДанных = Новый Массив;
		Для Каждого СтрокаТ ИЗ ТаблицаДанных Цикл
			
			СтруктураДанных = Новый Структура;
			СтруктураДанных.Вставить("phone"	 , СтрокаТ.НомерТелефона);
			СтруктураДанных.Вставить("user_token", СтрокаТ.КлючКлиента);
			СтруктураДанных.Вставить("use"		 , ?(ФлагИспользованияЗаписи <> Неопределено, ФлагИспользованияЗаписи И СотрудникНеУволенИзСЕ(Сотрудник, СтрокаТ.СтруктурнаяЕдиница), СтрокаТ.Использовать));
			
			СтруктураДанных.Вставить("club_id"	 , Строка(СтрокаТ.СтруктурнаяЕдиница.УникальныйИдентификатор()));
			СтруктураДанных.Вставить("club_name" , СтрокаТ.СтруктурнаяЕдиницаНаименование);
			
			МассивДанных.Добавить(СтруктураДанных);
			
		КонецЦикла;
	
		ТекстЗапроса = СобратьJson(МассивДанных);
		
		Метод = "director_app/director";
		
		РезультатЗапроса  = ВыполнитьPOSTЗапрос(Метод, ТекстЗапроса, ЗаголовкиHTTP);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

Функция СотрудникНеУволенИзСЕ(Сотрудник, СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	НастройкиПользователей.ДатаУвольнения КАК Значение
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиПользователей
	|ГДЕ
	|	НастройкиПользователей.Сотрудник = &Сотрудник
	|	И НастройкиПользователей.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
	
	Запрос.УстановитьПараметр("Сотрудник"      		, Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Не ЗначениеЗаполнено(Выборка.Значение), Истина);  
		
КонецФункции
	
// Функция, выполняет синхронизацию статуса моб приложения с CRM.
// 
Функция АктуализироватьДоступКличномуРасписанию_CRM(ВнешняяСистема, Сотрудник) Экспорт

	РезультатаОперции = Неопределено;
	
	Попытка 
		
		Параметры = РегистрыСведений.КлючиВнешнихСистем.ПолучитьПараметрыСотрудника(ВнешняяСистема, Сотрудник);
		
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("apikey"    , ВнешняяСистема.КлючПриложения);
		ЗаголовкиHTTP.Вставить("usertoken" , Параметры.КлючКлиента);
		
		Метод = "director_app/status";
		
		РезультатЗапроса  = ВыполнитьGETЗапрос(Метод, ЗаголовкиHTTP);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатаОперции;
		
КонецФункции

#Область МобильноеПриложениеМастера

// Функция, проверяет, настроена ли внешняя публикация.
// 
Функция ВнешняяПубликацияНастроена() Экспорт
	
	Возврат ЗначениеЗаполнено(Константы.ВнешняяПубликацияАдрес.Получить())
	И ЗначениеЗаполнено(Константы.ВнешняяПубликацияПользователь.Получить());
	
КонецФункции

// Функция, возвращает код подтверждения.
// 
Функция ПолучитьКодПодтвержденияДляАвторизации(НомерТелефона, ВнешняяСистема) Экспорт
	
	РезультатаОперции = Неопределено;
	
	Попытка
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("phone", НомерТелефона);
		
		Метод = "director_app/confirmation_code";
		
		РезультатЗапроса  = ВыполнитьGETЗапрос(Метод, ЗаголовкиHTTP);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатаОперции;
	
КонецФункции

