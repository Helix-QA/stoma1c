
#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик при загрузки формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	

	Параметры.Свойство("СоставнойПодборРежим",СоставнойПодборРежим); 
	Параметры.Свойство("ФормаШаблоновТекстовыхРеквизитов", ФормаШаблоныТекстовыхРеквизитов);
	Если Параметры.Свойство("Зуб") И ЗначениеЗаполнено(Параметры.Зуб) Тогда
		МассивВыделенныхЗубов.Добавить(Параметры.Зуб);
	КонецЕсли;
	ВидимостьПереключателя = Параметры.Свойство("РазрешитьМножественныйВыбор") И Параметры.РазрешитьМножественныйВыбор = Истина;
	Если СоставнойПодборРежим Тогда
		Элементы.ФормаГруппаРежимСоставногоВыбора.Видимость = Истина;
		Элементы.СписокКнопкаВыбрать.Видимость              = Ложь;
		Параметры.Свойство("ТипЗубнойФормулы",ТипЗубнойФормулы);
		УстановитьЗубнуюФормулу();
	Иначе
		Элементы.СписокКнопкаВыбрать.Видимость               = Истина;
		Элементы.СписокКнопкаВыбрать.КнопкаПоУмолчанию       = Истина;
		Элементы.ФормаГруппаРежимСоставногоВыбора.Видимость  = Истина;
		Элементы.ГруппаПодборЗубов.Видимость                 = Ложь;
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаКлиенте
// Обработчик при открытии формы на клиенте
//
Процедура ПриОткрытии(Отказ) 
	
	Если СоставнойПодборРежим Тогда
     	 ОбновитьSVGПодбор();
	 КонецЕсли; 
	 
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Обработчки выбора значения списка
//
Процедура СписокВыборЗначения(Элемент, Значение, СтандартнаяОбработка) 
	
	Если Не ФормаШаблоныТекстовыхРеквизитов Тогда 
		КодМКБ10 = ВернутьКодДиагноза(Значение);
		СтандартнаяОбработка = Ложь;	
		ОповеститьОВыборе(Новый Структура("Зубы, Диагноз, КодМКБ10", ?(СоставнойПодборРежим, МассивВыделенныхЗубов.ВыгрузитьЗначения(), Неопределено),
																	 Значение, ?(ЗначениеЗаполнено(КодМКБ10), КодМКБ10, "")));
	Иначе 
		СтандартнаяОбработка = Ложь;	
		ОповеститьОВыборе(Значение);
	КонецЕсли;  
	
	//ОповеститьОВыборе(Новый Структура("Зубы,Диагноз",МассивВыделенныхЗубов.ВыгрузитьЗначения(),Значение));
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Вернуть код диагноза
//
Функция ВернутьКодДиагноза(Диагноз) 
	Возврат СокрЛП(Диагноз.Код);		
КонецФункции

&НаКлиенте
// При нажатии на форму подбора
//
Процедура ПодборЗубовПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ДанныеЭлемента = ДанныеСобытия.Element.parentNode.id;
	
	Если ДанныеЭлемента = "Switch" тогда
		МассивВыделенныхЗубов.Очистить();
		ТипЗубнойФормулы            = ?(ТипЗубнойФормулы = 1, 0, 1);

		SVGВыделенныйЗуб            = "var selectzub"; 
		SVGМассивВыделенныхЗубов    = "var SelectedTeeth = [];";
				
		УстановитьЗубнуюФормулу();
		ОбновитьSVGПодбор();
	КонецЕсли;
	
	Если ДанныеЭлемента = "МножественныйРежимВыделения" ИЛИ ДанныеЭлемента = "ОдиночныйРежимВыделения" тогда
		РазрешитьМножественныйВыбор = ДанныеЭлемента = "МножественныйРежимВыделения";
	КонецЕсли;
	
	Если ДанныеЭлемента = "Del" Тогда
		МассивВыделенныхЗубов.Очистить();
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеЭлемента) И Найти(ДанныеЭлемента, "Зуб") > 0  Тогда
		Зуб = ДанныеЭлемента;
		Если Найти(Зуб, "Зуб") > 0 Тогда
			Зуб = ПредопределенноеЗначение("Перечисление.Зубы."+Зуб);
		Иначе
			Возврат;
		КонецЕсли;
		Если РазрешитьМножественныйВыбор Тогда
			НайденныйЭл = МассивВыделенныхЗубов.НайтиПоЗначению(Зуб);
			Если НайденныйЭл <> Неопределено Тогда			
				МассивВыделенныхЗубов.Удалить(НайденныйЭл);
			Иначе
				МассивВыделенныхЗубов.Добавить(Зуб);				
			КонецЕсли;		
		Иначе
			
			Если МассивВыделенныхЗубов.Количество() > 0 и Зуб = МассивВыделенныхЗубов[0].Значение Тогда
				МассивВыделенныхЗубов.Очистить();
			Иначе
				МассивВыделенныхЗубов.Очистить();
				МассивВыделенныхЗубов.Добавить(Зуб);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
// Процедура, обновляет картинку подбора зубов
//
Процедура ОбновитьSVGПодбор()
	
	Если МассивВыделенныхЗубов.Количество() > 0 Тогда
		мЗуб = СтрЗаменить(Строка(МассивВыделенныхЗубов[0].Значение), "Зуб", "");
		Svg  = СтрЗаменить(Svg, SVGВыделенныйЗуб, "var selectzub = '"+мЗуб+"';");	
		SVGВыделенныйЗуб = "var selectzub = '"+мЗуб+"';";
	Иначе
	   	Svg  = СтрЗаменить(Svg, SVGВыделенныйЗуб, "var selectzub;");	
		SVGВыделенныйЗуб = "var selectzub;";
	КонецЕсли;
	
	мМассив                 = "mas='";
	мМассив                 = мМассив + "';";
	SVGМассивЛечащихсяЗубов = "var mas='';";
	Svg                     = СтрЗаменить(Svg, SVGМассивЛечащихсяЗубов, мМассив);
	SVGМассивЛечащихсяЗубов = мМассив;
	
	мМассив = "var SelectedTeeth = [";
	Для Каждого строкаТЧ из МассивВыделенныхЗубов Цикл
		мМассив = мМассив + "'Цвет"+строкаТЧ.Значение+"',";		
	КонецЦикла;
	Если СтрДлина(мМассив) > 21 Тогда
		мМассив = Сред(мМассив, 1, СтрДлина(мМассив)-1);
	КонецЕсли;
	мМассив                  = мМассив + "];";
	Svg                      = СтрЗаменить(Svg, SVGМассивВыделенныхЗубов, мМассив);
	SVGМассивВыделенныхЗубов = мМассив;	
	
	ПодборЗубов              = Svg;	
		
КонецПроцедуры 

&НаСервере
// Процедура, выполняет получение макета ЗФ
//
Процедура УстановитьЗубнуюФормулу()
	
	SVGВыделенныйЗуб             = "var selectzub"; 
	SVGМассивВыделенныхЗубов     = "var SelectedTeeth = [];";

    ПодборЗубов = "<HTML xmlns='http://www.w3.org/1999/xhtml'>
	|<META contect='text/html; charset=utf-8' http-equiv='Content-Type'></META><LINK rel='stylesheet' type='text/css' href='__STYLE__'></LINK>
	|<META name='GENERATOR' content='MSHTML 8.00.6001.18702'></META>
	|<BASE href='v8config://v8cfgHelp/mdobject/id8d74233b-feb6-4170-918c-dfe5689c9b14/8eb4fad1-1fa6-403e-970f-2c12dbb43e23'></BASE>
	|<HEAD>
	|
	|<STYLE type=text/css>BODY {
	|	PADDING-BOTTOM: 0px; BACKGROUND-COLOR: #fff; MARGIN: 0px; PADDING-LEFT: 0px; PADDING-RIGHT: 0px; FONT: 13px Veranda,Arial,helv; OVERFLOW: auto; PADDING-TOP: 0px
	|}
	|TABLE {
	|	FONT: 13px Veranda,Arial,helv
	|}
	|TD {
	|	FONT: 13px Veranda,Arial,helv
	|}
	|.Level1 {
	|	BACKGROUND-IMAGE: url('../../mdpicture/id7b596014-1162-4a35-bf29-02d313671e51/00000000-0000-0000-0000-000000000000'); BORDER-BOTTOM: white 1px solid; TEXT-ALIGN: center; LINE-HEIGHT: 22px; BACKGROUND-COLOR: #c5374e; FONT-FAMILY: ""Arial""; HEIGHT: 22px; COLOR: white; FONT-SIZE: 16px; VERTICAL-ALIGN: middle; FONT-WEIGHT: bold
	|}
	|.Level2 {
	|	BACKGROUND-IMAGE: url('../../mdpicture/id2454bd49-37b5-4de4-a308-0c3acf8c4c6c/00000000-0000-0000-0000-000000000000'); BORDER-BOTTOM: white 1px solid; TEXT-ALIGN: center; LINE-HEIGHT: 18px; BACKGROUND-COLOR: #1a3867; FONT-FAMILY: ""Arial""; HEIGHT: 18px; COLOR: white; FONT-SIZE: 12px; VERTICAL-ALIGN: middle; FONT-WEIGHT: bold
	|}
	|.LevelDown {
	|	FONT-FAMILY: ""Arial""; COLOR: black; FONT-SIZE: 12px; CURSOR: pointer; FONT-WEIGHT: bold; HEIGHT: 22px; LINE-HEIGHT: 22px; VERTICAL-ALIGN: middle;
	|}
	|.BORDERBOTTOMLINE {
	|	BORDER-BOTTOM: #aeafb0 1px solid;
	|}
	|
	|</STYLE></HEAD>
	|
	|<BODY bgColor=#ffffff><IMG src=""D:\FormulaPodbor.svg"">
	|</BODY></HTML>";

	
	Если ТипЗубнойФормулы = 1 Тогда
		mSvg  = ПолучитьОбщийМакет("SVGПодборДетский").ПолучитьТекст();
	Иначе
		mSvg  = ПолучитьОбщийМакет("SVGПодборВзрослый").ПолучитьТекст();
	КонецЕсли;
	
	mHTML = ПолучитьОбщийМакет("HTMLДокумент").ПолучитьТекст();
	Svg   = СтрЗаменить(mHTML, "SVGElement", mSvg);
	Svg   = СтрЗаменить(Svg, "document.getElementById('Layer_1').setAttributeNS(null, 'height', window.innerHeight+'px')", "document.getElementById('Layer_1').setAttributeNS(null, 'height', (window.innerHeight - 15)+'px')");
	Если НЕ ВидимостьПереключателя Тогда
		Svg  = СтрЗаменить(Svg, "var ViewSelect = true;", "var ViewSelect = false;" );
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УдалитьДиагноз(Команда)
	
	ОповеститьОВыборе(Новый Структура("Зуб,Диагноз,УдалитьРеквизит",Неопределено,Неопределено,Истина));
	
КонецПроцедуры

#КонецОбласти








