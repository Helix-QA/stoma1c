&НаКлиенте
//Функция рекурсивного поиска в дереве доступных видов оплаты
Функция ПолучитьСтрокиСВнесеннойОплатой(
	ТипДенСредств					= Неопределено,
	ЛицевойСчет						= Неопределено,								 
	ЭквайрингНомерПлатежнойКарты	= Неопределено,
	СертификатПартия				= Неопределено)
		
	МассивСтрок = Новый Массив;

	Если ТипЗнч(ТипДенСредств) = Тип("ПеречислениеСсылка.ТипыДенежныхСредств") Тогда	
		МассивТиповДенСредств = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ТипДенСредств);
	Иначе
		МассивТиповДенСредств = ТипДенСредств;
	КонецЕсли;
	
	Для Каждого ЭлементВерхУр ИЗ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл	
		
		Если ЭлементВерхУр.Внесено > 0 Тогда
				
			Если МассивТиповДенСредств <> Неопределено 
				И МассивТиповДенСредств.Найти(ЭлементВерхУр.ТипДенежныхСредств) = Неопределено Тогда				
				Продолжить;
			КонецЕсли;	
			
			Если ЛицевойСчет <> Неопределено  			
				И ЭлементВерхУр.ЛицевойСчет <> ЛицевойСчет Тогда											
				Продолжить;
			КонецЕсли;
			
			Если ЭквайрингНомерПлатежнойКарты <> Неопределено  				
				И ЭлементВерхУр.ЭквайрингНомерПлатежнойКарты <> ЭквайрингНомерПлатежнойКарты Тогда													
				Продолжить;
			КонецЕсли;
			
			Если СертификатПартия <> Неопределено 				
				И ЭлементВерхУр.СертификатПартия <> СертификатПартия Тогда												
				Продолжить;
			КонецЕсли;
			
			МассивСтрок.Добавить(ЭлементВерхУр);
							
		КонецЕсли;
		
		Для Каждого ЭлементНизУр ИЗ ЭлементВерхУр.ПолучитьЭлементы() Цикл
			
			Если ЭлементНизУр.Внесено > 0 Тогда
				
				Если МассивТиповДенСредств <> Неопределено 
					И МассивТиповДенСредств.Найти(ЭлементНизУр.ТипДенежныхСредств) = Неопределено Тогда				
					Продолжить;
				КонецЕсли;	
				
				Если ЛицевойСчет <> Неопределено  			
					И ЭлементНизУр.ЛицевойСчет <> ЛицевойСчет Тогда											
					Продолжить;
				КонецЕсли;
				
				Если ЭквайрингНомерПлатежнойКарты <> Неопределено  				
					И ЭлементНизУр.ЭквайрингНомерПлатежнойКарты <> ЭквайрингНомерПлатежнойКарты Тогда													
					Продолжить;
				КонецЕсли;
				
				Если СертификатПартия <> Неопределено 				
					И ЭлементНизУр.СертификатПартия <> СертификатПартия Тогда												
					Продолжить;
				КонецЕсли;
				
				МассивСтрок.Добавить(ЭлементНизУр);
							
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат МассивСтрок;
	
КонецФункции

&НаСервере
// Функция рекурсивного поиска в дереве доступных видов оплаты
Функция ПолучитьСтрокиСВнесеннойОплатойСервер(
	ТипДенСредств = Неопределено,
	ВидЛицевогоСчета = Неопределено,								 
	ЭквайрингНомерПлатежнойКарты = Неопределено,
	СертификатПартия = Неопределено,
	БонусныйСчет = Неопределено,
	Пациент = Неопределено)
		
	МассивСтрок = Новый Массив;
	
	Для Каждого ЭлементВерхУр Из ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл	
		
		Если ЭлементВерхУр.Внесено > 0 Тогда
				
			Если ТипДенСредств <> Неопределено 
				И ЭлементВерхУр.ТипДенежныхСредств <> ТипДенСредств Тогда				
				Продолжить;
			КонецЕсли;	
			
			Если ВидЛицевогоСчета <> Неопределено  			
				И ЭлементВерхУр.ВидЛицевогоСчета <> ВидЛицевогоСчета Тогда											
				Продолжить;
			КонецЕсли;
			
			Если ЭквайрингНомерПлатежнойКарты <> Неопределено  				
				И ЭлементВерхУр.ЭквайрингНомерПлатежнойКарты <> ЭквайрингНомерПлатежнойКарты Тогда													
				Продолжить;
			КонецЕсли;
			
			Если СертификатПартия <> Неопределено 				
				И ЭлементВерхУр.СертификатПартия <> СертификатПартия Тогда												
				Продолжить;
			КонецЕсли;
			
			Если БонусныйСчет <> Неопределено 				
				И ЭлементВерхУр.БонусныйСчет <> БонусныйСчет Тогда												
				Продолжить;
			КонецЕсли;
			
			Если Пациент <> Неопределено И ЭлементВерхУр.Контрагент <> Пациент Тогда 
				Продолжить;
			КонецЕсли;

			МассивСтрок.Добавить(ЭлементВерхУр);
							
		КонецЕсли;
		
		Для Каждого ЭлементНизУр ИЗ ЭлементВерхУр.ПолучитьЭлементы() Цикл	
			
			Если ЭлементНизУр.Внесено > 0 Тогда
				
				Если ТипДенСредств <> Неопределено 
					И ЭлементНизУр.ТипДенежныхСредств <> ТипДенСредств Тогда				
					Продолжить;
				КонецЕсли;	
				
				Если ВидЛицевогоСчета <> Неопределено  			
					И ЭлементНизУр.ВидЛицевогоСчета <> ВидЛицевогоСчета Тогда											
					Продолжить;
				КонецЕсли;
				
				Если ЭквайрингНомерПлатежнойКарты <> Неопределено  				
					И ЭлементНизУр.ЭквайрингНомерПлатежнойКарты <> ЭквайрингНомерПлатежнойКарты Тогда													
					Продолжить;
				КонецЕсли;
				
				Если СертификатПартия <> Неопределено 				
					И ЭлементНизУр.СертификатПартия <> СертификатПартия Тогда												
					Продолжить;
				КонецЕсли;
				
				Если БонусныйСчет <> Неопределено  			
					И ЭлементНизУр.БонусныйСчет <> БонусныйСчет Тогда											
					Продолжить;
				КонецЕсли;
				
				Если Пациент <> Неопределено И ЭлементНизУр.Контрагент <> Пациент Тогда 
					Продолжить;
				КонецЕсли;

				МассивСтрок.Добавить(ЭлементНизУр);
							
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат МассивСтрок;
	
КонецФункции

&НаКлиенте
// Функция - Существуюет оплата проведенная по карте
// 
// Возвращаемое значение:
//   - 
// 
Функция ВыполнятьОперациюПоПлатежнойКарте()
	
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл
		
		Если СтрокаТ.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта") 
			И СтрокаТ.Внесено > 0   Тогда
			
			Возврат Истина;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Ложь;
