
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Контрагент") И ЗначениеЗаполнено(Параметры.Контрагент) Тогда
		ЭтаФорма.АвтоЗаголовок = ложь;
		ЭтаФорма.Заголовок = "История изменения статуса клиента";
		Элементы.Контрагент.Видимость = Ложь;
		Элементы.ОбновитьСтатусы.Видимость = Истина;
		Список.Параметры.УстановитьЗначениеПараметра("АктивностьОтбора", Истина);
		Список.Параметры.УстановитьЗначениеПараметра("Контрагент", Параметры.Контрагент);
		Элементы.БыстрыеОтборы.Видимость = Ложь;		
	Иначе
		Элементы.ОбновитьСтатусы.Видимость = Ложь;
		Список.Параметры.УстановитьЗначениеПараметра("АктивностьОтбора", Ложь);
		Список.Параметры.УстановитьЗначениеПараметра("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
		Элементы.БыстрыеОтборы.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти  

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля КонтрагентОтбор
//
Процедура КонтрагентОтборПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", КонтрагентОтбор, ЗначениеЗаполнено(КонтрагентОтбор));
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поля Статус.
//
Процедура СтатусОтборПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Статус", СтатусОтбор, ЗначениеЗаполнено(СтатусОтбор));

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - обработчик команды "ОбновитьСтатусы"
//
Процедура ОбновитьСтатусы(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьСтатусыПослеВопроса", ЭтотОбъект); 
	ТекстВопроса = "При обновлении статусов, все Приемы по данному пациенту, будут перепроведены!" + Символы.ПС + "Продолжить?";
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , , "Внимание");
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Обновить статусы после вопроса
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОбновитьСтатусыПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если РезультатВопроса = КодВозвратаДиалога.Нет Тогда 
		Возврат;
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Да Тогда 
		Параметр_Контрагент = Список.Параметры.Элементы.Найти("Контрагент");
		Если Параметр_Контрагент <> Неопределено Тогда 
			Если ЗначениеЗаполнено(Параметр_Контрагент.Значение) И Параметр_Контрагент.Использование Тогда
				МассивПриемов = ПолучитьПриемыПациента(Параметр_Контрагент.Значение);
				Коэфициент = 100 / МассивПриемов.Количество();
				Коэф = Коэфициент;
				Для Каждого Прием Из МассивПриемов Цикл
					Состояние("Проведение документов", ?(Цел(Коэф) < 1, 1, Цел(Коэф)), Строка(Прием) + "...");					
					ПровестиПриемПациента(Прием);
					Коэф = Коэф + Коэфициент;
				КонецЦикла;				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	//ЭтаФорма.ОтобразитьИзменениеДанных();
	Элементы.Список.Обновить();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
// Процедура инициализирует проведение документа
//
Процедура ПровестиПриемПациента(Прием)
	
	ПриемОбъект = Прием.ПолучитьОбъект();
	ПриемОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция возвращает все приемы по указанному пациенту
//
Функция  ПолучитьПриемыПациента(Пациент)
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Ссылка
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Контрагент = &Контрагент
	|	И Прием.Проведен = ИСТИНА
	|
	|УПОРЯДОЧИТЬ ПО
	|	Прием.Дата";
	
	Запрос.УстановитьПараметр("Контрагент", Пациент);				   
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

#КонецОбласти









