// Процедура - При отмене подтверждения записи
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  дополнительныеПараметры	 - 	 - 
//
Процедура ПриОтменеПодтвержденияЗаписи(РезультатВыбора, дополнительныеПараметры = Неопределено) Экспорт 
	
	Если РезультатВыбора = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(РезультатВыбора) = Тип("КодВозвратаДиалога") Тогда 
		Если РезультатВыбора = КодВозвратаДиалога.Да Тогда 
			Объект.ТелефонныйЗвонок = Ложь;
			// Меняем также и статус события
			Объект.Статус 			= ПредопределенноеЗначение("Перечисление.СтатусыСобытия.НеПодтверждена");
			УстановитьСвойстваЭлементамПодтвержденияЗаписи();
		Иначе
			Возврат;
		КонецЕсли;	
	КонецЕсли;
	
	Если ТипЗнч(РезультатВыбора) = Тип("Строка") Тогда 
		Если РезультатВыбора = "ПоказатьДиалог"	Тогда 
			ОткрытьДиалогСЧатБотом(Неопределено);			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	

