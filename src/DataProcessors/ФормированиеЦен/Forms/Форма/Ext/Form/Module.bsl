&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Период = ТекущаяДата();
	Объект.Период = ТекущаяДата();
	Объект.ВидЦен = Справочники.ВидыЦен.Розничная;
	Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	СтруктурнаяЕдиницаЗаполненияЦен = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ПорядокОкругления = Объект.ВидЦен.ПорядокОкругления;
	ОкруглятьВБольшуюСторону = Объект.ВидЦен.ОкруглятьВБольшуюСторону;
	
	Объект.Автор = ПараметрыСеанса.ТекущийПользователь;
	
	Элементы.ГруппаИзмененияЦен.Видимость = Ложь;
	
	КэшРеквизитов = Новый Структура;
	КэшРеквизитов.Вставить("ПорядокОкругления", Объект.ВидЦен.ПорядокОкругления);
	КэшРеквизитов.Вставить("ОкруглятьВБольшуюСторону", Объект.ВидЦен.ОкруглятьВБольшуюСторону);	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - обработчик события ПриИзменении поля ввода Номенклатура.
//
Процедура ЦеныНоменлатурыКартинкаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ЦеныНоменлатуры.ТекущиеДанные;
    СтрокаТабличнойЧасти.Пометка = Истина;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора" поле ввода "Упаковка"
//
Процедура ЦеныНоменлатурыУпаковкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбработкаТабличныхЧастейКлиент.ВыбратьУпаковкуНоменклатуры(ДанныеВыбора, СтандартнаяОбработка, Элементы.ЦеныНоменлатуры.ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поле ввода "ЦеныНоменлатурыНоменклатура"
//
Процедура ЦеныНоменлатурыНоменклатураПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.ЦеныНоменлатуры.ТекущиеДанные;
	
	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Упаковка) Тогда	
		СтрокаТаблицы.Упаковка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТаблицы.Номенклатура, "УпаковкаПоумолчанию");
	КонецЕсли;
	
КонецПроцедуры



