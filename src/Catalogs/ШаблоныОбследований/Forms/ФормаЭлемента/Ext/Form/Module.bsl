#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик создания формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Элементы.Код.Видимость = ОтображниеКода;
	Элементы.Код.ПоложениеЗаголовка = ?(ОтображниеКода, ПоложениеЗаголовкаЭлементаФормы.Авто, ПоложениеЗаголовкаЭлементаФормы.Нет);

	Элементы.Специализация.Видимость = Не Объект.Предопределенный; 
	Элементы.Наименование.МаксимальнаяШирина = ?(Объект.Предопределенный, 38, 51); 
	
	// Заполнить список используемых шрифтов
	ПолучитьИсториюИспользуемыхШрифтов();
	 // Заполнить списко размеров шрифтов
	 Для А = 1 По 14 Цикл		 
		 Элементы.РедактирвоаниеHTMLРазмерШрифта.СписокВыбора.Добавить(А);
	 КонецЦикла;	 
	 // Подготовка основы новго документа 
	 Если Объект.Ссылка.Пустая() Тогда		 
		 		 
		 Объект.HTMLШаблон = "<html>
		 |<head>
		 |<style type=""text/css"">
		 |.no_border_doc { 
		 | width: 21cm;
		 | height: 29cm;
		 |}
		 |
   		 |
		 |.element{
	     | padding: 1px;
	     | color: #AD7E0D;
         |}
		 |.element A{
	     | color: #000000;
	     | text-decoration: none;
         |}
		 |
         |.add_element A{
	     | color: #1834A1;
	     | text-decoration: none;
         |}
		 |.inline {
	     |display: inline;
         |}
         |.add_element A:hover {color: #0B78B9;}
         |.element A:hover{ color: #918F89;}
		 |
         |.add_element {color: #AD7E0D;}
         |BR {margin: 0 0px 0 0;}
		 |
         |P{
	     | margin-bottom: 4px;
	     | margin-top: 0px;
         |}
		 |
         |TABLE{
	     | margin-top: 0px;
	     | margin-bottom: 4px;
         |}
         |DIV{
	     | margin-bottom: 4px;
	     | margin-top: 0px;
         |}
         |H1{
	     | text-align: center;
	     | font-size: 14pt;
         |}
		 |</style>	
		 |</head>
		 |<body><div class=FORMAT >&nbsp</div></body></html>";	 

	 КонецЕсли;
	 
	 ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	 
КонецПроцедуры

&НаСервере 
// Обработчик при загрузке данных формы
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	// Заполнить дерево параметров
	ЗаполнитьДеревоПараметровСервер(); 
	
КонецПроцедуры

&НаКлиенте
// Обработчик открытия формы 
//
Процедура ПриОткрытии(Отказ)
	
	Элементы.ПарамтерыШаблонаРежимотображения.Картинка  = ?(НЕ ПарамтерыШаблонаРежимотображения, БиблиотекаКартинок.ВидОтображенияСписокНовый, БиблиотекаКартинок.ВидОтображенияДеревоНовый);
	Элементы.ПарамтерыШаблонаРежимотображения.Заголовок = ?(НЕ ПарамтерыШаблонаРежимотображения,"Список","Дерево");	
	Элементы.ПараметрыШаблонаСостояниеУзлов.Видимость   = НЕ ПарамтерыШаблонаРежимотображения;
    Элементы.ПараметрыШаблонаСостояниеУзлов.Картинка    = ?(ПараметрыШаблонаСостояниеУзлов, БиблиотекаКартинок.СвернутьСписок, БиблиотекаКартинок.РазвернутьСписок);
	Элементы.ПараметрыШаблонаСостояниеУзлов.Заголовок   = ?(ПараметрыШаблонаСостояниеУзлов,"Свернуть все","Развернуть все");
	// Если дерево не было обновлено при создании формы на сервер(первый пуск)
	Если НЕ ПараметрыШаблонаОбновлены Тогда
	     ЗаполнитьДеревоПараметровСервер();
    КонецЕсли;
	Если НЕ ПарамтерыШаблонаРежимотображения И ПараметрыШаблонаСостояниеУзлов  Тогда
		ОбщегоНазначенияКлиентСтоматология.РазвернутьДерево(Элементы.ПарамтерыШаблона,ПарамтерыШаблона);
    КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Обработчик перед записью     
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
		 
	 ТаблицаПараметров = Новый Массив; 
	 Док             = Элементы.HTMLШаблон.Документ.documentElement;
	 СписокЭлементов = Док.getElementsByTagName("A");	 
	 ПорядковыйНомер = 0;
	 Для Каждого Элемент Из СписокЭлементов Цикл		 		 
		 Если НЕ ЗначениеЗаполнено(Элемент.id) Тогда 
			 Продолжить; 
		 КонецЕсли;		
		 Элемент.title = Строка(ПорядковыйНомер);
		 // Вырезаем ИД дополнительного реквизита
		 РеквизитИД = Элемент.id;
		 Если СтрЧислоВхождений(РеквизитИД, ",") > 0 Тогда
		 	РеквизитИД = Лев(РеквизитИД, Найти(РеквизитИД,",") -1 );
		 КонецЕсли;
		 // Поиск сущестующей строки
		 Если ТаблицаПараметров.Найти(РеквизитИД) <> Неопределено Тогда
			 Продолжить;
		 КонецЕсли;
		 
		 ТаблицаПараметров.Добавить(Новый Структура("РеквизитИД, ПорядковыйНомер", РеквизитИД, ПорядковыйНомер));	
		 ПорядковыйНомер = ПорядковыйНомер + 1;
	 КонецЦикла;
	 СписокЭлементов = Док.getElementsByTagName("INPUT");	 
	 Для Каждого Элемент Из СписокЭлементов Цикл		 
		 Если ТаблицаПараметров.Найти(Элемент.id) <> Неопределено 
			 Тогда Продолжить; 
		 КонецЕсли;		
		 
		 ТаблицаПараметров.Добавить(Новый Структура("РеквизитИД, ПорядковыйНомер", Элемент.id, ПорядковыйНомер));
		 Элемент.title   = Строка(ПорядковыйНомер);
		 ПорядковыйНомер = ПорядковыйНомер + 1;
	 КонецЦикла;

	 ЗаписатьТаблицуСоответсвий(ТаблицаПараметров);	 
	 Объект.HTMLШаблон = "<html>" + Элементы.HTMLШаблон.Документ.documentElement.innerHTML + "</html>";
	 
КонецПроцедуры

&НаКлиенте
// Обработчик этой формы о записи нового объекта   
//
Процедура ОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)
	
	Если ТипЗнч(НовыйОбъект) = Тип("ПланВидовХарактеристикСсылка.ПараметрыОбследований") Тогда
		ПарамтерыШаблонаОбновить(Неопределено, НовыйОбъект);
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Активация строки шаблона
// 
Процедура ПарамтерыШаблонаПриАктивизацииСтроки(Элемент)	 
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда		
		Элементы.ПарамтерыШаблонаПарамтерыШаблонаУдалить.Доступность                 = Не ТекущиеДанные.Предопределенный;
		Элементы.ПарамтерыШаблонаКонтекстноеМенюПарамтерыШаблонаИзменить.Доступность = Не ТекущиеДанные.Предопределенный;
		Элементы.ПарамтерыШаблонаКонтекстноеМенюПарамтерыШаблонаУдалить.Доступность  = Не ТекущиеДанные.Предопределенный;
		ТекущийПараметр = ТекущиеДанные.Ссылка;		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработка выбора параметра шаблона
//
Процедура ПарамтерыШаблонаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные      = Элементы.ПарамтерыШаблона.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено И ТекущиеДанные.ЭтоГруппа = ложь Тогда
		
		ПараметрСсылка     = ТекущиеДанные.Ссылка;
		HTMLДокумент       = Элементы.HTMLШаблон.Документ;
		
		sel = HTMLДокумент.defaultView.getSelection();		
		
		range = sel.getRangeAt(0);
		Если range <> Неопределено Тогда
			range.deleteContents();
			HTMLКонтейнер = range.commonAncestorContainer;
		КонецЕсли;
		
		Если HTMLКонтейнер = Неопределено Тогда
			ПоказатьПредупреждение(,"Укажите позицию добавляемого реквизита в документе");
			Возврат;
		КонецЕсли;  
		
		Если ТекущиеДанные.ТипЗначения.СодержитТип(Тип("Булево")) Тогда
			HTMLКонтейнер.innerHtml = HTMLКонтейнер.innerHtml + Строка(ПараметрСсылка) + " <input type=""checkbox"" id=" 
			+ Строка(ПараметрСсылка.УникальныйИдентификатор()) + " value=""Ложь"">";
		Иначе	
			// Представление элемента 			
			Представление = ?(ТекущиеДанные.ТипПараметра = ПредопределенноеЗначение("Перечисление.ТипыПараметровШаблоновОбследований.Динамический"), 
			"...", "<выбрать...>");	
			
			HTMLКонтейнер.innerHtml = ?(ЗначениеЗаполнено(HTMLКонтейнер.innerHtml), HTMLКонтейнер.innerHtml, "")  		
			+ "<TABLE class=element><TBODY><TR><TD>"+Строка(ПараметрСсылка)+":"+"</TD><TD class=add_element><A id=" + ПараметрСсылка.УникальныйИдентификатор() 
			+ ",Addition title=0 href=about:>" + Представление + "</A></TD></TR></TBODY></TABLE>"; 	
			
		КонецЕсли;
		
		ЭтаФорма.Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик начало перетаскивания параметра
//
Процедура ПарамтерыШаблонаНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение) 
	
	 ПараметрыПеретаскивания.ДопустимыеДействия = ДопустимыеДействияПеретаскивания.Перемещение; 
	 
КонецПроцедуры                                                                                                                                     

&НаКлиенте
// Обработчик перетаскивания шаблона
//
Процедура ПарамтерыШаблонаПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле) 
	
	СсылкаИсточник = Неопределено;
	Если ПараметрыПеретаскивания.Значение.Количество()>0 Тогда
		СтрокаТ        = ПарамтерыШаблона.НайтиПоИдентификатору(ПараметрыПеретаскивания.Значение[0]);	 
		СсылкаИсточник = ?(НЕ СтрокаТ = Неопределено,СтрокаТ.Ссылка,Неопределено);
		Если СтрокаТ <> Неопределено И СтрокаТ.Предопределенный Тогда
			 ПоказатьПредупреждение(,"Перенос предопределенных элементов запрещен!");
			 ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
             Возврат;
		КонецЕсли;
	КонецЕсли;	 	
	СтрокаТ        = ПарамтерыШаблона.НайтиПоИдентификатору(Строка);
	СсылкаПриемник = ?(НЕ СтрокаТ = Неопределено,СтрокаТ.Ссылка,Неопределено);
	Если ЗначениеЗаполнено(СсылкаИсточник) И ЗначениеЗаполнено(СсылкаПриемник) Тогда
		Если СтрокаТ.Предопределенный Тогда
			 ПоказатьПредупреждение(,"Перенос элементов в группу предопределенных параметров запрещен!");
			 ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
             Возврат;
		КонецЕсли;
		ПереместитьПараметр(СсылкаИсточник,СсылкаПриемник);
		ПарамтерыШаблонаОбновить(Неопределено,СсылкаИсточник);
	Иначе
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте   
// Обработчик проверки перетаскивания 
//
Процедура ПарамтерыШаблонаПроверкаПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле) 
	
	Если ТипЗнч(Поле) = Тип("ПолеФормы") И Поле.Родитель = Элементы.ПарамтерыШаблона  Тогда	
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Перемещение;
		СтандартнаяОбработка = Ложь;
	Иначе 	
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Обработчик начало выбора 
//
Процедура РедактирвоаниеHTMLИмяШрифтаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка) 
	
	СтандартнаяОбработка = Ложь;
	ВыборШрифта = Новый ДиалогВыбораШрифта;
	ВыборШрифта.Показать(Новый ОписаниеОповещения("РедактирвоаниеHTMLИмяШрифтаПослеВыбора", ЭтотОбъект, Новый Структура("ВыборШрифта", ВыборШрифта))); 
	
КонецПроцедуры

&НаКлиенте
Процедура РедактирвоаниеHTMLИмяШрифтаПослеВыбора(Шрифт, ДополнительныеПараметры) Экспорт
	
	Если Шрифт <> Неопределено Тогда
		Если Элементы.HTMLШаблон.Документ.queryCommandSupported("FontName") Тогда
			Элементы.HTMLШаблон.Документ.execCommand("FontName", Истина, Шрифт.Имя);
			// Добавить имя шрифта в историю выбора
			Разрешить = Истина;
			// Проверка необходимости добавления шрифта в историю
			Для Каждого ЭлСписка ИЗ Элементы.РедактирвоаниеHTMLИмяШрифта.СписокВыбора Цикл
				Если ЭлСписка.Значение = Шрифт.Имя Тогда
					Разрешить = ЛОжь;
					Прервать;
				КонецЕсли;
			КонецЦикла;	
			// Внемение в историю шрифтов разрешено
			Если Разрешить Тогда
				Элементы.РедактирвоаниеHTMLИмяШрифта.СписокВыбора.Добавить(Шрифт.Имя);
				ДобавитьЗначениеВШаблоны(ЭтаФорма.ИмяФормы, "РедактирвоаниеHTMLИмяШрифта",Шрифт.Имя);
			КонецЕсли;	
		КонецЕсли;
		ЭтаФорма.ТекущийЭлемент = Элементы.HTMLШаблон;		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик выбора значения списка используемых шрифтов
//
Процедура РедактирвоаниеHTMLИмяШрифтаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка) 
	
	Если Элементы.HTMLШаблон.Документ.queryCommandSupported("FontName") Тогда
		Элементы.HTMLШаблон.Документ.execCommand("FontName", Истина, ВыбранноеЗначение);
	КонецЕсли;
	ЭтаФорма.ТекущийЭлемент = Элементы.HTMLШаблон; 
	
КонецПроцедуры

&НаКлиенте
// Обработчик выбора размера шрифта 
//
Процедура РедактирвоаниеHTMLРазмерШрифтаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка) 
	
	Если Элементы.HTMLШаблон.Документ.queryCommandSupported("FontSize") Тогда
		Элементы.HTMLШаблон.Документ.execCommand("FontSize", Истина, ВыбранноеЗначение);
	КонецЕсли;
	ЭтаФорма.ТекущийЭлемент = Элементы.HTMLШаблон; 
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Обновить дерево шаблонов
//
Процедура ПарамтерыШаблонаОбновить(Команда, СсылкаПозиционироваия = Неопределено)
	
	Если СсылкаПозиционироваия = Неопределено Тогда
		ПараметрыШаблонаТекущийПараметр = Неопределено;
		Если НЕ Элементы.ПарамтерыШаблона.ТекущиеДанные = Неопределено Тогда
			ПараметрыШаблонаТекущийПараметр = Элементы.ПарамтерыШаблона.ТекущиеДанные.Ссылка;
		КонецЕсли;
	Иначе
		ПараметрыШаблонаТекущийПараметр = СсылкаПозиционироваия;
	КонецЕсли;
	// Перезаполинть дерево
	ЗаполнитьДеревоПараметровСервер();
	Если НЕ ПарамтерыШаблонаРежимотображения И ПараметрыШаблонаСостояниеУзлов  Тогда
		ОбщегоНазначенияКлиентСтоматология.РазвернутьДерево(Элементы.ПарамтерыШаблона,ПарамтерыШаблона);
	КонецЕсли;
	// Позиционирование текущего элемента
	Если ЗначениеЗаполнено(ИдентификаторПозиционирования) Тогда
		 Элементы.ПарамтерыШаблона.ТекущаяСтрока = ИдентификаторПозиционирования;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// При изменении режима отображения дерева  
//
Процедура ПарамтерыШаблонаРежимотображения(Команда)	  
	
	ПарамтерыШаблонаРежимотображения = НЕ ПарамтерыШаблонаРежимотображения;	
	// Перезаполинть дерево
	ЗаполнитьДеревоПараметровСервер();			
	Элементы.ПарамтерыШаблонаРежимотображения.Картинка  = ?(НЕ ПарамтерыШаблонаРежимотображения, БиблиотекаКартинок.ВидОтображенияСписокНовый, БиблиотекаКартинок.ВидОтображенияДеревоНовый);
	Элементы.ПарамтерыШаблонаРежимотображения.Заголовок = ?(НЕ ПарамтерыШаблонаРежимотображения,"Список","Дерево");	
	Элементы.ПараметрыШаблонаСостояниеУзлов.Видимость   =  НЕ ПарамтерыШаблонаРежимотображения;
