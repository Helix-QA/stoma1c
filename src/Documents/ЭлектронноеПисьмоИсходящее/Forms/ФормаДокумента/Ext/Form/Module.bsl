// Процедура - Удалить письмо завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура УдалитьПисьмоЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		
		Если НЕ Объект.Ссылка.Пустая() Тогда
			УстановитьПометкуУдаления(Объект.Ссылка);
		КонецЕсли;
		
		Оповестить("ИзмененоЭлектронноеПисьмо");
		
		Прочитать(); // Обновляем данные на форме
		
		// Если письмо было удалено - закрываем форму
		Если Объект.ПометкаУдаления Тогда
			Модифицированность = Ложь;
			Закрыть();
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

