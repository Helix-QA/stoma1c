// Процедура - Установить свойства элементам формы
//
Процедура УстановитьСвойстваЭлементамФормы(ПриСозданииНаСервере = Ложь)
	
	УстановитьСвойстваЭлементамПереключателяАктивности();
	
	УстановитьСвойстваЭлементамПараметраАктивации();
	УстановитьСвойстваЭлементамПериодаАктивации();
	УстановитьСвойстваЭлементамПериодаПараметра();	
	УстановитьСвойстваЭлементамМоментаСобытия();
	УстановитьСвойстваЭлементамВыбораСтатусовКлиентов();
	УстановитьСвойстваЭлементамВыбораВидаСделок();
	УстановитьСвойстваЭлементамВидаЛицевыхСчетов();
	УстановитьСвойстваЭлементамВидаБонусныхСчетов();
	УстановитьСвойстваЭлементамСтатусаПредварительнойЗаписи();
	УстановитьСвойстваЭлементамПараметровСтраховыхПолисов();	
	УстановитьСвойстваЭлементамПричиныОтменыЗанятия();
	УстановитьСвойстваЭлементамФильтров();
	
	// Свойства элементов фильтра по статусу пациента приема		
	Элементы.ГруппаПараметрыСтатусПациентаПриема.Видимость	= Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен;
	
	// Свойства элементов фильтра по результату приема		
	Элементы.ГруппаПараметрыРезультатПриема.Видимость		= Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен;
	
	Если НЕ ПриСозданииНаСервере Тогда 
    	УстановитьСвойстваЭлементамДействий();
	КонецЕсли;	
	
	// Описание
	СформироватьОписаниеТриггерногоСобытия();
	
КонецПроцедуры

